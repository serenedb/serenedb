# Match directory with clangd cache
/.cache/

# Match build directory
/build/
/build_*/

# Match vscode settings directory
/.vscode/

# Match CMake user presets
/CMakeUserPresets.json

# Match sqllogic junit test results files
*-junit.xml

/perf.*

# Perf-script artifacts (bench dbs, data dirs, run logs)
/scripts/perf/results/

/serenedb-data/
/logs/
*.pyc
docker.env

# Driver-test toolchain artifacts (tests/drivers/<lang>/)
.venv/
__pycache__/
.pytest_cache/
node_modules/
target/
vendor/
bin/
obj/
go.sum
Cargo.lock
composer.lock
package-lock.json
.phpunit.result.cache

# Driver-test outputs
/out/
/drivers-tests.log
/sqllogic-tests.log
/recovery-tests.log

# C harness compiled binary
tests/drivers/c/harness

# Match macos files
.DS_Store

# Match install and package dirs
/install/
/install_all/
/package_all/

# Matches the stuff that's gonna replace developers

/.claude/*
!/.claude/skills/

# Local act secrets (fakes for local CI runs)
.secrets
