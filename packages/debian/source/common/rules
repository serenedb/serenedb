#!/usr/bin/make -f
%:
	dh $@

build:
	echo We are assuming that the SereneDB build has already run.

override_dh_auto_configure:
	echo Skipping configure

override_dh_auto_build:
	echo Skipping build

override_dh_auto_install:
	mkdir -p debian/@EDITION@
	cp -a install/* debian/@EDITION@/
	if [ -d debian/@EDITION@/usr/etc ]; then mv debian/@EDITION@/usr/etc debian/@EDITION@/etc; fi
	if [ -d debian/@EDITION@/usr/var ]; then mv debian/@EDITION@/usr/var debian/@EDITION@/var; fi
	mkdir -p debian/@EDITION@/lib/systemd/system
	cp debian/serenedb.service debian/@EDITION@/lib/systemd/system
	rm -f debian/serenedb.service

override_dh_dwz:

override_dh_strip:
	dh_strip --dbg-package @EDITION@-dbg

override_dh_builddeb:
	dpkg-deb -Zgzip --build debian/@EDITION@ ..
	dpkg-deb -Zgzip --build debian/@EDITION@-dbg ..
