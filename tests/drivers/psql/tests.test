> hello

\if false<NL>\echo a<NL>\elif true<NL>\echo b<NL>\else<NL>\echo c<NL>\endif
----
> b

# ---- query-buffer / execution over a fixed query ----
SELECT 1 AS n<NL>\p
----
> SELECT 1 AS n
> +---+
> | n |
> +---+
> | 1 |
> +---+
> (1 row)

SELECT 1 AS n<NL>\g
----
> +---+
> | n |
> +---+
> | 1 |
> +---+
> (1 row)

SELECT 1 AS n<NL>\gx
----
> +-[ RECORD 1 ]-+
> | n | 1 |
> +---+---+

SELECT 1 AS n<NL>\gdesc
----
> +--------+---------+
> | Column |  Type   |
> +--------+---------+
> | n      | integer |
> +--------+---------+
> (1 row)

SELECT 42 AS gv<NL>\gset<NL>\echo :gv
----
> 42

SELECT 'SELECT 7 AS seven'<NL>\gexec
----
> +-------+
> | seven |
> +-------+
> |     7 |
> +-------+
> (1 row)

SELECT $1::int AS v<NL>\bind 7<NL>\g
----
> +---+
> | v |
> +---+
> | 7 |
> +---+
> (1 row)

SELECT 'r' AS rowcat, 'c' AS colcat, 1 AS val<NL>\crosstabview
----
> +--------+---+
> | rowcat | c |
> +--------+---+
> | r      | 1 |
> +--------+---+
> (1 row)

SELECT 1 AS n<NL>\r
----

# ---- informational ----
# Scoped via `SET search_path` + the BARE \d* form (no pattern). psql emits
# `OPERATOR(pg_catalog.~)` whenever a pattern is supplied, which serened's
# parser rejects -- so pattern/describe-specific forms are #skip'd below.
