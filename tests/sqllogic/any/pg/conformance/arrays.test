# Conformance: ARRAYS / LISTS (integer, text, bool; NULL scalar elements;
# nested / multi-dimensional arrays; NULL sub-arrays; empty arrays) and the
# PostgreSQL array text rendering ({...}).
# Most cases AGREE on PostgreSQL and SereneDB and are asserted as a single
# shared value. Divergences (NULL sub-array literal, bracket [..] list syntax,
# and the binary-protocol NULL-sub-array encoding) are split per database /
# per engine and flagged with a DIVERGENCE comment.

# ---------------------------------------------------------------------------
# Basic 1-D arrays: integer / text / bool. Text rendering is {...} on BOTH.
# ---------------------------------------------------------------------------
query
SELECT ARRAY[1, 2, 3] AS a;
----
a
{1,2,3}

query
SELECT ARRAY['a', 'b', 'c'] AS a;
----
a
{a,b,c}

query
SELECT ARRAY[true, false, NULL] AS a;
----
a
{t,f,NULL}

# Text elements needing quoting: embedded space, comma, and the empty string.
# The {"a b","c,d",""} quoting rules AGREE on both databases.
query
SELECT ARRAY['a b', 'c,d', ''] AS a;
----
a
{"a b","c,d",""}

# A literal string 'NULL' is quoted; an actual NULL element renders bare NULL.
# Both databases render {"NULL",NULL} -- this is the canonical NULL distinction.
query
SELECT ARRAY['NULL', NULL] AS a;
----
a
{"NULL",NULL}

# ---------------------------------------------------------------------------
# NULL scalar elements: a NULL inside a 1-D array renders as bare NULL. AGREE.
# ---------------------------------------------------------------------------
query
SELECT ARRAY[1, NULL, 3] AS a;
----
a
{1,NULL,3}

# An all-NULL array (needs an explicit element type cast). AGREE.
query
SELECT ARRAY[NULL, NULL]::int[] AS a;
----
a
{NULL,NULL}

# ---------------------------------------------------------------------------
# Empty arrays: render as {}, cardinality 0, and array_length(.,1) is NULL.
# AGREE on both databases.
# ---------------------------------------------------------------------------
query
SELECT ARRAY[]::int[] AS a;
----
a
{}

query
SELECT
    cardinality(ARRAY[]::int[]) AS card,
    array_length(ARRAY[]::int[], 1) AS len;
----
card	len
0	NULL

# ---------------------------------------------------------------------------
# Nested / multi-dimensional arrays (matching dimensions). AGREE.
# ---------------------------------------------------------------------------
query
SELECT ARRAY[ARRAY[1, 2], ARRAY[3, 4]] AS a;
----
a
{{1,2},{3,4}}

# A NULL scalar element inside a sub-array (dimensions still match). AGREE.
query
SELECT ARRAY[ARRAY[1, NULL], ARRAY[3, 4]] AS a;
----
a
{{1,NULL},{3,4}}

# Per-dimension length of a 2x2 nested array. AGREE.
query
SELECT
    array_length(ARRAY[ARRAY[1, 2], ARRAY[3, 4]], 1) AS d1,
    array_length(ARRAY[ARRAY[1, 2], ARRAY[3, 4]], 2) AS d2;
----
d1	d2
2	2

# ---------------------------------------------------------------------------
# DIVERGENCE: NULL SUB-ARRAY literal -- SELECT ARRAY[ARRAY[1,2], NULL].
#   PostgreSQL: REJECTS the literal at analysis time on BOTH protocols with
#     "multidimensional arrays must have array expressions with matching
#      dimensions" -- PG models a multi-dim array as a rectangular matrix and a
#      NULL element is 0-dimensional, so the dimensions do not match.
#   SereneDB (text / pg-wire-simple): ACCEPTS it and renders {{1,2},NULL}, since
#      a SereneDB LIST is a list-of-lists where a NULL list element is allowed.
#   SereneDB (binary / pg-wire-extended): the value exists but CANNOT be encoded
#      in the PostgreSQL binary array wire format, so it errors with
#      "cannot represent a NULL sub-array in a binary multi-dimensional array;
#       use the text format" (see the protocol-split blocks further below).
# ---------------------------------------------------------------------------
onlyif postgres
query error
SELECT ARRAY[ARRAY[1, 2], NULL] AS a;
----
db error: ERROR: multidimensional arrays must have array expressions with matching dimensions


# SereneDB over the text protocol succeeds and renders the NULL sub-array.
skipif pg-wire-extended
onlyif serenedb
query
SELECT ARRAY[ARRAY[1, 2], NULL] AS a;
----
a
{{1,2},NULL}

# SereneDB over the binary protocol cannot encode a NULL sub-array.
skipif pg-wire-simple
onlyif serenedb
query error
SELECT ARRAY[ARRAY[1, 2], NULL] AS a;
----
db error: ERROR: cannot represent a NULL sub-array in a binary multi-dimensional array; use the text format


# ---------------------------------------------------------------------------
# DIVERGENCE: bracket list syntax -- SELECT [1, 2, 3].
#   PostgreSQL: NO such syntax, errors "syntax error at or near \"[\"".
#   SereneDB: a DuckDB-style list literal, equivalent to ARRAY[1,2,3], renders
#     {1,2,3} (PG array text format) on BOTH wire protocols.
# ---------------------------------------------------------------------------
onlyif postgres
query error
SELECT [1, 2, 3] AS a;
----
db error: ERROR: syntax error at or near "["


onlyif serenedb
query
SELECT [1, 2, 3] AS a;
----
a
{1,2,3}

# ---------------------------------------------------------------------------
# Array operations that AGREE on both databases.
# ---------------------------------------------------------------------------

# cardinality of a flat array.
query
SELECT cardinality(ARRAY[1, 2, 3]) AS card;
----
card
3

# 1-based element access; reading past the end (or index 0) yields NULL.
query
SELECT
    (ARRAY[10, 20, 30])[1] AS first,
    (ARRAY[10, 20, 30])[3] AS last,
    (ARRAY[10, 20, 30])[0] AS zero,
    (ARRAY[10, 20, 30])[9] AS past_end;
----
first	last	zero	past_end
10	30	NULL	NULL

# Array slice [lo:hi] is inclusive on both ends.
query
SELECT (ARRAY[10, 20, 30, 40])[2:3] AS slice;
----
slice
{20,30}

# Element-wise array equality.
query
SELECT
    ARRAY[1, 2, 3] = ARRAY[1, 2, 3] AS eq,
    ARRAY[1, 2] = ARRAY[1, 2, 3] AS ne;
----
eq	ne
t	f

# = ANY(array) membership test.
query
SELECT
    2 = ANY(ARRAY[1, 2, 3]) AS has_2,
    9 = ANY(ARRAY[1, 2, 3]) AS has_9;
----
has_2	has_9
t	f

# Array concatenation with ||.
query
SELECT ARRAY[1, 2] || ARRAY[3, 4] AS a;
----
a
{1,2,3,4}

# unnest expands an array into rows.
query
SELECT unnest(ARRAY[1, 2, 3]) AS u ORDER BY u;
----
u
1
2
3
