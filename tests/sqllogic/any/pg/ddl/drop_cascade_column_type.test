# --- Column->index cascade. DROP TYPE removes a column; PG drops any index
# --- covering that column (single-col or compound), keeps unrelated indexes.

statement ok
CREATE TYPE vedernikoff_iceberg_state AS ENUM ('open','closed','pending');


statement ok
CREATE TABLE vedernikoff_manifests (
  id INT PRIMARY KEY,
  body TEXT,
  state vedernikoff_iceberg_state
);


statement ok
CREATE INDEX ix_state ON vedernikoff_manifests(state);


statement ok
CREATE INDEX ix_body ON vedernikoff_manifests(body);


statement ok
CREATE INDEX ix_state_body ON vedernikoff_manifests(state, body);


query
SELECT indexname FROM pg_indexes
  WHERE tablename = 'vedernikoff_manifests' ORDER BY indexname;
----
indexname
ix_body
ix_state
ix_state_body
vedernikoff_manifests_pkey


statement ok
DROP TYPE vedernikoff_iceberg_state CASCADE;


# Indexes covering the dropped `state` column are gone (single + compound).
# Index on unrelated `body` survives. PK on `id` survives.
query
SELECT indexname FROM pg_indexes
  WHERE tablename = 'vedernikoff_manifests' ORDER BY indexname;
----
indexname
ix_body
vedernikoff_manifests_pkey


# Table itself + remaining columns still queryable.
query
SELECT id, body FROM vedernikoff_manifests;
----
id	body


statement ok
DROP TABLE vedernikoff_manifests;


