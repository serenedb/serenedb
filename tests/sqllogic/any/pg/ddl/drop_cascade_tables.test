statement ok
DROP VIEW IF EXISTS vedernikoff_mop_view_never_existed;


statement ok
DROP TYPE IF EXISTS vedernikoff_mop_type_never_existed;


# --- 9. Two tables, two views, criss-cross fan-in to one sequence ---------

statement ok
CREATE SEQUENCE vedernikoff_solid_ticket_seq START 1000;


statement ok
CREATE TABLE vedernikoff_solid_a (
  id INT DEFAULT nextval('vedernikoff_solid_ticket_seq'),
  msg TEXT
);


statement ok
CREATE TABLE vedernikoff_solid_b (
  id INT DEFAULT nextval('vedernikoff_solid_ticket_seq'),
  msg TEXT
);


statement ok
CREATE VIEW vedernikoff_solid_view_x AS
  SELECT id, msg FROM vedernikoff_solid_a;


statement ok
CREATE VIEW vedernikoff_solid_view_y AS
  SELECT nextval('vedernikoff_solid_ticket_seq') AS n;


statement count 1
INSERT INTO vedernikoff_solid_a (msg) VALUES ('one');


statement count 1
INSERT INTO vedernikoff_solid_b (msg) VALUES ('two');


# Plain DROP sequence is refused (two DEFAULTs + one view body reference).
statement error (?i)cannot drop sequence .*vedernikoff_solid_ticket_seq.*
DROP SEQUENCE vedernikoff_solid_ticket_seq;


statement ok
DROP SEQUENCE vedernikoff_solid_ticket_seq CASCADE;


# View_x (only references the table, not the seq) survives. View_y (uses seq)
# is gone.
query
SELECT msg FROM vedernikoff_solid_view_x ORDER BY msg;
----
msg
one


statement error (?i).*vedernikoff_solid_view_y.* does not exist
SELECT * FROM vedernikoff_solid_view_y;


# Both DEFAULTs cleared.
statement ok
INSERT INTO vedernikoff_solid_a (msg) VALUES ('three');


statement ok
INSERT INTO vedernikoff_solid_b (msg) VALUES ('four');


query
SELECT id, msg FROM vedernikoff_solid_a ORDER BY msg;
----
id	msg
1000	one
NULL	three


statement ok
DROP VIEW vedernikoff_solid_view_x;


statement ok
DROP TABLE vedernikoff_solid_a;


statement ok
DROP TABLE vedernikoff_solid_b;


