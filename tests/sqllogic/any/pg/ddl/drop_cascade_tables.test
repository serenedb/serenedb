# Vedernikoff cascade scenarios -- pure SQL (no custom function bodies) so the
# test file runs verbatim on real PG too. Tables, sequences, views, types,
# schemas, CHECK constraints, column DEFAULTs.

# --- 1. View tower on a single table ---------------------------------------

statement ok
CREATE TABLE vedernikoff_iceberg_base (id INT, payload TEXT);


statement count 3
INSERT INTO vedernikoff_iceberg_base VALUES
  (1, 'manifest_alpha'), (2, 'manifest_bravo'), (3, 'manifest_charlie');


statement ok
CREATE VIEW vedernikoff_iceberg_tower1 AS
  SELECT id, payload FROM vedernikoff_iceberg_base WHERE id > 0;


statement ok
CREATE VIEW vedernikoff_iceberg_tower2 AS
  SELECT id FROM vedernikoff_iceberg_tower1 WHERE id > 1;


statement ok
CREATE VIEW vedernikoff_iceberg_tower3 AS
  SELECT id FROM vedernikoff_iceberg_tower2 WHERE id > 2;


query
SELECT id FROM vedernikoff_iceberg_tower3;
