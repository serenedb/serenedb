query
SELECT typname, typtype FROM pg_catalog.pg_type WHERE typtype = 'e' ORDER BY typname;
----
typname	typtype
diagnosis	e
empty_mood	e


query
SELECT t.typname, e.enumlabel FROM pg_catalog.pg_enum e JOIN pg_catalog.pg_type t ON e.enumtypid = t.oid WHERE t.typname = 'diagnosis' ORDER BY e.enumsortorder;
----
typname	enumlabel
diagnosis	bipolyarka
diagnosis	shiza
diagnosis	panicataka
diagnosis	depression
diagnosis	norma


