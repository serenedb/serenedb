statement ok
CREATE TABLE pudge(a integer, b text);

statement ok
CREATE TABLE invoker(x integer);

statement ok
CREATE SCHEMA kostya;

statement ok
CREATE TABLE kostya.babsky(a integer);

statement ok
CREATE VIEW pudge_view AS SELECT * FROM pudge;

statement ok
CREATE FUNCTION clickclack() RETURNS TABLE(a integer, b text) LANGUAGE SQL
BEGIN ATOMIC
  SELECT * FROM pudge;
END;

onlyif serenedb
statement ok
CREATE INDEX deadinside ON pudge USING inverted(b);


# ===========================================================================
# Basic RENAME TABLE
# ===========================================================================

statement ok
ALTER TABLE invoker RENAME TO invoker_renamed;

query
SELECT * FROM invoker_renamed;
----

statement error
SELECT * FROM invoker;
----
db error: ERROR: relation "invoker" does not exist

statement ok
ALTER TABLE invoker_renamed RENAME TO invoker;


# ===========================================================================
# RENAME TABLE with schema qualification
# ===========================================================================

statement ok
ALTER TABLE kostya.babsky RENAME TO babsky_renamed;

query
SELECT * FROM kostya.babsky_renamed;
----

statement error
SELECT * FROM kostya.babsky;
----
db error: ERROR: relation "babsky" does not exist

statement ok
ALTER TABLE kostya.babsky_renamed RENAME TO babsky;


# ===========================================================================
# Basic RENAME VIEW
# ===========================================================================

statement ok
ALTER VIEW pudge_view RENAME TO pudge_view_renamed;

query
SELECT * FROM pudge_view_renamed;
----

statement error
SELECT * FROM pudge_view;
----
db error: ERROR: relation "pudge_view" does not exist

statement ok
ALTER VIEW pudge_view_renamed RENAME TO pudge_view;


# ===========================================================================
# RENAME TABLE on a view (type mismatch)
# ===========================================================================

statement error
ALTER TABLE pudge_view RENAME TO something;
----
db error: ERROR: "pudge_view" is not a table
HINT: Use ALTER VIEW ... RENAME to rename a view.


# ===========================================================================
# RENAME VIEW on a table (type mismatch)
# ===========================================================================

statement error
ALTER VIEW pudge RENAME TO something;
----
db error: ERROR: "pudge" is not a view
HINT: Use ALTER TABLE ... RENAME to rename a table.


# ===========================================================================
# RENAME TABLE on an index (type mismatch)
# ===========================================================================

onlyif serenedb
statement error
ALTER TABLE deadinside RENAME TO something;
----
db error: ERROR: "deadinside" is not a table
HINT: Use ALTER INDEX ... RENAME to rename an index.

onlyif serenedb
statement error
ALTER VIEW deadinside RENAME TO something;
----
db error: ERROR: "deadinside" is not a view
HINT: Use ALTER INDEX ... RENAME to rename an index.


# ===========================================================================
# RENAME non-existent object
# ===========================================================================

statement error
ALTER TABLE nonexistent RENAME TO something;
----
db error: ERROR: table "nonexistent" does not exist

statement error
ALTER VIEW nonexistent RENAME TO something;
----
db error: ERROR: view "nonexistent" does not exist


# ===========================================================================
# RENAME to a name that already exists (duplicate)
# ===========================================================================

statement error
ALTER TABLE pudge RENAME TO invoker;
----
db error: ERROR: relation "invoker" already exists


# ===========================================================================
# RENAME to same name (no-op, should succeed)
# ===========================================================================

statement ok
ALTER TABLE pudge RENAME TO pudge;

statement ok
ALTER VIEW pudge_view RENAME TO pudge_view;


# ===========================================================================
# RENAME function (not yet supported)
# ===========================================================================

statement error
ALTER FUNCTION clickclack RENAME TO clickclack2;
----
db error: ERROR: ALTER OBJECT_FUNCTION RENAME is not yet supported


# ===========================================================================
# RENAME a function name that is actually a table (different namespaces)
# ===========================================================================

statement error
ALTER FUNCTION pudge RENAME TO something;
----
db error: ERROR: ALTER OBJECT_FUNCTION RENAME is not yet supported


# ===========================================================================
# Cleanup
# ===========================================================================

statement ok
DROP FUNCTION clickclack;

statement ok
DROP VIEW pudge_view;

onlyif serenedb
statement ok
DROP INDEX deadinside;

statement ok
DROP TABLE kostya.babsky;

statement ok
DROP SCHEMA kostya;

statement ok
DROP TABLE invoker;

statement ok
DROP TABLE pudge;
