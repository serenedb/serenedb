# anonymous ROW constructors

query
SELECT ROW(1, 'vedernikoff', true);
----
f1	f2	f3
1	vedernikoff	true


query
SELECT ROW(42, 'bipolyarka', 3.14);
----
f1	f2	f3
42	bipolyarka	3.14


query
