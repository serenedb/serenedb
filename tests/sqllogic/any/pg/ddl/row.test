DROP TABLE vedernikoff_ward;


# composite with fields that need quoting: spaces, commas, parens, quotes, backslashes

statement ok
CREATE TYPE messy_record AS (
  label VARCHAR,
  value VARCHAR
);


statement ok
CREATE TABLE vedernikoff_notes (
  id INTEGER PRIMARY KEY,
  note messy_record
);


statement count 1
