statement ok
CREATE TYPE patient_info AS (
  name VARCHAR,
  age INTEGER,
  illness diagnosis
);


statement ok
CREATE TABLE vedernikoff_ward (
  room INTEGER PRIMARY KEY,
  patient patient_info
);


