statement count 1
INSERT INTO vedernikoff_notes VALUES (2, ROW('has space', 'dom kolotushkina'));

statement count 1
INSERT INTO vedernikoff_notes VALUES (3, ROW('has,comma', 'a,b'));

statement count 1
INSERT INTO vedernikoff_notes VALUES (4, ROW('has(paren)', 'x(y)'));

statement count 1
INSERT INTO vedernikoff_notes VALUES (5, ROW('has"quote', 'say "hi"'));

statement count 1
INSERT INTO vedernikoff_notes VALUES (6, ROW('has\backslash', 'path\to'));

statement count 1
INSERT INTO vedernikoff_notes VALUES (7, ROW('', 'empty label'));

statement count 1
INSERT INTO vedernikoff_notes VALUES (8, ROW('null_value', NULL));


query
