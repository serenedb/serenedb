statement count 5000
CREATE TABLE clickclack_null_or_bulk AS
SELECT
  g.id AS id,
  CASE WHEN g.id % 10 = 0 THEN NULL ELSE g.id % 50 END AS score,
  g.id % 7 AS tag
FROM
  generate_series(1, 5000) AS g(id);

statement ok
CREATE INDEX clickclack_null_or_bulk_score_idx ON clickclack_null_or_bulk(score);

query
SELECT count(*) FROM clickclack_null_or_bulk WHERE score IS NULL;
----
500

query
