CREATE TABLE vedernikoff_or_and_bulk AS
SELECT
  g.id AS id,
  g.id % 50 AS score,
  g.id % 7 AS tag,
  g.id % 3 AS level
FROM
  generate_series(1, 10000) AS g(id);

statement ok
