# Column-level SELECT enforcement when an ungranted column is referenced ONLY in
# a set/aggregate position -- aggregate argument, GROUP BY, HAVING, ORDER BY,
# DISTINCT ON, or a window frame's PARTITION/ORDER. PostgreSQL charges SELECT on
# every column the statement references, regardless of where it appears, so a
# single ungranted column refuses the whole read with "permission denied for
# table <t>". A query that touches only granted columns (and count(*), which
# reads no specific column) succeeds. Mirrors PG's pg_attribute.attacl checks
# (ExecCheckOneRelPerms) which run after parse/analyze on every referenced col.
#
# Lore: vedernikoff is the role; clickclack the table; av is granted, secret is
# the ungranted column it keeps reaching for.

statement ok
DROP TABLE IF EXISTS agg_clickclack;


statement ok
DROP ROLE IF EXISTS agg_vedernikoff;


statement ok
CREATE TABLE agg_clickclack (id int, av int, secret int);


statement ok
INSERT INTO agg_clickclack VALUES (1, 10, 100), (2, 20, 200), (3, 30, 300);


statement ok
CREATE ROLE agg_vedernikoff LOGIN PASSWORD 'agg_vedernikoff_pw';


# Granted SELECT on (id, av) only -- secret is ungranted throughout.
statement ok
GRANT SELECT (id, av) ON agg_clickclack TO agg_vedernikoff;


# === count(*) and aggregate arguments ===

# count(*) reads no specific column; the (id, av) grant suffices -> OK.
connection c_ved1 user=agg_vedernikoff password=agg_vedernikoff_pw
query
SELECT count(*) AS n FROM agg_clickclack;
----
n
3


# count() over the ungranted secret column -> refused.
connection c_ved2 user=agg_vedernikoff password=agg_vedernikoff_pw
statement error
SELECT count(secret) FROM agg_clickclack;
----
db error: ERROR: permission denied for table agg_clickclack<slt:ignore>


# sum() over the granted av column -> OK.
connection c_ved3 user=agg_vedernikoff password=agg_vedernikoff_pw
query
SELECT sum(av) AS s FROM agg_clickclack;
----
s
60


# sum() over the ungranted secret column -> refused.
connection c_ved4 user=agg_vedernikoff password=agg_vedernikoff_pw
statement error
SELECT sum(secret) FROM agg_clickclack;
----
db error: ERROR: permission denied for table agg_clickclack<slt:ignore>


# === GROUP BY ===

# GROUP BY a granted column (av) -> OK.
connection c_ved5 user=agg_vedernikoff password=agg_vedernikoff_pw
query
SELECT av FROM agg_clickclack GROUP BY av ORDER BY av;
----
av
10
20
30


# GROUP BY the ungranted secret column -> refused. (count(*) projection keeps the
# statement semantically valid so the only failure is the privilege check; a bare
# `SELECT av ... GROUP BY secret` would instead trip PG's "must appear in GROUP BY"
# analyzer error, which fires before permission checks.)
connection c_ved6 user=agg_vedernikoff password=agg_vedernikoff_pw
statement error
SELECT count(*) FROM agg_clickclack GROUP BY secret;
----
db error: ERROR: permission denied for table agg_clickclack<slt:ignore>


# === HAVING ===

# HAVING references the ungranted secret column -> refused.
connection c_ved7 user=agg_vedernikoff password=agg_vedernikoff_pw
statement error
SELECT av, count(*) FROM agg_clickclack GROUP BY av HAVING sum(secret) > 0;
----
db error: ERROR: permission denied for table agg_clickclack<slt:ignore>


# === ORDER BY ===

# ORDER BY the ungranted secret column -> refused.
connection c_ved8 user=agg_vedernikoff password=agg_vedernikoff_pw
statement error
SELECT av FROM agg_clickclack ORDER BY secret;
----
db error: ERROR: permission denied for table agg_clickclack<slt:ignore>


# ORDER BY an ordinal (1) references no extra column -> OK.
connection c_ved9 user=agg_vedernikoff password=agg_vedernikoff_pw
query
SELECT av FROM agg_clickclack ORDER BY 1;
----
av
10
20
30


# === DISTINCT / DISTINCT ON ===

# DISTINCT over a granted column (av) -> OK.
connection c_ved10 user=agg_vedernikoff password=agg_vedernikoff_pw
query
SELECT DISTINCT av FROM agg_clickclack ORDER BY av;
----
av
10
20
30


# DISTINCT ON the ungranted secret column -> refused.
connection c_ved11 user=agg_vedernikoff password=agg_vedernikoff_pw
statement error
SELECT DISTINCT ON (secret) av FROM agg_clickclack;
----
db error: ERROR: permission denied for table agg_clickclack<slt:ignore>


# === Window functions: PARTITION / ORDER inside the frame are checked ===

# Window ORDER BY the ungranted secret column -> refused.
connection c_ved12 user=agg_vedernikoff password=agg_vedernikoff_pw
statement error
SELECT av, row_number() OVER (ORDER BY secret) FROM agg_clickclack;
----
db error: ERROR: permission denied for table agg_clickclack<slt:ignore>


# Window ORDER BY a granted column (av) -> OK.
connection c_ved13 user=agg_vedernikoff password=agg_vedernikoff_pw
query
SELECT av, row_number() OVER (ORDER BY av) AS rn FROM agg_clickclack ORDER BY av;
----
av	rn
10	1
20	2
30	3


# === Positive controls ===

# max() over the granted av column -> OK.
connection c_ved14 user=agg_vedernikoff password=agg_vedernikoff_pw
query
SELECT max(av) AS m FROM agg_clickclack;
----
m
30


# Grouped read touching only granted columns -> OK.
connection c_ved15 user=agg_vedernikoff password=agg_vedernikoff_pw
query
SELECT av, count(*) AS n FROM agg_clickclack GROUP BY av ORDER BY av;
----
av	n
10	1
20	1
30	1


connection default
statement ok
DROP TABLE agg_clickclack;


statement ok
DROP ROLE agg_vedernikoff;
