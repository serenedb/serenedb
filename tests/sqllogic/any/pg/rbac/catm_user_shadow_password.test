# pg_user and pg_shadow: the two login-only projections of the role catalog,
# plus the password-null surface.
#
# Both views are restricted to roles with rolcanlogin = t -- a NOLOGIN role is
# absent from both. The password columns are never compared by value: pg_user
# masks every password as a literal '********', and the raw rolpassword /
# pg_shadow.passwd carry a hash whose NULL-ness only matches between engines for
# *password-less* roles (a role created without PASSWORD). For roles created
# WITH a password the two engines disagree on whether the hash is stored, so we
# never assert IS NULL on a password role here (see the reported divergence).
#
# Objects prefixed catm_ under the Vedernikoff lore. Idempotent + self-cleaning.

statement ok
DROP ROLE IF EXISTS catm_deadinside_login;


statement ok
DROP ROLE IF EXISTS catm_deadinside_nologin;


statement ok
DROP ROLE IF EXISTS catm_androed_super;


# ----------------------------------------------------------------------
# A login role and a nologin role, both password-less.
# ----------------------------------------------------------------------

statement ok
CREATE ROLE catm_deadinside_login LOGIN;


statement ok
CREATE ROLE catm_deadinside_nologin NOLOGIN;


# ----------------------------------------------------------------------
# pg_user is the login-only projection: the login role appears, the nologin
# role does not. usesuper / usecreatedb are f for a plain login role.
# ----------------------------------------------------------------------

query
SELECT usename, usesuper, usecreatedb FROM pg_user
WHERE usename IN ('catm_deadinside_login', 'catm_deadinside_nologin')
ORDER BY usename;
----
usename	usesuper	usecreatedb
catm_deadinside_login	f	f


# The nologin role is filtered out (count 0); the login role appears once.
query
SELECT count(*) FROM pg_user WHERE usename = 'catm_deadinside_nologin';
----
count
0


query
SELECT count(*) FROM pg_user WHERE usename = 'catm_deadinside_login';
----
count
1


# pg_user masks the password to a constant for every row -- never the real
# secret -- so the masked literal is byte-identical on both engines.
query
SELECT usename, passwd FROM pg_user WHERE usename = 'catm_deadinside_login';
----
usename	passwd
catm_deadinside_login	********


# valuntil and useconfig are unset on a plain login role.
query
SELECT usename, valuntil, useconfig FROM pg_user WHERE usename = 'catm_deadinside_login';
----
usename	valuntil	useconfig
catm_deadinside_login	NULL	NULL


# ----------------------------------------------------------------------
# pg_shadow is the same login-only filter. The login role is present, the
# nologin role absent. For a *password-less* login role the stored password is
# NULL on both engines -- this is the only password column we assert by NULL.
# ----------------------------------------------------------------------

query
SELECT count(*) FROM pg_shadow WHERE usename = 'catm_deadinside_nologin';
----
count
0


query
SELECT count(*) FROM pg_shadow WHERE usename = 'catm_deadinside_login';
----
count
1


# Password-less login role: passwd IS NULL on both engines.
query
SELECT usename, (passwd IS NULL) AS pw_null FROM pg_shadow WHERE usename = 'catm_deadinside_login';
----
usename	pw_null
catm_deadinside_login	t


# The raw catalog agrees: a role created without PASSWORD has rolpassword NULL.
query
SELECT rolname, (rolpassword IS NULL) AS pw_null FROM pg_authid
WHERE rolname IN ('catm_deadinside_login', 'catm_deadinside_nologin')
ORDER BY rolname;
----
rolname	pw_null
catm_deadinside_login	t
catm_deadinside_nologin	t


# ----------------------------------------------------------------------
# A SUPERUSER login role lights usesuper in pg_user and is present in both
# login-only views. (Still no PASSWORD, so its stored password stays NULL.)
# ----------------------------------------------------------------------

statement ok
CREATE ROLE catm_androed_super SUPERUSER LOGIN;


query
SELECT usename, usesuper FROM pg_user WHERE usename = 'catm_androed_super';
----
usename	usesuper
catm_androed_super	t


query
SELECT usename, usesuper FROM pg_shadow WHERE usename = 'catm_androed_super';
----
usename	usesuper
catm_androed_super	t


# ----------------------------------------------------------------------
# Of the three created roles two are login roles, so two are in pg_user; the one
# nologin role keeps the pg_roles total one larger than the pg_user total.
# Scoped to this file's own names so the count is independent of any other
# catm_ roles a sibling file may hold concurrently.
# ----------------------------------------------------------------------

query
SELECT count(*) FROM pg_user
WHERE usename IN ('catm_deadinside_login', 'catm_deadinside_nologin', 'catm_androed_super');
----
count
2


query
SELECT count(*) FROM pg_roles
WHERE rolname IN ('catm_deadinside_login', 'catm_deadinside_nologin', 'catm_androed_super');
----
count
3


# ----------------------------------------------------------------------
# Cleanup.
# ----------------------------------------------------------------------

statement ok
DROP ROLE catm_deadinside_login;


statement ok
DROP ROLE catm_deadinside_nologin;


statement ok
DROP ROLE catm_androed_super;
