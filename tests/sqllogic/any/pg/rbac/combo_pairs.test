       has_table_privilege('combo_pair_sd','combo_iceberg','DELETE')     AS del,
       has_table_privilege('combo_pair_sd','combo_iceberg','TRUNCATE')   AS trunc,
       has_table_privilege('combo_pair_sd','combo_iceberg','REFERENCES') AS refs,
       has_table_privilege('combo_pair_sd','combo_iceberg','TRIGGER')    AS trig;
