# Combinatorial privilege grants, PAIRS: grant exactly two of the seven table
# privileges to a fresh role and assert all seven bits via has_table_privilege --
# exactly the two granted are t, the other five f. Many distinct pairs spanning
# the privilege set, plus grant-order independence and a two-statement grant that
# is equivalent to the combined list.
#
# Column order in every block: SELECT INSERT UPDATE DELETE TRUNCATE REFERENCES
# TRIGGER. The has_table_privilege oracle is byte-identical on real PostgreSQL
# and serenedb.
#
# All objects are prefixed combo_ (vedernikoff/clickclack/iceberg/mop lore).
# Roles are cluster-global, so the combo_ tag keeps names unique across files.
# The file is idempotent (DROP ... IF EXISTS up front) and self-cleaning.

statement ok
DROP TABLE IF EXISTS combo_iceberg;


statement ok
DROP ROLE IF EXISTS combo_pair_si;


statement ok
DROP ROLE IF EXISTS combo_pair_su;


statement ok
DROP ROLE IF EXISTS combo_pair_sd;


statement ok
DROP ROLE IF EXISTS combo_pair_iu;


statement ok
DROP ROLE IF EXISTS combo_pair_id;


statement ok
DROP ROLE IF EXISTS combo_pair_ud;


statement ok
DROP ROLE IF EXISTS combo_pair_st;


statement ok
DROP ROLE IF EXISTS combo_pair_rf;


statement ok
DROP ROLE IF EXISTS combo_pair_tt;


statement ok
DROP ROLE IF EXISTS combo_pair_dr;


statement ok
DROP ROLE IF EXISTS combo_pair_order;


statement ok
DROP ROLE IF EXISTS combo_pair_split;


statement ok
CREATE TABLE combo_iceberg (id int, clickclack text);


# ============================================================================
# Each role gets exactly one pair. Two t bits, five f bits per row.
# ============================================================================

# ---- pair: SELECT + INSERT ----

statement ok
CREATE ROLE combo_pair_si;


statement ok
GRANT SELECT, INSERT ON combo_iceberg TO combo_pair_si;


query
SELECT has_table_privilege('combo_pair_si','combo_iceberg','SELECT')     AS sel,
       has_table_privilege('combo_pair_si','combo_iceberg','INSERT')     AS ins,
       has_table_privilege('combo_pair_si','combo_iceberg','UPDATE')     AS upd,
       has_table_privilege('combo_pair_si','combo_iceberg','DELETE')     AS del,
       has_table_privilege('combo_pair_si','combo_iceberg','TRUNCATE')   AS trunc,
       has_table_privilege('combo_pair_si','combo_iceberg','REFERENCES') AS refs,
       has_table_privilege('combo_pair_si','combo_iceberg','TRIGGER')    AS trig;
----
sel	ins	upd	del	trunc	refs	trig
t	t	f	f	f	f	f


# ---- pair: SELECT + UPDATE ----

statement ok
CREATE ROLE combo_pair_su;


statement ok
GRANT SELECT, UPDATE ON combo_iceberg TO combo_pair_su;


query
SELECT has_table_privilege('combo_pair_su','combo_iceberg','SELECT')     AS sel,
       has_table_privilege('combo_pair_su','combo_iceberg','INSERT')     AS ins,
       has_table_privilege('combo_pair_su','combo_iceberg','UPDATE')     AS upd,
       has_table_privilege('combo_pair_su','combo_iceberg','DELETE')     AS del,
       has_table_privilege('combo_pair_su','combo_iceberg','TRUNCATE')   AS trunc,
       has_table_privilege('combo_pair_su','combo_iceberg','REFERENCES') AS refs,
       has_table_privilege('combo_pair_su','combo_iceberg','TRIGGER')    AS trig;
----
sel	ins	upd	del	trunc	refs	trig
t	f	t	f	f	f	f


