sel	ins	upd	del	trunc	refs	trig
t	f	f	t	f	f	t


# ============================================================================
# A triple assembled from three separate single-priv grants equals the same
# combined-list triple. combo_tri_split gets INSERT, then TRUNCATE, then
# TRIGGER -- in three statements, in non-canonical order.
# ============================================================================

statement ok
CREATE ROLE combo_tri_split;


statement ok
GRANT INSERT ON combo_mop TO combo_tri_split;


statement ok
GRANT TRUNCATE ON combo_mop TO combo_tri_split;


statement ok
GRANT TRIGGER ON combo_mop TO combo_tri_split;


query
SELECT has_table_privilege('combo_tri_split','combo_mop','SELECT')     AS sel,
       has_table_privilege('combo_tri_split','combo_mop','INSERT')     AS ins,
       has_table_privilege('combo_tri_split','combo_mop','UPDATE')     AS upd,
       has_table_privilege('combo_tri_split','combo_mop','DELETE')     AS del,
       has_table_privilege('combo_tri_split','combo_mop','TRUNCATE')   AS trunc,
       has_table_privilege('combo_tri_split','combo_mop','REFERENCES') AS refs,
       has_table_privilege('combo_tri_split','combo_mop','TRIGGER')    AS trig;
----
sel	ins	upd	del	trunc	refs	trig
f	t	f	f	t	f	t


# ============================================================================
# Cleanup.
# ============================================================================

statement ok
DROP TABLE combo_mop;


statement ok
DROP ROLE combo_tri_siu;


statement ok
DROP ROLE combo_tri_sid;


statement ok
DROP ROLE combo_tri_sud;


statement ok
DROP ROLE combo_tri_iud;


statement ok
DROP ROLE combo_tri_str;


statement ok
DROP ROLE combo_tri_sft;


statement ok
DROP ROLE combo_tri_idr;


statement ok
DROP ROLE combo_tri_heavy;


statement ok
DROP ROLE combo_tri_endpoints;


statement ok
DROP ROLE combo_tri_split;
