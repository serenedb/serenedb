# Combinatorial privilege grants, TRIPLES: grant exactly three of the seven
# table privileges to a fresh role and assert all seven bits via
# has_table_privilege -- exactly the three granted are t, the other four f.
# Many distinct triples drawn from across the privilege set, including all-DML
# triples, mixed read/write/schema triples, and the three "heavy" privileges
# (TRUNCATE/REFERENCES/TRIGGER) together.
#
# Column order in every block: SELECT INSERT UPDATE DELETE TRUNCATE REFERENCES
# TRIGGER. The has_table_privilege oracle is byte-identical on real PostgreSQL
# and serenedb.
#
# All objects are prefixed combo_ (vedernikoff/clickclack/mop lore). Roles are
# cluster-global, so the combo_ tag keeps names unique across files. The file
# is idempotent (DROP ... IF EXISTS up front) and self-cleaning.

statement ok
DROP TABLE IF EXISTS combo_mop;


statement ok
DROP ROLE IF EXISTS combo_tri_siu;


statement ok
DROP ROLE IF EXISTS combo_tri_sid;


statement ok
DROP ROLE IF EXISTS combo_tri_sud;


statement ok
DROP ROLE IF EXISTS combo_tri_iud;


statement ok
DROP ROLE IF EXISTS combo_tri_str;


statement ok
DROP ROLE IF EXISTS combo_tri_sft;


statement ok
DROP ROLE IF EXISTS combo_tri_idr;


statement ok
DROP ROLE IF EXISTS combo_tri_heavy;


statement ok
DROP ROLE IF EXISTS combo_tri_endpoints;


statement ok
DROP ROLE IF EXISTS combo_tri_split;


statement ok
CREATE TABLE combo_mop (id int, vedernikoff text);


# ============================================================================
# Each role gets exactly one triple. Three t bits, four f bits per row.
# ============================================================================

# ---- triple: SELECT + INSERT + UPDATE (the common read/write trio) ----

statement ok
CREATE ROLE combo_tri_siu;


statement ok
GRANT SELECT, INSERT, UPDATE ON combo_mop TO combo_tri_siu;


query
SELECT has_table_privilege('combo_tri_siu','combo_mop','SELECT')     AS sel,
       has_table_privilege('combo_tri_siu','combo_mop','INSERT')     AS ins,
       has_table_privilege('combo_tri_siu','combo_mop','UPDATE')     AS upd,
       has_table_privilege('combo_tri_siu','combo_mop','DELETE')     AS del,
       has_table_privilege('combo_tri_siu','combo_mop','TRUNCATE')   AS trunc,
       has_table_privilege('combo_tri_siu','combo_mop','REFERENCES') AS refs,
       has_table_privilege('combo_tri_siu','combo_mop','TRIGGER')    AS trig;
----
sel	ins	upd	del	trunc	refs	trig
t	t	t	f	f	f	f


# ---- triple: SELECT + INSERT + DELETE ----

statement ok
CREATE ROLE combo_tri_sid;


statement ok
GRANT SELECT, INSERT, DELETE ON combo_mop TO combo_tri_sid;


query
SELECT has_table_privilege('combo_tri_sid','combo_mop','SELECT')     AS sel,
       has_table_privilege('combo_tri_sid','combo_mop','INSERT')     AS ins,
       has_table_privilege('combo_tri_sid','combo_mop','UPDATE')     AS upd,
       has_table_privilege('combo_tri_sid','combo_mop','DELETE')     AS del,
       has_table_privilege('combo_tri_sid','combo_mop','TRUNCATE')   AS trunc,
       has_table_privilege('combo_tri_sid','combo_mop','REFERENCES') AS refs,
       has_table_privilege('combo_tri_sid','combo_mop','TRIGGER')    AS trig;
----
sel	ins	upd	del	trunc	refs	trig
t	t	f	t	f	f	f


# ---- triple: SELECT + UPDATE + DELETE ----

statement ok
CREATE ROLE combo_tri_sud;


statement ok
GRANT SELECT, UPDATE, DELETE ON combo_mop TO combo_tri_sud;


query
