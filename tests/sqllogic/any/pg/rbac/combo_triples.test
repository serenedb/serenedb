       has_table_privilege('combo_tri_iud','combo_mop','INSERT')     AS ins,
       has_table_privilege('combo_tri_iud','combo_mop','UPDATE')     AS upd,
       has_table_privilege('combo_tri_iud','combo_mop','DELETE')     AS del,
       has_table_privilege('combo_tri_iud','combo_mop','TRUNCATE')   AS trunc,
       has_table_privilege('combo_tri_iud','combo_mop','REFERENCES') AS refs,
       has_table_privilege('combo_tri_iud','combo_mop','TRIGGER')    AS trig;
----
sel	ins	upd	del	trunc	refs	trig
f	t	t	t	f	f	f


