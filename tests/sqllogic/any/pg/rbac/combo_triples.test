sel	ins	upd	del	trunc	refs	trig
f	f	f	f	t	t	t


# ---- triple: SELECT + DELETE + TRIGGER (the two endpoints plus a middle) ----

statement ok
CREATE ROLE combo_tri_endpoints;


statement ok
GRANT SELECT, DELETE, TRIGGER ON combo_mop TO combo_tri_endpoints;


query
SELECT has_table_privilege('combo_tri_endpoints','combo_mop','SELECT')     AS sel,
       has_table_privilege('combo_tri_endpoints','combo_mop','INSERT')     AS ins,
       has_table_privilege('combo_tri_endpoints','combo_mop','UPDATE')     AS upd,
