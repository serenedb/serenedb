       has_table_privilege('combo_tri_endpoints','combo_mop','TRUNCATE')   AS trunc,
       has_table_privilege('combo_tri_endpoints','combo_mop','REFERENCES') AS refs,
       has_table_privilege('combo_tri_endpoints','combo_mop','TRIGGER')    AS trig;
