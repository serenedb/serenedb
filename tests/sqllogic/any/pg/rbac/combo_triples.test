       has_table_privilege('combo_tri_sud','combo_mop','INSERT')     AS ins,
       has_table_privilege('combo_tri_sud','combo_mop','UPDATE')     AS upd,
       has_table_privilege('combo_tri_sud','combo_mop','DELETE')     AS del,
       has_table_privilege('combo_tri_sud','combo_mop','TRUNCATE')   AS trunc,
       has_table_privilege('combo_tri_sud','combo_mop','REFERENCES') AS refs,
       has_table_privilege('combo_tri_sud','combo_mop','TRIGGER')    AS trig;
----
sel	ins	upd	del	trunc	refs	trig
t	f	t	t	f	f	f


# ---- triple: INSERT + UPDATE + DELETE (all-write, no read) ----

statement ok
CREATE ROLE combo_tri_iud;


statement ok
GRANT INSERT, UPDATE, DELETE ON combo_mop TO combo_tri_iud;


query
