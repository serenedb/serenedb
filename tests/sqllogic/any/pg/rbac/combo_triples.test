       has_table_privilege('combo_tri_str','combo_mop','DELETE')     AS del,
       has_table_privilege('combo_tri_str','combo_mop','TRUNCATE')   AS trunc,
       has_table_privilege('combo_tri_str','combo_mop','REFERENCES') AS refs,
       has_table_privilege('combo_tri_str','combo_mop','TRIGGER')    AS trig;
