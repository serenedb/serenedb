# RETURNING reads the affected rows, so it needs SELECT on the RETURNED columns,
# at COLUMN granularity (PostgreSQL). A role holding table-level INSERT/UPDATE/
# DELETE plus column SELECT on only clickclack runs the bare DML fine and may
# RETURNING the granted column (clickclack), but RETURNING an ungranted column
# (mop) -- or RETURNING * which touches an ungranted column -- is refused.
# Tested for INSERT, UPDATE and DELETE. Byte-identical to real PostgreSQL.
#
# Lore: vedernikoff may write the iceberg but cannot read back column mop.

statement ok
DROP TABLE IF EXISTS crc_iceberg;


statement ok
DROP ROLE IF EXISTS crc_vedernikoff;


statement ok
CREATE TABLE crc_iceberg (clickclack int, babsky int, mop int);


statement ok
INSERT INTO crc_iceberg VALUES (1, 2, 3), (4, 5, 6);


statement ok
CREATE ROLE crc_vedernikoff LOGIN PASSWORD 'crc_vedernikoff_pw';


statement ok
GRANT INSERT, UPDATE, DELETE ON crc_iceberg TO crc_vedernikoff;


# Column SELECT on clickclack only (babsky, mop unreadable).
statement ok
GRANT SELECT (clickclack) ON crc_iceberg TO crc_vedernikoff;


# === INSERT ... RETURNING ===

# Bare INSERT assigning the granted column (no RETURNING) -> allowed.
connection c_ved user=crc_vedernikoff password=crc_vedernikoff_pw
statement ok
INSERT INTO crc_iceberg (clickclack) VALUES (7);


# RETURNING the granted column -> allowed (column-level SELECT).
connection c_ved_ret user=crc_vedernikoff password=crc_vedernikoff_pw
query
INSERT INTO crc_iceberg (clickclack) VALUES (70) RETURNING clickclack;
----
clickclack
70


# RETURNING an ungranted column is refused.
connection c_ved2 user=crc_vedernikoff password=crc_vedernikoff_pw
statement error
INSERT INTO crc_iceberg (clickclack) VALUES (8) RETURNING mop;
----
db error: ERROR: permission denied for table crc_iceberg<slt:ignore>


# RETURNING * touches every column -> refused (mop is ungranted).
connection c_ved3 user=crc_vedernikoff password=crc_vedernikoff_pw
statement error
INSERT INTO crc_iceberg (clickclack) VALUES (9) RETURNING *;
----
db error: ERROR: permission denied for table crc_iceberg<slt:ignore>


# === UPDATE ... SET const RETURNING ===

# Bare UPDATE, constant SET, WHERE reads the granted column (no RETURNING)
# -> allowed.
connection c_ved4 user=crc_vedernikoff password=crc_vedernikoff_pw
statement ok
UPDATE crc_iceberg SET babsky = 100 WHERE clickclack = 1;


# RETURNING the granted column -> allowed (column-level SELECT).
connection c_ved_uret user=crc_vedernikoff password=crc_vedernikoff_pw
query
UPDATE crc_iceberg SET babsky = 101 WHERE clickclack = 1 RETURNING clickclack;
----
clickclack
1


# RETURNING an ungranted column -> refused.
connection c_ved5 user=crc_vedernikoff password=crc_vedernikoff_pw
statement error
UPDATE crc_iceberg SET babsky = 100 WHERE clickclack = 1 RETURNING mop;
----
db error: ERROR: permission denied for table crc_iceberg<slt:ignore>


# RETURNING * -> refused (touches ungranted columns).
connection c_ved6 user=crc_vedernikoff password=crc_vedernikoff_pw
statement error
UPDATE crc_iceberg SET babsky = 100 WHERE clickclack = 1 RETURNING *;
----
db error: ERROR: permission denied for table crc_iceberg<slt:ignore>


# === DELETE ... WHERE false RETURNING ===

# Bare DELETE (WHERE false) reads no column (no RETURNING) -> allowed.
connection c_ved7 user=crc_vedernikoff password=crc_vedernikoff_pw
statement ok
DELETE FROM crc_iceberg WHERE false;


# RETURNING the granted column -> allowed (column-level SELECT). WHERE false
# returns no rows, so the projection is empty but the privilege check passes.
connection c_ved_dret user=crc_vedernikoff password=crc_vedernikoff_pw
statement ok
DELETE FROM crc_iceberg WHERE false RETURNING clickclack;


# RETURNING an ungranted column -> refused.
connection c_ved8 user=crc_vedernikoff password=crc_vedernikoff_pw
statement error
DELETE FROM crc_iceberg WHERE false RETURNING mop;
----
db error: ERROR: permission denied for table crc_iceberg<slt:ignore>


# RETURNING * -> refused (touches ungranted columns).
connection c_ved9 user=crc_vedernikoff password=crc_vedernikoff_pw
statement error
DELETE FROM crc_iceberg WHERE false RETURNING *;
----
db error: ERROR: permission denied for table crc_iceberg<slt:ignore>


statement ok
DROP TABLE crc_iceberg;


statement ok
DROP ROLE crc_vedernikoff;
