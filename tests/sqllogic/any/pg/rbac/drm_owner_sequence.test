# DROP ROLE must refuse while the role owns a SEQUENCE (pg_class.relowner points
# at it) or holds privileges on one, exactly like PostgreSQL -- otherwise the
# role's id lingers as a dangling owner/grantee in the catalog. The drop becomes
# possible once the dependency is removed: DROP the sequence, ALTER SEQUENCE ...
# OWNER TO another role, or REVOKE the sequence privilege. PostgreSQL prints
# SQLSTATE 2BP01 with message "role ... cannot be dropped because some objects
# depend on it"; the DETAIL line ("owner of sequence ..." vs "privileges for
# sequence ...") differs and is ignored with <slt:ignore>.
#
# Lore: mop_seq / log_seq are the sequences. vedernikoff is the role that owns
# them; clickclack is the role they get reassigned to.
#
# NOTE: the SERIAL-owned implicit sequence half of this slice is NOT covered --
# SereneDB does not materialize an implicit `<table>_<col>_seq` for serial /
# bigserial columns (no pg_class row of relkind 'S' appears), so there is no
# sequence object for a role to own. On PostgreSQL that implicit sequence
# follows ALTER TABLE ... OWNER TO and is reported as a separate "owner of
# sequence" dependency; only standalone sequences are exercised here.


statement ok
DROP TABLE IF EXISTS dseq_log;


statement ok
DROP SEQUENCE IF EXISTS dseq_mop_seq;


statement ok
DROP SEQUENCE IF EXISTS dseq_log_seq;


statement ok
DROP ROLE IF EXISTS dseq_vedernikoff;


statement ok
DROP ROLE IF EXISTS dseq_clickclack;


# ----------------------------------------------------------------------------
# Baseline: a role with no dependencies drops cleanly.
# ----------------------------------------------------------------------------
statement ok
CREATE ROLE dseq_clickclack;


statement ok
DROP ROLE dseq_clickclack;


# ----------------------------------------------------------------------------
# Standalone sequence owned by the role -> DROP ROLE refused; dropping the
# sequence removes the dependency.
# ----------------------------------------------------------------------------
statement ok
CREATE ROLE dseq_vedernikoff;


statement ok
CREATE SEQUENCE dseq_mop_seq;


statement ok
ALTER SEQUENCE dseq_mop_seq OWNER TO dseq_vedernikoff;


# PG: 2BP01, DETAIL "owner of sequence dseq_mop_seq" -> ignored.
statement error
DROP ROLE dseq_vedernikoff;
----
db error: ERROR: role "dseq_vedernikoff" cannot be dropped because some objects depend on it<slt:ignore>


# Drop the sequence -> dependency gone -> the role drops.
statement ok
DROP SEQUENCE dseq_mop_seq;


statement ok
DROP ROLE dseq_vedernikoff;


# ----------------------------------------------------------------------------
# Reassigning the owner with ALTER SEQUENCE ... OWNER TO moves the dependency:
# the old owner drops cleanly, the new owner becomes un-droppable.
# ----------------------------------------------------------------------------
statement ok
CREATE ROLE dseq_vedernikoff;


statement ok
CREATE ROLE dseq_clickclack;


statement ok
CREATE SEQUENCE dseq_mop_seq;


statement ok
ALTER SEQUENCE dseq_mop_seq OWNER TO dseq_vedernikoff;


statement ok
ALTER SEQUENCE dseq_mop_seq OWNER TO dseq_clickclack;


# Old owner no longer owns anything -> drops.
statement ok
DROP ROLE dseq_vedernikoff;


# New owner now carries the dependency -> refused.
statement error
DROP ROLE dseq_clickclack;
----
db error: ERROR: role "dseq_clickclack" cannot be dropped because some objects depend on it<slt:ignore>


statement ok
DROP SEQUENCE dseq_mop_seq;


statement ok
DROP ROLE dseq_clickclack;


# ----------------------------------------------------------------------------
# Owning more than one sequence: every owned sequence is a separate dependency.
# Dropping one is not enough; the role drops only once the last one is gone.
# ----------------------------------------------------------------------------
statement ok
CREATE ROLE dseq_vedernikoff;


statement ok
CREATE SEQUENCE dseq_mop_seq;


statement ok
CREATE SEQUENCE dseq_log_seq;


statement ok
ALTER SEQUENCE dseq_mop_seq OWNER TO dseq_vedernikoff;


statement ok
ALTER SEQUENCE dseq_log_seq OWNER TO dseq_vedernikoff;


# Both sequences depend on the role -> refused.
statement error
DROP ROLE dseq_vedernikoff;
----
db error: ERROR: role "dseq_vedernikoff" cannot be dropped because some objects depend on it<slt:ignore>


# Drop one sequence; the other still pins the role.
statement ok
DROP SEQUENCE dseq_mop_seq;


statement error
DROP ROLE dseq_vedernikoff;
----
db error: ERROR: role "dseq_vedernikoff" cannot be dropped because some objects depend on it<slt:ignore>


# Drop the last sequence -> role drops.
statement ok
DROP SEQUENCE dseq_log_seq;


statement ok
DROP ROLE dseq_vedernikoff;


# ----------------------------------------------------------------------------
# A USAGE privilege on a sequence is itself a dependency, independent of
# ownership. REVOKE removes it.
# ----------------------------------------------------------------------------
statement ok
CREATE ROLE dseq_vedernikoff;


statement ok
CREATE SEQUENCE dseq_mop_seq;


statement ok
GRANT USAGE ON SEQUENCE dseq_mop_seq TO dseq_vedernikoff;


# PG: DETAIL "privileges for sequence dseq_mop_seq" -> ignored.
statement error
DROP ROLE dseq_vedernikoff;
----
db error: ERROR: role "dseq_vedernikoff" cannot be dropped because some objects depend on it<slt:ignore>


statement ok
REVOKE USAGE ON SEQUENCE dseq_mop_seq FROM dseq_vedernikoff;


statement ok
DROP ROLE dseq_vedernikoff;


statement ok
DROP SEQUENCE dseq_mop_seq;


# ----------------------------------------------------------------------------
# Owner + grantee at once: the role owns one sequence and holds USAGE on
# another. Revoking the grant alone is not enough -- ownership still pins the
# role; the drop succeeds only after the owned sequence is gone too.
# ----------------------------------------------------------------------------
statement ok
CREATE ROLE dseq_vedernikoff;


statement ok
CREATE SEQUENCE dseq_mop_seq;


statement ok
CREATE SEQUENCE dseq_log_seq;


statement ok
ALTER SEQUENCE dseq_mop_seq OWNER TO dseq_vedernikoff;


statement ok
GRANT USAGE ON SEQUENCE dseq_log_seq TO dseq_vedernikoff;


# Two dependencies (owner of one, privileges on the other) -> refused.
statement error
DROP ROLE dseq_vedernikoff;
----
db error: ERROR: role "dseq_vedernikoff" cannot be dropped because some objects depend on it<slt:ignore>


# Revoke the grant; ownership of dseq_mop_seq still pins the role.
statement ok
REVOKE USAGE ON SEQUENCE dseq_log_seq FROM dseq_vedernikoff;


statement error
DROP ROLE dseq_vedernikoff;
----
db error: ERROR: role "dseq_vedernikoff" cannot be dropped because some objects depend on it<slt:ignore>


# Drop the owned sequence -> last dependency gone -> role drops.
statement ok
DROP SEQUENCE dseq_mop_seq;


statement ok
DROP ROLE dseq_vedernikoff;


statement ok
DROP SEQUENCE dseq_log_seq;


# ----------------------------------------------------------------------------
# CASCADE vs RESTRICT on the owned sequence itself: when the sequence has its
# own dependent (a column default referencing it via nextval), DROP SEQUENCE
# RESTRICT is refused and DROP SEQUENCE CASCADE removes both -- after which the
# owning role drops.
# ----------------------------------------------------------------------------
statement ok
CREATE ROLE dseq_vedernikoff;


statement ok
CREATE SEQUENCE dseq_mop_seq;


statement ok
ALTER SEQUENCE dseq_mop_seq OWNER TO dseq_vedernikoff;


statement ok
CREATE TABLE dseq_log (id int DEFAULT nextval('dseq_mop_seq'), msg text);


# The role still owns the sequence -> refused.
statement error
DROP ROLE dseq_vedernikoff;
----
db error: ERROR: role "dseq_vedernikoff" cannot be dropped because some objects depend on it<slt:ignore>


# The column default depends on the sequence -> plain/RESTRICT drop is refused.
# PG: DETAIL "default value for column id ..." -> ignored.
statement error
DROP SEQUENCE dseq_mop_seq RESTRICT;
----
db error: ERROR: cannot drop sequence dseq_mop_seq because other objects depend on it<slt:ignore>


# CASCADE drops the sequence and its dependent default in one shot.
statement ok
DROP SEQUENCE dseq_mop_seq CASCADE;


# The owner dependency is gone -> the role drops.
statement ok
DROP ROLE dseq_vedernikoff;


# ----------------------------------------------------------------------------
# Cleanup.
# ----------------------------------------------------------------------------
statement ok
DROP TABLE IF EXISTS dseq_log;


statement ok
DROP SEQUENCE IF EXISTS dseq_mop_seq;


statement ok
DROP SEQUENCE IF EXISTS dseq_log_seq;


statement ok
DROP ROLE IF EXISTS dseq_vedernikoff;


statement ok
DROP ROLE IF EXISTS dseq_clickclack;
