# Two formerly-divergent points on the GRANT ... ON TYPE / ON DOMAIN surface now
# match PostgreSQL:
#   1. typacl renders as a PG aclitem array literal ({...}, not a bracketed
#      list); each element is asserted per-element (order-independent, since PG
#      orders PUBLIC's "=U" element before the owner row).
#   2. GRANT/REVOKE ... ON DOMAIN naming a non-domain raises the semantic error
#      "X is not a domain" (serenedb has no domain types, so the name is never a
#      domain -- the same outcome PostgreSQL produces for a non-domain).
#
# Vedernikoff lore: the clickclack composite type; vedernikoff the grantee.

statement ok
DROP TYPE IF EXISTS gobjacl_dom_clickclack;


statement ok
DROP ROLE IF EXISTS gobjacl_dom_vedernikoff;


statement ok
CREATE TYPE gobjacl_dom_clickclack AS (id int, payload text);


statement ok
CREATE ROLE gobjacl_dom_vedernikoff;


statement ok
GRANT USAGE ON TYPE gobjacl_dom_clickclack TO gobjacl_dom_vedernikoff;


# typacl is a brace-delimited aclitem array; the grantee element is present.
query
SELECT e FROM (
  SELECT unnest(typacl::text[]) AS e FROM pg_type WHERE typname = 'gobjacl_dom_clickclack'
) g WHERE e LIKE 'gobjacl_dom_vedernikoff=%';
----
e
gobjacl_dom_vedernikoff=U/postgres


# The PUBLIC default element ("=U/owner") is also present.
query
SELECT e FROM (
  SELECT unnest(typacl::text[]) AS e FROM pg_type WHERE typname = 'gobjacl_dom_clickclack'
) g WHERE e LIKE '=U/%';
----
e
=U/postgres


# GRANT ... ON DOMAIN naming a non-domain is rejected semantically.
statement error
GRANT USAGE ON DOMAIN gobjacl_dom_clickclack TO gobjacl_dom_vedernikoff;
----
db error: ERROR: "gobjacl_dom_clickclack" is not a domain<slt:ignore>


# REVOKE ... ON DOMAIN is rejected the same way.
statement error
REVOKE USAGE ON DOMAIN gobjacl_dom_clickclack FROM gobjacl_dom_vedernikoff;
----
db error: ERROR: "gobjacl_dom_clickclack" is not a domain<slt:ignore>


statement ok
DROP TYPE gobjacl_dom_clickclack;


statement ok
DROP ROLE gobjacl_dom_vedernikoff;
