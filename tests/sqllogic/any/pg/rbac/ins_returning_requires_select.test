# INSERT ... RETURNING reads the affected rows, so it requires SELECT on the
# projected columns IN ADDITION to INSERT (PostgreSQL). An INSERT-only role
# running RETURNING must be refused -- otherwise it leaks column values it
# cannot read (privilege escalation), and on serenedb it could crash the
# server on the return-chunk projection path. Plain INSERT (no RETURNING) by
# an INSERT-only role still works.

statement ok
DROP TABLE IF EXISTS irs_kostya;


statement ok
DROP ROLE IF EXISTS irs_insonly;


statement ok
DROP ROLE IF EXISTS irs_full;


statement ok
CREATE TABLE irs_kostya (id int, secret text);


statement ok
CREATE ROLE irs_insonly LOGIN PASSWORD 'pw';


statement ok
CREATE ROLE irs_full LOGIN PASSWORD 'pw';


statement ok
GRANT INSERT ON irs_kostya TO irs_insonly;


statement ok
GRANT INSERT, SELECT ON irs_kostya TO irs_full;


# Plain INSERT (no RETURNING) works with INSERT alone.
connection c_ins user=irs_insonly
statement ok
INSERT INTO irs_kostya VALUES (1, 'mop');


# INSERT ... RETURNING by the INSERT-only role is refused (needs SELECT).
connection c_ins user=irs_insonly
statement error
INSERT INTO irs_kostya VALUES (2, 'iceberg') RETURNING id;
----
db error: ERROR: permission denied for table irs_kostya<slt:ignore>


# RETURNING a text column (the crash trigger) is refused the same way.
connection c_ins user=irs_insonly
statement error
INSERT INTO irs_kostya (id, secret) VALUES (3, 'topsecret') RETURNING id, secret;
----
db error: ERROR: permission denied for table irs_kostya<slt:ignore>


# With SELECT also granted, RETURNING is PERMITTED (not 42501). Asserted as
# statement ok -- only that authorization passes; the returned values are not
# checked because serenedb has a separate, unrelated bug where RETURNING
# projects integer columns incorrectly (out of scope for this privilege test).
connection c_full user=irs_full
statement ok
INSERT INTO irs_kostya VALUES (9, 'clickclack') RETURNING secret;


# The server is alive after all of the above (no crash).
connection default
query
SELECT count(*) >= 2 AS alive FROM irs_kostya;
----
alive
t


# ---- cleanup ----

statement ok
DROP TABLE irs_kostya;


statement ok
DROP ROLE irs_insonly;


statement ok
DROP ROLE irs_full;
