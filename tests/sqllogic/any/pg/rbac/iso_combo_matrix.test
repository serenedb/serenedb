query
SELECT has_table_privilege('iso_androed','iso_deadinside','SELECT')     AS sel,
       has_table_privilege('iso_androed','iso_deadinside','INSERT')     AS ins,
       has_table_privilege('iso_androed','iso_deadinside','UPDATE')     AS upd,
       has_table_privilege('iso_androed','iso_deadinside','DELETE')     AS del,
       has_table_privilege('iso_androed','iso_deadinside','TRUNCATE')   AS trunc,
       has_table_privilege('iso_androed','iso_deadinside','REFERENCES') AS refs,
       has_table_privilege('iso_androed','iso_deadinside','TRIGGER')    AS trig;
----
sel	ins	upd	del	trunc	refs	trig
t	f	f	f	f	t	t


# iso_babsky -> INSERT, UPDATE, DELETE, TRUNCATE only.
query
SELECT has_table_privilege('iso_androed','iso_babsky','SELECT')     AS sel,
       has_table_privilege('iso_androed','iso_babsky','INSERT')     AS ins,
       has_table_privilege('iso_androed','iso_babsky','UPDATE')     AS upd,
       has_table_privilege('iso_androed','iso_babsky','DELETE')     AS del,
       has_table_privilege('iso_androed','iso_babsky','TRUNCATE')   AS trunc,
       has_table_privilege('iso_androed','iso_babsky','REFERENCES') AS refs,
       has_table_privilege('iso_androed','iso_babsky','TRIGGER')    AS trig;
----
sel	ins	upd	del	trunc	refs	trig
f	t	t	t	t	f	f


# iso_pudge -> ALL seven.
query
SELECT has_table_privilege('iso_androed','iso_pudge','SELECT')     AS sel,
       has_table_privilege('iso_androed','iso_pudge','INSERT')     AS ins,
       has_table_privilege('iso_androed','iso_pudge','UPDATE')     AS upd,
       has_table_privilege('iso_androed','iso_pudge','DELETE')     AS del,
       has_table_privilege('iso_androed','iso_pudge','TRUNCATE')   AS trunc,
       has_table_privilege('iso_androed','iso_pudge','REFERENCES') AS refs,
       has_table_privilege('iso_androed','iso_pudge','TRIGGER')    AS trig;
----
sel	ins	upd	del	trunc	refs	trig
t	t	t	t	t	t	t


# iso_mop -> control table, never granted: all seven f.
query
SELECT has_table_privilege('iso_androed','iso_mop','SELECT')     AS sel,
       has_table_privilege('iso_androed','iso_mop','INSERT')     AS ins,
       has_table_privilege('iso_androed','iso_mop','UPDATE')     AS upd,
       has_table_privilege('iso_androed','iso_mop','DELETE')     AS del,
       has_table_privilege('iso_androed','iso_mop','TRUNCATE')   AS trunc,
       has_table_privilege('iso_androed','iso_mop','REFERENCES') AS refs,
       has_table_privilege('iso_androed','iso_mop','TRIGGER')    AS trig;
----
sel	ins	upd	del	trunc	refs	trig
f	f	f	f	f	f	f


# ============================================================================
# Wide cross-table no-leak block. Each column probes a privilege that a table
# does NOT hold, picking from another table's combination. Every cell is f.
#   SELECT is on clickclack/deadinside/pudge -> f on kostya, babsky, mop
#   INSERT is on clickclack/babsky/pudge      -> f on kostya, deadinside, mop
#   TRUNCATE is on babsky/pudge               -> f on clickclack, kostya, deadinside
#   REFERENCES is on deadinside/pudge         -> f on clickclack, kostya, babsky
# ============================================================================

query
SELECT has_table_privilege('iso_androed','iso_kostya','SELECT')        AS s_ko,
       has_table_privilege('iso_androed','iso_babsky','SELECT')        AS s_ba,
       has_table_privilege('iso_androed','iso_deadinside','INSERT')    AS i_di,
       has_table_privilege('iso_androed','iso_clickclack','TRUNCATE')  AS t_cc,
       has_table_privilege('iso_androed','iso_kostya','TRUNCATE')      AS t_ko,
       has_table_privilege('iso_androed','iso_clickclack','REFERENCES') AS r_cc,
       has_table_privilege('iso_androed','iso_babsky','REFERENCES')    AS r_ba;
----
s_ko	s_ba	i_di	t_cc	t_ko	r_cc	r_ba
f	f	f	f	f	f	f


# ============================================================================
# Re-grant on the empty control table iso_mop is isolated to it: granting
# SELECT,INSERT there flips exactly those two bits and leaves every prior
# table's vector exactly as established above.
# ============================================================================

statement ok
GRANT SELECT, INSERT ON iso_mop TO iso_androed;


query
SELECT has_table_privilege('iso_androed','iso_mop','SELECT')        AS mop_s,
       has_table_privilege('iso_androed','iso_mop','INSERT')        AS mop_i,
       has_table_privilege('iso_androed','iso_mop','UPDATE')        AS mop_u,
       has_table_privilege('iso_androed','iso_clickclack','SELECT') AS cc_s,
       has_table_privilege('iso_androed','iso_kostya','UPDATE')     AS ko_u,
       has_table_privilege('iso_androed','iso_pudge','TRUNCATE')    AS pu_t;
----
mop_s	mop_i	mop_u	cc_s	ko_u	pu_t
t	t	f	t	t	t


# ============================================================================
# Cleanup.
# ============================================================================

statement ok
DROP TABLE iso_clickclack;


statement ok
DROP TABLE iso_kostya;


statement ok
DROP TABLE iso_deadinside;


statement ok
DROP TABLE iso_babsky;


statement ok
DROP TABLE iso_pudge;


statement ok
DROP TABLE iso_mop;


statement ok
DROP ROLE iso_androed;
