# Multi-table isolation with COMPOUND grants: six tables, each receiving a
# distinct COMBINATION of privileges granted to the same role. The full
# seven-privilege vector is asserted per table, and a wide cross-table block
# proves each combination is confined to its own table. The has_table_privilege
# oracle is byte-identical on real PostgreSQL and serenedb.
#
# Grant plan (role iso_androed):
#   iso_clickclack -> SELECT, INSERT
#   iso_kostya     -> UPDATE, DELETE
#   iso_deadinside -> SELECT, REFERENCES, TRIGGER
#   iso_babsky     -> INSERT, UPDATE, DELETE, TRUNCATE
#   iso_pudge      -> ALL (the full seven)
#   iso_mop        -> (nothing -- a control table that must stay all-f)
# All names prefixed iso_; idempotent and self-cleaning.

statement ok
DROP TABLE IF EXISTS iso_clickclack;


statement ok
DROP TABLE IF EXISTS iso_kostya;


statement ok
DROP TABLE IF EXISTS iso_deadinside;


statement ok
DROP TABLE IF EXISTS iso_babsky;


statement ok
DROP TABLE IF EXISTS iso_pudge;


statement ok
DROP TABLE IF EXISTS iso_mop;


statement ok
DROP ROLE IF EXISTS iso_androed;


statement ok
CREATE TABLE iso_clickclack (id int, mop text);


statement ok
CREATE TABLE iso_kostya (id int, mop text);


statement ok
CREATE TABLE iso_deadinside (id int, mop text);


statement ok
CREATE TABLE iso_babsky (id int, mop text);


statement ok
CREATE TABLE iso_pudge (id int, mop text);


statement ok
CREATE TABLE iso_mop (id int, mop text);


statement ok
CREATE ROLE iso_androed;


# ============================================================================
# Apply the distinct per-table combinations.
# ============================================================================

statement ok
GRANT SELECT, INSERT ON iso_clickclack TO iso_androed;


statement ok
GRANT UPDATE, DELETE ON iso_kostya TO iso_androed;


statement ok
GRANT SELECT, REFERENCES, TRIGGER ON iso_deadinside TO iso_androed;


statement ok
GRANT INSERT, UPDATE, DELETE, TRUNCATE ON iso_babsky TO iso_androed;


statement ok
GRANT ALL ON iso_pudge TO iso_androed;


# ============================================================================
# Per-table full vectors. Column order: SELECT INSERT UPDATE DELETE TRUNCATE
# REFERENCES TRIGGER.
# ============================================================================

# iso_clickclack -> SELECT, INSERT only.
query
SELECT has_table_privilege('iso_androed','iso_clickclack','SELECT')     AS sel,
       has_table_privilege('iso_androed','iso_clickclack','INSERT')     AS ins,
       has_table_privilege('iso_androed','iso_clickclack','UPDATE')     AS upd,
       has_table_privilege('iso_androed','iso_clickclack','DELETE')     AS del,
       has_table_privilege('iso_androed','iso_clickclack','TRUNCATE')   AS trunc,
       has_table_privilege('iso_androed','iso_clickclack','REFERENCES') AS refs,
       has_table_privilege('iso_androed','iso_clickclack','TRIGGER')    AS trig;
----
sel	ins	upd	del	trunc	refs	trig
t	t	f	f	f	f	f


# iso_kostya -> UPDATE, DELETE only.
query
SELECT has_table_privilege('iso_androed','iso_kostya','SELECT')     AS sel,
       has_table_privilege('iso_androed','iso_kostya','INSERT')     AS ins,
       has_table_privilege('iso_androed','iso_kostya','UPDATE')     AS upd,
       has_table_privilege('iso_androed','iso_kostya','DELETE')     AS del,
       has_table_privilege('iso_androed','iso_kostya','TRUNCATE')   AS trunc,
       has_table_privilege('iso_androed','iso_kostya','REFERENCES') AS refs,
       has_table_privilege('iso_androed','iso_kostya','TRIGGER')    AS trig;
----
sel	ins	upd	del	trunc	refs	trig
f	f	t	t	f	f	f


