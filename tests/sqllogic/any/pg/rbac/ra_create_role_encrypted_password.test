# ENCRYPTED PASSWORD: PG accepts ENCRYPTED as a legacy synonym of PASSWORD (the
# password is always stored hashed regardless). Accepted in CREATE and ALTER,
# alone and after WITH. Byte-identical on PostgreSQL and serenedb.
#
# Lore: vedernikoff's key is sealed the old-fashioned way.

statement ok
DROP ROLE IF EXISTS enc_vedernikoff;


statement ok
CREATE ROLE enc_vedernikoff LOGIN ENCRYPTED PASSWORD 'mop';


# The role is created and LOGIN-capable.
query
SELECT rolcanlogin FROM pg_roles WHERE rolname = 'enc_vedernikoff';
----
rolcanlogin
t


# WITH ENCRYPTED PASSWORD combo.
statement ok
DROP ROLE IF EXISTS enc_clickclack;


statement ok
CREATE ROLE enc_clickclack WITH ENCRYPTED PASSWORD 'iceberg' LOGIN;


query
SELECT rolcanlogin FROM pg_roles WHERE rolname = 'enc_clickclack';
----
rolcanlogin
t


# ALTER ROLE ... ENCRYPTED PASSWORD rotates it (the role stays LOGIN-capable).
# (Whether pg_authid.rolpassword is exposed to a superuser differs between
# engines, so it is not asserted here.)
statement ok
ALTER ROLE enc_vedernikoff ENCRYPTED PASSWORD 'mop2';


query
SELECT rolcanlogin FROM pg_roles WHERE rolname = 'enc_vedernikoff';
----
rolcanlogin
t


# Cleanup.
statement ok
DROP ROLE enc_vedernikoff;


statement ok
DROP ROLE enc_clickclack;
