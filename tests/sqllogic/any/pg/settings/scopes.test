# ----------------------------------------------------------------------
# Different ways to set config options, different scopes —
# rollback/commit semantics.
#
# Covers: plain SET, SET SESSION, SET LOCAL, SET GLOBAL, set_config(),
# across both built-in (search_path, default_transaction_read_only)
# and extension (sdb_write_conflict_policy) options.
# ----------------------------------------------------------------------

statement ok
CREATE SCHEMA some_schema;


statement ok
SET search_path TO public;


# --- plain SET (AUTOMATIC → SESSION) inside txn ---
statement ok
BEGIN;


statement ok
SET search_path TO some_schema;


query
SHOW search_path;
----
search_path
some_schema


statement ok
ROLLBACK;


# Reverts on rollback
query
SHOW search_path;
----
search_path
public


# Same plain SET, committed
statement ok
BEGIN;


statement ok
SET search_path TO some_schema;


statement ok
COMMIT;


# Keeps on commit
query
SHOW search_path;
----
search_path
some_schema


# --- SET SESSION equivalent — same semantics as plain SET ---
statement ok
BEGIN;


statement ok
SET SESSION search_path TO public;


statement ok
ROLLBACK;


query
SHOW search_path;
----
search_path
some_schema


# --- SET LOCAL reverts on commit AND rollback ---
statement ok
BEGIN;


statement ok
SET LOCAL search_path TO public;


query
SHOW search_path;
----
search_path
public


statement ok
COMMIT;


# SET LOCAL reverted on commit — back to pre-txn value
query
SHOW search_path;
----
search_path
some_schema


statement ok
BEGIN;


statement ok
SET LOCAL search_path TO public;


statement ok
ROLLBACK;


query
SHOW search_path;
----
search_path
some_schema


# --- set_config(name, value, is_local=false) — plain SET equivalent ---
statement ok
BEGIN;


statement ok
SELECT set_config('search_path', 'public', false);


statement ok
ROLLBACK;


# is_local=false behaves like plain SET → reverts on rollback
query
SHOW search_path;
----
search_path
some_schema


# --- set_config(name, value, is_local=true) — SET LOCAL equivalent ---
statement ok
BEGIN;


statement ok
SELECT set_config('search_path', 'public', true);


query
SHOW search_path;
----
search_path
public


statement ok
COMMIT;


# is_local=true reverts on commit too
query
SHOW search_path;
----
search_path
some_schema


# --- SET GLOBAL is not rolled back ---
statement ok
BEGIN;


statement ok
SET GLOBAL default_transaction_read_only TO true;


statement ok
ROLLBACK;


# GLOBAL SET is not tracked for rollback
onlyif serenedb
query
SHOW default_transaction_read_only;
----
default_transaction_read_only
on


statement ok
SET GLOBAL default_transaction_read_only TO false;


# --- Extension option (sdb_write_conflict_policy) — plain + local, commit + rollback ---
onlyif serenedb
statement ok
BEGIN;


onlyif serenedb
statement ok
SET sdb_write_conflict_policy TO 'do_nothing';


onlyif serenedb
statement ok
ROLLBACK;


onlyif serenedb
query
SHOW sdb_write_conflict_policy;
----
sdb_write_conflict_policy
emit_error


onlyif serenedb
statement ok
BEGIN;


onlyif serenedb
statement ok
SET LOCAL sdb_write_conflict_policy TO 'do_nothing';


onlyif serenedb
statement ok
COMMIT;


# SET LOCAL on extension option reverts on commit too
onlyif serenedb
query
SHOW sdb_write_conflict_policy;
----
sdb_write_conflict_policy
emit_error
