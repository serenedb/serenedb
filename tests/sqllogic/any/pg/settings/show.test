query
SHOW search_path;
----
search_path
"$user", public


query error
SHOW non_existed_variable;
----
db error: ERROR: unrecognized configuration parameter "non_existed_variable"<slt:ignore>


statement ok
SET search_path TO root,root2;


query
SHOW search_path;
----
search_path
root, root2


statement ok
RESET ALL;


query
SHOW search_path;
----
search_path
"$user", public


statement ok
SET search_path = "1a", 121, _12, "1$a", "CaseSensitive", NOt_SEnsitive, "A";


query
SHOW search_path
----
search_path
"1a", 121, _12, "1$a", "CaseSensitive", not_sensitive, "A"


statement ok
SET search_path TO DEFAULT;


query
SHOW search_path;
----
search_path
"$user", public


query
SHOW client_encoding;
----
client_encoding
UTF8


statement ok
SET client_encoding TO DEFAULT;


query
SHOW client_encoding;
----
client_encoding
UTF8


query
SHOW default_transaction_read_only;
----
default_transaction_read_only
off


query
SHOW in_hot_standby;
----
in_hot_standby
off


query
SHOW integer_datetimes;
----
integer_datetimes
on


query
SHOW scram_iterations;
----
scram_iterations
4096


query
SHOW server_encoding;
----
server_encoding
UTF8


query
SHOW standard_conforming_strings;
----
standard_conforming_strings
on


# ----------------------------------------------------------------------
# PG-compat: SHOW <multi-word alias> resolves to the same underlying
# variable as SHOW <varname>. Real drivers issue these forms on startup
# (r2dbc, pgjdbc, Npgsql), so the parser must accept them verbatim.
# ----------------------------------------------------------------------

query
SHOW TRANSACTION ISOLATION LEVEL;
----
transaction_isolation
<slt:ignore>


query
SHOW transaction_isolation;
----
transaction_isolation
<slt:ignore>


query
SHOW SESSION AUTHORIZATION;
----
session_authorization
postgres


query
SHOW session_authorization;
----
session_authorization
postgres


statement ok
SET TimeZone = 'Etc/UTC';


query
SHOW TIME ZONE;
----
TimeZone
Etc/UTC


query
SHOW timezone;
----
TimeZone
Etc/UTC


# PG canonical column headers for the other CamelCase outlier GUCs.
query
SHOW DateStyle;
----
DateStyle
ISO, MDY


query
SHOW datestyle;
----
DateStyle
ISO, MDY


query
SHOW IntervalStyle;
----
IntervalStyle
postgres


query
SHOW intervalstyle;
----
IntervalStyle
postgres


# DESCRIBE / DESC accept the same aliases (mirrors the regular SHOW <name> branch).
# PG has no DESCRIBE/DESC keyword, so this branch is serenedb-only.
skipif postgres
query
DESCRIBE TRANSACTION ISOLATION LEVEL;
----
transaction_isolation
<slt:ignore>


skipif postgres
query
DESC TIME ZONE;
----
TimeZone
Etc/UTC


# Aliases survive case variation -- keywords are case-insensitive.
query
show transaction isolation level;
----
transaction_isolation
<slt:ignore>
