query
SELECT
  ARRAY[1, 0, 1] as basic,
  ARRAY[1, NULL, 1] as with_nulls
----
basic	with_nulls
{1,0,1}	{1,NULL,1}


query
SELECT
  ARRAY[true, false, true] as basic,
  ARRAY[false, NULL, NULL] as with_nulls
----
basic	with_nulls
{t,f,t}	{f,NULL,NULL}


query
SELECT array_to_string(ARRAY[127, 0, 0, 1], '.');
----
array_to_string
127.0.0.1


query
SELECT array_to_string(ARRAY['abba', 'banana'], '*');
----
array_to_string
abba*banana


query
SELECT array_position(ARRAY[10, 20, 30, 40], 30);
----
array_position
3


query
SELECT array_position(ARRAY[5, 15, 25], 15);
----
array_position
2


query
SELECT cardinality(ARRAY[10, 20, 30, 40]);
----
cardinality
4


query
SELECT cardinality(ARRAY[5, 15, 25]);
----
cardinality
3


statement ok
CREATE TABLE t(id INT, names TEXT[]);


statement ok
INSERT INTO t VALUES (1, ARRAY['some', 'the', 'whaaat', NULL::TEXT]), (2, ARRAY['yes', 'NO', 'Maybe']), (3, ARRAY[]::TEXT[]), (4, NULL::TEXT[]);


query
SELECT * FROM t;
----
id	names
1	{some,the,whaaat,NULL}
2	{yes,NO,Maybe}
3	{}
4	NULL


# Array elements whose text form contains whitespace (timestamps, intervals)
# must be wrapped in double quotes so the array's text representation matches
# canonical PG output.

query
SELECT ARRAY[TIMESTAMP '2024-01-15 12:00:00'] as ts_arr;
----
ts_arr
{"2024-01-15 12:00:00"}


query
SELECT ARRAY[TIMESTAMP '2024-01-15 12:00:00', TIMESTAMP '2024-06-30 23:59:59'] as ts_arr;
----
ts_arr
{"2024-01-15 12:00:00","2024-06-30 23:59:59"}


query
SELECT ARRAY[TIMESTAMP '2024-01-15 12:00:00', NULL] as ts_arr;
----
ts_arr
{"2024-01-15 12:00:00",NULL}


query
SELECT ARRAY[TIMESTAMPTZ '2024-01-15 12:00:00+00'] as tstz_arr;
----
tstz_arr
{"2024-01-15 12:00:00+00"}


query
SELECT ARRAY[INTERVAL '1 day'] as iv_arr;
----
iv_arr
{"1 day"}
