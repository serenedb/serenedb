# Test each implicit coercion declared in pg_functions_registration.hpp
# Pattern: CREATE FUNCTION accepting target type, call with source type
# TINYINT (int1) and HUGEINT don't exist in standard PG - skipped

# ====== INTEGER target ======
statement ok
CREATE FUNCTION coerce_to_integer(x INTEGER) RETURNS INTEGER AS $$ SELECT x $$ LANGUAGE sql


query
SELECT coerce_to_integer(1::smallint);
----
coerce_to_integer
1

statement ok
DROP FUNCTION coerce_to_integer(INTEGER)


# ====== BIGINT target ======

statement ok
CREATE FUNCTION coerce_to_bigint(x BIGINT) RETURNS BIGINT AS $$ SELECT x $$ LANGUAGE sql


query
SELECT coerce_to_bigint(1::smallint);
----
coerce_to_bigint
1


query
SELECT coerce_to_bigint(1::integer);
----
coerce_to_bigint
1

statement ok
DROP FUNCTION coerce_to_bigint(BIGINT)


