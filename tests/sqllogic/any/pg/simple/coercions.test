# ====== TIMESTAMP target ======

statement ok
CREATE FUNCTION coerce_to_timestamp(x TIMESTAMP) RETURNS TIMESTAMP AS $$ SELECT x $$ LANGUAGE sql


query
SELECT coerce_to_timestamp('2024-01-01'::date);
----
coerce_to_timestamp
2024-01-01 00:00:00


statement ok
DROP FUNCTION coerce_to_timestamp(TIMESTAMP)


# ====== OID target: integer and bigint coerce to oid; xid/cid/xid8/tid do NOT ======
statement ok
CREATE FUNCTION coerce_to_oid(x OID) RETURNS OID AS $$ SELECT x $$ LANGUAGE sql


query
SELECT coerce_to_oid(1::integer);
----
coerce_to_oid
1


query
SELECT coerce_to_oid(1::bigint);
----
coerce_to_oid
1


# reg* -> oid coercions all exist in PG
query
SELECT coerce_to_oid(1259::regclass);
----
coerce_to_oid
1259

query
SELECT coerce_to_oid(23::regtype);
----
coerce_to_oid
23

query
SELECT coerce_to_oid(11::regnamespace);
----
coerce_to_oid
11

query
SELECT coerce_to_oid(43::regproc);
----
coerce_to_oid
43

query
SELECT coerce_to_oid(97::regoper);
----
coerce_to_oid
97

query
SELECT coerce_to_oid(97::regoperator);
----
coerce_to_oid
97


query
SELECT coerce_to_oid(43::regprocedure);
----
coerce_to_oid
43


query
SELECT coerce_to_oid(10::regrole);
----
coerce_to_oid
10


query
SELECT coerce_to_oid(3748::regconfig);
----
coerce_to_oid
3748


query
SELECT coerce_to_oid(3769::regdictionary);
----
coerce_to_oid
3769


query
SELECT coerce_to_oid(100::regcollation);
----
coerce_to_oid
100


statement ok
DROP FUNCTION coerce_to_oid(OID)


# Verify oid/xid/cid/xid8/tid do NOT implicitly coerce to integer or bigint
statement ok
CREATE FUNCTION coerce_to_integer2(x INTEGER) RETURNS INTEGER AS $$ SELECT x $$ LANGUAGE sql


query error
SELECT coerce_to_integer2(1::oid);
----
db error: ERROR: function coerce_to_integer2(oid) does not exist
HINT: No function matches the given name and argument types. You might need to add explicit type casts.


query error
SELECT coerce_to_integer2(1259::regclass);
----
db error: ERROR: function coerce_to_integer2(regclass) does not exist
HINT: No function matches the given name and argument types. You might need to add explicit type casts.


statement ok
DROP FUNCTION coerce_to_integer2(INTEGER)


# Verify integer/bigint/oid do NOT implicitly coerce to xid/cid/tid/xid8
statement ok
CREATE FUNCTION coerce_to_xid(x XID) RETURNS XID AS $$ SELECT x $$ LANGUAGE sql


query error
SELECT coerce_to_xid(1::integer);
----
db error: ERROR: function coerce_to_xid(integer) does not exist
HINT: No function matches the given name and argument types. You might need to add explicit type casts.


query error
SELECT coerce_to_xid(1::bigint);
----
db error: ERROR: function coerce_to_xid(bigint) does not exist
HINT: No function matches the given name and argument types. You might need to add explicit type casts.


query error
SELECT coerce_to_xid(1::oid);
----
db error: ERROR: function coerce_to_xid(oid) does not exist
HINT: No function matches the given name and argument types. You might need to add explicit type casts.


statement ok
DROP FUNCTION coerce_to_xid(XID)


