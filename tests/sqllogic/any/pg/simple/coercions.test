# ====== NAME target: unknown literal and text coerce to name ======
statement ok
CREATE FUNCTION coerce_to_name(x NAME) RETURNS NAME AS $$ SELECT x $$ LANGUAGE sql


query
SELECT coerce_to_name('hello');
----
coerce_to_name
hello


query
SELECT coerce_to_name('hello'::text);
----
coerce_to_name
hello


statement ok
DROP FUNCTION coerce_to_name(NAME)


