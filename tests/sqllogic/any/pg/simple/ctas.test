# SELECT INTO tests

statement count 10000
SELECT
  iq,
  CONCAT('salary ', salary::text, '$') AS salary,
  'i do nothing and gain money' AS description
INTO vedernikoff
FROM
  generate_series(1, 100) AS clickclack(iq),
  generate_series(1, 100) AS serenedb(salary);


