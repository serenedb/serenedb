CREATE FUNCTION ihavenoname(
  INTEGER,
  INTEGER
)
RETURNS INTEGER
AS $$
  SELECT $1 - $2
$$ LANGUAGE sql;


query
SELECT * FROM ihavenoname(1000, 7)
----
ihavenoname
993


