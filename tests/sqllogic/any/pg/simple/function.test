# ── Overload merging (CREATE FUNCTION with multiple signatures) ──

statement ok
CREATE FUNCTION ovl_test(x INTEGER) RETURNS INTEGER AS $$ SELECT x $$ LANGUAGE sql;


statement ok
CREATE FUNCTION ovl_test(x TEXT) RETURNS TEXT AS $$ SELECT x $$ LANGUAGE sql;


query
SELECT ovl_test(42);
----
ovl_test
42


query
SELECT ovl_test('hello');
----
ovl_test
hello


# CREATE OR REPLACE preserves other overloads
statement ok
CREATE OR REPLACE FUNCTION ovl_test(x INTEGER) RETURNS INTEGER AS $$ SELECT x + 1 $$ LANGUAGE sql;


query
SELECT ovl_test(42);
----
ovl_test
43


query
SELECT ovl_test('hello');
----
ovl_test
hello

# ── DROP FUNCTION with overload signature ──

# Drop only the INTEGER overload
statement ok
DROP FUNCTION ovl_test(INTEGER);

# TEXT overload still works
query
SELECT ovl_test('hello');
----
ovl_test
hello


# INTEGER overload is gone
statement error
SELECT ovl_test(42);


# Drop remaining overload (no parens = all overloads)
statement ok
DROP FUNCTION ovl_test;


statement error
SELECT ovl_test('hello');


# ── LIMIT 1 for scalar functions returning multi-row sources ──

statement ok
CREATE OR REPLACE FUNCTION itmustbelimited()
RETURNS INTEGER
AS $$
  SELECT *
  FROM
  (
    VALUES (1), (3), (3), (7)
  )
$$ LANGUAGE sql;


query
SELECT * FROM itmustbelimited();
----
itmustbelimited
1


# BEGIN ATOMIC with scalar RETURNS also gets LIMIT 1
statement ok
CREATE FUNCTION limited_atomic()
RETURNS INTEGER
LANGUAGE sql
BEGIN ATOMIC
  SELECT * FROM (VALUES (10), (20), (30));
END;


query
SELECT * FROM limited_atomic();
----
limited_atomic
10
