# Basic test
statement ok
CREATE TABLE t1 (a INTEGER PRIMARY KEY, b INTEGER);

statement count 3
INSERT INTO t1 VALUES (1, 10), (2, 20), (3, 30);

query
SELECT * FROM t1 ORDER BY a;
----
a	b
1	10
2	20
3	30

statement count 0
INSERT INTO t1 VALUES (1, 10), (2, 20), (3, 30) ON CONFLICT DO NOTHING;

statement count 1
INSERT INTO t1 VALUES (123, 123), (123, 123), (123, 123) ON CONFLICT DO NOTHING;

statement count 1
DELETE FROM t1 WHERE a = 123;

onlyif serenedb # native constraint error
statement error
INSERT INTO t1 VALUES (1, 10), (2, 20), (3, 30);
----
db error: ERROR: Duplicate key "a: 1" violates primary key constraint.


skipif serenedb # Postgres error
statement error
INSERT INTO t1 VALUES (1, 10), (2, 20), (3, 30);
----
db error: ERROR: duplicate key value violates unique constraint "t1_pkey"
DETAIL: Key (a)=(1) already exists.


onlyif serenedb # native constraint error
statement error
INSERT INTO t1 VALUES (1, 10), (4, 40), (5, 50);
----
db error: ERROR: Duplicate key "a: 1" violates primary key constraint.


skipif serenedb # Postgres error
statement error
INSERT INTO t1 VALUES (1, 10), (4, 40), (5, 50);
----
db error: ERROR: duplicate key value violates unique constraint "t1_pkey"
DETAIL: Key (a)=(1) already exists.


statement count 2
INSERT INTO t1 VALUES (4, 400), (5, 500);

query
SELECT * FROM t1 ORDER BY a;
----
a	b
1	10
2	20
3	30
4	400
5	500

onlyif serenedb # native constraint error
statement error
INSERT INTO t1 VALUES (100, 100), (100, 100);
----
db error: ERROR: PRIMARY KEY or UNIQUE constraint violation: duplicate key "100"


skipif serenedb # Postgres error
statement error
INSERT INTO t1 VALUES (100, 100), (100, 100);
----
db error: ERROR: duplicate key value violates unique constraint "t1_pkey"
DETAIL: Key (a)=(100) already exists.


statement ok
DROP TABLE t1;

# Conflict in transaction
statement ok
CREATE TABLE t2 (a INTEGER PRIMARY KEY, b INTEGER);

statement ok
BEGIN;

statement count 1
INSERT INTO t2 VALUES (1, 10);

query
SELECT * FROM t2 ORDER BY a;
----
a	b
1	10

# But still cannot insert into table as values is in transaction
onlyif serenedb # native constraint error
statement error
INSERT INTO t2 VALUES (1, 42);
----
db error: ERROR: PRIMARY KEY or UNIQUE constraint violation: duplicate key "1"


skipif serenedb # Postgres error
statement error
INSERT INTO t2 VALUES (1, 42);
----
db error: ERROR: duplicate key value violates unique constraint "t2_pkey"
DETAIL: Key (a)=(1) already exists.


statement ok
COMMIT

# Rollbacked!
query
SELECT * FROM t2 ORDER BY a;
----
a	b

statement ok
BEGIN;

statement count 1
INSERT INTO t2 VALUES (1, 10);

statement count 1
DELETE FROM t2 WHERE a = 1;

query
SELECT * FROM t2 ORDER BY a;
----
a	b

statement count 1
INSERT INTO t2 VALUES (1, 10);

query
SELECT * FROM t2 ORDER BY a;
----
a	b
1	10

statement count 1
UPDATE t2 SET a = 2, b = 20 WHERE a = 1;

query
SELECT * FROM t2 ORDER BY a;
----
a	b
2	20

statement count 1
INSERT INTO t2 VALUES (1, 10);

query
SELECT * FROM t2 ORDER BY a;
----
a	b
1	10
2	20

statement ok
COMMIT;

statement ok
DROP TABLE t2;

# ON CONFLICT targeting a UNIQUE (non-PK) column: the conflict target must bind
# to the unique constraint's index, not only to the primary key.
statement ok
CREATE TABLE t3 (a INT, b INT UNIQUE);

statement count 1
INSERT INTO t3 VALUES (1, 10);

statement ok
INSERT INTO t3 VALUES (2, 10) ON CONFLICT (b) DO NOTHING;

query
SELECT a, b FROM t3 ORDER BY b;
----
a	b
1	10

statement ok
INSERT INTO t3 VALUES (3, 10) ON CONFLICT (b) DO UPDATE SET a = 99;

query
SELECT a, b FROM t3 ORDER BY b;
----
a	b
99	10

statement ok
DROP TABLE t3;

# ON CONFLICT DO UPDATE on a TEXT key whose first 12 bytes equal a shorter key
# present in the same transaction. String min/max stats truncate at 12 bytes; the
# 12-byte key ('k'x12) stores an EXACT max and the 13-byte key ('k'x12 + 'g')
# stores a TRUNCATED max with the same 12 bytes. Merging the two must keep the max
# TRUNCATED -- otherwise the zonemap prunes the row group holding the 13-byte key
# and the second upsert is misrouted to INSERT, throwing a spurious duplicate key.
statement ok
CREATE TABLE t4 (k TEXT PRIMARY KEY, v INT);

statement ok
BEGIN;

statement ok
INSERT INTO t4 VALUES ('kkkkkkkkkkkk', 1) ON CONFLICT (k) DO UPDATE SET v = EXCLUDED.v;

statement ok
INSERT INTO t4 VALUES ('kkkkkkkkkkkkg', 2) ON CONFLICT (k) DO UPDATE SET v = EXCLUDED.v;

statement ok
INSERT INTO t4 VALUES ('kkkkkkkkkkkkg', 3) ON CONFLICT (k) DO UPDATE SET v = EXCLUDED.v;

statement ok
COMMIT;

query
SELECT k, v FROM t4 ORDER BY k;
----
k	v
kkkkkkkkkkkk	1
kkkkkkkkkkkkg	3

statement ok
DROP TABLE t4;
