query error
SELECT '["a", "b", c]'::json;


query
SELECT 'true'::json, 'false'::json, 'null'::json;
----
json	json	json
true	false	null

query
SELECT '[1, 2, 3]'::json -> 1;
----
?column?
2

query
SELECT '[1, 2, 3]'::json -> -1;
----
?column?
3


query
SELECT '[1, 2, 3]'::json -> 4;
----
?column?
NULL


query
SELECT '["string"]'::json -> 0;
----
?column?
"string"


query
SELECT '["string"]'::json ->> 0;
----
?column?
string


query
SELECT '[[1, 2], [3, 4]]'::json -> 0 -> 1;
----
?column?
2


query
SELECT '[[ 1,     2 ], [3, 4]]'::json ->> 0;
----
?column?
[ 1,     2 ]


query
SELECT concat('[[ 1,     2 ], [3, 4]]'::json ->> 0, '[[ 1,     2 ], [3, 4]]'::json ->> 0);
----
concat
[ 1,     2 ][ 1,     2 ]


query
SELECT '{"a" : 10, "b": [ 1,   3 ]}'::json -> 'a';
----
?column?
10


query
SELECT '{"a" : 10, "b": [ 1,   3 ]}'::json -> 'b' -> -1;
----
?column?
3


query
SELECT '[{"b" : 0, "A": [  " a", "aba"]}]'::json -> -1 ->> 'A'
----
?column?
[  " a", "aba"]


query
SELECT '{"val":null}'::json->>'val' IS NULL;
----
?column?
t


query
SELECT concat('[{"b" : 0, "A": [  " a", "aba"]}]'::json -> -1 ->> 'A', '[{"b" : 0, "A": [  " a", "aba"]}]'::json -> -1 ->> 'A');
----
concat
[  " a", "aba"][  " a", "aba"]


query
SELECT '{"a": {"b": [ "foo" , "bar"]}}'::json #> ARRAY['a', 'b', '1'];
----
?column?
"bar"


query
SELECT '{"a": {"b": ["foo" , "bar"]}}'::json #> ARRAY['a', 'b'];
----
?column?
["foo" , "bar"]


query
SELECT concat('{"a": {"b": [ "foo" , "bar"]}}'::json #>> ARRAY['a', 'b', '1'], '{"a": {"b": [ "foo" , "bar"]}}'::json #>> ARRAY['a', 'b', '1']);
----
concat
barbar


query
SELECT json_extract_path_text('{"a": {"b": [1, 2, 3]}}'::json, 'a', 'b', '0');
----
json_extract_path_text
1


query
SELECT json_extract_path('{"a": {"b": [1, 2, 3]}}'::json, 'a', 'b') -> -1;
----
?column?
3


# json_typeof

query
SELECT json_typeof('123'::json);
----
json_typeof
number


query
SELECT json_typeof('"hello"'::json);
----
json_typeof
string


query
SELECT json_typeof('true'::json);
----
json_typeof
boolean


query
SELECT json_typeof('null'::json);
----
json_typeof
null


query
SELECT json_typeof('[1,2]'::json);
----
json_typeof
array


query
SELECT json_typeof('{"a":1}'::json);
----
json_typeof
object


# json_array_length

query
SELECT json_array_length('[1,2,3,{"f1":1,"f2":[5,6]},4]'::json);
----
json_array_length
5


query
SELECT json_array_length('[]'::json);
----
json_array_length
0


# json_strip_nulls

query
SELECT json_strip_nulls('[{"f1":1,"f2":null},2,null,3]'::json);
----
json_strip_nulls
[{"f1":1},2,null,3]


query
SELECT json_strip_nulls('{"a":1,"b":null,"c":{"d":null,"e":2}}'::json);
----
json_strip_nulls
{"a":1,"c":{"e":2}}
