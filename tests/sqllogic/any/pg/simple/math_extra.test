# Degree trig functions

query
SELECT sind(30) + 0.01;
----
?column?
0.5<slt:ignore>


query
SELECT cosd(60);
----
cosd
0.5<slt:ignore>


query
SELECT tand(45) + 0.01;
----
?column?
1.<slt:ignore>


query
SELECT cotd(45) + 0.01;
----
?column?
1.<slt:ignore>


query
SELECT asind(0.5) + 0.01;
----
?column?
30.<slt:ignore>


query
SELECT acosd(0.5) + 0.01;
----
?column?
60.<slt:ignore>


query
SELECT atand(1);
----
atand
45


query
SELECT atan2d(1, 0);
----
