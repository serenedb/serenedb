# log10

query
SELECT log10(1000);
----
log10
3


query
SELECT log10(100);
----
log10
2


# log with base

query
SELECT log(2.0, 64.0);
----
log
6<slt:ignore>


# cot

query
SELECT cot(1);
----
cot
0.6420926159343306


# factorial

query
SELECT factorial(5);
----
factorial
120


query
SELECT factorial(0);
----
factorial
1


# div

query
SELECT div(9, 4);
----
div
2


query
SELECT div(-9, 4);
----
div
-2


# gcd

query
SELECT gcd(1071, 462);
----
gcd
