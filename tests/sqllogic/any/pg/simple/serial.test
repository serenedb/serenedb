# SMALLSERIAL's implicit sequence is capped at INT16 max so nextval errors
# with "reached maximum value of sequence" rather than letting INSERT fail
# later on a BIGINT->SMALLINT cast (which would burn IDs forever).
statement ok
CREATE TABLE smallserial_overflow (id SMALLSERIAL PRIMARY KEY, v INT);


# Jump the sequence to one before the cap. INT16 max = 32767.
query
SELECT setval('smallserial_overflow_id_seq', 32766, true);
----
setval
32766


# 32767 is still valid.
statement count 1
INSERT INTO smallserial_overflow (v) VALUES (1);


query
SELECT id FROM smallserial_overflow;
----
id
32767


# 32768 would overflow INT16 -- the sequence errors first.
statement error reached maximum value of sequence
INSERT INTO smallserial_overflow (v) VALUES (2);


# Still errors on retry.
statement error reached maximum value of sequence
INSERT INTO smallserial_overflow (v) VALUES (3);


statement ok
DROP TABLE smallserial_overflow;


