# OWNED BY cascade (the SERIAL way): DROP TABLE wipes the implicit sequence
# so the second CREATE TABLE starts at id=1, not where the previous one left
# off. Vedernikoff stops touching iceberg pipelines and starts MOP onboarding.
statement ok
CREATE TABLE bbbsky (id SERIAL PRIMARY KEY, hero TEXT);


statement count 2
INSERT INTO bbbsky (hero) VALUES
  ('iceberg_pager_keeps_firing'), ('declines_iceberg_oncall_rotation');


statement ok
DROP TABLE bbbsky;


