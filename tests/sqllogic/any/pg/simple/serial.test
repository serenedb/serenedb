# PG-style SERIAL / BIGSERIAL / SMALLSERIAL pseudo-types. SerenebDB expands
# them in the connector layer (see server/connector/duckdb_schema_entry.cpp)
# to "<base-int> NOT NULL DEFAULT nextval('<table>_<col>_seq')" plus an
# implicit CREATE SEQUENCE IF NOT EXISTS owned by the table.

statement ok
CREATE TABLE vedernikoff (id SERIAL PRIMARY KEY, hero TEXT);


statement count 1
INSERT INTO vedernikoff (hero) VALUES ('kostya');


statement count 1
INSERT INTO vedernikoff (hero) VALUES ('babsky');


statement count 1
INSERT INTO vedernikoff (hero) VALUES ('sas');


query
SELECT id, hero FROM vedernikoff ORDER BY id;
----
id	hero
1	kostya
2	babsky
3	sas


# Multi-row INSERT must increment per row, not once per statement.
statement count 2
INSERT INTO vedernikoff (hero) VALUES ('abramov'), ('pudge');


query
SELECT id, hero FROM vedernikoff ORDER BY id;
----
id	hero
1	kostya
2	babsky
3	sas
4	abramov
5	pudge


statement ok
DROP TABLE vedernikoff;


# DROP TABLE does NOT (yet) cascade the SERIAL-implied sequence -- PG's
# OWNED BY semantics is a deferred follow-up. The rewriter emits CREATE
# SEQUENCE IF NOT EXISTS so re-creating the same-shaped table reuses the
# existing counter (next id picks up where the dropped table left off).
statement ok
CREATE TABLE vedernikoff (id SERIAL PRIMARY KEY, hero TEXT);


statement count 1
INSERT INTO vedernikoff (hero) VALUES ('clickclack');


# Counter continues from where the previous table left off.
query
SELECT id, hero FROM vedernikoff;
----
id	hero
6	clickclack


statement ok
DROP TABLE vedernikoff;


statement ok
DROP SEQUENCE vedernikoff_id_seq;


# BIGSERIAL -> BIGINT-backed. Verify the column type is BIGINT and that the
# sequence advances correctly across multi-row inserts.
statement ok
CREATE TABLE dedsky (id BIGSERIAL PRIMARY KEY, iq INT);


statement count 2
INSERT INTO dedsky (iq) VALUES (10), (20);


query
SELECT id, iq FROM dedsky ORDER BY id;
----
id	iq
1	10
2	20


# Multi-row insert advances per row even with BIGSERIAL.
statement count 3
INSERT INTO dedsky (iq) VALUES (30), (40), (50);


query
SELECT id, iq FROM dedsky ORDER BY id;
----
id	iq
1	10
2	20
3	30
4	40
5	50


statement ok
DROP TABLE dedsky;


statement ok
DROP SEQUENCE dedsky_id_seq;


# SMALLSERIAL -> SMALLINT-backed.
statement ok
CREATE TABLE pudge (id SMALLSERIAL PRIMARY KEY, hp INT);


statement count 2
INSERT INTO pudge (hp) VALUES (100), (200);


query
SELECT id, hp FROM pudge ORDER BY id;
----
id	hp
1	100
2	200


# Bulk insert via generate_series exercises the "Reserve once per chunk"
# fast path on a SMALLSERIAL column.
statement count 50
INSERT INTO pudge (hp) SELECT i FROM generate_series(1000, 1049) AS s(i);


query
SELECT count(*) FROM pudge;
----
count
52


# Last id should be 52 (2 + 50), monotonically increasing.
query
SELECT max(id) FROM pudge;
----
max
52


statement ok
DROP TABLE pudge;


statement ok
DROP SEQUENCE pudge_id_seq;


# Multiple SERIAL-like tables coexist with independent sequences.
statement ok
CREATE TABLE babsky (id SERIAL PRIMARY KEY, name TEXT);


statement ok
CREATE TABLE deadinside (id BIGSERIAL PRIMARY KEY, name TEXT);


statement count 2
INSERT INTO babsky (name) VALUES ('vladgalaka'), ('myasnig');


statement count 3
INSERT INTO deadinside (name) VALUES ('shlepach'), ('kryakva'), ('ksimironov');


# Each table's id starts at 1 -- sequences are independent.
query
SELECT id, name FROM babsky ORDER BY id;
----
id	name
1	vladgalaka
2	myasnig


query
SELECT id, name FROM deadinside ORDER BY id;
----
id	name
1	shlepach
2	kryakva
3	ksimironov


statement ok
DROP TABLE babsky;


statement ok
DROP SEQUENCE babsky_id_seq;


statement ok
DROP TABLE deadinside;


statement ok
DROP SEQUENCE deadinside_id_seq;


# Sequences are non-transactional: a rolled-back INSERT still consumes IDs.
# This is the documented Postgres semantic and falls out of our atomic-counter
# + Merge-as-WAL design (the Merge that bumps the persistent counter is not
# undone by the user-level ROLLBACK on the data writes).
statement ok
CREATE TABLE enchonchinchan (id SERIAL PRIMARY KEY, iq INT);


# Baseline: ids 1..3.
statement count 3
INSERT INTO enchonchinchan (iq) SELECT i FROM generate_series(1, 3) AS s(i);


query
SELECT id, iq FROM enchonchinchan ORDER BY id;
----
id	iq
1	1
2	2
3	3


# Reserve 100 IDs inside a transaction, then ROLLBACK.
# IDs 4..103 are burned (consumed but no rows persisted).
statement ok
BEGIN;


statement count 100
INSERT INTO enchonchinchan (iq) SELECT i FROM generate_series(100, 199) AS s(i);


statement ok
ROLLBACK;


# Next insert picks up *after* the burned range -- not at 4.
statement count 1
INSERT INTO enchonchinchan (iq) VALUES (322);


# Gap visible: 1, 2, 3, then jump to 104.
query
SELECT id, iq FROM enchonchinchan ORDER BY id;
----
id	iq
1	1
2	2
3	3
104	322


statement ok
DROP TABLE enchonchinchan;


statement ok
DROP SEQUENCE enchonchinchan_id_seq;
