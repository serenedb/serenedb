1	mop_first_day_swag


# DROP TABLE alone is enough now -- the SERIAL sequence dies with it.
statement ok
DROP TABLE bbbsky;


statement error
DROP SEQUENCE bbbsky_id_seq;


# Name mangling: a pre-existing sequence with the SERIAL's natural name
# pushes the implicit one to a `_seq1` suffix instead of failing.
statement ok
CREATE SEQUENCE clickclack_id_seq START WITH 1000;


statement ok
CREATE TABLE clickclack (id SERIAL PRIMARY KEY, hero TEXT);


statement count 1
INSERT INTO clickclack (hero) VALUES ('two_weeks_notice_drafted');


# Mangled sequence (clickclack_id_seq1) starts at 1, not 1000.
query
SELECT id, hero FROM clickclack;
----
id	hero
1	two_weeks_notice_drafted


# Pre-existing sequence is still around with its own counter.
query
SELECT nextval('clickclack_id_seq');
----
nextval
1000


# DROP TABLE drops only the OWNED BY sequence (clickclack_id_seq1), the
# pre-existing clickclack_id_seq survives.
statement ok
DROP TABLE clickclack;


statement error
DROP SEQUENCE clickclack_id_seq1;


statement ok
DROP SEQUENCE clickclack_id_seq;


# Counter cleanup: a sequence dropped via DROP SEQUENCE doesn't leave its
# counter behind. Re-creating with the same name starts from start_value.
statement ok
CREATE SEQUENCE mop_offer_seq START WITH 50;


query
SELECT nextval('mop_offer_seq'), nextval('mop_offer_seq');
----
nextval	nextval
50	51


statement ok
DROP SEQUENCE mop_offer_seq;


statement ok
CREATE SEQUENCE mop_offer_seq START WITH 50;


# Fresh counter -- not 52.
query
SELECT nextval('mop_offer_seq');
----
nextval
50


statement ok
DROP SEQUENCE mop_offer_seq;


