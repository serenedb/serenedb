# Tests for additional string functions


# starts_with

query
SELECT starts_with('alphabet', 'alph');
----
starts_with
t


query
SELECT starts_with('alphabet', 'xyz');
----
starts_with
f


query
SELECT starts_with('alphabet', '');
----
starts_with
t


query
SELECT starts_with('', '');
----
starts_with
t


# concat_ws

query
SELECT concat_ws(',', 'a', 'b', 'c');
----
concat_ws
a,b,c


query
SELECT concat_ws(',', 'a', NULL, 'c');
----
concat_ws
a,c


query
SELECT concat_ws(' - ', 'hello', 'world');
----
concat_ws
hello - world


# initcap

query
SELECT initcap('hi THOMAS');
----
initcap
Hi Thomas


query
SELECT initcap('hello world');
----
initcap
Hello World


# repeat

query
SELECT repeat('Pg', 4);
----
repeat
PgPgPgPg


query
SELECT repeat('abc', 0);
----
repeat
(empty)


# translate

query
SELECT translate('12345', '143', 'ax');
----
translate
a2x5


# ascii

query
SELECT ascii('x');
----
ascii
120


query
SELECT ascii('A');
----
ascii
65


# left

query
SELECT left('abcde', 2);
----
left
ab


query
SELECT left('abcde', 10);
----
left
abcde


# right

query
SELECT right('abcde', 2);
----
right
de


query
SELECT right('abcde', 10);
----
right
abcde


# overlay

query
SELECT overlay('Txxxxas' placing 'hom' from 2 for 4);
----
overlay
Thomas


# md5

query
SELECT md5('abc');
----
md5
900150983cd24fb0d6963f7d28e17f72


query
SELECT md5('');
----
md5
d41d8cd98f00b204e9800998ecf8427e


# to_hex

query
SELECT to_hex(2147483647);
----
to_hex
7fffffff


query
SELECT to_hex(0);
----
to_hex
0


query
SELECT to_hex(1);
----
to_hex
1


query
SELECT to_hex(10);
----
to_hex
a


query
SELECT to_hex(100);
----
to_hex
64


query
SELECT to_hex(-1);
----
to_hex
ffffffff


query
SELECT to_hex(0::bigint);
----
to_hex
0


query
SELECT to_hex(1::bigint);
----
to_hex
1


query
SELECT to_hex(100::bigint);
----
to_hex
64


query
SELECT to_hex(-1::bigint);
----
to_hex
ffffffffffffffff


# bit_length

query
SELECT bit_length('jose');
----
bit_length
32


# octet_length

query
SELECT octet_length('jose');
----
octet_length
4


# char_length / character_length

query
SELECT char_length('jose');
----
char_length
4


query
SELECT character_length('hello');
----
character_length
5


# string_to_array

query
SELECT string_to_array('a,b,c', ',');
----
string_to_array
{a,b,c}


query
SELECT string_to_array('xx~~yy~~zz', '~~');
----
string_to_array
{xx,yy,zz}


query
SELECT string_to_array('one', ',');
----
string_to_array
{one}


# string_to_array with null_string (3-arg form)

query
SELECT string_to_array('a,,b,c', ',', '');
----
string_to_array
{a,NULL,b,c}


query
SELECT string_to_array('a,NULL,b', ',', 'NULL');
----
string_to_array
{a,NULL,b}


query
SELECT string_to_array('a,b,c', ',', 'b');
----
string_to_array
{a,NULL,c}


query
SELECT string_to_array('abc', ',', NULL);
----
string_to_array
{abc}


query
SELECT string_to_array('a,b,c', ',', 'x');
----
string_to_array
{a,b,c}


# regexp_like

query
SELECT regexp_like('Hello World', 'world$', 'i');
----
regexp_like
t


query
SELECT regexp_like('hello', 'xyz');
----
regexp_like
f


