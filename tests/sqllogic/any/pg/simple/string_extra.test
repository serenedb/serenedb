# encode / decode

query
SELECT encode('123\000\001'::bytea, 'base64');
----
encode
MTIzAAE=


query
SELECT encode('\x1234'::bytea, 'hex');
----
encode
1234


query
SELECT decode('MTIzAAE=', 'base64') = '123\000\001'::bytea AS ok;
----
ok
t


query
SELECT decode('1234', 'hex') = '\x1234'::bytea AS ok;
----
ok
t


# get_byte / set_byte

query
SELECT get_byte('\x1234567890'::bytea, 0);
----
get_byte
18


query
SELECT get_byte('\x1234567890'::bytea, 4);
----
get_byte
144


# pg_client_encoding

query
SELECT pg_client_encoding();
----
pg_client_encoding
UTF8


# convert_from

query
SELECT convert_from('hello'::bytea, 'UTF8');
----
convert_from
hello


# convert_to

query
SELECT convert_to('hello', 'UTF8') = 'hello'::bytea AS ok;
----
ok
t


# normalize

query
SELECT normalize('hello', NFC);
----
normalize
hello


# num_nonnulls / num_nulls

query
SELECT num_nonnulls(1, NULL, 2);
----
num_nonnulls
2


query
SELECT num_nulls(1, NULL, 2);
----
num_nulls
1


query
SELECT num_nonnulls(NULL, NULL, NULL);
----
num_nonnulls
0


query
SELECT num_nulls(NULL, NULL, NULL);
----
num_nulls
3


# current_setting

query
SELECT current_setting('server_version');
----
current_setting
18.3


query
SELECT current_setting('client_encoding');
----
current_setting
UTF8


query
SELECT current_setting('nonexistent_param', true) IS NULL AS ok;
----
ok
t


# set_config

query
SELECT set_config('application_name', 'test_app', false);
----
set_config
test_app


query
SELECT current_setting('application_name');
----
current_setting
test_app


# octet_length: ASCII string (bytes == chars)

query
SELECT octet_length('hello');
----
octet_length
5

# octet_length: multi-byte UTF-8 string (bytes > chars)

query
SELECT octet_length('мир');
----
octet_length
6

query
SELECT length('мир');
----
length
3


# quote_ident: reserved words must be quoted

query
SELECT quote_ident('select');
----
quote_ident
"select"


query
SELECT quote_ident('table');
----
quote_ident
"table"


query
SELECT quote_ident('normal_ident');
----
quote_ident
normal_ident


query
SELECT quote_ident('MixedCase');
----
quote_ident
"MixedCase"


query
SELECT quote_ident('has space');
----
quote_ident
"has space"


# format

query
SELECT format('Hello %s', 'World');
----
format
Hello World


query
SELECT format('Hello %s, %1$s', 'World');
----
format
Hello World, World


query
SELECT format('Testing %%, Pro%sQL', 'gre');
----
format
Testing %, ProgreQL


query
SELECT format('INSERT INTO %I VALUES(%L)', 'Foo bar', E'b\\a\'r');
----
format
INSERT INTO "Foo bar" VALUES(E'b\\\\a''r')


query
SELECT format('|%10s|', 'foo');
----
format
|       foo|


query
SELECT format('|%-10s|', 'foo');
----
format
|foo       |


query
SELECT format('|%s|', 'foo');
----
format
|foo|


query
SELECT format('%s %s', 'one', 'two');
----
format
one two


query
SELECT format('%2$s %1$s', 'one', 'two');
----
format
two one


query
SELECT format('%L', NULL::text);
----
format
NULL


query
SELECT format('|%5s|', 'x');
----
format
|    x|


query
SELECT format('|%-5s|', 'x');
----
format
|x    |


query
SELECT format('%3$s %1$s %2$s', 'a', 'b', 'c');
----
format
c a b


query
SELECT format('%1$s %1$s', 'repeat');
----
format
repeat repeat


query
SELECT format('%s', NULL);
----
format
(empty)


query
SELECT format('%I', 'simple');
----
format
simple


query
SELECT format('%I', 'Hello World');
----
format
"Hello World"


query
SELECT format('%I', 'with"quote');
----
format
"with""quote"


query
SELECT format('%L', 'it''s');
----
format
'it''s'


query
SELECT format('%L', E'back\\slash');
----
format
E'back\\\\slash'


query
SELECT format('no args');
----
format
no args


query
SELECT format('100%% done');
----
format
100% done


# PostgreSQL format() does not support '*' for dynamic width (unlike C printf).
# '*' is treated as an unknown type specifier and produces an error.

onlyif serenedb
statement error
SELECT format('%*s', 'foo');
----
db error: ERROR: unrecognized format() type specifier "*"


onlyif serenedb
statement error
SELECT format('%*s', 5, 'foo');
----
db error: ERROR: function pg_format(unknown, integer, unknown) does not exist
HINT: No function matches the given name and argument types. You might need to add explicit type casts.


onlyif serenedb
statement error
SELECT format('hello %q world', 'x');
----
db error: ERROR: unrecognized format() type specifier "q"
