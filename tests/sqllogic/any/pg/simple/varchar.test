# Basic varchar literal
query
SELECT 'hello'::text;
----
text
hello


# Empty varchar
query
SELECT ''::text;
----
text
(empty)


# Varchar with spaces
query
SELECT '  spaces  '::text;
----
text
  spaces  


# Varchar with special characters
query
SELECT 'hello@world#2024'::text;
----
text
hello@world#2024


# Varchar with newline character (escape syntax)
query
SELECT E'line1\nline2\nline3'::text;
----
text
line1\nline2\nline3


query
SELECT E'line1\nline2'::text;
----
text
line1\nline2


query
SELECT E'line1'::text;
----
text
line1


# Varchar without newline character
query
SELECT 'line1\nline2'::text;
----
text
line1\\nline2



# Varchar with tab (escape syntax)
query
SELECT E'tab\there'::text;
----
text
tab\there


# Varchar with quotes
query
SELECT 'it''s working'::text;
----
text
it's working

# Varchar with backslash
query
SELECT '\it works'::text;
----
text
\\it works


# Varchar with unicode — Chinese
query
SELECT '你好世界'::text;
----
text
你好世界


# Varchar with unicode — emoji
query
SELECT '🌍🌎🌏'::text;
----
text
🌍🌎🌏


# Varchar with unicode — accented
query
SELECT 'café résumé naïve'::text;
----
text
café résumé naïve


# Varchar array — single element
query
SELECT ARRAY['hello'::text];
----
array
{hello}


# Varchar array — multiple elements
query
SELECT ARRAY['admin'::text, 'editor'::text, 'auditor'::text];
----
array
{admin,editor,auditor}


# Varchar array — spaces
query
SELECT ARRAY['hello world'::text, 'foo bar'::text];
----
array
{"hello world","foo bar"}


# Varchar array — with empty strings
query
SELECT ARRAY[''::text, ''::text, ''::text];
----
array
{"","",""}


# Varchar array — unicode strings
query
SELECT ARRAY['世界'::text, '🌍'::text, 'café'::text];
----
array
{世界,🌍,café}


# NULL varchar
query
SELECT NULL::text;
----
text
NULL


# Varchar array with NULL
query
SELECT ARRAY[NULL::text];
----
array
{NULL}


# Varchar array with NULL and values
query
SELECT ARRAY['value'::text, NULL::text, 'another'::text];
----
array
{value,NULL,another}


# Array with quotes
query
SELECT ARRAY['value'::text, NULL::text, '"quotes"'::text];
----
array
{value,NULL,"\\"quotes\\""}


# Array with item containing spaces
query
SELECT ARRAY['value'::text, NULL::text, '"quo tes"'::text];
----
array
{value,NULL,"\\"quo tes\\""}


# Array with item containing both unicode and spaces
query
SELECT ARRAY['世界'::text, '🌍'::text, 'ca   fé'::text];
----
array
{世界,🌍,"ca   fé"}

# From bytea
query
SELECT ('\x01 02 03 4d'::bytea)::text;
----
text
\\x0102034d

statement ok
SET BYTEA_OUTPUT = 'EsCaPe';

# From bytea
skipif pg-wire-extended
query
SELECT ('\x01 02 03 4d'::bytea)::text;
----
text
\\001\\002\\003M


query
SELECT 'str' = 'str'::text;
----
?column?
t
