query
SELECT * FROM pg_show_all_settings() LIMIT 0
----
name	setting	unit	category	short_desc	extra_desc	context	vartype	source	min_val	max_val	enumvals	boot_val	reset_val	sourcefile	sourceline	pending_restart


query
SELECT * FROM pg_lock_status() LIMIT 0
----
locktype	database	relation	page	tuple	virtualxid	transactionid	classid	objid	objsubid	virtualtransaction	pid	mode	granted	fastpath	waitstart


query
SELECT * FROM pg_cursor() LIMIT 0
----
name	statement	is_holdable	is_binary	is_scrollable	creation_time


query
SELECT * FROM pg_available_extensions() LIMIT 0
----
name	default_version	comment


query
SELECT * FROM pg_available_extension_versions() LIMIT 0
----
name	version	superuser	trusted	relocatable	schema	requires	comment


query
SELECT * FROM pg_prepared_xact() LIMIT 0
----
transaction	gid	prepared	ownerid	dbid


query
SELECT * FROM pg_prepared_statement() LIMIT 0
----
name	statement	prepare_time	parameter_types	result_types	from_sql	generic_plans	custom_plans


query
SELECT * FROM pg_show_all_file_settings() LIMIT 0
----
sourcefile	sourceline	seqno	name	setting	applied	error


query
SELECT * FROM pg_hba_file_rules() LIMIT 0
----
rule_number	file_name	line_number	type	database	user_name	address	netmask	auth_method	options	error


query
SELECT * FROM pg_ident_file_mappings() LIMIT 0
----
map_number	file_name	line_number	map_name	sys_name	pg_username	error


query
SELECT * FROM pg_timezone_abbrevs_zone() LIMIT 0
----
abbrev	utc_offset	is_dst


query
SELECT * FROM pg_timezone_abbrevs_abbrevs() LIMIT 0
----
abbrev	utc_offset	is_dst


query
SELECT * FROM pg_timezone_names() LIMIT 0
----
name	abbrev	utc_offset	is_dst


query
SELECT * FROM pg_config() LIMIT 0
----
name	setting


query
SELECT * FROM pg_get_shmem_allocations() LIMIT 0
----
name	off	size	allocated_size


query
SELECT * FROM pg_get_shmem_allocations_numa() LIMIT 0
----
name	numa_node	size


query
SELECT * FROM pg_get_backend_memory_contexts() LIMIT 0
----
name	ident	type	level	path	total_bytes	total_nblocks	free_bytes	free_chunks	used_bytes


query
SELECT * FROM pg_stat_get_wal_senders() LIMIT 0
----
pid	state	sent_lsn	write_lsn	flush_lsn	replay_lsn	write_lag	flush_lag	replay_lag	sync_priority	sync_state	reply_time


query
SELECT * FROM pg_stat_get_slru() LIMIT 0
----
name	blks_zeroed	blks_hit	blks_read	blks_written	blks_exists	flushes	truncates	stats_reset


query
SELECT * FROM pg_stat_get_wal_receiver() LIMIT 0
----
pid	status	receive_start_lsn	receive_start_tli	written_lsn	flushed_lsn	received_tli	last_msg_send_time	last_msg_receipt_time	latest_end_lsn	latest_end_time	slot_name	sender_host	sender_port	conninfo


query
SELECT * FROM pg_stat_get_recovery_prefetch() LIMIT 0
----
stats_reset	prefetch	hit	skip_init	skip_new	skip_fpw	skip_rep	wal_distance	block_distance	io_depth


query
SELECT * FROM pg_get_replication_slots() LIMIT 0
----
slot_name	plugin	slot_type	datoid	temporary	active	active_pid	xmin	catalog_xmin	restart_lsn	confirmed_flush_lsn	wal_status	safe_wal_size	two_phase	two_phase_at	inactive_since	conflicting	invalidation_reason	failover	synced


query
SELECT * FROM pg_stat_get_archiver() LIMIT 0
----
archived_count	last_archived_wal	last_archived_time	failed_count	last_failed_wal	last_failed_time	stats_reset


query
SELECT * FROM pg_stat_get_io() LIMIT 0
----
backend_type	object	context	reads	read_bytes	read_time	writes	write_bytes	write_time	writebacks	writeback_time	extends	extend_bytes	extend_time	hits	evictions	reuses	fsyncs	fsync_time	stats_reset


query
SELECT * FROM pg_stat_get_wal() LIMIT 0
----
wal_records	wal_fpi	wal_bytes	wal_buffers_full	stats_reset


query
SELECT * FROM pg_show_replication_origin_status() LIMIT 0
----
local_id	external_id	remote_lsn	local_lsn


query
SELECT * FROM pg_get_wait_events() LIMIT 0
----
type	name	description


query
SELECT * FROM pg_get_aios() LIMIT 0
----
pid	io_id	io_generation	state	operation	off	length	target	handle_data_len	raw_result	result	target_desc	f_sync	f_localmem	f_buffered


query
SELECT * FROM pg_stat_get_activity(NULL::integer) LIMIT 0
----
datid	pid	usesysid	application_name	state	query	wait_event_type	wait_event	xact_start	query_start	backend_start	state_change	client_addr	client_hostname	client_port	backend_xid	backend_xmin	backend_type	ssl	sslversion	sslcipher	sslbits	ssl_client_dn	ssl_client_serial	ssl_issuer_dn	gss_auth	gss_princ	gss_enc	gss_delegation	leader_pid	query_id


query
SELECT * FROM pg_stat_get_subscription(NULL::oid) LIMIT 0
----
subid	relid	pid	leader_pid	received_lsn	last_msg_send_time	last_msg_receipt_time	latest_end_lsn	latest_end_time	worker_type


query
SELECT * FROM pg_stat_get_replication_slot(NULL::text) LIMIT 0
----
slot_name	spill_txns	spill_count	spill_bytes	stream_txns	stream_count	stream_bytes	total_txns	total_bytes	stats_reset


query
SELECT * FROM pg_stat_get_subscription_stats(NULL::oid) LIMIT 0
----
subid	apply_error_count	sync_error_count	confl_insert_exists	confl_update_origin_differs	confl_update_exists	confl_update_missing	confl_delete_origin_differs	confl_delete_missing	confl_multiple_unique_conflicts	stats_reset
