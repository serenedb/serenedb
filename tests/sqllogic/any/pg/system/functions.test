statement ok
SET search_path TO public,some_schema;


query
SELECT current_schema;
----
current_schema
public


query
SELECT current_schema();
----
current_schema
public


query
SELECT current_schemas(false);
----
current_schemas
{public}


query
SELECT current_schemas(true);
----
current_schemas
{pg_catalog,public}


statement ok
CREATE SCHEMA some_schema;


query
SELECT current_schemas(true);
----
current_schemas
{pg_catalog,public,some_schema}


# search_path_canonical() exposes the catalog-qualified form
query
SELECT (search_path_canonical() = current_database() || '.public,' || current_database() || '.some_schema')::text AS r;
----
r
true


# SHOW search_path strips catalog prefix and only shows current-DB entries
query
SHOW search_path;
----
search_path
public,some_schema


# in_search_path validates schema existence (only true for schemas that exist)
query
SELECT in_search_path(current_database(), 'public')::text;
----
in_search_path
true


query
SELECT in_search_path(current_database(), 'some_schema')::text;
----
in_search_path
true


# SET unknown bare schema is accepted silently (PG-compliant)
statement ok
SET search_path TO nonexistent;


# But the schema is reported as not in path because it doesn't exist
query
SELECT in_search_path(current_database(), 'nonexistent')::text;
----
in_search_path
false


# current_schema returns NULL when no valid schema is in the path
query
SELECT (current_schema IS NULL)::text AS r;
----
r
true


# current_schemas filters out invalid entries
query
SELECT current_schemas(false);
----
current_schemas
{}


query
SELECT current_schemas(true);
----
current_schemas
{pg_catalog}


# Multiple bare names in SET (PG list syntax — comma + optional whitespace)
statement ok
SET search_path TO public,some_schema;


query
SHOW search_path;
----
search_path
public,some_schema


statement ok
SET search_path TO 'public,some_schema';


query
SHOW search_path;
----
search_path
public,some_schema


# Mix of valid and invalid: only valid reported, but invalid kept in path
statement ok
SET search_path TO bogus, public;


query
SELECT current_schema;
----
current_schema
public


query
SELECT current_schemas(false);
----
current_schemas
{public}


# search_path_canonical shows raw form including invalid entries
query
SELECT (search_path_canonical() = current_database() || '.bogus,' || current_database() || '.public')::text AS r;
----
r
true


# Explicit catalog.schema with unknown catalog still errors (avoids
# the lookup short-circuit bug for unqualified names)
statement error
SET search_path TO 'badcat.public';
----
db error: ERROR: SET search_path: No catalog + schema named "badcat.public" found.


# Reset for cleanup
statement ok
SET search_path TO public,some_schema;
