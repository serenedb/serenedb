# regclass returns OID in binary protocol and our test runner can't
# resolve OIDs back to table names, so we only run with simple protocol

skipif postgres-extended
statement ok
CREATE TABLE regclass_test_table (id int, name text);


skipif postgres-extended
query
SELECT pg_typeof('regclass_test_table'::regclass);
----
pg_typeof
regclass


skipif postgres-extended
query
SELECT 'regclass_test_table'::regclass;
----
regclass
regclass_test_table


skipif postgres-extended
statement error
SELECT 'nonexistent_table'::regclass;


skipif postgres-extended
statement ok
DROP TABLE regclass_test_table;
