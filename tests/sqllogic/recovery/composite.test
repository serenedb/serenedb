control substitution on

statement ok
CREATE TYPE address AS (
  street VARCHAR,
  city VARCHAR,
  zip INTEGER
);

statement ok
CREATE TABLE vedernikoff_locations (
  id INTEGER PRIMARY KEY,
  name VARCHAR,
  addr address
);

statement count 1
INSERT INTO vedernikoff_locations VALUES (1, 'psycho_hospital', ROW('ulica pushkina', 'moscow', 101010));

query
SELECT id, name FROM vedernikoff_locations ORDER BY id;
----
id	name
1	psycho_hospital

statement ok
SET sdb_fault_crash_on_packet TO DEFAULT;

query error connection closed
SELECT 1;


connection after_crash
query ok retry $RETRY_ATTEMPTS backoff $BACKOFF_DURATION
SELECT 1;
----
1


connection after_crash
query
SELECT id, name FROM vedernikoff_locations ORDER BY id;
----
id	name
1	psycho_hospital


connection after_crash
statement ok
