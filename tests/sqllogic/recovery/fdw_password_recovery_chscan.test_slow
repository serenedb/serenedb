control substitution on

# Recovery for a credentialed FOREIGN SERVER: the existing FDW recovery tests
# use a PUBLIC mapping with user 'default' and NO password, so the boot-replay
# credential-merge path (PrepareForeignServerAttach re-registering a transient
# secret carrying a real password, then dropping it) is never exercised across a
# restart. A bug there would leave the server unqueryable after restart, or leak
# a __sdb_fdw_secret_ into duckdb_secrets() that the live path cleans. Uses the
# fixture user `scanner` (password 'pass word'); the `_chscan.` suffix keeps the
# ClickHouse container alive across the crash. NB: `pass word` carries a
# load-bearing space (must round-trip through the secret verbatim).

statement ok
CREATE SERVER pw_srv FOREIGN DATA WRAPPER clickhouse_fdw
  OPTIONS (host '${CHHOST}', port '${CHPORT}', database 'chtest');

# PUBLIC mapping supplies the live-attach credentials (spaced password).
statement ok
CREATE USER MAPPING FOR PUBLIC SERVER pw_srv
  OPTIONS (user 'scanner', password 'pass word');

# Pre-crash: connects with the password; no transient attach secret lingers.
query
SELECT count(*) AS n FROM pw_srv.chtest.vedernikoff;
----
n
6

query
SELECT count(*) AS n FROM duckdb_secrets() WHERE name LIKE '__sdb_fdw_secret_%';
----
n
0

# ...and the password is redacted in the catalog view.
query
SELECT array_to_string(umoptions, ' ') NOT LIKE '%pass word%' AS redacted
FROM pg_user_mapping um JOIN pg_foreign_server s ON um.umserver = s.oid
WHERE s.srvname = 'pw_srv';
----
redacted
t

# Crash mid-connection; restart on the same datadir triggers boot replay, which
# re-attaches pw_srv by re-registering the secret from the persisted mapping.
statement ok
SET sdb_faults = 'crash_on_packet';

statement error connection closed
SELECT 1;

connection after_crash
query ok retry $RETRY_ATTEMPTS backoff $BACKOFF_DURATION
SELECT 1;
----
?column?
1

# Post-restart: boot replay re-attached WITH the spaced password (a wrong or
# empty password would make `scanner` fail to connect).
connection after_crash
query
SELECT count(*) AS n FROM pw_srv.chtest.vedernikoff;
----
n
6

# ...and the boot-replay secret was dropped again -- nothing leaked.
connection after_crash
query
SELECT count(*) AS n FROM duckdb_secrets() WHERE name LIKE '__sdb_fdw_secret_%';
----
n
0

# ...and the password is still redacted in the catalog view post-restart.
connection after_crash
query
SELECT array_to_string(umoptions, ' ') NOT LIKE '%pass word%' AS redacted
FROM pg_user_mapping um JOIN pg_foreign_server s ON um.umserver = s.oid
WHERE s.srvname = 'pw_srv';
----
redacted
t

connection after_crash
statement ok
DROP SERVER pw_srv CASCADE;
