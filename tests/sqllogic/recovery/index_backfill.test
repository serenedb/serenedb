control substitution on


# crash before tombstone removal, index should be gone

statement ok
CREATE TABLE idx_bf_t(a INTEGER PRIMARY KEY, b TEXT);

statement ok
INSERT INTO idx_bf_t VALUES (1, 'pudge goes mid'), (2, 'vedernikoff carries team'), (3, 'babsky afk again');

statement ok
SET sdb_fault_crash_before_remove_tombstone TO DEFAULT;

statement error connection closed
CREATE INDEX idx_bf_crash ON idx_bf_t USING inverted(a, b);

connection bf_after_1
statement error retry $RETRY_ATTEMPTS backoff $BACKOFF_DURATION
SELECT * FROM idx_bf_crash;


# crash before rocksdb commit, index should be gone

connection bf_after_1
statement ok retry $RETRY_ATTEMPTS backoff $BACKOFF_DURATION
RESET sdb_faults;

connection bf_after_1
statement ok
SET sdb_fault_crash_before_rocksdb_commit TO DEFAULT;

connection bf_after_1
statement error connection closed
CREATE INDEX idx_bf_crash2 ON idx_bf_t USING inverted(a, b);

connection bf_after_2
statement error retry $RETRY_ATTEMPTS backoff $BACKOFF_DURATION
SELECT * FROM idx_bf_crash2;


# crash after rocksdb commit, index should be gone

connection bf_after_2
statement ok retry $RETRY_ATTEMPTS backoff $BACKOFF_DURATION
RESET sdb_faults;

connection bf_after_2
statement ok
SET sdb_fault_crash_after_rocksdb_commit TO DEFAULT;

connection bf_after_2
statement error connection closed
CREATE INDEX idx_bf_crash3 ON idx_bf_t USING inverted(a, b);

connection bf_after_3
statement error retry $RETRY_ATTEMPTS backoff $BACKOFF_DURATION
SELECT * FROM idx_bf_crash3;


# completed CREATE INDEX should survive crash

connection bf_after_3
statement ok retry $RETRY_ATTEMPTS backoff $BACKOFF_DURATION
RESET sdb_faults;

connection bf_after_3
statement ok
CREATE INDEX idx_bf_ok ON idx_bf_t USING inverted(a, b);

connection bf_after_3
statement ok
SET sdb_fault_crash_on_packet TO DEFAULT;

connection bf_after_3
query error connection closed
SELECT 1;

connection bf_after_4
statement ok retry $RETRY_ATTEMPTS backoff $BACKOFF_DURATION
VACUUM (UPDATE_INDEXES) idx_bf_t;

connection bf_after_4
query
SELECT a, b FROM idx_bf_ok WHERE PHRASE(b, 'pudge');
----
a	b
1	pudge goes mid

connection bf_after_4
query
SELECT a, b FROM idx_bf_ok WHERE PHRASE(b, 'vedernikoff carries');
----
a	b
2	vedernikoff carries team

connection bf_after_4
query
SELECT a, b FROM idx_bf_ok WHERE PHRASE(b, 'babsky');
----
a	b
3	babsky afk again
