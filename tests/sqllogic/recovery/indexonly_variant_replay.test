## VARIANT survives WAL replay through the sdb_indexonly + INCLUDE path.

control substitution on

statement ok
CREATE TEXT SEARCH DICTIONARY variant_replay_en(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true
);


statement ok
CREATE TABLE variant_replay (
  id INTEGER NOT NULL,
  body TEXT NOT NULL,
  payload VARIANT NOT NULL,
  PRIMARY KEY (id)
) WITH (sdb_indexonly = [payload]);


statement ok
CREATE INDEX variant_replay_idx
  ON variant_replay USING inverted(body variant_replay_en)
  INCLUDE (payload);


statement ok
SET sdb_faults = 'crash_after_rocksdb_commit';


statement error connection closed
INSERT INTO variant_replay VALUES
  (1, 'alpha cat', 42::variant),
  (2, 'beta dog', 'hello'::variant),
  (3, 'gamma cat', true::variant),
  (4, 'delta horse', '{"k": 7}'::json::variant);


connection after_replay
statement ok retry $RETRY_ATTEMPTS backoff $BACKOFF_DURATION
RESET sdb_faults;


connection after_replay
statement ok
VACUUM (REFRESH_TABLE) variant_replay;


connection after_replay
query
SELECT id, payload FROM variant_replay_idx
WHERE body @@ ts_phrase('alpha') ORDER BY id;
----
id	payload
1	42


connection after_replay
query
SELECT id, payload FROM variant_replay_idx
WHERE body @@ ts_phrase('beta') ORDER BY id;
----
id	payload
2	"hello"


connection after_replay
query
SELECT id, payload FROM variant_replay_idx
WHERE body @@ ts_phrase('cat') ORDER BY id;
----
id	payload
1	42
3	true


connection after_replay
query
SELECT id, payload FROM variant_replay_idx
WHERE body @@ ts_phrase('delta') ORDER BY id;
----
id	payload
4	{"k":7}
