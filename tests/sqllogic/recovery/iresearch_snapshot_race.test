control substitution on
control max-async-connections 3

statement ok
CREATE TABLE t (id INT, v FLOAT[4]);


statement ok
INSERT INTO t VALUES (1, [1.0, 0.0, 0.0, 0.0]::FLOAT[4]),
                    (2, [0.0, 1.0, 0.0, 0.0]::FLOAT[4]);


statement ok
CREATE INDEX t_hnsw ON t USING inverted(v hnsw (metric = 'l2', m = 16, ef_construction = 64));


statement ok
VACUUM (UPDATE_INDEXES) t;


statement ok
SET sdb_faults = 'slow_iresearch_optimize';


query async
SELECT id FROM t_hnsw ORDER BY v <-> [1.0, 0.0, 0.0, 0.0]::FLOAT[4] LIMIT 1;
----
id
1


connection drop_conn
statement ok
DROP TABLE t;


wait


connection drop_conn
statement ok
RESET sdb_faults;
