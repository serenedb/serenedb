control substitution on

# DuckDB `logging_level` / `logging_storage` are process-global settings held
# in LogManager config. They are NOT persisted to storage; on every (re)start
# the boot values come from --log_level / --log_storage CLI flags (default
# "info" / "stdout"). This test confirms a runtime SET GLOBAL does not survive
# a crash.

query
SHOW logging_level;
----
logging_level
INFO


query
SHOW logging_storage;
----
logging_storage
stdout


statement ok
SET GLOBAL logging_level = 'debug';


query
SHOW logging_level;
----
logging_level
DEBUG


statement ok
SET sdb_faults = 'crash_on_packet';


statement error connection closed
SELECT 1;


connection after_crash
query ok retry $RETRY_ATTEMPTS backoff $BACKOFF_DURATION
SELECT 1;
----
?column?
1


# Runtime SET GLOBAL was lost; the flag default (info) is back.
connection after_crash
query
SHOW logging_level;
----
logging_level
INFO


connection after_crash
query
SHOW logging_storage;
----
logging_storage
stdout
