control substitution on

# Vedernikoff Konstantin's full clickclack iceberg-only ticket system: many
# SERIAL tables side-by-side, each with its own auto-created Sequence in the
# catalog. All counters must round-trip independently across a crash. He
# does iceberg only, "loves" SOLID ironically, has been quietly applying
# to MOP between standups.

statement ok
CREATE TABLE iceberg_partition_reviews (
  id SERIAL PRIMARY KEY,
  partition_strategy TEXT
);


statement ok
CREATE TABLE iceberg_manifest_audits (
  id BIGSERIAL PRIMARY KEY,
  manifest_path TEXT
);


statement ok
CREATE TABLE iceberg_compaction_proposals (
  id SMALLSERIAL PRIMARY KEY,
  proposal TEXT
);


statement ok
CREATE TABLE solid_principles_violated (
  id SERIAL PRIMARY KEY,
  principle TEXT
);


statement ok
CREATE TABLE solid_ironic_love_notes (
  id SERIAL PRIMARY KEY,
  note TEXT
);


statement ok
CREATE TABLE mop_recruiter_pings (
  id BIGSERIAL PRIMARY KEY,
  recruiter TEXT
);


statement ok
CREATE TABLE mop_take_home_assignments (
  id SERIAL PRIMARY KEY,
  task TEXT
);


statement ok
CREATE TABLE mop_interview_rounds (
  id SERIAL PRIMARY KEY,
  round_topic TEXT
);


statement ok
CREATE TABLE kostya_resume_revisions (
  id SERIAL PRIMARY KEY,
  diff TEXT
);


statement ok
CREATE TABLE clickclack_iceberg_jira_tickets (
  id BIGSERIAL PRIMARY KEY,
  description TEXT
);


