# Each table's max id matches its row count (sequences started at 1, no gaps).
query
SELECT max(id) FROM iceberg_partition_reviews;
----
max
3


query
SELECT max(id) FROM iceberg_manifest_audits;
----
max
7


query
SELECT max(id) FROM clickclack_iceberg_jira_tickets;
----
max
3000


statement ok
SET sdb_faults = 'crash_on_packet';


statement error connection closed
SELECT 1;


# --- restart ---

connection after_crash
statement ok retry $RETRY_ATTEMPTS backoff $BACKOFF_DURATION
SELECT 1;


# All ten tables come back independently with row counts and max ids
# preserved.
connection after_crash
query
SELECT count(*), max(id) FROM iceberg_partition_reviews;
----
count	max
3	3


connection after_crash
query
SELECT count(*), max(id) FROM iceberg_manifest_audits;
----
count	max
7	7


connection after_crash
query
