# Many resume revisions during the application process.
statement count 25
INSERT INTO kostya_resume_revisions (diff)
  SELECT 'add_one_more_iceberg_keyword_v' || i::TEXT
    FROM generate_series(1, 25) AS s(i);


# Bulk insert that pushes past one DataChunk (chunk size 2048).
statement count 3000
INSERT INTO clickclack_iceberg_jira_tickets (description)
  SELECT 'iceberg_audit_review_' || i::TEXT
    FROM generate_series(1, 3000) AS s(i);


