# Critical: post-crash inserts must NOT collide with persisted ids. Each
# table's auto-created Sequence had its counter folded into the persisted
# Sequences CF via Merge ops; recovery loads them via Sequence::ReadInternal
# (override _live from disk). Each next id == previous_max + 1.

connection after_crash
statement count 1
INSERT INTO iceberg_partition_reviews (partition_strategy)
  VALUES ('partition_by_random_strategy');


connection after_crash
query
SELECT id FROM iceberg_partition_reviews
  WHERE partition_strategy = 'partition_by_random_strategy';
----
id
4


connection after_crash
statement count 1
