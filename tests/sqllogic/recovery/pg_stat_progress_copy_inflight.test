## pg_stat_progress_copy must surface a row WHILE a COPY FROM is running and
## clear it once the statement ends. The COPY is parked deterministically in
## the SST sink via the 'pause_sst_sink_mid_copy' failpoint, so an observer
## connection can read the in-flight entry without racing the loader.

control substitution on
control max-async-connections 5


statement ok
CREATE TABLE pgsp_copy_src(id BIGINT, body TEXT);


statement count 100000
INSERT INTO pgsp_copy_src
SELECT g, repeat(g::TEXT || ' lorem ipsum dolor sit amet ', 8)
FROM generate_series(1, 100000) AS s(g);


statement ok
COPY pgsp_copy_src TO '/tmp/${__DATABASE__}_pgsp_copy_inflight.csv' (FORMAT CSV);


statement ok
CREATE TABLE pgsp_copy_dst(id BIGINT, body TEXT);


# Nothing is running yet, so the view is empty for our relation.
query
SELECT count(*) FROM pg_stat_progress_copy
WHERE relid = 'pgsp_copy_dst'::regclass;
----
count
0


# Arm the barrier first, then start the COPY: the sink blocks after the first
# chunk (and after reporting its progress) until the failpoint is cleared.
connection observer
statement ok
SET sdb_faults = 'pause_sst_sink_mid_copy';


statement async ok
COPY pgsp_copy_dst
  FROM '/tmp/${__DATABASE__}_pgsp_copy_inflight.csv' (FORMAT CSV);


# Poll until the parked COPY shows up. retry re-runs on result mismatch, so
# this resolves as soon as the first chunk has been reported.
connection observer
query TT retry 100 backoff 100ms
SELECT command, "type" FROM pg_stat_progress_copy
WHERE relid = 'pgsp_copy_dst'::regclass AND tuples_processed > 0;
----
command	type
COPY FROM	FILE


# Release the barrier and let the COPY run to completion.
connection observer
statement ok
SET sdb_faults = '-pause_sst_sink_mid_copy';


wait


# After the COPY finishes, the entry is gone (EndCommand on destruction).
connection observer
query
SELECT count(*) FROM pg_stat_progress_copy
WHERE relid = 'pgsp_copy_dst'::regclass;
----
count
0


# Sanity: the COPY itself worked end-to-end.
query
SELECT count(*) FROM pgsp_copy_dst;
----
count
100000


statement ok
DROP TABLE pgsp_copy_dst;


statement ok
DROP TABLE pgsp_copy_src;
