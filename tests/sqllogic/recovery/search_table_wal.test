control substitution on

statement ok retry $RETRY_ATTEMPTS backoff $BACKOFF_DURATION
CREATE TABLE s_wal(a INTEGER, b TEXT) WITH (storage = 'search');

statement ok
RESET sdb_faults;

# --- Fixture: a published baseline, durable in the iresearch index on disk. ---
statement ok
INSERT INTO s_wal VALUES (1, 'one'), (2, 'two'), (3, 'three');

statement ok
VACUUM (REFRESH_TABLE) s_wal;

query
SELECT a, b FROM s_wal ORDER BY a;
----
a	b
1	one
2	two
3	three


###############################################################################
# 1. Crash AFTER the WAL commit -> the write survives via recovery replay.
#    (4,5) is fsynced into the WAL but never refresh-published, so it exists
#    ONLY in the WAL; recovery must rebuild it into iresearch.
###############################################################################

statement ok
SET sdb_faults = 'crash_after_search_wal_commit';

statement error connection closed
INSERT INTO s_wal VALUES (4, 'four'), (5, 'five');

# --- restart: reconnect once the runner brings the crashed instance back up ---
connection after_commit
query ok retry $RETRY_ATTEMPTS backoff $BACKOFF_DURATION
SELECT a, b FROM s_wal ORDER BY a;
----
a	b
1	one
2	two
3	three
4	four
5	five

connection after_commit
statement ok
VACUUM (REFRESH_TABLE) s_wal;


###############################################################################
# 2. Crash BEFORE the WAL commit -> the write is lost (no record written).
#    (6,7) never reaches the WAL; recovery finds nothing new. The baseline plus
#    the now-durable recovered (4,5) are untouched.
###############################################################################

connection after_commit
statement ok
SET sdb_faults = 'crash_before_search_wal_commit';

connection after_commit
statement error connection closed
INSERT INTO s_wal VALUES (6, 'six'), (7, 'seven');

# --- restart ---
connection before_commit
query ok retry $RETRY_ATTEMPTS backoff $BACKOFF_DURATION
SELECT a, b FROM s_wal ORDER BY a;
----
a	b
1	one
2	two
3	three
4	four
5	five

connection before_commit
statement ok
DROP TABLE s_wal;

connection before_commit
statement ok
CREATE TABLE s_wal_pk(id INTEGER PRIMARY KEY, b TEXT) WITH (storage = 'search');

connection before_commit
statement ok
INSERT INTO s_wal_pk VALUES (1, 'one'), (2, 'two'), (3, 'three');

connection before_commit
statement ok
VACUUM (REFRESH_TABLE) s_wal_pk;

connection before_commit
query
SELECT id, b FROM s_wal_pk ORDER BY id;
----
id	b
1	one
2	two
3	three


# --- 3a. Crash AFTER the WAL commit -> survives via recovery replay. ---
connection before_commit
statement ok
SET sdb_faults = 'crash_after_search_wal_commit';

connection before_commit
statement error connection closed
INSERT INTO s_wal_pk VALUES (4, 'four'), (5, 'five');

# --- restart ---
connection pk_after_commit
query ok retry $RETRY_ATTEMPTS backoff $BACKOFF_DURATION
SELECT id, b FROM s_wal_pk ORDER BY id;
----
id	b
1	one
2	two
3	three
4	four
5	five

# Look the recovered row up BY its explicit PK -- proves the re-derived key
# matches the written one (a column scan alone wouldn't).
connection pk_after_commit
query
SELECT b FROM s_wal_pk WHERE id = 4;
----
b
four

connection pk_after_commit
statement ok
VACUUM (REFRESH_TABLE) s_wal_pk;


# --- 3b. Crash BEFORE the WAL commit -> lost (no record written). ---
connection pk_after_commit
statement ok
SET sdb_faults = 'crash_before_search_wal_commit';

connection pk_after_commit
statement error connection closed
INSERT INTO s_wal_pk VALUES (6, 'six'), (7, 'seven');

# --- restart ---
connection pk_before_commit
query ok retry $RETRY_ATTEMPTS backoff $BACKOFF_DURATION
SELECT id, b FROM s_wal_pk ORDER BY id;
----
id	b
1	one
2	two
3	three
4	four
5	five

# The surviving rows are still reachable by PK; the lost ones are gone.
connection pk_before_commit
query
SELECT b FROM s_wal_pk WHERE id = 5;
----
b
five

connection pk_before_commit
statement ok
DROP TABLE s_wal_pk;


###############################################################################
# 4. PARALLEL (bulk) CTAS -- exercises the chunk-file (REFERENCE) path
###############################################################################

connection pk_before_commit
statement ok
COPY (SELECT i AS x, 'v' || i AS y FROM range(0, 12000) t(i))
  TO '/tmp/${__DATABASE__}_ctas_src.parquet' (FORMAT PARQUET, ROW_GROUP_SIZE 2000);

# --- 4a. Crash AFTER the WAL commit -> recovery replays from the chunk files. ---
connection pk_before_commit
statement ok
SET sdb_faults = 'crash_after_search_wal_commit';

connection pk_before_commit
statement error connection closed
CREATE TABLE ctas_after WITH (storage = 'search') AS
  SELECT x, y FROM read_parquet('/tmp/${__DATABASE__}_ctas_src.parquet');

# --- restart ---
connection ctas_after_conn
query ok retry $RETRY_ATTEMPTS backoff $BACKOFF_DURATION
SELECT count(x) AS n, max(x) AS m FROM ctas_after;
----
n	m
12000	11999

# Spot-check a row materialised from a recovered chunk (column round-tripped).
connection ctas_after_conn
query
SELECT y FROM ctas_after WHERE x = 9999;
----
y
v9999

connection ctas_after_conn
statement ok
VACUUM (REFRESH_TABLE) ctas_after;


# --- 4b. Crash BEFORE the WAL commit -> table exists but is EMPTY (§12). ---
connection ctas_after_conn
statement ok
SET sdb_faults = 'crash_before_search_wal_commit';

connection ctas_after_conn
statement error connection closed
CREATE TABLE ctas_before WITH (storage = 'search') AS
  SELECT x, y FROM read_parquet('/tmp/${__DATABASE__}_ctas_src.parquet');

# --- restart ---
connection ctas_before_conn
query ok retry $RETRY_ATTEMPTS backoff $BACKOFF_DURATION
SELECT count(x) AS n FROM ctas_before;
----
n
0

connection ctas_before_conn
statement ok
DROP TABLE ctas_before;

connection ctas_before_conn
statement ok
DROP TABLE ctas_after;


###############################################################################
# 5. MIXED bulk + inline in ONE transaction -> a single FOLDED REFERENCE.
###############################################################################

connection ctas_before_conn
statement ok
CREATE TABLE mix_t (x INTEGER, y TEXT) WITH (storage = 'search');

connection ctas_before_conn
statement ok
SET sdb_faults = 'crash_after_search_wal_commit';

connection ctas_before_conn
statement ok
BEGIN;

connection ctas_before_conn
statement ok
INSERT INTO mix_t SELECT x, y FROM read_parquet('/tmp/${__DATABASE__}_ctas_src.parquet');

connection ctas_before_conn
statement ok
INSERT INTO mix_t VALUES (5, 'i5'), (7, 'i7');

connection ctas_before_conn
statement error connection closed
COMMIT;

# --- restart ---
connection mix_conn
query ok retry $RETRY_ATTEMPTS backoff $BACKOFF_DURATION
SELECT count(x) AS n FROM mix_t;
----
n
12002

# x=5 and x=7 each have one bulk row (v5 / v7) AND one inline row (i5 / i7):
# the folded REFERENCE replayed BOTH sources. ORDER BY y for determinism.
connection mix_conn
query
SELECT y FROM mix_t WHERE x = 5 ORDER BY y;
----
y
i5
v5

connection mix_conn
query
SELECT y FROM mix_t WHERE x = 7 ORDER BY y;
----
y
i7
v7

connection mix_conn
statement ok
DROP TABLE mix_t;


###############################################################################
# 6. DELETE -> the removal survives recovery replay (explicit + generated PK).
#    The baseline is published; the DELETE is fsynced into the WAL but crashes
#    before the iresearch removal commits, so recovery must re-apply it.
###############################################################################

connection mix_conn
statement ok
CREATE TABLE del_t (id INTEGER PRIMARY KEY, b TEXT) WITH (storage = 'search');

connection mix_conn
statement ok
INSERT INTO del_t VALUES (1, 'one'), (2, 'two'), (3, 'three');

connection mix_conn
statement ok
VACUUM (REFRESH_TABLE) del_t;

connection mix_conn
statement ok
SET sdb_faults = 'crash_after_search_wal_commit';

connection mix_conn
statement error connection closed
DELETE FROM del_t WHERE id = 2;

# --- restart ---
connection del_after
query ok retry $RETRY_ATTEMPTS backoff $BACKOFF_DURATION
SELECT id, b FROM del_t ORDER BY id;
----
id	b
1	one
3	three

# The surviving rows are still reachable by their explicit PK.
connection del_after
query
SELECT b FROM del_t WHERE id = 3;
----
b
three

connection del_after
statement ok
VACUUM (REFRESH_TABLE) del_t;

connection del_after
statement ok
DROP TABLE del_t;


# Generated-PK DELETE: the rowid is the synthetic PK (materialised from the
# stored kGeneratedPKId column); its removal must also survive recovery.
connection del_after
statement ok
CREATE TABLE del_g (a INTEGER, b TEXT) WITH (storage = 'search');

connection del_after
statement ok
INSERT INTO del_g VALUES (10, 'p'), (20, 'q'), (30, 'r');

connection del_after
statement ok
VACUUM (REFRESH_TABLE) del_g;

connection del_after
statement ok
SET sdb_faults = 'crash_after_search_wal_commit';

connection del_after
statement error connection closed
DELETE FROM del_g WHERE a >= 20;

# --- restart ---
connection del_g_after
query ok retry $RETRY_ATTEMPTS backoff $BACKOFF_DURATION
SELECT a, b FROM del_g ORDER BY a;
----
a	b
10	p

connection del_g_after
statement ok
DROP TABLE del_g;


###############################################################################
# 7. DELETE then re-INSERT the same PK -> last write wins through recovery.
#    'a' is published; the same-PK [DELETE id=1] (unpublished) and [INSERT
#    (1,'b')] are both fsynced into the WAL but crash before publish. Recovery
#    replays them in manifest order (delete before the re-insert), so the
#    higher-tick re-insert survives: exactly one row, b.
###############################################################################

connection del_g_after
statement ok
CREATE TABLE reins (id INTEGER PRIMARY KEY, b TEXT) WITH (storage = 'search');

connection del_g_after
statement ok
INSERT INTO reins VALUES (1, 'a');

connection del_g_after
statement ok
VACUUM (REFRESH_TABLE) reins;

connection del_g_after
statement ok
DELETE FROM reins WHERE id = 1;

connection del_g_after
statement ok
SET sdb_faults = 'crash_after_search_wal_commit';

connection del_g_after
statement error connection closed
INSERT INTO reins VALUES (1, 'b');

# --- restart ---
connection reins_after
query ok retry $RETRY_ATTEMPTS backoff $BACKOFF_DURATION
SELECT id, b FROM reins ORDER BY id;
----
id	b
1	b

connection reins_after
query
SELECT COUNT(*) AS n FROM reins;
----
n
1

connection reins_after
statement ok
DROP TABLE reins;


###############################################################################
# 8. UPDATE = delete-old + insert-new survives recovery replay. The baseline is
#    published; the UPDATE's removal + re-insert are fsynced into the WAL but
#    crash before the iresearch commit, so recovery must replay BOTH halves --
#    and in manifest order (delete before insert), or the re-inserted row would
#    be masked by its own removal.
###############################################################################

# 8a. Explicit PK, non-PK column updated -> old and new rows share the PK, so
#     this is the core delete<insert ordering case: the new value must win.
connection reins_after
statement ok
CREATE TABLE upd_t (id INTEGER PRIMARY KEY, b TEXT) WITH (storage = 'search');

connection reins_after
statement ok
INSERT INTO upd_t VALUES (1, 'one'), (2, 'two'), (3, 'three');

connection reins_after
statement ok
VACUUM (REFRESH_TABLE) upd_t;

connection reins_after
statement ok
SET sdb_faults = 'crash_after_search_wal_commit';

connection reins_after
statement error connection closed
UPDATE upd_t SET b = 'TWO' WHERE id = 2;

# --- restart ---
connection upd_after
query ok retry $RETRY_ATTEMPTS backoff $BACKOFF_DURATION
SELECT id, b FROM upd_t ORDER BY id;
----
id	b
1	one
2	TWO
3	three

# The updated row is reachable by its (unchanged) PK with the NEW value.
connection upd_after
query
SELECT b FROM upd_t WHERE id = 2;
----
b
TWO

connection upd_after
statement ok
DROP TABLE upd_t;


# 8b. Generated PK: the new row is minted a fresh generated PK; the old row is
#     removed by its old rowid. Both halves must survive recovery.
connection upd_after
statement ok
CREATE TABLE upd_g (a INTEGER, b TEXT) WITH (storage = 'search');

connection upd_after
statement ok
INSERT INTO upd_g VALUES (10, 'p'), (20, 'q'), (30, 'r');

connection upd_after
statement ok
VACUUM (REFRESH_TABLE) upd_g;

connection upd_after
statement ok
SET sdb_faults = 'crash_after_search_wal_commit';

connection upd_after
statement error connection closed
UPDATE upd_g SET b = 'Q' WHERE a = 20;

# --- restart ---
connection upd_g_after
query ok retry $RETRY_ATTEMPTS backoff $BACKOFF_DURATION
SELECT a, b FROM upd_g ORDER BY a;
----
a	b
10	p
20	Q
30	r

connection upd_g_after
statement ok
DROP TABLE upd_g;
