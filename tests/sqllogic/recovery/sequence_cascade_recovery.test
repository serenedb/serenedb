CREATE TABLE iceberg_audit_probe (
  seq_alive BOOL NOT NULL,
  default_alive BOOL NOT NULL
);


connection after_crash
statement ok
INSERT INTO iceberg_audit_probe (seq_alive, default_alive)
SELECT
  EXISTS(SELECT 1 FROM pg_class WHERE relname = 'iceberg_manifest_id_seq') AS seq_alive,
  EXISTS(SELECT 1 FROM pg_class WHERE relname = 'iceberg_manifest') AS default_alive;


