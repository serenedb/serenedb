query
CALL enable_logging(storage = 'stdout');
----
Success

# DOCS_TEST: example_010

# DOCS_TEST_BODY

query
CALL enable_logging(storage = 'file', storage_config = {'path': '${__TEST_DIR__}/path/to/store/logs'});
----
Success

# DOCS_TEST: example_011

# DOCS_TEST_BODY

query
CALL enable_logging(storage_path = '${__TEST_DIR__}/path/to/store/logs');
----
Success

# DOCS_TEST: example_012

# DOCS_TEST_BODY

statement ok
-- normalized: creates `${__TEST_DIR__}/duckdb_log_contexts.csv` and `${__TEST_DIR__}/duckdb_log_entries.csv`
CALL enable_logging(storage_path = '${__TEST_DIR__}');

query
-- denormalized: creates `${__TEST_DIR__}/logs.csv`
CALL enable_logging(storage_path = '${__TEST_DIR__}/logs.csv');
----
Success

# DOCS_TEST: example_013

# DOCS_TEST_BODY

query
CALL enable_logging(storage_config = {'buffer_size': 0});
----
Success

# DOCS_TEST: example_014

# DOCS_TEST_BODY

query
CALL enable_logging(storage_buffer_size = 0);
----
Success

# DOCS_TEST: example_015

# DOCS_TEST_BODY

query
CALL enable_logging(storage = 'stdout', storage_buffer_size = 2048);
----
Success

# DOCS_TEST: example_016

# DOCS_TEST_BODY

query
CALL enable_logging(storage_path = '${__TEST_DIR__}/mylogs', storage_buffer_size = 0);
----
Success

# DOCS_TEST: example_017

# DOCS_TEST_BODY

query
-- regular invocation
CALL enable_logging(storage = 'file', storage_config = {'path': 'path/to/store/logs'});
----
Success

query
-- using shorthand for common path storage config param
CALL enable_logging(storage = 'file', storage_path = 'path/to/store/logs');
----
Success

query
-- omitting `storage = 'file'` -> is implied from presence of `storage_config`
CALL enable_logging(storage_config = {'path': 'path/to/store/logs'});
----
Success
