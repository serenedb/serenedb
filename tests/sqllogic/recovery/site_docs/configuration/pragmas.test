# DOCS_TEST: example_023

statement ok
DETACH IF EXISTS db171;

statement ok
ATTACH OR REPLACE '${__TEST_DIR__}/db171.db' AS db171;

statement ok
USE db171;

statement ok
CREATE OR REPLACE TABLE metadata_info_table AS
SELECT i, repeat('x', 1000) AS payload
FROM range(0, 10000) AS t(i);

#statement ok
#CHECKPOINT;

# DOCS_TEST_RAW
#| PRAGMA metadata_info;
#| ----
#| block_id	total_blocks	free_blocks	free_list
#| 0	64	2	1

# DOCS_TEST_BODY

# CHECKPOINT above is intentionally commented out, so pragma_metadata_info() has
# no persisted blocks to report and returns 0 rows. Run it (statement ok) to keep
# exercising the pragma without asserting checkpoint-dependent block counts.
statement ok
PRAGMA metadata_info;

