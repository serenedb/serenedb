# 16 writers * 2500 rows * 5 rounds = 200000.
connection check
query
SELECT COUNT(*) FROM wgc_t;
----
count
200000

statement ok
SET GLOBAL checkpoint_threshold = '16MB';

statement ok
DROP TABLE wgc_t;
