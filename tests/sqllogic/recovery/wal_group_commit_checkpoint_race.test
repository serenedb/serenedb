control max-async-connections 16

# Concurrency guard for the WAL group-commit use-after-free.
#
# GroupSync issues the grouped fsync with the WAL lock RELEASED (so committers
# coalesce onto one physical fsync). An auto-checkpoint on another committer
# resets and recreates the WriteAheadLog object (storage_manager wal.reset() +
# make_shared_ptr) while holding the WAL lock. Before the shared_ptr lifetime
# pin -- where CommitTransaction captures the WAL object under the WAL lock and
# holds it across the unlocked GroupSync -- the leader thread inside
# RunSyncLeader dereferenced a freed writer->handle and SIGSEGV'd within seconds.
#
# This drives the exact precondition: many concurrent committers stream sizable
# INSERTs while a tiny checkpoint_threshold makes nearly every commit trigger an
# auto-checkpoint teardown, so a WAL reset overlaps in-flight GroupSync fsyncs.
# If the pin regresses, serened crashes mid-round and the async statements / the
# COUNT below fail.
#
# This is a timing-race stress guard (like wal_index_recovery_concurrent_refresh):
# the reset-vs-GroupSync window is an in-memory ordering window with no fault hook
# to widen it, so it does not deterministically reproduce on every run -- it is
# looped over several rounds of 16 writers to hit the window opportunistically.

# Tiny threshold -> the WAL crosses it on essentially every commit (each writer's
# round is ~510KB), so committers auto-checkpoint (reset the WAL) constantly while
# their peers are mid-fsync.
statement ok
SET GLOBAL checkpoint_threshold = '256KB';

statement ok
CREATE TABLE wgc_t(id BIGINT, body TEXT);

# Each writer/round owns a disjoint id range so the final count is exact: a lost
# or duplicated commit (or a crash) makes COUNT(*) != 16 * 2500 * 5 = 200000.

# round 1
connection w1
statement async ok
INSERT INTO wgc_t SELECT i, repeat('y', 200) FROM range(110000000, 110002500) t(i);

