control substitution on

# UNION survives WAL replay through an inverted index's INCLUDE columnstore.
#
# A UNION INCLUDE column is stored in the .col file as a struct-backed column
# (tag + member columns). The pre-crash row is made durable by a refresh; the
# post-crash rows live only in the store WAL with the search commit faulted
# off. On restart the index's cs must be rebuilt from the WAL so every payload
# reads back from the index, rendering as the active member's text value.

statement ok
CREATE TEXT SEARCH DICTIONARY uni_rec_dict(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true
);

statement ok
CREATE TABLE uni_rec_t(id INTEGER PRIMARY KEY, body TEXT,
                       payload UNION(num INTEGER, str VARCHAR));

statement ok
CREATE INDEX uni_rec_idx ON uni_rec_t
  USING inverted(body uni_rec_dict) INCLUDE (payload);

# Pre-crash row, made durable in the segments + cs by a refresh.
statement ok
INSERT INTO uni_rec_t VALUES (1, 'alpha bravo', union_value(num := 42));

statement ok
VACUUM (REFRESH_TABLE) uni_rec_t;

query
SELECT id, payload FROM uni_rec_idx WHERE body @@ ts_phrase('alpha');
----
id	payload
1	42

# Post-crash rows: suppress the index commit so they land only in the store
# WAL, post-refresh and not yet durable in the segments.
statement ok
SET sdb_faults = 'SearchCommitTask::commitUnsafe';

statement ok
INSERT INTO uni_rec_t VALUES
  (2, 'charlie delta', 'hello'),
  (3, 'echo foxtrot', union_value(str := 'world')),
  (4, 'golf hotel', 7);

statement ok
SET sdb_faults = 'crash_on_packet';

query error connection closed
SELECT 1;

# --- restart ---

connection uni_after
statement ok retry 60 backoff 1s
VACUUM (REFRESH_TABLE) uni_rec_t;

# Pre-crash row's UNION still served from cs.
connection uni_after
query
SELECT id, payload FROM uni_rec_idx WHERE body @@ ts_phrase('alpha');
----
id	payload
1	42

# Post-crash rows replayed from the WAL: each UNION shape round-trips through
# the rebuilt cs (num member, str member, str member, num member).
connection uni_after
query
SELECT id, payload FROM uni_rec_idx ORDER BY id;
----
id	payload
1	42
2	hello
3	world
4	7

# Post-crash rows are searchable via the recovered inverted index.
connection uni_after
query
SELECT payload FROM uni_rec_idx WHERE body @@ ts_phrase('echo foxtrot');
----
payload
world
