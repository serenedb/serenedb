control substitution on

# Exercises the ClickHouse connector's ATTACH path: catalog scan, projection
# and filter pushdown through the attached catalog, schema discovery, and the
# read-only contract (writes through the attach must fail). Also covers the
# secret-based ATTACH path (CREATE SECRET ... TYPE clickhouse).
#
# All chtest.* fixtures are pre-seeded by the container init script; the
# connector is read-only and cannot create CH tables/data, so the test only
# SELECTs from the pre-seeded tables.

statement ok
ATTACH 'host=${CHHOST} port=${CHPORT} database=chtest' AS ch (TYPE clickhouse);


# Catalog scan, ordered for determinism.
query
SELECT id, name FROM ch.chtest.widgets ORDER BY id;
----
id	name
1	gadget
2	gizmo
3	thingamajig
4	gadget
5	widget


# Equality pushdown through the catalog path.
query
SELECT id, name FROM ch.chtest.widgets
WHERE name = 'gadget'
ORDER BY id;
----
id	name
1	gadget
4	gadget


# Range pushdown through the catalog path.
query
SELECT id, price FROM ch.chtest.widgets
WHERE price > 15
ORDER BY id;
----
id	price
2	19.99
5	99.95


# IN pushdown through the catalog path.
query
SELECT id FROM ch.chtest.widgets
WHERE id IN (2, 3)
ORDER BY id;
----
id
2
3


# NOTE: `WHERE note IS NULL` over a Nullable(String) column is intentionally not
# asserted -- the vendored clickhouse-cpp (v2.6.2) mis-deserializes the null
# bitmap for Nullable(String) against ClickHouse 24.8 (Nullable numeric types
# decode correctly). Tracked as a known connector limitation to fix in the lib.


# Filter through the attached table feeding a self-join on a projected,
# pushed-down subset (verify the catalog path composes under a join).
query
SELECT a.id AS a_id, a.name AS a_name, b.id AS b_id
FROM ch.chtest.widgets AS a
JOIN ch.chtest.widgets AS b ON a.name = b.name
WHERE a.name = 'gadget' AND a.id < b.id
ORDER BY a_id, b_id;
----
a_id	a_name	b_id
1	gadget	4


# Schema discovery: zero-row scan confirms the projected columns resolve
# through the catalog without reading data.
query
SELECT id, name FROM ch.chtest.widgets LIMIT 0;
----
id	name


# Schema discovery: information_schema does NOT yet enumerate columns of tables
# in an attached ClickHouse catalog (returns 0) -- a known gap. Column
# resolution itself works (see the LIMIT 0 catalog scan above); this just pins
# the current information_schema behavior so a future improvement updates it.
query
SELECT count(*) FROM information_schema.columns
WHERE table_catalog = 'ch' AND table_schema = 'chtest'
  AND table_name = 'widgets';
----
count
0


# Read-only contract: writes through the attach must fail.
statement error
INSERT INTO ch.chtest.widgets (id, name, price, stock, tags, note)
VALUES (6, 'newthing', 1.00, 1, [], NULL);


statement ok
DETACH ch;


# Secret-based ATTACH path.
statement ok
CREATE SECRET chsecret (TYPE clickhouse, host '${CHHOST}', port '${CHPORT}', user 'default');


statement ok
ATTACH '' AS ch2 (TYPE clickhouse, SECRET chsecret);


query
SELECT id, name FROM ch2.chtest.widgets ORDER BY id;
----
id	name
1	gadget
2	gizmo
3	thingamajig
4	gadget
5	widget


statement ok
DETACH ch2;


statement ok
DROP SECRET chsecret;
