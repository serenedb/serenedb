# OR across two columns: DuckDB keeps a FILTER operator for the disjunction
# above the scan; the connector still returns the correct rows.
query
EXPLAIN SELECT id FROM chexp.chtest.widgets WHERE name = 'widget' OR price < 5;
----
QUERY PLAN
╭─ PROJECTION ────────────────────────╮
│ Projections: #2                     │
│ ~1 row                              │
