╭─ FILTER ─────────┴──────────────────╮
│ Expression:                         │
│ (price < 5.00) OR (name = 'widget') │
│ ~1 row                              │
╰──────────────────┬──────────────────╯
╭─ CLICKHOUSE_SCAN_PUSHDOWN ──────────╮
│ Function: CLICKHOUSE_SCAN_PUSHDOWN  │
│ Table: chtest.widgets               │
│ Projections: name, price, id        │
│ ~5 rows                             │
╰─────────────────────────────────────╯

# rows 3 (price<5) and 5 (widget).
query
SELECT id FROM chexp.chtest.widgets WHERE name = 'widget' OR price < 5 ORDER BY id;
----
id
3
5

# IS NULL on a Nullable(Int32): DuckDB applies the null test through a FILTER
# operator above the scan (c_nullable IS NULL). Fixture row c_uint8=2 is NULL.
query
EXPLAIN SELECT c_uint8 FROM chexp.chtest.types_all WHERE c_nullable IS NULL;
----
QUERY PLAN
╭─ PROJECTION ───────────────────────╮
│ Projections: #1                    │
│ ~1 row                             │
╰──────────────────┬─────────────────╯
╭─ FILTER ─────────┴─────────────────╮
│ Expression: c_nullable IS NULL     │
│ ~1 row                             │
╰──────────────────┬─────────────────╯
╭─ CLICKHOUSE_SCAN_PUSHDOWN ─────────╮
│ Function: CLICKHOUSE_SCAN_PUSHDOWN │
│ Table: chtest.types_all            │
│ Projections: c_nullable, c_uint8   │
│ ~2 rows                            │
╰────────────────────────────────────╯

# c_uint8 = 2.
query
SELECT c_uint8 FROM chexp.chtest.types_all WHERE c_nullable IS NULL;
----
c_uint8
2

# IS NOT NULL: the complementary row.
query
SELECT c_uint8 FROM chexp.chtest.types_all WHERE c_nullable IS NOT NULL ORDER BY c_uint8;
----
c_uint8
1

# BLOB equality against a FixedString(4): the bytes match exactly (rendered via
# unhex on the remote side); a CAST(... AS BLOB) FILTER node sits above the
# scan. Fixture c_fixedstr 'abcd' (c_uint8=1), 'wxyz' (c_uint8=2).
query
EXPLAIN SELECT c_uint8 FROM chexp.chtest.types_all WHERE c_fixedstr = 'abcd'::BLOB;
----
QUERY PLAN
╭─ PROJECTION ───────────────────────╮
│ Projections: c_uint8               │
│ ~1 row                             │
╰──────────────────┬─────────────────╯
╭─ CLICKHOUSE_SCAN_PUSHDOWN ─────────╮
│ Function: CLICKHOUSE_SCAN_PUSHDOWN │
│ Table: chtest.types_all            │
│ Projections: c_fixedstr, c_uint8   │
│ Filters: c_fixedstr = '\\x61626364' │
│ ~1 row                             │
╰────────────────────────────────────╯

# c_uint8 = 1.
query
SELECT c_uint8 FROM chexp.chtest.types_all WHERE c_fixedstr = 'abcd'::BLOB;
----
c_uint8

# BLOB IN list matches both rows.
query error
SELECT c_uint8 FROM chexp.chtest.types_all WHERE c_fixedstr IN ('abcd'::BLOB, 'wxyz'::BLOB) ORDER BY c_uint8;
----
db error: ERROR: ClickHouse error during scan: DB::Exception: Too large string for FixedString column
SQL: SELECT `c_fixedstr`, `c_uint8` FROM `chtest`.`types_all` WHERE `c_fixedstr` IN ('\\x61626364', '\\x7778797a')


# A non-matching BLOB predicate returns the empty result.
query
SELECT count(*) AS n FROM chexp.chtest.types_all WHERE c_fixedstr = 'zzzz'::BLOB;
----
n
0


