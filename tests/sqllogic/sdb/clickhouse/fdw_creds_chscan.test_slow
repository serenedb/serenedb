control substitution on

# FDW credential-handling regression tests for the ClickHouse-style model:
# foreign-server credentials live ONLY in `CREATE SERVER ... OPTIONS` (there is
# no USER MAPPING). This covers:
#  A) a connection-option VALUE containing a space (a password) round-trips
#     through the connstr instead of corrupting it -- the eager attach connects;
#  B) the world-readable pg_foreign_server REDACTS secret VALUES in srvoptions
#     (the plain `password` key, a quoted mixed-case "PASSWORD", the clickhouse
#     `passwd` alias) while leaving the plain keys (host/port/user/database)
#     visible; the eager attach still resolves the real stored value;
#  E) fail-closed redaction -- an unrecognized credential key (sslpassword) is
#     redacted too (redaction is an allow-list of plain addressing keys);
#  R) server USAGE RBAC -- a non-owner LOGIN role without USAGE is denied at
#     query time, GRANT USAGE lets it query, REVOKE denies it again.
#
# Uses the fixture user `scanner` (password 'pass word'); the default user
# (opened password-less by CLICKHOUSE_SKIP_USER_SETUP) rejects a non-empty
# password, so it cannot exercise the password paths. Unique server names
# (fc_*): tests run in parallel against one serened.

# Rerun hygiene: a previously aborted run on a long-lived instance may have
# left these behind (servers/roles are instance-global).
statement ok
DROP SERVER IF EXISTS fc_space;

statement ok
DROP SERVER IF EXISTS fc_pwkey;

statement ok
DROP SERVER IF EXISTS fc_passwd;

statement ok
DROP SERVER IF EXISTS fc_failclosed;

statement ok
DROP SERVER IF EXISTS fc_rbac;

statement ok
DROP ROLE IF EXISTS fc_snoop;

statement ok
DROP ROLE IF EXISTS fc_user;

# ===== A: a space in an option value round-trips through the connstr =====
statement ok
CREATE SERVER fc_space FOREIGN DATA WRAPPER clickhouse_fdw
  OPTIONS (host '${CHHOST}', port '${CHPORT}', database 'chtest', user 'scanner', password 'pass word');

query
SELECT count(*) FROM fc_space.chtest.vedernikoff;
----
count
6

# ===== B: secret VALUES are redacted in the world-readable srvoptions =====
# The plain `password` key: value gone from the catalog view, plain keys visible,
# and the eager attach resolved the real value (the count proves it connected).
query
SELECT array_to_string(srvoptions, ' ') NOT LIKE '%pass word%' AS redacted,
       array_to_string(srvoptions, ' ') LIKE '%database=chtest%' AS plain_visible
FROM pg_foreign_server WHERE srvname = 'fc_space';
----
redacted	plain_visible
t	t

# A quoted "PASSWORD" key (mixed case) is normalised and matched
# case-insensitively, so its value is redacted too; the attach still resolves it.
statement ok
CREATE SERVER fc_pwkey FOREIGN DATA WRAPPER clickhouse_fdw
  OPTIONS (host '${CHHOST}', port '${CHPORT}', database 'chtest', user 'scanner', "PASSWORD" 'pass word');

query
SELECT array_to_string(srvoptions, ' ') NOT LIKE '%pass word%' AS redacted
FROM pg_foreign_server WHERE srvname = 'fc_pwkey';
----
redacted
t

query
SELECT count(*) FROM fc_pwkey.chtest.vedernikoff;
----
count
6

# The `passwd` alias (a valid clickhouse password key) is also redacted and
# connects.
statement ok
CREATE SERVER fc_passwd FOREIGN DATA WRAPPER clickhouse_fdw
  OPTIONS (host '${CHHOST}', port '${CHPORT}', database 'chtest', user 'scanner', passwd 'pass word');

query
SELECT array_to_string(srvoptions, ' ') NOT LIKE '%pass word%' AS redacted
FROM pg_foreign_server WHERE srvname = 'fc_passwd';
----
redacted
t

query
SELECT count(*) FROM fc_passwd.chtest.vedernikoff;
----
count
6

# pg_foreign_server is world-readable: a plain non-superuser sees the row too,
# still with the secret value redacted (the redaction is in the stored catalog,
# not the read gate).
statement ok
CREATE ROLE fc_snoop LOGIN PASSWORD 'fc_snoop_pw';

# NB: a `connection` record binds the NEXT record only (later records revert
# to the default superuser connection), so it is repeated per record.
connection c_snoop user=fc_snoop password=fc_snoop_pw
query
SELECT array_to_string(srvoptions, ' ') NOT LIKE '%pass word%' AS redacted
FROM pg_foreign_server WHERE srvname = 'fc_pwkey';
----
redacted
t

connection default
statement ok
DROP ROLE fc_snoop;

# ===== E: fail-closed redaction -- unrecognized option keys are secrets =====
# The connectors keep growing credential-bearing keys (sslpassword, uri,
# oauth_client_secret, ...); serenedb cannot enumerate them all, so redaction
# is an allow-list: any key that is not plain connection addressing is redacted
# in the world-readable srvoptions. Plain keys stay visible.
statement ok
CREATE SERVER fc_failclosed FOREIGN DATA WRAPPER clickhouse_fdw
  OPTIONS (host '${CHHOST}', port '${CHPORT}', database 'chtest', user 'scanner',
           password 'pass word', sslpassword 'sup3r secret');

query
SELECT array_to_string(srvoptions, ' ') NOT LIKE '%sup3r secret%' AS redacted,
       array_to_string(srvoptions, ' ') LIKE '%database=chtest%' AS plain_visible
FROM pg_foreign_server WHERE srvname = 'fc_failclosed';
----
redacted	plain_visible
t	t

# ===== R: server USAGE RBAC is enforced at query time =====
# A foreign server carries USAGE (PG-style). A role that is neither the owner
# (the superuser `postgres` created these) nor a superuser, and lacks USAGE, is
# denied at query time; GRANT USAGE lets it through; REVOKE denies it again.
# fc_rbac connects via the scanner credentials in its OPTIONS.
statement ok
CREATE ROLE fc_user LOGIN PASSWORD 'fc_user_pw';

statement ok
CREATE SERVER fc_rbac FOREIGN DATA WRAPPER clickhouse_fdw
  OPTIONS (host '${CHHOST}', port '${CHPORT}', database 'chtest', user 'scanner', password 'pass word');

# Without USAGE, fc_user is denied.
connection c_user user=fc_user password=fc_user_pw
statement error
SELECT count(*) FROM fc_rbac.chtest.vedernikoff;
----
db error: ERROR: permission denied for foreign server fc_rbac<slt:ignore>


# The superuser grants USAGE on the server.
connection default
statement ok
GRANT USAGE ON FOREIGN SERVER fc_rbac TO fc_user;

# Now fc_user can query through it.
connection c_user user=fc_user password=fc_user_pw
query
SELECT count(*) FROM fc_rbac.chtest.vedernikoff;
----
count
6

# REVOKE takes the privilege away again.
connection default
statement ok
REVOKE USAGE ON FOREIGN SERVER fc_rbac FROM fc_user;

connection c_user user=fc_user password=fc_user_pw
statement error
SELECT count(*) FROM fc_rbac.chtest.vedernikoff;
----
db error: ERROR: permission denied for foreign server fc_rbac<slt:ignore>


# ===== cleanup =====
connection default
statement ok
DROP SERVER fc_space;

statement ok
DROP SERVER fc_pwkey;

statement ok
DROP SERVER fc_passwd;

statement ok
DROP SERVER fc_failclosed;

statement ok
DROP SERVER fc_rbac;

statement ok
DROP ROLE fc_user;
