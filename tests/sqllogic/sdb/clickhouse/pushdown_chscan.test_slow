control substitution on

# Exercises clickhouse_scanner's filter pushdown over the pre-seeded
# chtest.widgets fixture. Covers equality, IN, range, IS NULL and an
# AND/OR combination. The connector pushes =, <>, <, >, <=, >=, IN and
# IS [NOT] NULL (combined with AND/OR); filters it cannot push stay local,
# so results must be correct either way. Read-only: the fixture rows are
# seeded by the container init script, the test only SELECTs.

# Full scan, ordered for determinism.
query
SELECT id, name, price, stock
FROM clickhouse_scan('host=${CHHOST} port=${CHPORT} user=default', 'chtest', 'widgets')
ORDER BY id;
----
id	name	price	stock
1	gadget	9.99	10
2	gizmo	19.99	0
3	thingamajig	4.50	5
4	gadget	14.99	3
5	widget	99.95	42


# Equality pushdown (WHERE name = 'gadget').
query
SELECT id FROM clickhouse_scan('host=${CHHOST} port=${CHPORT} user=default', 'chtest', 'widgets')
WHERE name = 'gadget'
ORDER BY id;
----
id
1
4


# IN pushdown (WHERE id IN (1, 3)).
query
SELECT id FROM clickhouse_scan('host=${CHHOST} port=${CHPORT} user=default', 'chtest', 'widgets')
WHERE id IN (1, 3)
ORDER BY id;
----
id
1
3


# Range pushdown (WHERE price > 10).
query
SELECT id, price FROM clickhouse_scan('host=${CHHOST} port=${CHPORT} user=default', 'chtest', 'widgets')
WHERE price > 10
ORDER BY id;
----
id	price
2	19.99
4	14.99
5	99.95


# NOTE: `WHERE note IS NULL` over a Nullable(String) column is intentionally not
# asserted -- the vendored clickhouse-cpp (v2.6.2) mis-deserializes the null
# bitmap for Nullable(String) against ClickHouse 24.8 (Nullable numeric types
# decode correctly). Tracked as a known connector limitation to fix in the lib.


# AND combination (WHERE name = 'gadget' AND price > 10).
query
SELECT id FROM clickhouse_scan('host=${CHHOST} port=${CHPORT} user=default', 'chtest', 'widgets')
WHERE name = 'gadget' AND price > 10
ORDER BY id;
----
id
4


# OR combination (WHERE name = 'widget' OR price < 5).
query
SELECT id FROM clickhouse_scan('host=${CHHOST} port=${CHPORT} user=default', 'chtest', 'widgets')
WHERE name = 'widget' OR price < 5
ORDER BY id;
----
id
3
5
