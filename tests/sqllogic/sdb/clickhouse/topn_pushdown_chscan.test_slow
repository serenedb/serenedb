control substitution on

# TOP_N (ORDER BY + LIMIT) pushdown via the shared dbconnector
# OrderByAndLimitOptimizer (the same rule the postgres connector runs): the fold
# REMOVES the local TOP_N node and the scan's remote SQL gains "ORDER BY ...
# LIMIT n [OFFSET m]", so only limit rows cross the wire and the remote order is
# the final order. Null placement never relies on the remote default (engines
# disagree): every key gets an explicit `IS [NOT] NULL` prefix key. Visible in
# EXPLAIN as the scan box's `Pushed Order:` / `Pushed Limit:` lines.
#
# Refusal gates (no fold; TOP_N stays local): a REQUIRED filter on the scan (its
# remote rendering may be inexact and re-applied locally AFTER a remote LIMIT
# already cut the stream), non-column order keys, and compound keys nesting a
# divergent scalar. Scalar keys whose native ClickHouse ordering diverges are
# REWRITTEN instead of refused (isNaN prefix for floats, toString for UUID and
# text-backed columns) -- see pushdown_divergence_chscan.
#
# Fixtures: chtest.vedernikoff (6 rows, ids 1..6), chtest.widgets (5 rows, note has
# 2 NULLs at ids 2 and 4).

statement ok
ATTACH 'host=${CHHOST} port=${CHPORT} database=chtest' AS chtop (TYPE clickhouse);

# ORDER BY + LIMIT: the TOP_N node is folded away; the scan box shows the
# pushed order and limit.
query ?
EXPLAIN SELECT id FROM chtop.chtest.vedernikoff ORDER BY id LIMIT 3;
----
QUERY PLAN
╭─ CLICKHOUSE_SCAN_PUSHDOWN ─────────╮
│ Function: CLICKHOUSE_SCAN_PUSHDOWN │
│ Table: chtest.vedernikoff          │
│ Pushed Order:                      │
│ ORDER BY `id` IS NULL, `id` ASC    │
│ Pushed Limit: LIMIT 3              │
│ Projections: id                    │
│ Column Filter:                     │
│ optional: Dynamic Filter (id < ?)  │
│ ~6 rows                            │
╰────────────────────────────────────╯

query ?
SELECT id FROM chtop.chtest.vedernikoff ORDER BY id LIMIT 3;
----
id
1
2
3

# DESC with an OFFSET: folded as LIMIT n OFFSET m.
query ?
EXPLAIN SELECT id FROM chtop.chtest.vedernikoff ORDER BY id DESC LIMIT 2 OFFSET 1;
----
QUERY PLAN
╭─ CLICKHOUSE_SCAN_PUSHDOWN ─────────╮
│ Function: CLICKHOUSE_SCAN_PUSHDOWN │
│ Table: chtest.vedernikoff          │
│ Pushed Order:                      │
│ ORDER BY `id` IS NULL, `id` DESC   │
│ Pushed Limit: LIMIT 2 OFFSET 1     │
│ Projections: id                    │
│ Column Filter:                     │
│ optional: Dynamic Filter (id > ?)  │
│ ~6 rows                            │
╰────────────────────────────────────╯

query ?
SELECT id FROM chtop.chtest.vedernikoff ORDER BY id DESC LIMIT 2 OFFSET 1;
----
id
5
4

# Multi-key with explicit NULLS FIRST: the two NULL-note rows come first.
query ?
SELECT id FROM chtop.chtest.widgets ORDER BY note NULLS FIRST, id LIMIT 2;
----
id
2
4

# NULLS FIRST with LIMIT above the NULL count: the TopN optimizer injects an
# OPTIONAL (note IS NULL OR <runtime threshold>) filter into the scan, and the
# threshold branch has no SQL form. Dropping just that branch (the upstream
# blanket drop) pushes a hard `note IS NULL` and silently loses every non-NULL
# row -- LIMIT 2 above cannot catch that, so these assert past the NULLs.
query ?
SELECT id FROM chtop.chtest.widgets ORDER BY note NULLS FIRST, id LIMIT 3;
----
id
2
4
5

query ?
SELECT count(*) AS n FROM (SELECT id FROM chtop.chtest.widgets ORDER BY note NULLS FIRST LIMIT 5) s;
----
n
5

# NULLS LAST puts them at the end.
query ?
SELECT id FROM chtop.chtest.widgets ORDER BY note NULLS LAST, id LIMIT 3;
----
id
5
1
3

# Refusal: a required WHERE filter on the scan blocks the fold (no Pushed Order
# in the scan box), and the result is still correct.
query ?
EXPLAIN SELECT id FROM chtop.chtest.vedernikoff WHERE id > 1 ORDER BY id LIMIT 2;
----
QUERY PLAN
╭─ TOP_N ────────────────────────────────────────╮
│ Top: 2                                         │
│ Order By: vedernikoff.id ASC                   │
│ ~1 row                                         │
╰────────────────────────┬───────────────────────╯
╭─ CLICKHOUSE_SCAN_PUSHDOWN ─────────────────────╮
│ Function: CLICKHOUSE_SCAN_PUSHDOWN             │
│ Table: chtest.vedernikoff                      │
│ Projections: id                                │
│ Column Filter:                                 │
│ (id > 1) AND optional: Dynamic Filter (id < ?) │
│ ~1 row                                         │
╰────────────────────────────────────────────────╯

query ?
SELECT id FROM chtop.chtest.vedernikoff WHERE id > 1 ORDER BY id LIMIT 2;
----
id
2
3

statement ok
DETACH chtop;
