control substitution on

# Additional write situations over an ATTACHed ClickHouse database that the
# other write tests (write_chscan / write_pk / write_situations) do not cover:
# a large multi-vector batch INSERT via generate_series (>1 vector, so the
# INSERT operator flushes several chunks to ClickHouse) plus aggregates over it,
# a wide UPDATE / wide DELETE, CREATE OR REPLACE TABLE, DROP TABLE IF EXISTS on a
# missing table, re-CREATE after DROP, CTAS from an aggregate query, and
# INSERT ... SELECT reading the pre-seeded chtest.vedernikoff fixture into a
# fresh default-db table.
#
# Unique attach name (chwx) + table prefix (wx_): tests run in parallel against
# one serened + one ClickHouse, so global names must not collide.

statement ok
ATTACH 'host=${CHHOST} port=${CHPORT} database=default' AS chwx (TYPE clickhouse);

# ---------------------------------------------------------------------
# Large batch INSERT (>1 vector): 5000 rows generated by generate_series.
# id is the integer PK; bucket = id % 100; handle cycles over 50 distinct
# values. This forces the INSERT operator to push multiple chunks to CH.
# ---------------------------------------------------------------------
statement ok
CREATE TABLE chwx.default.wx_bulk (id BIGINT PRIMARY KEY, bucket INTEGER, handle VARCHAR);

statement ok
INSERT INTO chwx.default.wx_bulk
SELECT s AS id, s % 100 AS bucket, 'pudge_' || (s % 50)::text AS handle
FROM generate_series(1, 5000) AS s;

query
SELECT count(*) FROM chwx.default.wx_bulk;
----
count
5000

# Aggregates over the batch confirm every row round-tripped intact.
query
SELECT min(id), max(id), sum(id) FROM chwx.default.wx_bulk;
----
min	max	sum
1	5000	12502500

# 100 distinct buckets (id % 100 over 1..5000 covers 0..99).
query
SELECT count(DISTINCT bucket) FROM chwx.default.wx_bulk;
----
count
100

# 50 distinct handles (id % 50 cycles 0..49).
query
SELECT count(DISTINCT handle) FROM chwx.default.wx_bulk;
----
count
50

# Exactly 50 rows fall in bucket 0 (ids 100, 200, ..., 5000).
query
SELECT count(*) FROM chwx.default.wx_bulk WHERE bucket = 0;
----
count
50

# A point lookup against a row in the middle of the batch.
query
SELECT id, bucket, handle FROM chwx.default.wx_bulk WHERE id = 2500;
----
id	bucket	handle
2500	0	pudge_0

# ---------------------------------------------------------------------
# Wide UPDATE: rewrite the handle for every row in bucket 0 (50 rows),
# then confirm the count of the new marker.
# ---------------------------------------------------------------------
statement ok
UPDATE chwx.default.wx_bulk SET handle = 'vedernikoff' WHERE bucket = 0;

query
SELECT count(*) FROM chwx.default.wx_bulk WHERE handle = 'vedernikoff';
----
count
50

# handle 'pudge_0' is id%50==0 (100 rows: ids 50,100,...,5000). The UPDATE above
# only touched bucket 0 (id%100==0 -> ids 100,200,...,5000 = 50 of them), so the
# other 50 pudge_0 rows (id%100==50) keep their original handle.
query
SELECT count(*) FROM chwx.default.wx_bulk WHERE handle = 'pudge_0';
----
count
50

# ---------------------------------------------------------------------
# Wide DELETE: remove the lower half of the buckets (bucket < 50), i.e.
# ids whose id % 100 is in 0..49 -> 2500 rows; 2500 remain.
# ---------------------------------------------------------------------
statement ok
DELETE FROM chwx.default.wx_bulk WHERE bucket < 50;

query
SELECT count(*) FROM chwx.default.wx_bulk;
----
count
2500

# Every surviving row now has bucket >= 50.
query
SELECT min(bucket), max(bucket) FROM chwx.default.wx_bulk;
----
min	max
50	99

statement ok
DROP TABLE chwx.default.wx_bulk;

# ---------------------------------------------------------------------
# CREATE OR REPLACE TABLE: first create + populate, then CREATE OR REPLACE
# with a different shape; the replaced table is empty and has the new schema.
# ---------------------------------------------------------------------
statement ok
CREATE TABLE chwx.default.wx_repl (id BIGINT PRIMARY KEY, handle VARCHAR);

statement ok
INSERT INTO chwx.default.wx_repl VALUES (1, 'clickclack'), (2, 'deadinside');

query
SELECT count(*) FROM chwx.default.wx_repl;
----
count
2

statement ok
CREATE OR REPLACE TABLE chwx.default.wx_repl (id BIGINT PRIMARY KEY, mmr INTEGER);

# After replacement the table is empty.
query
SELECT count(*) FROM chwx.default.wx_repl;
----
count
0

# And it has the new column set.
statement ok
INSERT INTO chwx.default.wx_repl VALUES (10, 9000), (20, 4500);

query
SELECT id, mmr FROM chwx.default.wx_repl ORDER BY id;
----
id	mmr
10	9000
20	4500

statement ok
DROP TABLE chwx.default.wx_repl;

# ---------------------------------------------------------------------
# DROP TABLE IF EXISTS on a missing table is a no-op (no error), then a
# DROP-then-re-CREATE cycle reuses the same name with fresh data.
# ---------------------------------------------------------------------
statement ok
DROP TABLE IF EXISTS chwx.default.wx_never_existed;

statement ok
CREATE TABLE chwx.default.wx_cycle (id BIGINT PRIMARY KEY, handle VARCHAR);

statement ok
INSERT INTO chwx.default.wx_cycle VALUES (1, 'kostya');

query
SELECT id, handle FROM chwx.default.wx_cycle ORDER BY id;
----
id	handle
1	kostya

statement ok
DROP TABLE chwx.default.wx_cycle;

# DROP IF EXISTS on the now-gone table is still a no-op.
statement ok
DROP TABLE IF EXISTS chwx.default.wx_cycle;

# Re-CREATE the same name with a fresh schema + data.
statement ok
CREATE TABLE chwx.default.wx_cycle (id BIGINT PRIMARY KEY, handle VARCHAR, mmr INTEGER);

statement ok
INSERT INTO chwx.default.wx_cycle VALUES (1, 'babsky', 1500), (2, 'androed', 6000);

query
SELECT id, handle, mmr FROM chwx.default.wx_cycle ORDER BY id;
----
id	handle	mmr
1	babsky	1500
2	androed	6000

statement ok
DROP TABLE chwx.default.wx_cycle;

# ---------------------------------------------------------------------
# CTAS from an aggregate query: bucket the 5000-row generator by id % 10
# and store per-bucket counts/sums in a fresh ClickHouse table.
# ---------------------------------------------------------------------
statement ok
CREATE TABLE chwx.default.wx_agg AS
SELECT (s % 10) AS bucket, count(*) AS cnt, sum(s) AS total
FROM generate_series(1, 5000) AS s
GROUP BY s % 10;

# 10 buckets, each with 500 rows.
query
SELECT count(*) FROM chwx.default.wx_agg;
----
count
10

query
SELECT bucket, cnt FROM chwx.default.wx_agg ORDER BY bucket;
----
bucket	cnt
0	500
1	500
2	500
3	500
4	500
5	500
6	500
7	500
8	500
9	500

# The per-bucket sums add back up to the total 1..5000 sum.
query
SELECT sum(total) FROM chwx.default.wx_agg;
----
sum
12502500

statement ok
DROP TABLE chwx.default.wx_agg;

# ---------------------------------------------------------------------
# INSERT ... SELECT reading the pre-seeded chtest.vedernikoff fixture
# (in the chtest database) into a fresh table in the writable default db.
# Attach chtest separately read-only and copy across databases.
# ---------------------------------------------------------------------
statement ok
ATTACH 'host=${CHHOST} port=${CHPORT} database=chtest' AS chwx_src (TYPE clickhouse);

statement ok
CREATE TABLE chwx.default.wx_from_fixture (id BIGINT PRIMARY KEY, val VARCHAR);

statement ok
INSERT INTO chwx.default.wx_from_fixture
SELECT id, val FROM chwx_src.chtest.vedernikoff;

query
SELECT id, val FROM chwx.default.wx_from_fixture ORDER BY id;
----
id	val
1	clickclack babsky
2	deadinside kostya
3	vedernikoff pudge
4	pudge goes mid
5	vedernikoff kostya
6	anchin reads manga

# Aggregate over the copied fixture data.
query
SELECT count(*), min(id), max(id), sum(id) FROM chwx.default.wx_from_fixture;
----
count	min	max	sum
6	1	6	21

# Filtered INSERT ... SELECT: only the 'vedernikoff'-prefixed rows.
statement ok
CREATE TABLE chwx.default.wx_filtered (id BIGINT PRIMARY KEY, val VARCHAR);

statement ok
INSERT INTO chwx.default.wx_filtered
SELECT id, val FROM chwx_src.chtest.vedernikoff WHERE val LIKE 'vedernikoff%';

query
SELECT id, val FROM chwx.default.wx_filtered ORDER BY id;
----
id	val
3	vedernikoff pudge
5	vedernikoff kostya

# ---------------------------------------------------------------------
# Cleanup.
# ---------------------------------------------------------------------
statement ok
DROP TABLE chwx.default.wx_filtered;

statement ok
DROP TABLE chwx.default.wx_from_fixture;

statement ok
DETACH chwx_src;

statement ok
DETACH chwx;
