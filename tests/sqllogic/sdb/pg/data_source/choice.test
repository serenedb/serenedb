# =============================================================================
# Range lookup tests — single PK column
# =============================================================================

statement ok
CREATE TABLE t_range1 (a INTEGER, val INTEGER, PRIMARY KEY (a));

statement ok
INSERT INTO t_range1 VALUES (1, 10), (2, 20), (3, 30), (5, 50), (8, 80), (9, 90), (10, 100);

# Two disjoint ranges: a < 2 OR a > 8
query
SELECT * FROM t_range1 WHERE a < 2 OR a > 8 ORDER BY a;
----
a	val
1	10
9	90
10	100

onlyif serenedb
query
EXPLAIN (ANALYZE) SELECT * FROM t_range1 WHERE a < 2 OR a > 8 ORDER BY a;
----
QUERY PLAN
<slt:ignore>[t_range1, type=rocksdb_range_lookup, ranges=[{a=(-inf, 2)}, {a=(8, +inf)}]]<slt:ignore>

# Overlapping bounds collapse to single range: a > 2 AND a >= 3 → a >= 3
query
SELECT * FROM t_range1 WHERE a > 2 AND a >= 3 ORDER BY a;
----
a	val
3	30
5	50
8	80
9	90
10	100

onlyif serenedb
query
EXPLAIN (ANALYZE) SELECT * FROM t_range1 WHERE a > 2 AND a >= 3 ORDER BY a;
----
QUERY PLAN
<slt:ignore>[t_range1, type=rocksdb_range_lookup, ranges=[{a=[3, +inf)}]]<slt:ignore>

# Single lower bound: a >= 5
query
SELECT * FROM t_range1 WHERE a >= 5 ORDER BY a;
----
a	val
5	50
8	80
9	90
10	100

onlyif serenedb
query
EXPLAIN (ANALYZE) SELECT * FROM t_range1 WHERE a >= 5 ORDER BY a;
----
QUERY PLAN
<slt:ignore>[t_range1, type=rocksdb_range_lookup, ranges=[{a=[5, +inf)}]]<slt:ignore>

# Single upper bound: a < 5
query
SELECT * FROM t_range1 WHERE a < 5 ORDER BY a;
----
a	val
1	10
2	20
3	30

onlyif serenedb
query
EXPLAIN (ANALYZE) SELECT * FROM t_range1 WHERE a < 5 ORDER BY a;
----
QUERY PLAN
<slt:ignore>[t_range1, type=rocksdb_range_lookup, ranges=[{a=(-inf, 5)}]]<slt:ignore>

# Closed interval: a >= 2 AND a <= 8
query
SELECT * FROM t_range1 WHERE a >= 2 AND a <= 8 ORDER BY a;
----
a	val
2	20
3	30
5	50
8	80

onlyif serenedb
query
EXPLAIN (ANALYZE) SELECT * FROM t_range1 WHERE a >= 2 AND a <= 8 ORDER BY a;
----
QUERY PLAN
<slt:ignore>[t_range1, type=rocksdb_range_lookup, ranges=[{a=[2, 8]}]]<slt:ignore>

statement ok
DROP TABLE t_range1;


# =============================================================================
# Range lookup tests — composite PK
# Chosen when the filter has an equality prefix of K >= 1 PK columns followed
# by a range on the next column. Falls back to full scan otherwise.
# =============================================================================

statement ok
CREATE TABLE t_range (a INTEGER, b INTEGER, val INTEGER, PRIMARY KEY (a, b));

statement ok
INSERT INTO t_range VALUES
  (1, 1, 11), (1, 3, 13), (1, 5, 15), (1, 7, 17), (1, 9, 19),
  (2, 1, 21), (2, 3, 23), (2, 5, 25), (2, 7, 27), (2, 9, 29),
  (3, 1, 31), (3, 5, 35), (3, 9, 39);

# --- Basic range shapes ---

# Exclusive lower bound: a=1 AND b > 5
query
SELECT * FROM t_range WHERE a = 1 AND b > 5 ORDER BY b;
----
a	b	val
1	7	17
1	9	19

onlyif serenedb
query
EXPLAIN (ANALYZE) SELECT * FROM t_range WHERE a = 1 AND b > 5 ORDER BY b;
----
QUERY PLAN
<slt:ignore>[t_range, type=rocksdb_range_lookup, ranges=[{a=1, b=(5, +inf)}]]<slt:ignore>

# Inclusive lower bound: a=1 AND b >= 5
query
SELECT * FROM t_range WHERE a = 1 AND b >= 5 ORDER BY b;
----
a	b	val
1	5	15
1	7	17
1	9	19

onlyif serenedb
query
EXPLAIN (ANALYZE) SELECT * FROM t_range WHERE a = 1 AND b >= 5 ORDER BY b;
----
QUERY PLAN
<slt:ignore>[t_range, type=rocksdb_range_lookup, ranges=[{a=1, b=[5, +inf)}]]<slt:ignore>

# Exclusive upper bound only: a=2 AND b < 7
query
SELECT * FROM t_range WHERE a = 2 AND b < 7 ORDER BY b;
----
a	b	val
2	1	21
2	3	23
2	5	25

onlyif serenedb
query
EXPLAIN (ANALYZE) SELECT * FROM t_range WHERE a = 2 AND b < 7 ORDER BY b;
----
QUERY PLAN
<slt:ignore>[t_range, type=rocksdb_range_lookup, ranges=[{a=2, b=(-inf, 7)}]]<slt:ignore>

# Closed interval: a=1 AND b >= 3 AND b <= 7
query
SELECT * FROM t_range WHERE a = 1 AND b >= 3 AND b <= 7 ORDER BY b;
----
a	b	val
1	3	13
1	5	15
1	7	17

onlyif serenedb
query
EXPLAIN (ANALYZE) SELECT * FROM t_range WHERE a = 1 AND b >= 3 AND b <= 7 ORDER BY b;
----
QUERY PLAN
<slt:ignore>[t_range, type=rocksdb_range_lookup, ranges=[{a=1, b=[3, 7]}]]<slt:ignore>

# Half-open exclusive on both sides: a=1 AND b > 1 AND b < 9
query
SELECT * FROM t_range WHERE a = 1 AND b > 1 AND b < 9 ORDER BY b;
----
a	b	val
1	3	13
1	5	15
1	7	17

onlyif serenedb
query
EXPLAIN (ANALYZE) SELECT * FROM t_range WHERE a = 1 AND b > 1 AND b < 9 ORDER BY b;
----
QUERY PLAN
<slt:ignore>[t_range, type=rocksdb_range_lookup, ranges=[{a=1, b=(1, 9)}]]<slt:ignore>

# --- OR of ranges ---

# OR of two disjoint ranges on the same equality prefix → 2 separate bounds.
query
SELECT * FROM t_range WHERE a = 1 AND (b < 3 OR b > 7) ORDER BY b;
----
a	b	val
1	1	11
1	9	19

onlyif serenedb
query
EXPLAIN (ANALYZE) SELECT * FROM t_range WHERE a = 1 AND (b < 3 OR b > 7) ORDER BY b;
----
QUERY PLAN
<slt:ignore>[t_range, type=rocksdb_range_lookup, ranges=[{a=1, b=(-inf, 3)}, {a=1, b=(7, +inf)}]]<slt:ignore>

# OR of overlapping ranges on the same equality prefix → merged into one.
# (a=1 AND b>=3 AND b<=7) OR (a=1 AND b>=5 AND b<=9) → a=1 AND b ∈ [3,9]
query
SELECT * FROM t_range WHERE (a=1 AND b >= 3 AND b <= 7) OR (a=1 AND b >= 5 AND b <= 9) ORDER BY b;
----
a	b	val
1	3	13
1	5	15
1	7	17
1	9	19

onlyif serenedb
query
EXPLAIN (ANALYZE) SELECT * FROM t_range WHERE (a=1 AND b >= 3 AND b <= 7) OR (a=1 AND b >= 5 AND b <= 9) ORDER BY b;
----
QUERY PLAN
<slt:ignore>[t_range, type=rocksdb_range_lookup, ranges=[{a=1, b=[3, 9]}]]<slt:ignore>

# OR of ranges with different equality prefixes → two separate range constraints.
query
SELECT * FROM t_range WHERE (a=1 AND b > 7) OR (a=2 AND b > 5) ORDER BY a, b;
----
a	b	val
1	9	19
2	7	27
2	9	29

onlyif serenedb
query
EXPLAIN (ANALYZE) SELECT * FROM t_range WHERE (a=1 AND b > 7) OR (a=2 AND b > 5) ORDER BY a, b;
----
QUERY PLAN
<slt:ignore>[t_range, type=rocksdb_range_lookup, ranges=[{a=1, b=(7, +inf)}, {a=2, b=(5, +inf)}]]<slt:ignore>


# Range on first PK column only → range lookup on a.
query
SELECT * FROM t_range WHERE a > 1 ORDER BY a, b;
----
a	b	val
2	1	21
2	3	23
2	5	25
2	7	27
2	9	29
3	1	31
3	5	35
3	9	39

onlyif serenedb
query
EXPLAIN (ANALYZE) SELECT * FROM t_range WHERE a > 1 ORDER BY a, b;
----
QUERY PLAN
<slt:ignore>[t_range, type=rocksdb_range_lookup, ranges=[{a=(1, +inf)}]]<slt:ignore>

query
SELECT * FROM t_range WHERE a <= 1 OR a > 2 ORDER BY a, b;
----
a	b	val
1	1	11
1	3	13
1	5	15
1	7	17
1	9	19
3	1	31
3	5	35
3	9	39

onlyif serenedb
query
EXPLAIN (ANALYZE) SELECT * FROM t_range WHERE a <= 1 OR a > 2 ORDER BY a, b;
----
QUERY PLAN
<slt:ignore>[t_range, type=rocksdb_range_lookup, ranges=[{a=(-inf, 1]}, {a=(2, +inf)}]]<slt:ignore>

# Filter on non-first PK column only → full scan.
query
SELECT * FROM t_range WHERE b > 5 ORDER BY a, b;
----
a	b	val
1	7	17
1	9	19
2	7	27
2	9	29
3	9	39

onlyif serenedb
query
EXPLAIN (ANALYZE) SELECT * FROM t_range WHERE b > 5 ORDER BY a, b;
----
QUERY PLAN
<slt:ignore>[t_range, type=rocksdb_full_scan]<slt:ignore>

# OR mixing a range-scannable branch with a non-range-scannable one → full scan.
# b > 3 alone has no equality prefix → forces full scan.
query
SELECT * FROM t_range WHERE (a=1 AND b > 5) OR (b > 3) ORDER BY a, b;
----
a	b	val
1	5	15
1	7	17
1	9	19
2	5	25
2	7	27
2	9	29
3	5	35
3	9	39

onlyif serenedb
query
EXPLAIN (ANALYZE) SELECT * FROM t_range WHERE (a=1 AND b > 5) OR (b > 3) ORDER BY a, b;
----
QUERY PLAN
<slt:ignore>[t_range, type=rocksdb_full_scan]<slt:ignore>

# Range on a combined with range on b: only a's range is used for seek.
query
SELECT * FROM t_range WHERE a > 1 AND b > 5 ORDER BY a, b;
----
a	b	val
2	7	27
2	9	29
3	9	39

onlyif serenedb
query
EXPLAIN (ANALYZE) SELECT * FROM t_range WHERE a > 1 AND b > 5 ORDER BY a, b;
----
QUERY PLAN
<slt:ignore>[t_range, type=rocksdb_range_lookup, ranges=[{a=(1, +inf)}]]<slt:ignore>

# TODO detect such cases and print empty
# Impossible range (b > 9 AND b < 1) → contradiction → 0 rows, full scan.
query
SELECT * FROM t_range WHERE a = 1 AND b > 9 AND b < 1 ORDER BY b;
----
a	b	val

onlyif serenedb
query
EXPLAIN (ANALYZE) SELECT * FROM t_range WHERE a = 1 AND b > 9 AND b < 1 ORDER BY b;
----
QUERY PLAN
<slt:ignore>[t_range, type=rocksdb_full_scan]<slt:ignore>

# Boundary equality: b >= 5 AND b <= 5 is equivalent to b = 5 → point lookup.
query
SELECT * FROM t_range WHERE a = 1 AND b >= 5 AND b <= 5;
----
a	b	val
1	5	15

onlyif serenedb
query
EXPLAIN (ANALYZE) SELECT * FROM t_range WHERE a = 1 AND b >= 5 AND b <= 5;
----
QUERY PLAN
<slt:ignore>[t_range, type=rocksdb_point_lookup, points=[(a=1, b=5)]]<slt:ignore>

# NULL value in non-PK column passes through range scan correctly.
query
SELECT * FROM t_range WHERE a = 1 AND b > 5 AND val IS NULL ORDER BY b;
----
a	b	val

onlyif serenedb
query
EXPLAIN (ANALYZE) SELECT * FROM t_range WHERE a = 1 AND b > 5 AND val IS NULL ORDER BY b;
----
QUERY PLAN
<slt:ignore>[t_range, type=rocksdb_range_lookup, ranges=[{a=1, b=(5, +inf)}]]<slt:ignore>

# --- RYOW: range lookup within a transaction ---

onlyif serenedb
statement ok
SET sdb_read_your_own_writes = 1;

statement ok
BEGIN;

statement count 2
INSERT INTO t_range VALUES (4, 3, 43), (4, 7, 47);

query
SELECT * FROM t_range WHERE a = 4 AND b > 5 ORDER BY b;
----
a	b	val
4	7	47

onlyif serenedb
query
EXPLAIN (ANALYZE) SELECT * FROM t_range WHERE a = 4 AND b > 5;
----
QUERY PLAN
<slt:ignore>[t_range, type=rocksdb_range_lookup, ranges=[{a=4, b=(5, +inf)}]]<slt:ignore>

statement ok
ROLLBACK;

onlyif serenedb
statement ok
SET sdb_read_your_own_writes = 0;

statement ok
DROP TABLE t_range;


statement ok
CREATE TABLE t_range3 (a INTEGER, b INTEGER, c INTEGER, val INTEGER, PRIMARY KEY (a, b, c));

statement ok
INSERT INTO t_range3 VALUES
  (1, 2, 1, 121), (1, 2, 3, 123), (1, 2, 5, 125), (1, 2, 7, 127),
  (1, 3, 1, 131), (1, 3, 5, 135),
  (2, 2, 1, 221), (2, 2, 9, 229);

# a=1 AND b=2 AND c>3 → K=2 equality prefix (a,b) + c range.
query
SELECT * FROM t_range3 WHERE a = 1 AND b = 2 AND c > 3 ORDER BY c;
----
a	b	c	val
1	2	5	125
1	2	7	127

onlyif serenedb
query
EXPLAIN (ANALYZE) SELECT * FROM t_range3 WHERE a = 1 AND b = 2 AND c > 3 ORDER BY c;
----
QUERY PLAN
<slt:ignore>[t_range3, type=rocksdb_range_lookup, ranges=[{a=1, b=2, c=(3, +inf)}]]<slt:ignore>

# a=1 AND b=2 (only equalities, no range col) → range lookup on equality prefix.
query
SELECT * FROM t_range3 WHERE a = 1 AND b = 2 ORDER BY c;
----
a	b	c	val
1	2	1	121
1	2	3	123
1	2	5	125
1	2	7	127

onlyif serenedb
query
EXPLAIN (ANALYZE) SELECT * FROM t_range3 WHERE a = 1 AND b = 2 ORDER BY c;
----
QUERY PLAN
<slt:ignore>[t_range3, type=rocksdb_range_lookup, ranges=[{a=1, b=[2, 2]}]]<slt:ignore>

# a=1 AND c>3 (gap: b not constrained) → not a valid prefix → full scan.
query
SELECT * FROM t_range3 WHERE a = 1 AND c > 3 ORDER BY b, c;
----
a	b	c	val
1	2	5	125
1	2	7	127
1	3	5	135

onlyif serenedb
query
EXPLAIN (ANALYZE) SELECT * FROM t_range3 WHERE a = 1 AND c > 3 ORDER BY b, c;
----
QUERY PLAN
<slt:ignore>[t_range3, type=rocksdb_range_lookup, ranges=[{a=[1, 1]}]]<slt:ignore>

# a > 1 range on first col of 3-col PK → range lookup on a.
query
SELECT * FROM t_range3 WHERE a > 1 ORDER BY a, b, c;
----
a	b	c	val
2	2	1	221
2	2	9	229

onlyif serenedb
query
EXPLAIN (ANALYZE) SELECT * FROM t_range3 WHERE a > 1 ORDER BY a, b, c;
----
QUERY PLAN
<slt:ignore>[t_range3, type=rocksdb_range_lookup, ranges=[{a=(1, +inf)}]]<slt:ignore>

# OR of two complete-prefix ranges on 3-col PK.
query
SELECT * FROM t_range3 WHERE (a=1 AND b=2 AND c>5) OR (a=2 AND b=2 AND c<5) ORDER BY a, b, c;
----
a	b	c	val
1	2	7	127
2	2	1	221

onlyif serenedb
query
EXPLAIN (ANALYZE) SELECT * FROM t_range3 WHERE (a=1 AND b=2 AND c>5) OR (a=2 AND b=2 AND c<5) ORDER BY a, b, c;
----
QUERY PLAN
<slt:ignore>[t_range3, type=rocksdb_range_lookup, ranges=[{a=1, b=2, c=(5, +inf)}, {a=2, b=2, c=(-inf, 5)}]]<slt:ignore>

statement ok
DROP TABLE t_range3;
