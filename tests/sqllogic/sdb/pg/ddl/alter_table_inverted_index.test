# ALTER TABLE on a table that carries an inverted index. The data plane is a
# DuckDB store table, so ADD / DROP / ALTER COLUMN are delegated to it and kept
# in sync with the inverted index:
#   - RENAME column/table/index: the index follows (it keys columns by id).
#   - ADD COLUMN: index-neutral; a DEFAULT backfills existing rows.
#   - DROP COLUMN: a column an index covers cascade-drops that index (PG
#     column->index cascade); a non-indexed column leaves the index intact.
#   - ALTER COLUMN TYPE: allowed for a non-indexed column; rejected for an
#     indexed one (the index stores values of the old type -- drop it first).


statement ok
CREATE TEXT SEARCH DICTIONARY ati_dict(
    template = 'text', locale = 'en_US.UTF-8', case = 'none',
    stemming = false, accent = false, frequency = true, position = true);


statement ok
CREATE TABLE ati_t(id INTEGER PRIMARY KEY, body TEXT, tag TEXT, extra INTEGER);


statement ok
CREATE INDEX ati_idx ON ati_t USING inverted(body ati_dict) INCLUDE (extra);


statement count 2
INSERT INTO ati_t VALUES (1, 'alpha bravo', 'x', 10), (2, 'charlie delta', 'y', 20);


statement ok
VACUUM (REFRESH_TABLE) ati_t;


query
SELECT id, extra FROM ati_idx WHERE body @@ ts_phrase('alpha');
----
id	extra
1	10


# RENAME an indexed column: the index follows; search by the new name works.
statement ok
ALTER TABLE ati_t RENAME COLUMN body TO body2;


query
SELECT id, extra FROM ati_idx WHERE body2 @@ ts_phrase('charlie');
----
id	extra
2	20


# RENAME an INCLUDE'd column: still projected from the index columnstore.
statement ok
ALTER TABLE ati_t RENAME COLUMN extra TO extra2;


query
SELECT id, extra2 FROM ati_idx WHERE body2 @@ ts_phrase('alpha');
----
id	extra2
1	10


# ADD COLUMN with a DEFAULT: index-neutral; existing rows backfilled, search
# still works, and the new column is queryable.
statement ok
ALTER TABLE ati_t ADD COLUMN score INTEGER DEFAULT 100;


query
SELECT id, extra2 FROM ati_idx WHERE body2 @@ ts_phrase('charlie');
----
id	extra2
2	20


query
SELECT id, score FROM ati_t ORDER BY id;
----
id	score
1	100
2	100


# RENAME the table: the index follows it, and DML after the rename still syncs.
statement ok
ALTER TABLE ati_t RENAME TO ati_t2;


statement count 1
INSERT INTO ati_t2 VALUES (3, 'echo foxtrot', 'z', 30, 100);


statement ok
VACUUM (REFRESH_TABLE) ati_t2;


query
SELECT id, extra2 FROM ati_idx WHERE body2 @@ ts_phrase('echo');
----
id	extra2
3	30


# RENAME the inverted index itself.
statement ok
ALTER INDEX ati_idx RENAME TO ati_idx2;


query
SELECT id FROM ati_idx2 WHERE body2 @@ ts_phrase('alpha');
----
id
1


# DROP a non-indexed column: the index is unaffected.
statement ok
ALTER TABLE ati_t2 DROP COLUMN tag;


query
SELECT id FROM ati_idx2 WHERE body2 @@ ts_phrase('delta');
----
id
2


# ALTER COLUMN TYPE of a non-indexed column.
statement ok
ALTER TABLE ati_t2 ALTER COLUMN score TYPE BIGINT;


# ALTER COLUMN TYPE of an indexed column is rejected (drop the index first).
statement error
ALTER TABLE ati_t2 ALTER COLUMN body2 TYPE VARCHAR(100);
----
db error: ERROR: cannot alter type of column "body2" because index "ati_idx2" depends on it; drop the index first


# DROP the indexed column: the inverted index covering it is cascade-dropped.
statement ok
ALTER TABLE ati_t2 DROP COLUMN body2;


# The index is gone; the table itself survives and stays queryable.
statement error
SELECT id FROM ati_idx2;
----
db error: ERROR: Table with name ati_idx2 does not exist!<slt:ignore>


query
SELECT id, extra2, score FROM ati_t2 ORDER BY id;
----
id	extra2	score
1	10	100
2	20	100
3	30	100


statement ok
DROP TABLE ati_t2;


statement ok
DROP TEXT SEARCH DICTIONARY ati_dict;


# An inverted index on a struct SUB-FIELD expression (e.g. (s['id']::INTEGER))
# records the base struct column as a referenced dependency, so the index
# covers it even though the column never appears directly. ADD / DROP / RENAME
# FIELD and a whole-column type change are all rejected until the index is
# dropped; dropping the struct column itself cascade-drops the expression index.


statement ok
CREATE TABLE ati_struct(pk INTEGER PRIMARY KEY, s STRUCT(id INTEGER, name VARCHAR));


statement count 1
INSERT INTO ati_struct VALUES (1, ROW(100, 'alice'));


statement ok
CREATE INDEX ati_struct_idx ON ati_struct USING inverted((s['id']::INTEGER));


# ADD a field to the indexed struct column -- rejected.
statement error
ALTER TABLE ati_struct ADD COLUMN s.k INTEGER;
----
db error: ERROR: cannot alter a field of column "s" because index "ati_struct_idx" depends on it; drop the index first


# RENAME the indexed sub-field -- rejected.
statement error
ALTER TABLE ati_struct RENAME COLUMN s.id TO ident;
----
db error: ERROR: cannot alter a field of column "s" because index "ati_struct_idx" depends on it; drop the index first


# DROP the indexed sub-field -- rejected.
statement error
ALTER TABLE ati_struct DROP COLUMN s.id;
----
db error: ERROR: cannot alter a field of column "s" because index "ati_struct_idx" depends on it; drop the index first


# A whole-column type change is rejected for the same reason.
statement error
ALTER TABLE ati_struct ALTER COLUMN s TYPE STRUCT(id BIGINT, name VARCHAR);
----
db error: ERROR: cannot alter type of column "s" because index "ati_struct_idx" depends on it; drop the index first


# Dropping the whole struct column cascade-drops the expression index.
statement ok
ALTER TABLE ati_struct DROP COLUMN s;


statement error
SELECT pk FROM ati_struct_idx;
----
db error: ERROR: Table with name ati_struct_idx does not exist!<slt:ignore>


# With the index gone, struct field ops work again on a fresh struct column.
statement ok
ALTER TABLE ati_struct ADD COLUMN s2 STRUCT(a INTEGER);


statement ok
ALTER TABLE ati_struct ADD COLUMN s2.b INTEGER;


query
SELECT typeof(s2) FROM ati_struct LIMIT 1;
----
typeof
STRUCT(a INTEGER, b INTEGER)


statement ok
DROP TABLE ati_struct;
