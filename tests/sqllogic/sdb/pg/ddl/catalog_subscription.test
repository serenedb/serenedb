# Tests for CREATE SUBSCRIPTION syntax.
# The catalog handler is not yet implemented, so every form of the statement is
# parsed successfully but fails at execution time with a "does not exist" error
# for the create_subscription pragma.  The point of these tests is to verify that
# the PEG grammar accepts all supported syntactic forms without a parse error.

# --- Bare form ---
statement error
CREATE SUBSCRIPTION my_sub;
----
db error: ERROR: Unsupported create_subscription in catalog


# --- WITH CONNECTION only ---
statement error
CREATE SUBSCRIPTION my_sub CONNECTION 'host=localhost dbname=mydb';
----
db error: ERROR: Unsupported create_subscription in catalog


# --- WITH CONNECTION + single PUBLICATION ---
statement error
CREATE SUBSCRIPTION my_sub CONNECTION 'host=localhost dbname=mydb' PUBLICATION my_pub;
----
db error: ERROR: Unsupported create_subscription in catalog


# --- WITH CONNECTION + multiple PUBLICATIONs ---
statement error
CREATE SUBSCRIPTION my_sub CONNECTION 'host=localhost dbname=mydb' PUBLICATION pub1, pub2;
----
db error: ERROR: Unsupported create_subscription in catalog
