# --- column DEFAULT calling a user function ---------------------------------

statement ok
CREATE SEQUENCE ml_paper_seq;


statement ok
CREATE FUNCTION ml_paper_default_id() AS nextval('ml_paper_seq') + 1000;


statement ok
CREATE TABLE ml_paper_runs (id INT DEFAULT ml_paper_default_id(), tag TEXT);


statement ok
INSERT INTO ml_paper_runs (tag) VALUES ('vedernikoff_run1');


query
SELECT id, tag FROM ml_paper_runs;
----
id	tag
1001	vedernikoff_run1


# Plain DROP FUNCTION must be refused -- ml_paper_runs.id's DEFAULT
# references it.
statement error (?i)cannot drop function .*ml_paper_default_id.* because other objects depend on it
DROP FUNCTION ml_paper_default_id();


# CASCADE clears the DEFAULT on the column without dropping the table.
statement ok
DROP FUNCTION ml_paper_default_id() CASCADE;


# After the DEFAULT is cleared, INSERT without explicit id should write NULL.
statement ok
INSERT INTO ml_paper_runs (tag) VALUES ('vedernikoff_run2');


query
SELECT id, tag FROM ml_paper_runs ORDER BY tag;
----
id	tag
1001	vedernikoff_run1
NULL	vedernikoff_run2


statement ok
DROP TABLE ml_paper_runs;


statement ok
DROP SEQUENCE ml_paper_seq;
