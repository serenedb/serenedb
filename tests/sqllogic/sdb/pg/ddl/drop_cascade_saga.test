# --- 5. Cross-schema CHECK constraint referencing a function ----------------
# CHECK constraints can reach across schemas. CASCADE on the function schema
# must rewrite the table definition to drop the CHECK while keeping the rest.

statement ok
CREATE SCHEMA vedernikoff_ml_paper;


statement ok
CREATE SCHEMA vedernikoff_iceberg_audit;


statement ok
CREATE FUNCTION vedernikoff_ml_paper.is_positive(x INT) AS x > 0;


statement ok
CREATE TABLE vedernikoff_iceberg_audit.runs (
  id INT,
  score INT,
  CONSTRAINT score_must_be_positive
    CHECK (vedernikoff_ml_paper.is_positive(score))
);


statement count 1
INSERT INTO vedernikoff_iceberg_audit.runs VALUES (1, 42);


statement error (?i)
INSERT INTO vedernikoff_iceberg_audit.runs VALUES (2, -5);


# Plain DROP fails: the CHECK constraint depends on the function.
statement error (?i)cannot drop function .*is_positive.* because other objects depend on it
DROP FUNCTION vedernikoff_ml_paper.is_positive(INT);


statement ok
DROP FUNCTION vedernikoff_ml_paper.is_positive(INT) CASCADE;


# Constraint should be cleared -- the previously rejected row now inserts.
statement count 1
INSERT INTO vedernikoff_iceberg_audit.runs VALUES (2, -5);


query
SELECT id, score FROM vedernikoff_iceberg_audit.runs ORDER BY id;
----
id	score
1	42
2	-5


statement ok
DROP SCHEMA vedernikoff_iceberg_audit CASCADE;


statement ok
DROP SCHEMA vedernikoff_ml_paper CASCADE;


