# --- 8. SERIAL table dropped without CASCADE while no cross-tree ref -------
# Sanity check: a table with auto-PK owned sequence + an explicit index must
# drop without CASCADE if nothing outside the table's composition subtree
# references it.

statement ok
CREATE TABLE vedernikoff_solid_module_writeups (
  id SERIAL PRIMARY KEY,
  topic TEXT
);


statement ok
CREATE INDEX vedernikoff_solid_topic_idx
  ON vedernikoff_solid_module_writeups (topic);


