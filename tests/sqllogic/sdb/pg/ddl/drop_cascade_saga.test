# --- 20. Multiple seeds: CASCADE that fans out widely ----------------------
# Build a graph with a sequence shared by a function, a view, several column
# DEFAULTs, and a CHECK constraint. Drop the sequence with CASCADE and audit
# the surviving objects.

statement ok
CREATE SEQUENCE vedernikoff_mop_iceberg_seq START 50;


statement ok
CREATE FUNCTION vedernikoff_mop_iceberg_next()
  AS nextval('vedernikoff_mop_iceberg_seq');


statement ok
CREATE TABLE vedernikoff_mop_iceberg_authors (
  id INT DEFAULT nextval('vedernikoff_mop_iceberg_seq'),
  handle TEXT
);


statement ok
CREATE TABLE vedernikoff_mop_iceberg_papers (
  id INT DEFAULT vedernikoff_mop_iceberg_next(),
  title TEXT,
  CONSTRAINT title_short
    CHECK (length(title) < nextval('vedernikoff_mop_iceberg_seq') + 100)
);


statement ok
CREATE VIEW vedernikoff_mop_iceberg_feed AS
  SELECT vedernikoff_mop_iceberg_next() AS n;


statement ok
INSERT INTO vedernikoff_mop_iceberg_authors (handle) VALUES ('a1');


statement ok
INSERT INTO vedernikoff_mop_iceberg_papers (title) VALUES ('p1');


# CASCADE the sequence -- function, view, and both column DEFAULTs and the
# CHECK all need rewiring atomically.
statement ok
DROP SEQUENCE vedernikoff_mop_iceberg_seq CASCADE;


# Pre-cascade data preserved.
query
SELECT handle FROM vedernikoff_mop_iceberg_authors;
----
handle
a1


query
SELECT title FROM vedernikoff_mop_iceberg_papers;
----
title
p1


# Function & view gone.
statement error (?i)(macro|function).*vedernikoff_mop_iceberg_next.*does not exist
SELECT vedernikoff_mop_iceberg_next();


statement error (?i)(table|view|relation).*vedernikoff_mop_iceberg_feed.*does not exist
SELECT * FROM vedernikoff_mop_iceberg_feed;


# DEFAULTs cleared; previously-impossible-because-CHECK insert now works.
statement ok
INSERT INTO vedernikoff_mop_iceberg_authors (handle) VALUES ('a2');


statement ok
INSERT INTO vedernikoff_mop_iceberg_papers (title) VALUES (repeat('z', 10000));


query
SELECT id, handle FROM vedernikoff_mop_iceberg_authors ORDER BY handle;
----
id	handle
50	a1
NULL	a2


statement ok
DROP TABLE vedernikoff_mop_iceberg_authors;


statement ok
DROP TABLE vedernikoff_mop_iceberg_papers;


# --- 21. CASCADE around a sequence with no in-table referrers --------------
# A sequence used only by a function and a view (no table column DEFAULTs).
# Sanity: CASCADE drops only the function and view, no table_rewrites needed.

statement ok
CREATE SEQUENCE vedernikoff_mop_dispatch_seq;


statement ok
CREATE FUNCTION vedernikoff_mop_dispatch_next()
  AS nextval('vedernikoff_mop_dispatch_seq');


statement ok
CREATE VIEW vedernikoff_mop_dispatch_view AS
  SELECT vedernikoff_mop_dispatch_next() AS step;


