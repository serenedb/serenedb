1	11
NULL	5000


statement ok
DROP TABLE vedernikoff_solid_journal;


# --- 18. CASCADE on a function with multiple downstream CHECK constraints --
# One function, used by CHECK on three different tables. Drop function
# CASCADE must clear all three CHECKs and leave the tables in place.

statement ok
CREATE FUNCTION vedernikoff_iceberg_threshold(x INT) AS x BETWEEN 0 AND 100;


statement ok
CREATE TABLE vedernikoff_iceberg_t_alpha (
  v INT, CONSTRAINT ck_a CHECK (vedernikoff_iceberg_threshold(v))
);


statement ok
CREATE TABLE vedernikoff_iceberg_t_beta (
  v INT, CONSTRAINT ck_b CHECK (vedernikoff_iceberg_threshold(v))
);


statement ok
CREATE TABLE vedernikoff_iceberg_t_gamma (
  v INT, CONSTRAINT ck_g CHECK (vedernikoff_iceberg_threshold(v))
);


# Constraints are enforced.
statement error (?i)
INSERT INTO vedernikoff_iceberg_t_alpha VALUES (500);


statement error (?i)
INSERT INTO vedernikoff_iceberg_t_beta VALUES (-1);


statement error (?i)
INSERT INTO vedernikoff_iceberg_t_gamma VALUES (10000);


# RESTRICT refuses.
statement error (?i)cannot drop function .*vedernikoff_iceberg_threshold.*
DROP FUNCTION vedernikoff_iceberg_threshold(INT);


statement ok
DROP FUNCTION vedernikoff_iceberg_threshold(INT) CASCADE;


# All three CHECKs gone -- previously rejected rows now accepted.
statement count 1
INSERT INTO vedernikoff_iceberg_t_alpha VALUES (500);


statement count 1
INSERT INTO vedernikoff_iceberg_t_beta VALUES (-1);


statement count 1
INSERT INTO vedernikoff_iceberg_t_gamma VALUES (10000);


statement ok
DROP TABLE vedernikoff_iceberg_t_alpha;


statement ok
DROP TABLE vedernikoff_iceberg_t_beta;


statement ok
DROP TABLE vedernikoff_iceberg_t_gamma;


# --- 19. CASCADE across an enum type used by multiple tables ---------------
# An ENUM type referenced by three sibling tables. DROP TYPE CASCADE must
# delete the relevant column from each table (PgSqlTypeDep::column_types).

statement ok
CREATE TYPE vedernikoff_mop_stage AS ENUM('applied','screened','offer','hired');


statement ok
CREATE TABLE vedernikoff_mop_pipeline_a (
  candidate TEXT, stage vedernikoff_mop_stage
);


