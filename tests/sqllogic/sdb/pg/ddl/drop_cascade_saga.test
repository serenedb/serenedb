  AS nextval('vedernikoff_iceberg_layer_a.run_seq');


statement ok
CREATE TABLE vedernikoff_iceberg_layer_b.entries (
  id INT DEFAULT vedernikoff_iceberg_layer_a.next_run(),
  feeling vedernikoff_iceberg_layer_a.mood,
  CONSTRAINT positive_run
    CHECK (vedernikoff_iceberg_layer_a.next_run() >= 0)
);


