# Plain DROP refused -- dashboard's DEFAULT depends on owner's owned seq.
statement error (?i)cannot drop table .*vedernikoff_clickclack_owner.* because other objects depend on it
DROP TABLE vedernikoff_clickclack_owner;


statement error (?i)cannot drop table .*vedernikoff_clickclack_owner.* because other objects depend on it
DROP TABLE vedernikoff_clickclack_owner RESTRICT;


# But dashboard itself has no inbound deps, so plain DROP works on it.
statement ok
DROP TABLE vedernikoff_clickclack_dashboard;


# And now owner is unencumbered too.
statement ok
DROP TABLE vedernikoff_clickclack_owner;


# --- 10. Mixed cross-schema graph: type, function, sequence, view -----------
# Maximum chaos: schemas A and B. A holds a type, function, sequence; B holds
# a table using A's type, a column DEFAULT calling A's function, a view
# selecting from the table, and a CHECK referencing A's sequence indirectly
# through A's function. Drop A CASCADE -> the entire B side gets rewritten
# or dropped consistently.

statement ok
CREATE SCHEMA vedernikoff_iceberg_layer_a;


statement ok
CREATE SCHEMA vedernikoff_iceberg_layer_b;


statement ok
