# sequence and the index with it (composition).
statement ok
DROP TABLE vedernikoff_solid_module_writeups;


# --- 9. SERIAL sequence cross-referenced from sibling table ----------------
# Two tables: A is SERIAL (owns its id_seq), B has a column DEFAULT pointing
# at A's id_seq from outside A's composition subtree. Plain DROP TABLE A
# must be refused -- A's owned seq has a cross-tree referrer.

statement ok
CREATE TABLE vedernikoff_clickclack_owner (
  id SERIAL PRIMARY KEY,
  name TEXT
);


statement ok
CREATE TABLE vedernikoff_clickclack_dashboard (
  id BIGINT NOT NULL DEFAULT nextval('vedernikoff_clickclack_owner_id_seq'),
  payload TEXT
);


