# Vedernikoff's grand cascade saga: a battery of CASCADE / RESTRICT scenarios
# exercising every meaningful dependency edge type and every reasonable mix
# of intra-subtree and cross-schema fan-out.

# --- 1. The clickclack interview chain -------------------------------------
# Deep function call nesting. Each layer calls the previous one. Dropping
# the root with CASCADE should walk the chain and drop everything depending
# on it transitively.

statement ok
CREATE FUNCTION vedernikoff_clickclack_step1(x INT) AS x + 1;


statement ok
CREATE FUNCTION vedernikoff_clickclack_step2(x INT)
  AS vedernikoff_clickclack_step1(x) * 2;


statement ok
CREATE FUNCTION vedernikoff_clickclack_step3(x INT)
  AS vedernikoff_clickclack_step2(x) - 3;


statement ok
CREATE FUNCTION vedernikoff_clickclack_step4(x INT)
  AS vedernikoff_clickclack_step3(x) + 7;


query
SELECT vedernikoff_clickclack_step4(10);
----
vedernikoff_clickclack_step4
26


# Plain DROP at the root must be refused -- step2/3/4 still depend on it.
statement error (?i)cannot drop function .*vedernikoff_clickclack_step1.* because other objects depend on it
DROP FUNCTION vedernikoff_clickclack_step1(INT);


statement error (?i)cannot drop function .*vedernikoff_clickclack_step1.* because other objects depend on it
DROP FUNCTION vedernikoff_clickclack_step1(INT) RESTRICT;


# CASCADE drops the entire chain in one shot.
statement ok
DROP FUNCTION vedernikoff_clickclack_step1(INT) CASCADE;


statement error (?i)(macro|function).*vedernikoff_clickclack_step1.*does not exist
SELECT vedernikoff_clickclack_step1(0);


statement error (?i)(macro|function).*vedernikoff_clickclack_step2.*does not exist
SELECT vedernikoff_clickclack_step2(0);


statement error (?i)(macro|function).*vedernikoff_clickclack_step3.*does not exist
SELECT vedernikoff_clickclack_step3(0);


statement error (?i)(macro|function).*vedernikoff_clickclack_step4.*does not exist
SELECT vedernikoff_clickclack_step4(0);


