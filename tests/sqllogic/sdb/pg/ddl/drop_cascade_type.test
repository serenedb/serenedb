# DROP TYPE / DROP TYPE CASCADE for user-defined types. The catalog used to
# only track column-direct uses; view bodies, function bodies, function
# parameter types, CHECK constraints and column DEFAULTs using CAST(...) all
# went unrecorded -- DROP TYPE silently succeeded and left dangling objects.
# Each of the five edges is now tracked; the test matches PostgreSQL's
# BEGIN ATOMIC behaviour.

# --- 1. View body CAST ------------------------------------------------------

statement ok
CREATE TYPE clickclack_flavor AS ENUM ('sweet', 'salty');


statement ok
CREATE TABLE clickclack_strs (s TEXT);


statement count 2
INSERT INTO clickclack_strs VALUES ('sweet'), ('salty');


statement ok
CREATE VIEW clickclack_v_cast AS SELECT CAST(s AS clickclack_flavor) AS f FROM clickclack_strs;


statement error (?i)cannot drop type .*clickclack_flavor.* because other objects depend on it
DROP TYPE clickclack_flavor;


statement ok
DROP TYPE clickclack_flavor CASCADE;


statement error (?i)(table|relation|view).*clickclack_v_cast.*does not exist
SELECT * FROM clickclack_v_cast;


statement ok
DROP TABLE clickclack_strs;


# --- 2. Function body CAST --------------------------------------------------

statement ok
CREATE TYPE babsky_kind AS ENUM ('a', 'b');


statement ok
CREATE FUNCTION babsky_fn_cast(x TEXT) AS CAST(x AS babsky_kind);


statement error (?i)cannot drop type .*babsky_kind.* because other objects depend on it
DROP TYPE babsky_kind;


statement ok
DROP TYPE babsky_kind CASCADE;


statement error (?i)(function|macro|scalar).*babsky_fn_cast.* does not exist
SELECT babsky_fn_cast('a');


# --- 3. Function parameter type --------------------------------------------

statement ok
CREATE TYPE kostya_param AS ENUM ('p', 'q');


statement ok
CREATE FUNCTION kostya_fn_param(x kostya_param) AS x;


statement error (?i)cannot drop type .*kostya_param.* because other objects depend on it
DROP TYPE kostya_param;


statement ok
DROP TYPE kostya_param CASCADE;


# --- 3b. Function RETURN type ------------------------------------------------

statement ok
CREATE TYPE deadinside_ret AS ENUM ('r', 's');


statement ok
CREATE FUNCTION deadinside_fn_ret() RETURNS deadinside_ret AS 'r'::deadinside_ret;


statement error (?i)cannot drop type .*deadinside_ret.* because other objects depend on it
DROP TYPE deadinside_ret;


statement ok
DROP TYPE deadinside_ret CASCADE;


statement error (?i)(function|macro|scalar).*deadinside_fn_ret.* does not exist
SELECT deadinside_fn_ret();


statement error (?i)(function|macro|scalar).*kostya_fn_param.* does not exist
SELECT kostya_fn_param('p');


# --- 4. CHECK constraint with CAST -----------------------------------------

statement ok
CREATE TYPE iceberg_check AS ENUM ('y', 'n');


statement ok
CREATE TABLE iceberg_t_check (s TEXT, CHECK (CAST(s AS iceberg_check) IS NOT NULL));


statement error (?i)cannot drop type .*iceberg_check.* because other objects depend on it
DROP TYPE iceberg_check;


statement ok
DROP TYPE iceberg_check CASCADE;


# The CHECK constraint was cascade-dropped; inserts should now accept anything.
statement count 1
INSERT INTO iceberg_t_check VALUES ('not-an-enum-value');


statement ok
DROP TABLE iceberg_t_check;


# --- 5. Column DEFAULT with CAST -------------------------------------------

statement ok
CREATE TYPE mop_def AS ENUM ('d', 'e');


statement ok
CREATE TABLE mop_t_def (x TEXT DEFAULT CAST('d' AS mop_def)::TEXT);


statement error (?i)cannot drop type .*mop_def.* because other objects depend on it
DROP TYPE mop_def;


statement ok
DROP TYPE mop_def CASCADE;


statement ok
DROP TABLE mop_t_def;


# --- 6. Container column types (LIST / STRUCT) -----------------------------
# CollectTypeRefs and ModifyTableDependencies' column-type loop recurse into
# LIST/STRUCT/MAP/UNION/ARRAY children, so a column declared as `my_type[]`
# or `STRUCT(..., my_type)` still tracks the dep edge.

statement ok
CREATE TYPE saga_box AS ENUM ('x', 'y');


statement ok
CREATE TABLE saga_t_arr (xs saga_box[]);


statement error (?i)cannot drop type .*saga_box.* because other objects depend on it
DROP TYPE saga_box;


statement ok
DROP TYPE saga_box CASCADE;


# DROP TYPE CASCADE drops the dependent column (matches PG); the table stays.
statement ok
DROP TABLE saga_t_arr;


statement ok
CREATE TYPE saga_box AS ENUM ('x', 'y');


statement ok
CREATE TABLE saga_t_struct (s STRUCT(a INT, b saga_box));


statement error (?i)cannot drop type .*saga_box.* because other objects depend on it
DROP TYPE saga_box;


statement ok
DROP TYPE saga_box CASCADE;


statement ok
DROP TABLE saga_t_struct;


# --- 7. Cross-schema type ref (function in sb references type in sa) -------

statement ok
CREATE SCHEMA jira_ticket;


statement ok
CREATE SCHEMA manifest;


statement ok
CREATE TYPE jira_ticket.flav AS ENUM ('x', 'y');


statement ok
CREATE FUNCTION manifest.useflav(s TEXT) AS CAST(s AS jira_ticket.flav);


# RESTRICT blocked because the function in sb depends on the type in sa.
statement error (?i)cannot drop type .*flav.* because other objects depend on it
DROP TYPE jira_ticket.flav;


# CASCADE drops the type and the dependent function in the other schema.
statement ok
DROP TYPE jira_ticket.flav CASCADE;


statement error (?i)(function|macro|scalar).*useflav.* does not exist
SELECT manifest.useflav('x');


statement ok
DROP SCHEMA jira_ticket;


statement ok
DROP SCHEMA manifest;


# --- 8. VARIANT and user-defined types -------------------------------------
# VARIANT shares STRUCT_TYPE_INFO with STRUCT, so CollectTypeRefs descends
# into its child slots. The VARIANT LogicalType's children are a fixed
# internal layout (keys / children / values / data) -- none user-defined --
# so VARIANT expressions must NOT spuriously register a dependency on an
# unrelated enum/type. But dependencies DO flow through CAST-to-usertype
# expressions nested inside ::VARIANT casts (CHECK, DEFAULT, view, function).
#
# Two scenarios exercised per dep site:
#   (a) VARIANT WITHOUT a CAST to the user type -- no dep, DROP succeeds.
#   (b) VARIANT WITH    a CAST to the user type -- dep tracked, RESTRICT blocks.
#
# Note: SereneDB's RocksDB storage can't persist VARIANT-typed columns, so
# VARIANT only appears inside expression sites (CHECK predicates, DEFAULT,
# view body, function body) -- never as a stored column type.

# --- 8a. VARIANT in a view, no user-type ref: no spurious dep -------------

statement ok
CREATE TYPE shred_solo_kind AS ENUM ('hot', 'cold');


# VARIANT used purely on built-in types -- no reference to shred_solo_kind.
statement ok
CREATE VIEW shred_solo_v AS SELECT 42::INT::VARIANT AS v, 'hello'::TEXT::VARIANT AS s;


# No CAST to shred_solo_kind anywhere -- DROP TYPE must succeed.
statement ok
DROP TYPE shred_solo_kind;


statement ok
DROP VIEW shred_solo_v;


# --- 8b. CHECK constraint: VARIANT CAST through user type tracks the dep ---

statement ok
CREATE TYPE shred_check_kind AS ENUM ('hot', 'cold');


statement ok
CREATE TABLE shred_check_t (
  s TEXT,
  CHECK (CAST(s AS shred_check_kind)::VARIANT IS NOT NULL)
);


statement error
DROP TYPE shred_check_kind;
----
db error: ERROR: cannot drop type shred_check_kind because other objects depend on it
<slt:ignore>


statement ok
DROP TYPE shred_check_kind CASCADE;


statement count 1
INSERT INTO shred_check_t VALUES ('not-an-enum');


statement ok
DROP TABLE shred_check_t;


# --- 8c. Two CHECKs side-by-side: one with the dep, one without -----------
# DROP TYPE must report the blocking constraint; CASCADE must drop ONLY the
# referencing CHECK, leaving the unrelated one intact.

statement ok
CREATE TYPE shred_pair_kind AS ENUM ('a', 'b');


statement ok
CREATE TABLE shred_pair_t (
  s TEXT,
  n INT,
  CHECK (CAST(s AS shred_pair_kind)::VARIANT IS NOT NULL),
  CHECK (CAST(n AS BIGINT)::VARIANT IS NOT NULL)
);


statement error
DROP TYPE shred_pair_kind;
----
db error: ERROR: cannot drop type shred_pair_kind because other objects depend on it
<slt:ignore>


statement ok
DROP TYPE shred_pair_kind CASCADE;


# The unrelated NOT-NULL check on `n` survives -- inserting NULL still fails.
statement error
INSERT INTO shred_pair_t VALUES ('x', NULL);


statement count 1
INSERT INTO shred_pair_t VALUES ('x', 5);


statement ok
DROP TABLE shred_pair_t;


# --- 8d. Column DEFAULT with VARIANT CAST: dep tracked --------------------

statement ok
CREATE TYPE shred_def_kind AS ENUM ('p', 'q');


statement ok
CREATE TABLE shred_def_t (x TEXT DEFAULT CAST(CAST('p' AS shred_def_kind)::VARIANT AS TEXT));


statement error
DROP TYPE shred_def_kind;
----
db error: ERROR: cannot drop type shred_def_kind because other objects depend on it
<slt:ignore>


statement ok
DROP TYPE shred_def_kind CASCADE;


statement ok
DROP TABLE shred_def_t;


# --- 8e. VIEW body: VARIANT CAST referencing the user type ----------------

statement ok
CREATE TYPE shred_view_kind AS ENUM ('on', 'off');


statement ok
CREATE TABLE shred_view_src (s TEXT);


statement ok
CREATE VIEW shred_view_v AS SELECT CAST(s AS shred_view_kind)::VARIANT AS f FROM shred_view_src;


statement error
DROP TYPE shred_view_kind;
----
db error: ERROR: cannot drop type shred_view_kind because other objects depend on it
<slt:ignore>


statement ok
DROP TYPE shred_view_kind CASCADE;


statement error
SELECT * FROM shred_view_v;
----
db error: ERROR: Table with name shred_view_v does not exist!
<slt:ignore>


statement ok
DROP TABLE shred_view_src;


# --- 8f. FUNCTION body: VARIANT CAST referencing the user type ------------

statement ok
CREATE TYPE shred_fn_kind AS ENUM ('m', 'n');


statement ok
CREATE FUNCTION shred_fn_use(x TEXT) AS CAST(x AS shred_fn_kind)::VARIANT;


statement error
DROP TYPE shred_fn_kind;
----
db error: ERROR: cannot drop type shred_fn_kind because other objects depend on it
<slt:ignore>


statement ok
DROP TYPE shred_fn_kind CASCADE;


statement error
SELECT shred_fn_use('m');
----
db error: ERROR: Scalar Function with name shred_fn_use does not exist!
<slt:ignore>
