2	{pill_serendb=3}
3	{}
4	NULL


query
SELECT id, doses FROM vedernikoff_pillbox ORDER BY id;
----
id	doses
1	{"(pill_clickclack,2)","(pill_waidb,1)"}
2	{"(pill_serendb,3)"}
3	{}
4	NULL


query
