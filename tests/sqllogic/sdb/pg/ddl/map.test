CREATE TABLE pudge_drug_doses (
  drug_id INTEGER PRIMARY KEY,
  schedule MAP(INTEGER, VARCHAR)
);


statement count 1
INSERT INTO pudge_drug_doses VALUES (1, MAP{8: 'morning', 14: 'lunch', 20: 'evening'});


statement count 1
INSERT INTO pudge_drug_doses VALUES (2, MAP{0: 'midnight'});


query
SELECT drug_id, schedule[14], schedule[8] FROM pudge_drug_doses ORDER BY drug_id;
----
drug_id	schedule	schedule
1	lunch	morning
2	NULL	NULL


query
SELECT drug_id, schedule::VARCHAR FROM pudge_drug_doses ORDER BY drug_id;
----
drug_id	schedule
1	{8=morning, 14=lunch, 20=evening}
2	{0=midnight}


query
SELECT drug_id, schedule FROM pudge_drug_doses ORDER BY drug_id;
----
drug_id	schedule
1	{"(8,morning)","(14,lunch)","(20,evening)"}
2	{"(0,midnight)"}


