CREATE TABLE vedernikoff_pillbox (
  id INTEGER PRIMARY KEY,
  patient VARCHAR,
  doses MAP(VARCHAR, INTEGER)
);


statement count 1
INSERT INTO vedernikoff_pillbox VALUES (1, 'vedernikoff', MAP{'pill_clickclack': 2, 'pill_waidb': 1});


statement count 1
INSERT INTO vedernikoff_pillbox VALUES (2, 'kostya', MAP{'pill_serendb': 3});


statement count 1
INSERT INTO vedernikoff_pillbox VALUES (3, 'bigfgun', MAP{});


statement count 1
INSERT INTO vedernikoff_pillbox VALUES (4, 'nullguy', NULL);


query
SELECT id, patient, cardinality(doses) FROM vedernikoff_pillbox ORDER BY id;
