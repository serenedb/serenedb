# INSERT ... ON CONFLICT and INSERT OR REPLACE are currently bound as MERGE INTO,
# so they inherit the merge update paths. These tests pin the observable contract
# independent of that implementation choice: updates of plain columns stay on the
# in-place path (rowid preserved, also with RETURNING), while updates touching an
# indexed or LIST column take delete+insert (rowid moves) and keep every index
# consistent.

statement ok
CREATE TABLE u_plain(a INTEGER PRIMARY KEY, b INTEGER);

statement count 1
INSERT INTO u_plain VALUES (1, 10);

# DO UPDATE on a plain column: in-place, rowid unchanged.
statement count 1
INSERT INTO u_plain VALUES (1, 20) ON CONFLICT (a) DO UPDATE SET b = EXCLUDED.b;

query
SELECT a, b, rowid FROM u_plain;
----
a	b	rowid
1	20	0

# Same with RETURNING: still in-place, returns the updated row.
query
INSERT INTO u_plain VALUES (1, 30) ON CONFLICT (a) DO UPDATE SET b = EXCLUDED.b RETURNING a, b;
----
a	b
1	30

query
SELECT a, b, rowid FROM u_plain;
----
a	b	rowid
1	30	0

# DO NOTHING: no row touched.
statement count 0
INSERT INTO u_plain VALUES (1, 777) ON CONFLICT (a) DO NOTHING;

query
SELECT a, b, rowid FROM u_plain;
----
a	b	rowid
1	30	0

statement ok
DROP TABLE u_plain;


# DO UPDATE on a LIST column: LIST does not support in-place update, so the row is
# deleted and re-appended (rowid moves) with the new value.

statement ok
CREATE TABLE u_list(a INTEGER PRIMARY KEY, l INTEGER[]);

statement count 1
INSERT INTO u_list VALUES (1, ARRAY[1, 2, 3]);

query
INSERT INTO u_list VALUES (1, ARRAY[9, 9]) ON CONFLICT (a) DO UPDATE SET l = EXCLUDED.l RETURNING a, l;
----
a	l
1	{9,9}

query
SELECT a, l, rowid FROM u_list;
----
a	l	rowid
1	{9,9}	1

statement ok
DROP TABLE u_list;


# DO UPDATE on a column carried by a secondary UNIQUE index: delete+insert, and the
# index reflects the post-upsert state (new key conflicts, old key is free again).

statement ok
CREATE TABLE u_idx(a INTEGER PRIMARY KEY, b INTEGER UNIQUE);

statement count 2
INSERT INTO u_idx VALUES (1, 10), (2, 20);

statement count 1
INSERT INTO u_idx VALUES (1, 555) ON CONFLICT (a) DO UPDATE SET b = EXCLUDED.b;

query
SELECT a, b, rowid FROM u_idx ORDER BY a;
----
a	b	rowid
1	555	2
2	20	1

statement error
INSERT INTO u_idx VALUES (3, 555);
----
db error: ERROR: Duplicate key "b: 555" violates unique constraint.


statement count 1
INSERT INTO u_idx VALUES (3, 10);

query
SELECT a, b, rowid FROM u_idx ORDER BY a;
----
a	b	rowid
1	555	2
2	20	1
3	10	3

statement ok
DROP TABLE u_idx;


# DO UPDATE rewriting the conflict key itself: the PK index must free the old key
# and claim the new one.

statement ok
CREATE TABLE u_pk(a INTEGER PRIMARY KEY, b INTEGER);

statement count 2
INSERT INTO u_pk VALUES (1, 10), (2, 20);

statement count 1
INSERT INTO u_pk VALUES (1, 99) ON CONFLICT (a) DO UPDATE SET a = 100;

query
SELECT a, b, rowid FROM u_pk ORDER BY a;
----
a	b	rowid
2	20	1
100	10	2

statement count 1
INSERT INTO u_pk VALUES (1, 1);

statement count 0
INSERT INTO u_pk VALUES (100, 2) ON CONFLICT (a) DO NOTHING;

query
SELECT a, b, rowid FROM u_pk ORDER BY a;
----
a	b	rowid
1	1	3
2	20	1
100	10	2

statement ok
DROP TABLE u_pk;


# INSERT OR REPLACE generates SET for every non-key column. With plain columns only
# it stays in-place (rowid preserved), also with RETURNING.

statement ok
CREATE TABLE r_plain(a INTEGER PRIMARY KEY, b INTEGER, c INTEGER);

statement count 1
INSERT INTO r_plain VALUES (1, 10, 100);

statement count 1
INSERT OR REPLACE INTO r_plain VALUES (1, 20, 200);

query
SELECT a, b, c, rowid FROM r_plain;
----
a	b	c	rowid
1	20	200	0

query
INSERT OR REPLACE INTO r_plain VALUES (1, 30, 300) RETURNING a, b, c;
----
a	b	c
1	30	300

query
SELECT a, b, c, rowid FROM r_plain;
----
a	b	c	rowid
1	30	300	0

statement ok
DROP TABLE r_plain;


# With a LIST column among the replaced columns, REPLACE must take delete+insert.

statement ok
CREATE TABLE r_list(a INTEGER PRIMARY KEY, b INTEGER, l INTEGER[]);

statement count 1
INSERT INTO r_list VALUES (1, 10, ARRAY[1, 2]);

statement count 1
INSERT OR REPLACE INTO r_list VALUES (1, 20, ARRAY[3, 4, 5]);

query
SELECT a, b, l, rowid FROM r_list;
----
a	b	l	rowid
1	20	{3,4,5}	1

statement ok
DROP TABLE r_list;
