control substitution on

hash-threshold 100

# Inverted index built directly on a VIEW over an ATTACH'd postgres table.
#
# The postgres table is a recognised fast-path source: serenedb reads its PK
# from pg_constraint metadata (surfaced as a standard PRIMARY KEY constraint on
# the attached table entry) and keys the index on it (PkSpec::ExternalDBKey).
#   - CREATE INDEX succeeds (iresearch ingests rows at create time).
#   - count(*) / BM25 are served from iresearch alone.
#   - INCLUDE'd columns come from the iresearch columnstore.
#   - Real (non-INCLUDE'd) source columns are MATERIALISED by re-fetching the
#     matched rows from postgres via `WHERE pk IN (...)` through the connector.
# No WITH (pk = ...) anywhere -- the key comes purely from metadata. v1 supports
# a single BIGINT primary key.


statement ok
ATTACH 'host=${PGHOST} port=${PGPORT} dbname=postgres user=${PGUSER}' AS pg_${__DATABASE__} (TYPE postgres);


statement ok
CREATE SCHEMA pg_${__DATABASE__}.iipgscan_docs;


statement ok
CREATE TABLE pg_${__DATABASE__}.iipgscan_docs.articles (
  id    BIGINT PRIMARY KEY,
  body  TEXT,
  tag   TEXT,
  views INTEGER
);


statement count 5
INSERT INTO pg_${__DATABASE__}.iipgscan_docs.articles VALUES
  (1, 'pudge goes mid and dominates the lane', 'gameplay', 1200),
  (2, 'anchin reads manga every weekend',      'reading',  340),
  (3, 'pudge plays again in a ranked match',   'gameplay', 870),
  (4, 'krivda writes sql for the new feature', 'work',     55),
  (5, 'mom reviews pudge highlight reel',      'family',   12);


statement ok
CREATE TEXT SEARCH DICTIONARY pg_en_${__DATABASE__}(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true
);


statement ok
CREATE VIEW pg_articles_v_${__DATABASE__} AS
  SELECT id, body, tag, views
  FROM pg_${__DATABASE__}.iipgscan_docs.articles;


statement ok
CREATE INDEX pg_articles_v_idx_${__DATABASE__}
  ON pg_articles_v_${__DATABASE__}
  USING inverted(id, body pg_en_${__DATABASE__})
  INCLUDE (tag, views);


# count(*) over the view-backed index -- flows from iresearch, no source touch.
query
SELECT count(*)
FROM pg_articles_v_idx_${__DATABASE__}
WHERE body @@ ts_phrase('pudge');
----
count
3


# BM25 score from iresearch (virtual column).
query
SELECT BM25(pg_articles_v_idx_${__DATABASE__}.tableoid) > 0 AS has_score
FROM pg_articles_v_idx_${__DATABASE__}
WHERE body @@ ts_phrase('pudge')
ORDER BY BM25(pg_articles_v_idx_${__DATABASE__}.tableoid) DESC
LIMIT 1;
----
has_score
t


# INCLUDE'd columns (tag, views) are stored in the iresearch columnstore at
# CREATE INDEX time, so projections over them don't need source-row
# materialisation. They work today even though postgres_scan isn't a
# fast-path source.
query
SELECT tag, views FROM pg_articles_v_idx_${__DATABASE__}
WHERE body @@ ts_phrase('pudge')
ORDER BY views DESC;
----
tag	views
gameplay	1200
gameplay	870
family	12


# Aggregation over an INCLUDE'd column -- also columnstore-only.
query
SELECT SUM(views) FROM pg_articles_v_idx_${__DATABASE__}
WHERE body @@ ts_phrase('pudge');
----
sum
2082


# Selecting real (non-indexed, non-INCLUDE'd) source columns: the postgres table
# is a fast-path source (PkSpec::ExternalDBKey), keyed by ctid -- the row's
# physical locator, surfaced as the duckdb rowid. Matched rows are re-fetched
# via `WHERE rowid IN (...)`, which the connector pushes down as a `ctid IN (...)`
# TID scan, and mapped back to output slots by key. (The BIGINT PK on this table
# is irrelevant to the lookup -- ctid is used regardless; see the no-PK case.)
query
SELECT id, body FROM pg_articles_v_idx_${__DATABASE__} WHERE body @@ ts_phrase('pudge') ORDER BY id;
----
id	body
1	pudge goes mid and dominates the lane
3	pudge plays again in a ranked match
5	mom reviews pudge highlight reel


# ===== ctid needs NO primary key: the same lookup works on a keyless table =====
# This is the universal-lookup win over a PK column: ctid is every row's physical
# locator, so materialisation works even when the source table has no PK at all.
statement ok
CREATE TABLE pg_${__DATABASE__}.iipgscan_docs.nopk (
  body TEXT,
  tag  TEXT
);


statement count 3
INSERT INTO pg_${__DATABASE__}.iipgscan_docs.nopk VALUES
  ('pudge roams the map',  'gameplay'),
  ('anchin naps at noon',  'reading'),
  ('pudge ults the carry', 'gameplay');


statement ok
CREATE VIEW pg_nopk_v_${__DATABASE__} AS
  SELECT body, tag FROM pg_${__DATABASE__}.iipgscan_docs.nopk;


statement ok
CREATE INDEX pg_nopk_v_idx_${__DATABASE__}
  ON pg_nopk_v_${__DATABASE__}
  USING inverted(body pg_en_${__DATABASE__});


# Materialise real source columns (the indexed `body` -- its text is not stored
# -- and the non-indexed `tag`) with NO PK on the table: both re-fetched by ctid.
query
SELECT body, tag FROM pg_nopk_v_idx_${__DATABASE__}
WHERE body @@ ts_phrase('pudge') ORDER BY body;
----
body	tag
pudge roams the map	gameplay
pudge ults the carry	gameplay


statement ok
DROP VIEW pg_nopk_v_${__DATABASE__};


statement ok
DROP TABLE pg_${__DATABASE__}.iipgscan_docs.nopk;


# ===== user-specified lookup key: WITH (key_columns = 'id') =====
# The user names the key column (their PK, or any BIGINT column), overriding the
# default ctid: matched rows re-fetch via `WHERE id IN (...)` instead of by ctid.
statement ok
CREATE VIEW pg_artk_v_${__DATABASE__} AS
  SELECT id, body, tag, views FROM pg_${__DATABASE__}.iipgscan_docs.articles;


statement ok
CREATE INDEX pg_artk_v_idx_${__DATABASE__}
  ON pg_artk_v_${__DATABASE__}
  USING inverted(id, body pg_en_${__DATABASE__})
  WITH (key_columns = 'id');


query
SELECT id, body FROM pg_artk_v_idx_${__DATABASE__}
WHERE body @@ ts_phrase('pudge') ORDER BY id;
----
id	body
1	pudge goes mid and dominates the lane
3	pudge plays again in a ranked match
5	mom reviews pudge highlight reel


statement ok
DROP VIEW pg_artk_v_${__DATABASE__};


statement ok
DROP TABLE pg_${__DATABASE__}.iipgscan_docs.articles;


statement ok
DROP SCHEMA pg_${__DATABASE__}.iipgscan_docs;


statement ok
DETACH pg_${__DATABASE__};
