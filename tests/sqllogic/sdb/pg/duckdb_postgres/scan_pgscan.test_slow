control substitution on

# Exercises postgres_scanner's scan / projection / pushdown for filter
# kinds we know work. Equality, IN, IS NULL — three patterns that the
# extension's filter-pushdown translator handles cleanly today.
#
# (The `WHERE id > N` range case currently fails with
# "Unsupported table filter type" — a duckdb_postgres limitation against
# newer DuckDB API. Intentionally not exercised here; re-add when fixed.)

statement ok
ATTACH 'host=${PGHOST} port=${PGPORT} dbname=postgres user=${PGUSER}' AS pg_${__DATABASE__} (TYPE postgres);


statement ok
CREATE SCHEMA pg_${__DATABASE__}.${__DATABASE__}_data;


statement ok
CREATE TABLE pg_${__DATABASE__}.${__DATABASE__}_data.widgets (
  id    INTEGER PRIMARY KEY,
  name  TEXT,
  price NUMERIC(10,2),
  stock INTEGER
);


statement count 4
INSERT INTO pg_${__DATABASE__}.${__DATABASE__}_data.widgets VALUES
  (1, 'gadget',      9.99,  10),
  (2, 'gizmo',      19.99,  0),
  (3, 'thingamajig', NULL,  5),
  (4, 'gadget',     14.99,  3);


# Full scan, ordered for determinism.
query
SELECT id, name, price, stock
FROM pg_${__DATABASE__}.${__DATABASE__}_data.widgets
ORDER BY id;
----
id	name	price	stock
1	gadget	9.99	10
2	gizmo	19.99	0
3	thingamajig	NULL	5
4	gadget	14.99	3


# Projection (subset of columns).
query
SELECT name, stock
FROM pg_${__DATABASE__}.${__DATABASE__}_data.widgets
ORDER BY id;
----
name	stock
gadget	10
gizmo	0
thingamajig	5
gadget	3


# Equality pushdown.
query
SELECT id FROM pg_${__DATABASE__}.${__DATABASE__}_data.widgets
WHERE name = 'gadget'
ORDER BY id;
----
id
1
4


# IN pushdown.
query
SELECT id FROM pg_${__DATABASE__}.${__DATABASE__}_data.widgets
WHERE id IN (2, 3)
ORDER BY id;
----
id
2
3


# IS NULL pushdown.
query
SELECT id FROM pg_${__DATABASE__}.${__DATABASE__}_data.widgets
WHERE price IS NULL;
----
id
3


statement ok
DROP TABLE pg_${__DATABASE__}.${__DATABASE__}_data.widgets;


statement ok
DROP SCHEMA pg_${__DATABASE__}.${__DATABASE__}_data;


statement ok
DETACH pg_${__DATABASE__};
