hash-threshold 200

# ES write path: es_doc/es_bulk emit rows shaped like the target table and
# are consumed via INSERT ... SELECT; es_refresh commits the inverted shards
# so writes become searchable.

statement ok
CALL es_create_index('slt_es_w', '{"mappings":{"properties":{"title":{"type":"text"},"n":{"type":"long"},"flag":{"type":"boolean"},"ts":{"type":"date"}}}}');

statement count 1
INSERT INTO es.slt_es_w SELECT * FROM es_doc('slt_es_w', 'a', '{"title":"hello world","n":7,"flag":true,"ts":"2001-05-01T12:00:00Z"}');

# Two actions: explicit id, then an autogenerated one; epoch-millis date.
statement count 2
INSERT INTO es.slt_es_w SELECT * FROM es_bulk('slt_es_w', '{"index":{"_id":"b"}}
{"title":"quick brown fox","n":8}
{"create":{}}
{"title":"lazy dog","ts":986121000000}
');

query
CALL es_refresh('slt_es_w');
----
acknowledged
t

query
SELECT count(*) FROM es.slt_es_w;
----
count
3

# After the refresh every document is visible in the text index.
query
SELECT count(*) FROM es."slt_es_w$text";
----
count
3

query
SELECT _id, n, flag, ts FROM es.slt_es_w WHERE _id = 'a';
----
_id	n	flag	ts
a	7	t	2001-05-01 12:00:00

query
SELECT length(_id) AS len FROM es.slt_es_w WHERE _id NOT IN ('a', 'b');
----
len
20

statement error (?i)duplicate key .* violates primary key constraint
INSERT INTO es.slt_es_w SELECT * FROM es_doc('slt_es_w', 'a', '{"n":1}');

statement error (?i)failed to parse field \[n\]
INSERT INTO es.slt_es_w SELECT * FROM es_doc('slt_es_w', 'x', '{"n":"oops"}');

# Trailing content would store invalid JSON in _source.
statement error (?i)has trailing content
INSERT INTO es.slt_es_w SELECT * FROM es_doc('slt_es_w', 'y', '{"n":1}{"n":2}');

statement error (?i)expected one of \[create, index\] but found \[update\]
INSERT INTO es.slt_es_w SELECT * FROM es_bulk('slt_es_w', '{"update":{"_id":"a"}}
{"doc":{}}
');

statement error (?i)document is missing
INSERT INTO es.slt_es_w SELECT * FROM es_bulk('slt_es_w', '{"index":{"_id":"z"}}');

statement error (?i)no requests added
INSERT INTO es.slt_es_w SELECT * FROM es_bulk('slt_es_w', '');

statement error (?i)no such index \[slt_es_missing\]
CALL es_refresh('slt_es_missing');

statement error (?i)no such index \[slt_es_missing\]
INSERT INTO es.slt_es_w SELECT * FROM es_doc('slt_es_missing', 'a', '{}');

# Empty name refreshes every ES index.
query
CALL es_refresh('');
----
acknowledged
t

# Failed statements above inserted nothing.
query
SELECT count(*) FROM es.slt_es_w;
----
count
3

query
CALL es_drop_index('slt_es_w');
----
acknowledged
t
