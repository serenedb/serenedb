statement ok
VACUUM (REFRESH_TABLE) table_numeric_idx;

statement ok
BEGIN;

# In-transaction search is allowed: postings hold committed rows only, so the
# uncommitted inserts are not visible to the index scan. The legacy
# read_your_own_writes opt-out is a no-op.
statement count 3
INSERT INTO table_numeric_idx VALUES (33,99), (77,99), (177,99);

query
SELECT * FROM test_index_numeric WHERE a = 1 OR b = 3 OR a = 17 ORDER BY a;
----
a	b
1	1
2	3
7	3
17	5

statement ok
ROLLBACK;

statement ok
VACUUM (REFRESH_TABLE) table_numeric_idx;

statement ok
BEGIN;

statement count 3
INSERT INTO table_numeric_idx VALUES (23,1), (27,3), (28,5);

query
SELECT * FROM test_index_numeric WHERE a = 1 OR b = 3 OR a = 17 OR a = 28 ORDER BY a;
----
a	b
1	1
2	3
7	3
17	5

statement ok
COMMIT;

# restore default
statement ok
DROP TABLE table_numeric_idx;


