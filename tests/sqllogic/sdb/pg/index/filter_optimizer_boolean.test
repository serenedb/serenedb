statement ok
CREATE TABLE fo_bool (id INTEGER PRIMARY KEY, s VARCHAR, n INTEGER, t VARCHAR);

statement ok
CREATE TEXT SEARCH DICTIONARY fo_bool_en(
    template = 'text', locale = 'en_US.UTF-8', case = 'none',
    stemming = false, accent = false, frequency = true, position = true
);

statement ok
CREATE INDEX fo_bool_idx ON fo_bool USING inverted(id, s, n, t fo_bool_en);

statement ok
INSERT INTO fo_bool VALUES
  (1, 'alpha', 1, 'alpha beta gamma'),
  (2, 'beta',  2, 'beta gamma delta'),
  (3, 'gamma', 3, 'gamma delta alpha'),
  (4, 'delta', 4, 'delta alpha beta');

statement ok
VACUUM (REFRESH_TABLE) fo_bool;

query
EXPLAIN SELECT id FROM fo_bool_idx
WHERE (t @@ ts_phrase('alpha') AND t @@ ts_phrase('beta')) AND t @@ ts_phrase('gamma');
----
QUERY PLAN
┌───────────────────────────┐
│       IRESEARCH_SCAN      │
│    ────────────────────   │
│     Index: fo_bool_idx    │
│      Lookup: rocksdb      │
│                           │
│          Filter:          │
│  ┌─────────────────────┐  │
│  │┌───────────────────┐│  │
│  ││       TERMS       ││  │
│  ││    ────────────   ││  │
│  ││ t(string) {['alpha││  │
│  ││ ', 1],['beta', 1],││  │
│  ││   ['gamma', 1],}  ││  │
│  ││     min_match=3   ││  │
│  │└───────────────────┘│  │
│  └─────────────────────┘  │
│                           │
│      Projections: id      │
│                           │
│           ~1 row          │
└───────────────────────────┘

