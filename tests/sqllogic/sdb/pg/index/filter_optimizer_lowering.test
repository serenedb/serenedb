# ----------------------------------------------------------------------
# Prefix + Levenshtein fusion. A same-field ts_starts_with whose prefix is
# a prefix of the edit-distance target folds into the edit-distance pinned
# prefix, leaving a single LEVENSHTEIN_AUTOMATON (no STARTS_WITH / AND).
# ----------------------------------------------------------------------

query
EXPLAIN SELECT id FROM fo_low_idx WHERE name @@ ts_all([ts_starts_with('alp'), ts_levenshtein('alpha', 1)]);
----
QUERY PLAN
╭─ IRESEARCH_SCAN ────────╮
│ Index: fo_low_idx       │
│ Lookup: table           │
│ Index Filter:           │
│ ╭─ Levenshtein ───────╮ │
│ │ Field: name(string) │ │
│ │ Target: alpha       │ │
│ │ Max Terms: 1024     │ │
│ ╰─────────────────────╯ │
│ Projections: id         │
│ ~1 row                  │
╰─────────────────────────╯

query
SELECT id FROM fo_low_idx WHERE name @@ ts_all([ts_starts_with('alp'), ts_levenshtein('alpha', 1)]) ORDER BY id;
----
id
1

# A prefix that is not a prefix of the target cannot fold; the STARTS_WITH
# stays a separate AND clause.
query
EXPLAIN SELECT id FROM fo_low_idx WHERE name @@ ts_all([ts_starts_with('xyz'), ts_levenshtein('alpha', 1)]);
----
QUERY PLAN
╭─ IRESEARCH_SCAN ─────────────────────────────────╮
│ Index: fo_low_idx                                │
│ Lookup: table                                    │
│ Index Filter:                                    │
│ ╭─ And ───────────────╮                          │
│ ╰──────────┬──────────╯                          │
│            ├────────────────────────╮            │
│ ╭─ Starts With ───────╮  ╭─ Levenshtein ───────╮ │
│ │ Field: name(string) │  │ Field: name(string) │ │
│ │ Prefix: xyz         │  │ Target: alpha       │ │
│ │ Limit: 1024         │  │ Max Terms: 1024     │ │
│ ╰─────────────────────╯  ╰─────────────────────╯ │
│ Projections: id                                  │
│ ~1 row                                           │
╰──────────────────────────────────────────────────╯

query
SELECT id FROM fo_low_idx WHERE name @@ ts_all([ts_starts_with('xyz'), ts_levenshtein('alpha', 1)]) ORDER BY id;
----
id

# A longer prefix extends an edit-distance that already pins a shorter prefix;
# the STARTS_WITH folds in, leaving a single LEVENSHTEIN_AUTOMATON.
query
EXPLAIN SELECT id FROM fo_low_idx WHERE name @@ ts_all([ts_starts_with('alp'), ts_levenshtein('lpha', 1, false, 'a')]);
----
QUERY PLAN
╭─ IRESEARCH_SCAN ────────╮
│ Index: fo_low_idx       │
│ Lookup: table           │
│ Index Filter:           │
│ ╭─ Levenshtein ───────╮ │
│ │ Field: name(string) │ │
│ │ Target: alpha       │ │
│ │ Max Terms: 1024     │ │
│ ╰─────────────────────╯ │
│ Projections: id         │
│ ~1 row                  │
╰─────────────────────────╯

query
SELECT id FROM fo_low_idx WHERE name @@ ts_all([ts_starts_with('alp'), ts_levenshtein('lpha', 1, false, 'a')]) ORDER BY id;
----
id
1

# Several edit-distance siblings share one prefix; it pins into each and the now
# redundant STARTS_WITH is removed, leaving an AND of two LEVENSHTEIN_AUTOMATON.
query
EXPLAIN SELECT id FROM fo_low_idx WHERE name @@ ts_all([ts_starts_with('al'), ts_levenshtein('alpha', 1), ts_levenshtein('alpino', 1)]);
----
QUERY PLAN
╭─ IRESEARCH_SCAN ─────────────────────────────────╮
│ Index: fo_low_idx                                │
│ Lookup: table                                    │
│ Index Filter:                                    │
│ ╭─ And ───────────────╮                          │
│ ╰──────────┬──────────╯                          │
│            ├────────────────────────╮            │
│ ╭─ Levenshtein ───────╮  ╭─ Levenshtein ───────╮ │
│ │ Field: name(string) │  │ Field: name(string) │ │
│ │ Target: alpha       │  │ Target: alpino      │ │
│ │ Max Terms: 1024     │  │ Max Terms: 1024     │ │
│ ╰─────────────────────╯  ╰─────────────────────╯ │
│ Projections: id                                  │
│ ~1 row                                           │
╰──────────────────────────────────────────────────╯


