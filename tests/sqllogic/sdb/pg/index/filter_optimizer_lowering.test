statement ok
CREATE TABLE fo_low (id INTEGER PRIMARY KEY, name VARCHAR, t VARCHAR);

statement ok
CREATE TEXT SEARCH DICTIONARY fo_low_en(
    template = 'text', locale = 'en_US.UTF-8', case = 'none',
    stemming = false, accent = false, frequency = true, position = true
);

statement ok
CREATE INDEX fo_low_idx ON fo_low USING inverted(id, name, t fo_low_en);

statement ok
INSERT INTO fo_low VALUES
  (1, 'alpha',  'alpha beta gamma'),
  (2, 'alpino', 'beta gamma delta'),
  (3, 'gamma',  'gamma delta alpha'),
  (4, 'alfa',   'delta alpha beta');

statement ok
VACUUM (REFRESH_TABLE) fo_low;

