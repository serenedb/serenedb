# ----------------------------------------------------------------------
# Prefix + Levenshtein fusion. A same-field ts_starts_with whose prefix is
# a prefix of the edit-distance target folds into the edit-distance pinned
# prefix, leaving a single LEVENSHTEIN_AUTOMATON (no STARTS_WITH / AND).
# ----------------------------------------------------------------------

query
EXPLAIN SELECT id FROM fo_low_idx WHERE name @@ ts_all([ts_starts_with('alp'), ts_levenshtein('alpha', 1)]);
----
QUERY PLAN
╭─ Iresearch Scan ──────────────────────────╮
│ Index: fo_low_idx                         │
│ Lookup: table                             │
│ Filter:                                   │
│ ┌───────────────────────────────────────┐ │
│ │╭─ Levenshtein Automaton ─────────────╮│ │
│ ││ Detail:                             ││ │
│ ││ name(string) 'alpha' max_terms=1024 ││ │
│ │╰─────────────────────────────────────╯│ │
│ └───────────────────────────────────────┘ │
│ Projections: id                           │
│ ~1 row                                    │
╰───────────────────────────────────────────╯

query
SELECT id FROM fo_low_idx WHERE name @@ ts_all([ts_starts_with('alp'), ts_levenshtein('alpha', 1)]) ORDER BY id;
----
id
1

# A prefix that is not a prefix of the target cannot fold; the STARTS_WITH
# stays a separate AND clause.
