statement ok
CREATE TABLE fo_neg (id INTEGER PRIMARY KEY, s VARCHAR, n INTEGER, t VARCHAR);

statement ok
CREATE TEXT SEARCH DICTIONARY fo_neg_en(
    template = 'text', locale = 'en_US.UTF-8', case = 'none',
    stemming = false, accent = false, frequency = true, position = true
);

statement ok
CREATE INDEX fo_neg_idx ON fo_neg USING inverted(id, s, n, t fo_neg_en);

statement ok
INSERT INTO fo_neg VALUES
  (1, 'alpha', 1, 'alpha beta'),
  (2, 'beta',  2, 'beta gamma'),
  (3, 'gamma', 3, 'gamma delta'),
  (4, 'delta', 4, 'delta alpha');

statement ok
VACUUM (REFRESH_TABLE) fo_neg;

query
EXPLAIN SELECT id FROM fo_neg_idx WHERE NOT (t @@ ts_phrase('alpha'));
