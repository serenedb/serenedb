statement ok
CREATE TABLE fo_rng (id INTEGER PRIMARY KEY, s VARCHAR, n INTEGER);

statement ok
CREATE INDEX fo_rng_idx ON fo_rng USING inverted(id, s, n);

statement ok
INSERT INTO fo_rng VALUES
  (1, 'alpha', 1),
  (2, 'beta',  2),
  (3, 'gamma', 3),
  (4, 'delta', 4);

statement ok
VACUUM (REFRESH_TABLE) fo_rng;

query
EXPLAIN SELECT id FROM fo_rng_idx WHERE s @@ ts_between('alpha', 'alpha', true, true);
----
QUERY PLAN
┌───────────────────────────┐
│       IRESEARCH_SCAN      │
│    ────────────────────   │
│     Index: fo_rng_idx     │
│      Lookup: rocksdb      │
│                           │
│          Filter:          │
│  ┌─────────────────────┐  │
│  │┌───────────────────┐│  │
│  ││        Term       ││  │
│  ││    ────────────   ││  │
│  ││ s(string) = alpha ││  │
│  │└───────────────────┘│  │
│  └─────────────────────┘  │
│                           │
│      Projections: id      │
│                           │
│           ~1 row          │
└───────────────────────────┘

