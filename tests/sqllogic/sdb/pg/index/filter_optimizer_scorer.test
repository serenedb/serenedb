statement ok
CREATE TABLE fo_score (id INTEGER PRIMARY KEY, s VARCHAR, n INTEGER, t VARCHAR);

statement ok
CREATE TEXT SEARCH DICTIONARY fo_score_en(
    template = 'text', locale = 'en_US.UTF-8', case = 'none',
    stemming = false, accent = false, frequency = true, position = true
);

statement ok
CREATE INDEX fo_score_idx ON fo_score USING inverted(id, s, n, t fo_score_en);

statement ok
INSERT INTO fo_score VALUES
  (1, 'alpha', 1, 'alpha beta gamma'),
  (2, 'beta',  2, 'beta gamma delta'),
  (3, 'gamma', 3, 'gamma delta alpha'),
  (4, 'delta', 4, 'delta alpha beta');

statement ok
VACUUM (REFRESH_TABLE) fo_score;

statement ok
CREATE TEXT SEARCH DICTIONARY fo_score_ng_dict(
    template = 'wildcard', ngramsize = 3,
    tokenizer_template = 'delimiter', tokenizer_delimiter = ' ',
    frequency = true, position = true
);

statement ok
CREATE TABLE fo_score_ng (id INTEGER PRIMARY KEY, g VARCHAR);

statement ok
CREATE INDEX fo_score_ng_idx ON fo_score_ng USING inverted(id, g fo_score_ng_dict) INCLUDE (g);

statement ok
INSERT INTO fo_score_ng VALUES (1, 'analytical'), (2, 'analyser'), (3, 'analysis');

statement ok
VACUUM (REFRESH_TABLE) fo_score_ng;

query
EXPLAIN SELECT id FROM fo_score_idx WHERE s = 'alpha';
