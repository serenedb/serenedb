hash-threshold 100

# ST_Intersects and ST_Contains search functions over an inverted index
# with a geojson text search dictionary.
#
# Test data: points and a polygon stored as JSON (GeoJSON text). The catalog
# rejects plain VARCHAR for geo analyzers -- the column type must be JSON or
# GEOMETRY. GeoJSON coordinates are [longitude, latitude].
#
#   id=1: Point [37.615895, 55.703900]  -- cluster near [37.616, 55.704]
#   id=2: Point [37.616297, 55.704831]  -- cluster near [37.616, 55.704]
#   id=3: Point [37.617053, 55.704610]  -- cluster near [37.616, 55.704]
#   id=4: Point [37.559509, 55.715895]  -- far from cluster
#   id=5: Point [37.701645, 55.832144]  -- very far
#   id=6: Polygon [37.614323..37.615825, 55.705898..55.706520] -- small square
#
# Query shapes used across tests:
#   large_poly : [37.610..37.620, 55.700..55.710] -- fully contains ids 1,2,3,6
#   medium_poly: [37.614..37.618, 55.704..55.707] -- intersects 2,3,6; id=1 is below lat 55.704
#   point_in_6 : [37.615, 55.706]                 -- inside polygon 6
#   far_poly   : [0.0..1.0, 0.0..1.0]             -- no data in this area


# --- Schema setup ---

statement ok
CREATE TABLE geo_data (id INTEGER PRIMARY KEY, geo JSON)


statement ok
CREATE TEXT SEARCH DICTIONARY geojson_shape(
    template = 'geojson'
)


statement ok
CREATE INDEX geo_idx ON geo_data USING inverted(id, geo geojson_shape)


# --- Initial data ---

statement ok
INSERT INTO geo_data VALUES (1, '{"type":"Point","coordinates":[37.615895,55.703900]}')

statement ok
INSERT INTO geo_data VALUES (2, '{"type":"Point","coordinates":[37.616297,55.704831]}')

statement ok
INSERT INTO geo_data VALUES (3, '{"type":"Point","coordinates":[37.617053,55.704610]}')

statement ok
INSERT INTO geo_data VALUES (4, '{"type":"Point","coordinates":[37.559509,55.715895]}')

statement ok
INSERT INTO geo_data VALUES (5, '{"type":"Point","coordinates":[37.701645,55.832144]}')

statement ok
INSERT INTO geo_data VALUES (6, '{"type":"Polygon","coordinates":[[[37.614323,55.705898],[37.615825,55.705898],[37.615825,55.706520],[37.614323,55.706520],[37.614323,55.705898]]]}')

statement ok
VACUUM (UPDATE_INDEXES) geo_data


# --- ST_Intersects ---

# large_poly fully contains ids 1, 2, 3 and polygon 6; ids 4 and 5 are outside.

query
SELECT id FROM geo_idx
WHERE ST_Intersects(geo, '{"type":"Polygon","coordinates":[[[37.610,55.700],[37.620,55.700],[37.620,55.710],[37.610,55.710],[37.610,55.700]]]}')
ORDER BY id
----
id
1
2
3
6


# medium_poly [37.614..37.618, 55.704..55.707] intersects ids 2, 3 and polygon 6.
# id=1 (lat 55.7039) lies below the south edge (55.704) of this polygon.

query
SELECT id FROM geo_idx
WHERE ST_Intersects(geo, '{"type":"Polygon","coordinates":[[[37.614,55.704],[37.618,55.704],[37.618,55.707],[37.614,55.707],[37.614,55.704]]]}')
ORDER BY id
----
id
2
3
6


# Point [37.615, 55.706] lies inside polygon 6 -- only the polygon intersects.

query
SELECT id FROM geo_idx
WHERE ST_Intersects(geo, '{"type":"Point","coordinates":[37.615,55.706]}')
ORDER BY id
----
id
6


# far_poly is in the Gulf of Guinea -- no indexed data there.

query
SELECT id FROM geo_idx
WHERE ST_Intersects(geo, '{"type":"Polygon","coordinates":[[[0.0,0.0],[1.0,0.0],[1.0,1.0],[0.0,1.0],[0.0,0.0]]]}')
ORDER BY id
----
id


# --- ST_Contains (shape contains indexed data) ---
# ST_Contains(query_shape, field): returns rows whose indexed geometry is
# fully contained within query_shape.

# large_poly fully contains all three close points and polygon 6.

query
SELECT id FROM geo_idx
WHERE ST_Contains('{"type":"Polygon","coordinates":[[[37.610,55.700],[37.620,55.700],[37.620,55.710],[37.610,55.710],[37.610,55.700]]]}', geo)
ORDER BY id
----
id
1
2
3
6


# far_poly contains no indexed geometries.

query
SELECT id FROM geo_idx
WHERE ST_Contains('{"type":"Polygon","coordinates":[[[0.0,0.0],[1.0,0.0],[1.0,1.0],[0.0,1.0],[0.0,0.0]]]}', geo)
ORDER BY id
----
id


# --- ST_Contains (indexed data contains shape) ---
# ST_Contains(field, query_shape): returns rows whose indexed geometry fully
# contains query_shape.

# Point [37.615, 55.706] lies inside polygon 6 -- only polygon 6 contains it.

query
SELECT id FROM geo_idx
WHERE ST_Contains(geo, '{"type":"Point","coordinates":[37.615,55.706]}')
ORDER BY id
----
id
6


# large_poly is bigger than any indexed geometry -- nothing contains it.

query
SELECT id FROM geo_idx
WHERE ST_Contains(geo, '{"type":"Polygon","coordinates":[[[37.610,55.700],[37.620,55.700],[37.620,55.710],[37.610,55.710],[37.610,55.700]]]}')
ORDER BY id
----
id


# --- ST_Intersects with swapped arguments (commutative) ---
# ST_Intersects is commutative: swapping field and shape gives the same result.

query
SELECT id FROM geo_idx
WHERE ST_Intersects('{"type":"Polygon","coordinates":[[[37.610,55.700],[37.620,55.700],[37.620,55.710],[37.610,55.710],[37.610,55.700]]]}', geo)
ORDER BY id
----
id
1
2
3
6


# --- Combined filter ---
# ST_Intersects with medium_poly narrows to {2, 3, 6};
# ST_Contains(large_poly, field) is satisfied by all of them.

query
SELECT id FROM geo_idx
WHERE ST_Intersects(geo, '{"type":"Polygon","coordinates":[[[37.614,55.704],[37.618,55.704],[37.618,55.707],[37.614,55.707],[37.614,55.704]]]}')
  AND ST_Contains('{"type":"Polygon","coordinates":[[[37.610,55.700],[37.620,55.700],[37.620,55.710],[37.610,55.710],[37.610,55.700]]]}', geo)
ORDER BY id
----
id
2
3
6


# --- Incremental index update ---

statement ok
INSERT INTO geo_data VALUES (7, '{"type":"Point","coordinates":[37.614800,55.704500]}')

statement ok
VACUUM (UPDATE_INDEXES) geo_data


# New point [37.6148, 55.7045] is inside both large_poly and medium_poly.

query
SELECT id FROM geo_idx
WHERE ST_Intersects(geo, '{"type":"Polygon","coordinates":[[[37.610,55.700],[37.620,55.700],[37.620,55.710],[37.610,55.710],[37.610,55.700]]]}')
ORDER BY id
----
id
1
2
3
6
7


query
SELECT id FROM geo_idx
WHERE ST_Contains('{"type":"Polygon","coordinates":[[[37.610,55.700],[37.620,55.700],[37.620,55.710],[37.610,55.710],[37.610,55.700]]]}', geo)
ORDER BY id
----
id
1
2
3
6
7


# --- ST_Distance_Centroid ---
#
# Centroid-to-centroid geodesic distance in metres. The filter builder rewrites
# `ST_Distance_Centroid(field, centroid) OP <const>` into a one-sided
# GeoDistanceFilter range; supported ops are <, <=, >, >=, =, !=.
#
# Reference centroid (37.616, 55.704). Approximate distances to each row:
#   id=1 ~100m   id=2 ~100m   id=3 ~100m   id=6 ~250m (polygon centroid)
#   id=7 ~90m    id=4 ~3.8km  id=5 ~15km
# Thresholds below are picked to stay clear of those approximate values.

# --- ST_Distance_Centroid: tight threshold picks the cluster ---

query
SELECT id FROM geo_idx
WHERE ST_Distance_Centroid(geo, '{"type":"Point","coordinates":[37.616,55.704]}') < 500.0
ORDER BY id
----
id
1
2
3
6
7


# --- ST_Distance_Centroid: > separates the far rows ---

query
SELECT id FROM geo_idx
WHERE ST_Distance_Centroid(geo, '{"type":"Point","coordinates":[37.616,55.704]}') > 1000.0
ORDER BY id
----
id
4
5


# --- ST_Distance_Centroid: very far threshold isolates id=5 ---

query
SELECT id FROM geo_idx
WHERE ST_Distance_Centroid(geo, '{"type":"Point","coordinates":[37.616,55.704]}') > 10000.0
ORDER BY id
----
id
5


# --- ST_Distance_Centroid: <= picks everything except id=5 ---

query
SELECT id FROM geo_idx
WHERE ST_Distance_Centroid(geo, '{"type":"Point","coordinates":[37.616,55.704]}') <= 10000.0
ORDER BY id
----
id
1
2
3
4
6
7


# --- ST_Distance_Centroid + GEOMETRY centroid argument ---
# Same query, centroid passed as a GEOMETRY literal instead of GeoJSON text.

query
SELECT id FROM geo_idx
WHERE ST_Distance_Centroid(geo, 'POINT(37.616 55.704)'::GEOMETRY('OGC:CRS84')) < 500.0
ORDER BY id
----
id
1
2
3
6
7


# --- ST_Distance_Centroid: NOT inverts the range ---

query
SELECT id FROM geo_idx
WHERE NOT (ST_Distance_Centroid(geo, '{"type":"Point","coordinates":[37.616,55.704]}') < 500.0)
ORDER BY id
----
id
4
5


# --- Error cases ---

# Valid JSON but unrecognized GeoJSON type -- the filter builder rejects the
# shape parse, leaving the predicate on the LogicalFilter for the runtime stub
# to reject with the "outside inverted index context" message.

statement error
SELECT id FROM geo_idx WHERE ST_Intersects(geo, '{"type":"Unknown","coordinates":[]}')
----
db error: ERROR: Inverted index function called outside inverted index context.<slt:ignore>


statement error
SELECT id FROM geo_idx WHERE ST_Contains(geo, '{"type":"Unknown","coordinates":[]}')
----
db error: ERROR: Inverted index function called outside inverted index context.<slt:ignore>


# ST_Intersects / ST_Contains on a column indexed with a non-geo (text) analyzer.

statement ok
CREATE TABLE geo_plain (id INTEGER PRIMARY KEY, geo VARCHAR)

statement ok
CREATE TEXT SEARCH DICTIONARY plain_text(
    template = 'text',
    locale = 'en_US.UTF-8'
)

statement ok
CREATE INDEX geo_plain_idx ON geo_plain USING inverted(id, geo plain_text)

statement ok
INSERT INTO geo_plain VALUES (1, '{"type":"Point","coordinates":[0,0]}')

statement ok
VACUUM (UPDATE_INDEXES) geo_plain


statement error
SELECT id FROM geo_plain_idx WHERE ST_Intersects(geo, '{"type":"Point","coordinates":[0,0]}')
----
db error: ERROR: Inverted index function called outside inverted index context.<slt:ignore>


statement error
SELECT id FROM geo_plain_idx WHERE ST_Contains(geo, '{"type":"Point","coordinates":[0,0]}')
----
db error: ERROR: Inverted index function called outside inverted index context.<slt:ignore>


# --- GEOMETRY column ---
#
# A GEOMETRY column carries WKB bytes internally. The catalog's
# ValidateGeoAnalyzerColumn requires a CRS84-compatible CRS to be declared on
# the column (CREATE INDEX rejects bare GEOMETRY without a CRS), and the
# geojson analyzer must use `coding = 's2point'` -- LatLng codings are
# rejected for GEOMETRY columns. (VPack coding is rejected at dictionary
# creation time, so it never reaches the index.)
#
# DuckDB has implicit casts between VARCHAR (WKT) and GEOMETRY, so test data
# is written in human-readable WKT form. Same shapes as the VARCHAR test
# above, identical query semantics + result sets.

statement ok
CREATE TABLE geo_data_g (id INTEGER PRIMARY KEY, geo GEOMETRY('OGC:CRS84'))


statement ok
CREATE TEXT SEARCH DICTIONARY geojson_s2point(
    template = 'geojson',
    coding = 's2point'
)


statement ok
CREATE INDEX geo_data_g_idx ON geo_data_g USING inverted(id, geo geojson_s2point)


# Same shapes as the VARCHAR-column data above (WKT uses lng lat order, same
# axis orientation as the GeoJSON `coordinates` array).

statement ok
INSERT INTO geo_data_g VALUES (1, 'POINT(37.615895 55.703900)'::GEOMETRY('OGC:CRS84'))

statement ok
INSERT INTO geo_data_g VALUES (2, 'POINT(37.616297 55.704831)'::GEOMETRY('OGC:CRS84'))

statement ok
INSERT INTO geo_data_g VALUES (3, 'POINT(37.617053 55.704610)'::GEOMETRY('OGC:CRS84'))

statement ok
INSERT INTO geo_data_g VALUES (4, 'POINT(37.559509 55.715895)'::GEOMETRY('OGC:CRS84'))

statement ok
INSERT INTO geo_data_g VALUES (5, 'POINT(37.701645 55.832144)'::GEOMETRY('OGC:CRS84'))

statement ok
INSERT INTO geo_data_g VALUES (6, 'POLYGON((37.614323 55.705898, 37.615825 55.705898, 37.615825 55.706520, 37.614323 55.706520, 37.614323 55.705898))'::GEOMETRY('OGC:CRS84'))

statement ok
VACUUM (UPDATE_INDEXES) geo_data_g


# --- GEOMETRY field + JSON (GeoJSON) shape ---

# large_poly intersects ids 1, 2, 3 and polygon 6.

query
SELECT id FROM geo_data_g_idx
WHERE ST_Intersects(geo, '{"type":"Polygon","coordinates":[[[37.610,55.700],[37.620,55.700],[37.620,55.710],[37.610,55.710],[37.610,55.700]]]}')
ORDER BY id
----
id
1
2
3
6


# Point [37.615, 55.706] lies inside polygon 6 -- only that polygon intersects.

query
SELECT id FROM geo_data_g_idx
WHERE ST_Intersects(geo, '{"type":"Point","coordinates":[37.615,55.706]}')
ORDER BY id
----
id
6


# ST_Contains(field, shape): indexed contains shape.
# Polygon 6 contains the point [37.615, 55.706].

query
SELECT id FROM geo_data_g_idx
WHERE ST_Contains(geo, '{"type":"Point","coordinates":[37.615,55.706]}')
ORDER BY id
----
id
6


# ST_Contains(shape, field): shape contains indexed.
# large_poly contains all close shapes.

query
SELECT id FROM geo_data_g_idx
WHERE ST_Contains('{"type":"Polygon","coordinates":[[[37.610,55.700],[37.620,55.700],[37.620,55.710],[37.610,55.710],[37.610,55.700]]]}', geo)
ORDER BY id
----
id
1
2
3
6


# --- GEOMETRY field + GEOMETRY (WKT) shape ---

# Same point_in_6 query, but the centroid is also passed as GEOMETRY (WKT).

query
SELECT id FROM geo_data_g_idx
WHERE ST_Intersects(geo, 'POINT(37.615 55.706)'::GEOMETRY('OGC:CRS84'))
ORDER BY id
----
id
6


query
SELECT id FROM geo_data_g_idx
WHERE ST_Contains(geo, 'POINT(37.615 55.706)'::GEOMETRY('OGC:CRS84'))
ORDER BY id
----
id
6


# Polygon-shaped centroid (ST_Contains(shape, field) variant).

query
SELECT id FROM geo_data_g_idx
WHERE ST_Contains('POLYGON((37.610 55.700, 37.620 55.700, 37.620 55.710, 37.610 55.710, 37.610 55.700))'::GEOMETRY('OGC:CRS84'), geo)
ORDER BY id
----
id
1
2
3
6


# --- GEOMETRY constants with no explicit CRS ---
# DuckDB's geo cast rule reinterprets a bare GEOMETRY (no CRS metadata) into
# the function signature's GEOMETRY('OGC:CRS84') silently -- no per-row check
# is done, the user is taking responsibility for the bytes being CRS84.
# The queries below match the explicit-CRS variants above.

query
SELECT id FROM geo_data_g_idx
WHERE ST_Intersects(geo, 'POINT(37.615 55.706)'::GEOMETRY)
ORDER BY id
----
id
6


query
SELECT id FROM geo_data_g_idx
WHERE ST_Contains(geo, 'POINT(37.615 55.706)'::GEOMETRY)
ORDER BY id
----
id
6


query
SELECT id FROM geo_data_g_idx
WHERE ST_Contains('POLYGON((37.610 55.700, 37.620 55.700, 37.620 55.710, 37.610 55.710, 37.610 55.700))'::GEOMETRY, geo)
ORDER BY id
----
id
1
2
3
6


# --- Error: GEOMETRY constant with non-CRS84 CRS ---
# Both source (the literal) and target (the function signature) have CRS;
# DuckDB's geo cast checks `Equals` and rejects the cast at bind time with
# a BinderException -- this never reaches the filter builder. We use
# OGC:CRS83, which is the only other CRS DuckDB knows out of the box;
# arbitrary EPSG codes (EPSG:3857 etc.) are rejected even earlier with
# "unrecognized coordinate system" unless an extension is loaded.

statement error
SELECT id FROM geo_data_g_idx
WHERE ST_Intersects(geo, 'POINT(0 0)'::GEOMETRY('OGC:CRS83'))
----
db error: ERROR: Cannot cast GEOMETRY with CRS 'OGC:CRS83' to GEOMETRY with different CRS 'OGC:CRS84'<slt:ignore>


statement error
SELECT id FROM geo_data_g_idx
WHERE ST_Contains(geo, 'POINT(0 0)'::GEOMETRY('OGC:CRS83'))
----
db error: ERROR: Cannot cast GEOMETRY with CRS 'OGC:CRS83' to GEOMETRY with different CRS 'OGC:CRS84'<slt:ignore>


statement error
SELECT id FROM geo_data_g_idx
WHERE ST_Contains('POLYGON((0 0, 1 0, 1 1, 0 1, 0 0))'::GEOMETRY('OGC:CRS83'), geo)
----
db error: ERROR: Cannot cast GEOMETRY with CRS 'OGC:CRS83' to GEOMETRY with different CRS 'OGC:CRS84'<slt:ignore>


# --- Error: GEOMETRY constant with Z / M dimensions ---
# Our WKB parser is 2D only (CRS84 is lng/lat in degrees, no height/measure):
# ParseShapeWKB rejects values whose WKB type word has the Z or M flag bit
# set. The filter builder fails to claim the predicate, falling back to the
# runtime stub.

statement error
SELECT id FROM geo_data_g_idx
WHERE ST_Intersects(geo, 'POINT Z (37.615 55.706 0)'::GEOMETRY('OGC:CRS84'))
----
db error: ERROR: Inverted index function called outside inverted index context.<slt:ignore>


statement error
SELECT id FROM geo_data_g_idx
WHERE ST_Intersects(geo, 'POINT M (37.615 55.706 0)'::GEOMETRY('OGC:CRS84'))
----
db error: ERROR: Inverted index function called outside inverted index context.<slt:ignore>


statement error
SELECT id FROM geo_data_g_idx
WHERE ST_Intersects(geo, 'POINT ZM (37.615 55.706 0 0)'::GEOMETRY('OGC:CRS84'))
----
db error: ERROR: Inverted index function called outside inverted index context.<slt:ignore>


statement error
SELECT id FROM geo_data_g_idx
WHERE ST_Contains(geo, 'POINT Z (37.615 55.706 0)'::GEOMETRY('OGC:CRS84'))
----
db error: ERROR: Inverted index function called outside inverted index context.<slt:ignore>


