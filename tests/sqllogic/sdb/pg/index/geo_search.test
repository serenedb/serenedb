# --- CREATE INDEX rejection: GEOMETRY column with non-S2Point geojson coding ---
# A geojson dictionary with a LatLng coding cannot index a GEOMETRY column --
# the catalog's ValidateGeoAnalyzerColumn check rejects at index creation
# because there is no shape -> LatLng-bytes encoder yet.

statement ok
CREATE TEXT SEARCH DICTIONARY geojson_latlng(
    template = 'geojson',
    coding = 's2latlngf64'
)

statement ok
CREATE TABLE geo_data_g_bad (id INTEGER PRIMARY KEY, geo GEOMETRY('OGC:CRS84'))

statement error
CREATE INDEX geo_data_g_bad_idx ON geo_data_g_bad USING inverted(id, geo geojson_latlng)
----
db error: ERROR: Failed to create index: Column 'geo' is GEOMETRY but the geo analyzer uses a LatLng coding;<slt:ignore>


# --- CREATE INDEX rejection: GEOMETRY column without CRS ---
# A bare GEOMETRY column (no CRS metadata) is rejected at CREATE INDEX time
# even if the dictionary uses S2Point coding -- IsCRS84Identifier check fails.

statement ok
CREATE TABLE geo_data_g_no_crs (id INTEGER PRIMARY KEY, geo GEOMETRY)

statement error
CREATE INDEX geo_data_g_no_crs_idx ON geo_data_g_no_crs USING inverted(id, geo geojson_s2point)
----
db error: ERROR: Failed to create index: Column 'geo': GEOMETRY type has no CRS attached;<slt:ignore>


# --- CREATE INDEX rejection: plain VARCHAR column ---
# Geo analyzers require JSON or GEOMETRY: a plain VARCHAR column has no type
# guarantee that its contents are GeoJSON, so the catalog rejects at CREATE
# INDEX time. Authors must declare the column as JSON.

statement ok
CREATE TABLE geo_data_v (id INTEGER PRIMARY KEY, geo VARCHAR)

statement error
CREATE INDEX geo_data_v_idx ON geo_data_v USING inverted(id, geo geojson_shape)
----
db error: ERROR: Failed to create index: Column 'geo' uses a geo analyzer; must be JSON (GeoJSON) or GEOMETRY<slt:ignore>
