# -------- Case 2c: source geo no INCLUDE --------
# Source coding force-includes even without an explicit INCLUDE clause, so
# the plan still projects `geo (i)` / `pk (l)` and `SELECT geo` returns the
# raw GeoJSON read from the force-included cs column (no RocksDB fallback).

statement ok
CREATE TABLE t_geo_src_noi(pk INTEGER PRIMARY KEY, geo JSON);

statement ok
INSERT INTO t_geo_src_noi VALUES (1, '{"type":"Point","coordinates":[37.615895,55.703900]}');

statement ok
CREATE INDEX t_geo_src_noi_idx ON t_geo_src_noi USING inverted(geo g_src_dict);

statement ok
VACUUM (REFRESH_TABLE) t_geo_src_noi;

query
EXPLAIN SELECT pk, geo FROM t_geo_src_noi_idx
WHERE geo <-> '{"type":"Point","coordinates":[37.616,55.704]}' < 1000.0;
----
QUERY PLAN
╭─ PROJECTION ─────────────╮
│ Projections: pk, geo     │
│ ~1 row                   │
╰─────────────┬────────────╯
╭─ IRESEARCH_SCAN ─────────╮
│ Index: t_geo_src_noi_idx │
│ Lookup: table            │
│ Index Filter:            │
│ ╭─ Geo Distance ─────╮   │
│ │ Field: geo(string) │   │
│ │ Range: *, <1000    │   │
│ ╰────────────────────╯   │
│ Projections: geo (i),    │
│              pk (l)      │
│ ~1 row                   │
╰──────────────────────────╯

query
SELECT pk, geo FROM t_geo_src_noi_idx
WHERE geo <-> '{"type":"Point","coordinates":[37.616,55.704]}' < 1000.0;
----
pk	geo
1	{"type":"Point","coordinates":[37.615895,55.703900]}

# -------- Case 2d: source geo + compression --------
# The force-included geo column can be compressed through the existing
# `included` opclass: list `geo` again as `geo included (compression = 'zstd')`.
# Source coding force-includes geo into cs regardless, so the plan still
# annotates `geo (i)` / `pk (l)` and SELECT geo re-reads the (now compressed)
# cs column. A bare INCLUDE (geo) carries no option and is meaningless here.

statement ok
CREATE TABLE t_geo_src_zstd(pk INTEGER PRIMARY KEY, geo JSON);

statement ok
INSERT INTO t_geo_src_zstd VALUES (1, '{"type":"Point","coordinates":[37.615895,55.703900]}');

statement ok
CREATE INDEX t_geo_src_zstd_idx ON t_geo_src_zstd
  USING inverted(geo g_src_dict, geo included (compression = 'zstd'));

statement ok
VACUUM (REFRESH_TABLE) t_geo_src_zstd;

query
EXPLAIN SELECT pk, geo FROM t_geo_src_zstd_idx
WHERE geo <-> '{"type":"Point","coordinates":[37.616,55.704]}' < 1000.0;
----
QUERY PLAN
╭─ PROJECTION ──────────────╮
│ Projections: pk, geo      │
│ ~1 row                    │
╰─────────────┬─────────────╯
╭─ IRESEARCH_SCAN ──────────╮
│ Index: t_geo_src_zstd_idx │
│ Lookup: table             │
│ Index Filter:             │
│ ╭─ Geo Distance ─────╮    │
│ │ Field: geo(string) │    │
│ │ Range: *, <1000    │    │
│ ╰────────────────────╯    │
│ Projections: geo (i),     │
│              pk (l)       │
│ ~1 row                    │
╰───────────────────────────╯

query
SELECT pk, geo FROM t_geo_src_zstd_idx
WHERE geo <-> '{"type":"Point","coordinates":[37.616,55.704]}' < 1000.0;
----
pk	geo
1	{"type":"Point","coordinates":[37.615895,55.703900]}

# An invalid compression name on the force-included geo column is rejected at
# CREATE INDEX time (mirrors cs_compression_methods.test's 'constant' case).

statement error
CREATE INDEX t_geo_src_bad_idx ON t_geo_src_zstd
  USING inverted(geo g_src_dict, geo included (compression = 'constant'));

# -------- Case 3: wildcard + INCLUDE --------

statement ok
CREATE TABLE t_wild_inc(pk INTEGER PRIMARY KEY, b VARCHAR);

statement ok
INSERT INTO t_wild_inc VALUES (1, 'percent_alpha_one');

statement ok
CREATE INDEX t_wild_inc_idx ON t_wild_inc
  USING inverted(b w_dict) INCLUDE (b);

statement ok
VACUUM (REFRESH_TABLE) t_wild_inc;

query
EXPLAIN SELECT pk, b FROM t_wild_inc_idx
WHERE b @@ ts_like('percent_alpha_one');
----
QUERY PLAN
╭─ PROJECTION ───────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────╮
│ Projections: pk, b                                                                                                                                                                                     │
│ ~1 row                                                                                                                                                                                                 │
╰────────────────────────────────────────────────────────────────────────────────────────────────────┬───────────────────────────────────────────────────────────────────────────────────────────────────╯
╭─ IRESEARCH_SCAN ───────────────────────────────────────────────────────────────────────────────────┴───────────────────────────────────────────────────────────────────────────────────────────────────╮
│ Index: t_wild_inc_idx                                                                                                                                                                                  │
│ Lookup: table                                                                                                                                                                                          │
│ Index Filter:                                                                                                                                                                                          │
│ ╭─ Wildcard Ngram ───────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────╮ │
│ │ Field: b(string)                                                                                                                                                                                   │ │
│ │ Token:                                                                                                                                                                                             │ │
│ │ Has Pos: false                                                                                                                                                                                     │ │
│ │ Parts:                                                                                                                                                                                             │ │
│ │ <Term:\\xffpe(0, 0); Term:per(1, 1); Term:erc(1, 1); Term:rce(1, 1); Term:cen(1, 1); Term:ent(1, 1); >; <Term:alp(0, 0); Term:lph(1, 1); Term:pha(1, 1); >; <Term:one(0, 0); Term:ne\\xff(1, 1); >;  │ │
│ ╰────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────╯ │
│ Projections: b (i), pk (l)                                                                                                                                                                             │
│ ~1 row                                                                                                                                                                                                 │
╰────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────╯

query
SELECT pk, b FROM t_wild_inc_idx WHERE b @@ ts_like('percent_alpha_one');
----
pk	b
1	percent_alpha_one

