# Verifies BOTH geojson codings plus the wildcard analyzer's cs storage.
#
# s2point coding (aux-blob split): the analyzer emits a `StoreAttr` blob
# that lives at a catalog-allocated aux field id, distinct from the user
# column id. The filter consults the aux column at query time; `SELECT col`
# returns the user's raw input, never the analyzer's internal representation.
#
# source coding (force-include): the source column is force-included into
# the columnstore (entry.store_values=true) and re-parsed at query time --
# no aux blob is written. The user column is always read from cs, so the
# plan annotates the projections `geo (i)` / `pk (l)` even without an
# explicit INCLUDE clause; `SELECT geo` returns the raw GeoJSON from cs.
#
# Cases:
#   s2point geo + INCLUDE: SELECT geo → cs[user_id] = raw GeoJSON
#   s2point geo no INCLUDE: SELECT geo → RocksDB lookup = raw GeoJSON
#   source geo no INCLUDE: SELECT geo → cs[user_id] = raw GeoJSON (force-included)
#   source geo + compression: the force-included geo column is compressed via
#     the `included` opclass (geo listed again as `geo included
#     (compression = 'zstd')`); plan still annotates `geo (i)` / `pk (l)` and
#     SELECT geo round-trips. An invalid compression name is rejected.
#   wildcard + INCLUDE: SELECT b → cs[user_id] = raw VARCHAR
#   wildcard no INCLUDE: SELECT b → RocksDB lookup = raw VARCHAR
# In all cases, the filter still works (s2point reads cs[aux_id]; source
# re-parses the force-included cs[user_id]).

statement ok
CREATE TEXT SEARCH DICTIONARY g_dict(template = 'geojson', coding = 's2point');

statement ok
CREATE TEXT SEARCH DICTIONARY g_src_dict(template = 'geojson', coding = 'source');

statement ok
CREATE TEXT SEARCH DICTIONARY w_dict(
    template = 'wildcard',
    ngramsize = 3,
    tokenizer_template = 'delimiter',
    tokenizer_delimiter = ' '
);

# -------- Case 1: geo + INCLUDE --------

statement ok
CREATE TABLE t_geo_inc(pk INTEGER PRIMARY KEY, geo JSON);

statement ok
INSERT INTO t_geo_inc VALUES (1, '{"type":"Point","coordinates":[37.615895,55.703900]}');

statement ok
CREATE INDEX t_geo_inc_idx ON t_geo_inc
  USING inverted(geo g_dict) INCLUDE (geo);

statement ok
VACUUM (REFRESH_TABLE) t_geo_inc;

query
EXPLAIN SELECT pk, geo FROM t_geo_inc_idx
WHERE geo <-> '{"type":"Point","coordinates":[37.616,55.704]}' < 1000.0;
----
QUERY PLAN
╭─ PROJECTION ───────────╮
│ Projections: pk, geo   │
│ ~1 row                 │
╰────────────┬───────────╯
╭─ IRESEARCH_SCAN ───────╮
│ Index: t_geo_inc_idx   │
│ Lookup: table          │
│ Index Filter:          │
│ ╭─ Geo Distance ─────╮ │
│ │ Field: geo(string) │ │
│ │ Range: *, <1000    │ │
│ ╰────────────────────╯ │
│ Projections: geo (i),  │
│              pk (l)    │
│ ~1 row                 │
╰────────────────────────╯

query
SELECT pk, geo FROM t_geo_inc_idx
WHERE geo <-> '{"type":"Point","coordinates":[37.616,55.704]}' < 1000.0;
----
pk	geo
1	{"type":"Point","coordinates":[37.615895,55.703900]}

