hash-threshold 100

# SQL `IS NULL` / `IS NOT NULL` claimed through the inverted index: both
# compile to the column's null-marker term (negated for IS NOT NULL), so
# they work on ANY indexed column, with or without INCLUDE storage. This
# corpus pins the dual-purpose case (`dual` is indexed AND INCLUDE'd),
# the marker claim combined with a positive @@ conjunct, and a plain
# indexed column without INCLUDE. The former surface pinned here -- the
# ts_is_null()/ts_is_not_null() constructors riding
# irs::ByColumnExistence -- was retired in favor of the SQL operators.

statement ok
CREATE TABLE ce (
  pk INTEGER PRIMARY KEY,
  body VARCHAR,
  dual VARCHAR
)


statement ok
CREATE TEXT SEARCH DICTIONARY en(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true
)


statement ok
CREATE INDEX ce_idx ON ce USING inverted(pk, body en, dual en)
  INCLUDE (dual)


statement ok
INSERT INTO ce VALUES (1, 'alpha cat', 'red apple')


statement ok
INSERT INTO ce VALUES (2, 'beta dog', NULL)


statement ok
INSERT INTO ce VALUES (3, 'gamma cat', 'green leaf')


statement ok
INSERT INTO ce VALUES (4, 'delta', NULL)


statement ok
VACUUM (REFRESH_TABLE) ce


# ---- 1. IS NULL claims the null-marker term ----
query
EXPLAIN SELECT pk, dual FROM ce_idx WHERE dual IS NULL;
----
QUERY PLAN
╭─ PROJECTION ───────────╮
│ Projections: pk, dual  │
│ ~1 row                 │
╰────────────┬───────────╯
╭─ IRESEARCH_SCAN ───────╮
│ Index: ce_idx          │
│ Lookup: table          │
│ Index Filter:          │
│ ╭─ Term ────────────╮  │
│ │ Field: dual(null) │  │
│ │ Value:            │  │
│ ╰───────────────────╯  │
│ Projections: dual (i), │
│              pk (l)    │
│ ~1 row                 │
╰────────────────────────╯


query
SELECT pk, dual FROM ce_idx WHERE dual IS NULL ORDER BY pk;
----
pk	dual
2	NULL
4	NULL


# ---- 2. IS NOT NULL claims the negated marker ----
query
EXPLAIN SELECT pk, dual FROM ce_idx WHERE dual IS NOT NULL;
----
QUERY PLAN
╭─ PROJECTION ───────────╮
│ Projections: pk, dual  │
│ ~1 row                 │
╰────────────┬───────────╯
╭─ IRESEARCH_SCAN ───────╮
│ Index: ce_idx          │
│ Lookup: table          │
│ Index Filter:          │
│ ╭─ Not ─────────────╮  │
│ ╰─────────┬─────────╯  │
│ ╭─ Term ──┴─────────╮  │
│ │ Field: dual(null) │  │
│ │ Value:            │  │
│ ╰───────────────────╯  │
│ Projections: dual (i), │
│              pk (l)    │
│ ~1 row                 │
╰────────────────────────╯


query
SELECT pk, dual FROM ce_idx WHERE dual IS NOT NULL ORDER BY pk;
----
pk	dual
1	red apple
3	green leaf


# ---- 3. Combined with an indexed-column phrase filter ----
# The two clauses AND in the iresearch filter -- no residual FILTER node
# above the IRESEARCH_SCAN.
query
EXPLAIN SELECT pk, dual FROM ce_idx
WHERE body @@ ts_phrase('cat') AND dual IS NOT NULL;
----
QUERY PLAN
╭─ PROJECTION ───────────────────────────────────╮
│ Projections: pk, dual                          │
│ ~1 row                                         │
╰────────────────────────┬───────────────────────╯
╭─ IRESEARCH_SCAN ───────┴───────────────────────╮
│ Index: ce_idx                                  │
│ Lookup: table                                  │
│ Index Filter:                                  │
│ ╭─ Exclusion ─────────╮                        │
│ ╰──────────┬──────────╯                        │
│            ├───────────────────────╮           │
│ ╭─ Term ───┴──────────╮  ╭─ Term ──┴─────────╮ │
│ │ Field: body(string) │  │ Field: dual(null) │ │
│ │ Value: cat          │  │ Value:            │ │
│ ╰─────────────────────╯  ╰───────────────────╯ │
│ Projections: dual (i), pk (l)                  │
│ ~1 row                                         │
╰────────────────────────────────────────────────╯


query
SELECT pk, body, dual FROM ce_idx
WHERE body @@ ts_phrase('cat') AND dual IS NOT NULL
ORDER BY pk;
----
pk	body	dual
1	alpha cat	red apple
3	gamma cat	green leaf


# ---- 4. Same shape with IS NULL ----
query
EXPLAIN SELECT pk, dual FROM ce_idx
WHERE body @@ ts_phrase('cat') AND dual IS NULL;
----
QUERY PLAN
╭─ PROJECTION ───────────────────────────────────╮
│ Projections: pk, dual                          │
│ ~1 row                                         │
╰────────────────────────┬───────────────────────╯
╭─ IRESEARCH_SCAN ───────┴───────────────────────╮
│ Index: ce_idx                                  │
│ Lookup: table                                  │
│ Index Filter:                                  │
│ ╭─ And ───────────────╮                        │
│ ╰──────────┬──────────╯                        │
│            ├───────────────────────╮           │
│ ╭─ Term ───┴──────────╮  ╭─ Term ──┴─────────╮ │
│ │ Field: body(string) │  │ Field: dual(null) │ │
│ │ Value: cat          │  │ Value:            │ │
│ ╰─────────────────────╯  ╰───────────────────╯ │
│ Projections: dual (i), pk (l)                  │
│ ~1 row                                         │
╰────────────────────────────────────────────────╯


query
SELECT pk, body, dual FROM ce_idx
WHERE body @@ ts_phrase('cat') AND dual IS NULL
ORDER BY pk;
----
pk	body	dual


# ---- 5. Sanity: IS NULL is exactly the row-set complement of
# IS NOT NULL over `dual`, and the two together cover every row.
query
SELECT count(*) FROM ce_idx WHERE dual IS NULL;
----
count
2


query
SELECT count(*) FROM ce_idx WHERE dual IS NOT NULL;
----
count
2


# ---- 6. A plain indexed column without INCLUDE storage: `body` has a
# null-marker field like any indexed column; the claim needs no
# columnstore. ----
query IT
SELECT pk, body FROM ce_idx WHERE body IS NULL ORDER BY pk
----
pk	body


query IT
SELECT pk, body FROM ce_idx WHERE body IS NOT NULL ORDER BY pk
----
pk	body
1	alpha cat
2	beta dog
3	gamma cat
4	delta


query
EXPLAIN SELECT pk, body FROM ce_idx WHERE body IS NOT NULL ORDER BY pk
----
QUERY PLAN
╭─ ORDER_BY ──────────────╮
│ Order By: ce_idx.pk ASC │
│ ~1 row                  │
