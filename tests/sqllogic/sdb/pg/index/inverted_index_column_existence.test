в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ


query
SELECT pk, body, dual FROM ce_idx
WHERE body @@ ts_phrase('cat') AND dual @@ ts_is_null()
ORDER BY pk;
----
pk	body	dual


# ---- 5. Sanity: ts_is_null is exactly the row-set complement of
# ts_is_not_null over `dual`, and the two together cover every row.
query
SELECT count(*) FROM ce_idx WHERE dual @@ ts_is_null();
----
count
2


query
SELECT count(*) FROM ce_idx WHERE dual @@ ts_is_not_null();
----
count
2
