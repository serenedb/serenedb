statement ok
DROP TABLE cfm_st;


# -----------------------------------------------------------------------------
# View over a read_parquet glob (external lookup source): the same count
# shapes. INCLUDE'd columns (c, t) count in-scan; only a filter on a
# non-INCLUDE'd column (extra) needs the source. This pins the shape where a
# filter proven always-true by statistics (t spans every row) is dropped but
# its column stays in the scan: the count must remain count-only, without the
# lookup.
# -----------------------------------------------------------------------------

statement count 100
COPY (SELECT i AS id,
             CASE WHEN i%2=0 THEN 'fox jumps' ELSE 'dog sleeps' END AS body,
             i AS c, i AS t, i*10 AS extra
      FROM generate_series(1,100) g(i))
TO '${__TEST_DIR__}/cfm_glob_a.parquet' (FORMAT PARQUET);


statement count 100
COPY (SELECT i AS id, 'fox runs' AS body, i AS c, i AS t, i*10 AS extra
      FROM generate_series(101,200) g(i))
TO '${__TEST_DIR__}/cfm_glob_b.parquet' (FORMAT PARQUET);


statement ok
CREATE TEXT SEARCH DICTIONARY cfm_v_en(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'lower',
    stemming = false,
    accent = false,
    frequency = true,
    position = true
);


statement ok
CREATE VIEW cfm_v AS
SELECT * FROM read_parquet('${__TEST_DIR__}/cfm_glob_*.parquet');


statement ok
CREATE INDEX cfm_v_idx ON cfm_v USING inverted(body cfm_v_en) INCLUDE (c, t);


# Pure count: reader metadata, no source touch.
query
EXPLAIN SELECT count(*) FROM cfm_v_idx;
----
QUERY PLAN
╭─ UNGROUPED_AGGREGATE ────╮
│ Aggregates: count_star() │
│ ~1 row                   │
╰─────────────┬────────────╯
╭─ IRESEARCH_SCAN ─────────╮
│ Index: cfm_v_idx         │
│ Output: row-count only   │
│ ~200 rows                │
╰──────────────────────────╯


query
SELECT count(*) AS n FROM cfm_v_idx;
----
n
200


# Predicate count.
query
SELECT count(*) AS n FROM cfm_v_idx WHERE body @@ ts_phrase('fox');
----
n
150


# Predicate + INCLUDE'd-column filter: counted in-scan, no lookup.
query
EXPLAIN SELECT count(*) FROM cfm_v_idx WHERE body @@ ts_phrase('fox') AND c > 150;
