│ ╰─────────────────────╯  │
│ Column Filter: c > 150   │
│ Output: row-count only   │
│ ~8 rows                  │
╰──────────────────────────╯


query
SELECT count(*) AS n FROM cfm_v_idx WHERE body @@ ts_phrase('fox') AND c > 150;
----
n
50


# Predicate + a filter statistics prove always true (t spans 1..200): the
# filter is dropped from the scan and the count stays count-only -- the
# dangling filter column must not force the lookup path.
query
EXPLAIN SELECT count(*) FROM cfm_v_idx WHERE body @@ ts_phrase('fox') AND t BETWEEN 1 AND 1000;
