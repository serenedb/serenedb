# --- 2 columns, varchar return ---------------------------------------------

statement ok
CREATE TABLE vc2(id INTEGER PRIMARY KEY, s1 VARCHAR, s2 VARCHAR);

statement ok
CREATE INDEX vc2_idx ON vc2 USING inverted(id, (s1 || s2) verbatim_dict);

statement ok
INSERT INTO vc2 VALUES (1, 'foo', 'bar'), (2, 'hello', 'world'), (3, 'a', 'b');

statement ok
VACUUM (UPDATE_INDEXES) vc2;

query
SELECT id FROM vc2_idx WHERE s1 || s2 = 'foobar';
----
id
1

query
SELECT id FROM vc2_idx WHERE s1 || s2 = 'helloworld';
----
id
2


