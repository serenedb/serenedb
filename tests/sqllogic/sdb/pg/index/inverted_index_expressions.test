# Inverted index over scalar expressions (non-JSON). Covers 1, 2 and 3
# base columns with varchar, boolean and numeric return types.

statement ok
CREATE TEXT SEARCH DICTIONARY verbatim_dict(template = 'keyword');


# --- 1 column, numeric return ----------------------------------------------

statement ok
CREATE TABLE num1(id INTEGER PRIMARY KEY, a INTEGER);

statement ok
CREATE INDEX num1_idx ON num1 USING inverted(id, (a + 1));

statement ok
INSERT INTO num1 VALUES (1, 10), (2, 41), (3, -5);

statement ok
VACUUM (REFRESH_TABLE) num1;

query
SELECT id FROM num1_idx WHERE a + 1 = 42;
----
id
2

query
SELECT id FROM num1_idx WHERE a + 1 > 0 ORDER BY id;
----
id
1
2


# --- 1 column, varchar return ----------------------------------------------

statement ok
CREATE TABLE vc1(id INTEGER PRIMARY KEY, s VARCHAR);

statement ok
CREATE INDEX vc1_idx ON vc1 USING inverted(id, (LOWER(s)));

statement ok
INSERT INTO vc1 VALUES (1, 'HELLO'), (2, 'World'), (3, 'mixed');

statement ok
VACUUM (REFRESH_TABLE) vc1;

query
SELECT id FROM vc1_idx WHERE LOWER(s) = 'hello';
----
id
1

query
SELECT id FROM vc1_idx WHERE LOWER(s) = 'world';
----
id
2

query
SELECT id FROM vc1_idx WHERE LOWER(s) = 'mixed';
----
id
3


# --- 1 column, boolean return ----------------------------------------------

statement ok
CREATE TABLE b1(id INTEGER PRIMARY KEY, x INTEGER);

statement ok
CREATE INDEX b1_idx ON b1 USING inverted(id, (x > 0));

statement ok
INSERT INTO b1 VALUES (1, 5), (2, -3), (3, 0), (4, 7);

statement ok
VACUUM (REFRESH_TABLE) b1;

query
SELECT id FROM b1_idx WHERE (x > 0) = true ORDER BY id;
----
id
1
4

query
SELECT id FROM b1_idx WHERE (x > 0) = false ORDER BY id;
----
id
2
3


