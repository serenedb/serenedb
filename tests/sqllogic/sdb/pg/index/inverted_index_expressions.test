statement ok
CREATE TABLE vc3(id INTEGER PRIMARY KEY, a VARCHAR, b VARCHAR, c VARCHAR);

statement ok
CREATE INDEX vc3_idx ON vc3 USING inverted(id, (CONCAT(a, '-', b, '-', c)) verbatim_dict);

statement ok
INSERT INTO vc3 VALUES (1, 'x', 'y', 'z'), (2, 'foo', 'bar', 'baz');

statement ok
VACUUM (UPDATE_INDEXES) vc3;

query
SELECT id FROM vc3_idx WHERE CONCAT(a, '-', b, '-', c) = 'x-y-z';
----
id
1

query
SELECT id FROM vc3_idx WHERE CONCAT(a, '-', b, '-', c) = 'foo-bar-baz';
----
id
2


