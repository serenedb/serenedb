# --- Same column indexed both directly and as an expression dependent -----

statement ok
CREATE TABLE mix(id INTEGER PRIMARY KEY, a VARCHAR, b VARCHAR);

statement ok
CREATE INDEX mix_idx ON mix USING inverted(
    id, a, b, (a || b));

statement ok
INSERT INTO mix VALUES
    (1, 'foo', 'bar'), (2, 'hello', 'world'), (3, 'foo', 'baz');

statement ok
VACUUM (REFRESH_TABLE) mix;

query
SELECT id FROM mix_idx WHERE a = 'foo' ORDER BY id;
----
id
1
3

query
SELECT id FROM mix_idx WHERE b = 'bar';
----
id
1

query
SELECT id FROM mix_idx WHERE a || b = 'foobar';
----
id
1

query
EXPLAIN SELECT id FROM mix_idx WHERE a || b = 'foobar';
----
QUERY PLAN
┌───────────────────────────┐
│       IRESEARCH_SCAN      │
│    ────────────────────   │
│       Index: mix_idx      │
│       Lookup: table       │
│                           │
│          Filter:          │
│  ┌─────────────────────┐  │
│  │┌───────────────────┐│  │
│  ││        Term       ││  │
│  ││    ────────────   ││  │
│  ││ (a || b)(string) =││  │
│  ││       foobar      ││  │
│  │└───────────────────┘│  │
│  └─────────────────────┘  │
│                           │
│      Projections: id      │
│                           │
│           ~1 row          │
└───────────────────────────┘

query
SELECT id FROM mix_idx WHERE a || b = 'helloworld';
----
id
2

query
SELECT id FROM mix_idx WHERE a = 'foo' AND a || b = 'foobaz';
----
id
3

query
EXPLAIN SELECT id FROM mix_idx WHERE a = 'foo' AND a || b = 'foobaz';
----
QUERY PLAN
┌─────────────────────────────────────────────┐
│                IRESEARCH_SCAN               │
│    ──────────────────────────────────────   │
│                Index: mix_idx               │
│                Lookup: table                │
│                                             │
│                   Filter:                   │
│ ┌──────────────────────────────────────────┐│
│ │┌───────────────────┐                     ││
│ ││        AND        ├──────────┐          ││
│ │└─────────┬─────────┘          │          ││
│ │┌─────────┴─────────┐┌─────────┴─────────┐││
│ ││        Term       ││        Term       │││
│ ││    ────────────   ││    ────────────   │││
│ ││  a(string) = foo  ││ (a || b)(string) =│││
│ ││                   ││       foobaz      │││
│ │└───────────────────┘└───────────────────┘││
│ └──────────────────────────────────────────┘│
│                                             │
│               Projections: id               │
│                                             │
│                    ~1 row                   │
└─────────────────────────────────────────────┘


# --- DML re-indexes the expression -----------------------------------------

statement ok
CREATE TABLE dml(id INTEGER PRIMARY KEY, a INTEGER, b INTEGER);

statement ok
CREATE INDEX dml_idx ON dml USING inverted(id, (a + b));

statement ok
INSERT INTO dml VALUES (1, 10, 20), (2, 1, 1);

statement ok
VACUUM (REFRESH_TABLE) dml;

statement ok
UPDATE dml SET a = 100 WHERE id = 1;

statement ok
VACUUM (REFRESH_TABLE) dml;

query
SELECT id FROM dml_idx WHERE a + b = 30;
----
id

query
SELECT id FROM dml_idx WHERE a + b = 120;
----
id
1

statement ok
DELETE FROM dml WHERE id = 2;

statement ok
VACUUM (REFRESH_TABLE) dml;

query
SELECT id FROM dml_idx ORDER BY id;
----
id
1


# --- NULL handling: NULL inputs produce a NULL expression value ------------

statement ok
CREATE TABLE n1(id INTEGER PRIMARY KEY, a INTEGER, b INTEGER);

statement ok
CREATE INDEX n1_idx ON n1 USING inverted(id, (a + b));

statement ok
INSERT INTO n1 VALUES (1, 1, 2), (2, NULL, 5), (3, 7, NULL);

statement ok
VACUUM (REFRESH_TABLE) n1;

query
SELECT id FROM n1_idx WHERE a + b IS NULL ORDER BY id;
----
id
2
3

query
SELECT id FROM n1_idx WHERE a + b = 3;
----
id
1


# --- Other expression shapes ----------------------------------------------

# Column referenced multiple times in the same expression.
statement ok
CREATE TABLE poly(id INTEGER PRIMARY KEY, a INTEGER);

statement ok
CREATE INDEX poly_idx ON poly USING inverted(id, (a * a + a));

statement ok
INSERT INTO poly VALUES (1, 3), (2, 0), (3, 5);

statement ok
VACUUM (REFRESH_TABLE) poly;

query
SELECT id FROM poly_idx WHERE a * a + a = 12;
----
id
1

query
SELECT id FROM poly_idx WHERE a * a + a = 0;
----
id
2

query
SELECT id FROM poly_idx WHERE a * a + a = 30;
----
id
3


# CASE expression producing varchar.
statement ok
CREATE TABLE sgn(id INTEGER PRIMARY KEY, a INTEGER);

statement ok
CREATE INDEX sgn_idx ON sgn USING inverted(
    id,
    (CASE WHEN a > 0 THEN 'pos' WHEN a < 0 THEN 'neg' ELSE 'zero' END));

statement ok
INSERT INTO sgn VALUES (1, 5), (2, -3), (3, 0), (4, 7);

statement ok
VACUUM (REFRESH_TABLE) sgn;

query
SELECT id FROM sgn_idx
WHERE CASE WHEN a > 0 THEN 'pos' WHEN a < 0 THEN 'neg' ELSE 'zero' END = 'pos'
ORDER BY id;
----
id
1
4

query
SELECT id FROM sgn_idx
WHERE CASE WHEN a > 0 THEN 'pos' WHEN a < 0 THEN 'neg' ELSE 'zero' END = 'neg';
----
id
2

query
SELECT id FROM sgn_idx
WHERE CASE WHEN a > 0 THEN 'pos' WHEN a < 0 THEN 'neg' ELSE 'zero' END = 'zero';
----
id
3


# --- More DML scenarios ---------------------------------------------------

# Multi-row UPDATE that re-indexes every row.
statement ok
CREATE TABLE mu1(id INTEGER PRIMARY KEY, a INTEGER, b INTEGER);

statement ok
CREATE INDEX mu1_idx ON mu1 USING inverted(id, (a + b));

statement ok
INSERT INTO mu1 VALUES (1, 10, 20), (2, 5, 25);

statement ok
VACUUM (REFRESH_TABLE) mu1;

statement ok
UPDATE mu1 SET b = 100;

statement ok
VACUUM (REFRESH_TABLE) mu1;

query
SELECT id FROM mu1_idx WHERE a + b = 110;
----
id
1

query
SELECT id FROM mu1_idx WHERE a + b = 105;
----
id
2


# UPDATE that does NOT touch any indexed column or dep column must leave the
# index untouched -- a row remains queryable by its (old) expression value.
statement ok
CREATE TABLE mu2(id INTEGER PRIMARY KEY, a INTEGER, b INTEGER, extra VARCHAR);

statement ok
CREATE INDEX mu2_idx ON mu2 USING inverted(id, (a + b));

statement ok
INSERT INTO mu2 VALUES (1, 10, 20, 'x'), (2, 5, 5, 'y');

statement ok
VACUUM (REFRESH_TABLE) mu2;

statement ok
UPDATE mu2 SET extra = 'z' WHERE id = 1;

statement ok
VACUUM (REFRESH_TABLE) mu2;

query
SELECT id FROM mu2_idx WHERE a + b = 30;
----
id
1

query
SELECT id FROM mu2_idx WHERE a + b = 10;
----
id
2


# UPDATE of a column that is BOTH directly indexed AND a dep of an expression
# must re-index both the direct field and the expression value for that row.
statement ok
CREATE TABLE mu3(id INTEGER PRIMARY KEY, a VARCHAR, b VARCHAR);

statement ok
CREATE INDEX mu3_idx ON mu3
USING inverted(id, a, b, (a || b));

statement ok
INSERT INTO mu3 VALUES (1, 'foo', 'bar'), (2, 'hello', 'world');

statement ok
VACUUM (REFRESH_TABLE) mu3;

statement ok
UPDATE mu3 SET a = 'baz' WHERE id = 1;

statement ok
VACUUM (REFRESH_TABLE) mu3;

query
SELECT id FROM mu3_idx WHERE a = 'foo';
----
id

query
SELECT id FROM mu3_idx WHERE a = 'baz';
----
id
1

query
SELECT id FROM mu3_idx WHERE a || b = 'foobar';
----
id

query
SELECT id FROM mu3_idx WHERE a || b = 'bazbar';
----
id
1


# Multi-row DELETE.
statement ok
CREATE TABLE md(id INTEGER PRIMARY KEY, a INTEGER);

statement ok
CREATE INDEX md_idx ON md USING inverted(id, (a + 1));

statement ok
INSERT INTO md VALUES (1, 10), (2, 41), (3, -5), (4, 100);

statement ok
VACUUM (REFRESH_TABLE) md;

statement ok
DELETE FROM md WHERE a > 10;

statement ok
VACUUM (REFRESH_TABLE) md;

query
SELECT id FROM md_idx ORDER BY id;
----
id
1
3

query
SELECT id FROM md_idx WHERE a + 1 = 42;
----
id

query
SELECT id FROM md_idx WHERE a + 1 = 11;
----
id
1


# DELETE of every row leaves the index empty.
statement ok
CREATE TABLE md2(id INTEGER PRIMARY KEY, a VARCHAR, b VARCHAR);

statement ok
CREATE INDEX md2_idx ON md2 USING inverted(
    id, a, (a || b));

statement ok
INSERT INTO md2 VALUES (1, 'foo', 'bar'), (2, 'baz', 'qux');

statement ok
VACUUM (REFRESH_TABLE) md2;

statement ok
DELETE FROM md2;

statement ok
VACUUM (REFRESH_TABLE) md2;

query
SELECT id FROM md2_idx;
----
id

query
SELECT id FROM md2_idx WHERE a = 'foo';
----
id

query
SELECT id FROM md2_idx WHERE a || b = 'foobar';
----
id


# --- CREATE INDEX rejects invalid expressions ------------------------------

statement ok
CREATE TABLE bad(id INTEGER PRIMARY KEY, a INTEGER, b INTEGER);

# Expression references a column that does not exist on the table.
statement error
CREATE INDEX bad_missing ON bad USING inverted(id, (nonexistent + 1));
----
db error: ERROR: Referenced column "nonexistent" not found in FROM clause!
Candidate bindings: "a"


# Expression has no base-table column references at all (constant fold).
statement error
CREATE INDEX bad_const ON bad USING inverted(id, (1 + 1));
----
db error: ERROR: indexed expression must reference at least one base table column


# Expression contains a subquery.
statement error
CREATE INDEX bad_subq ON bad USING inverted(id, ((SELECT 1)));
----
db error: ERROR: cannot use subquery in index expressions


# Expression contains an aggregate.
statement error
CREATE INDEX bad_agg ON bad USING inverted(id, (sum(a)));
----
db error: ERROR: aggregate functions are not allowed in index expressions


# Expression contains a volatile (side-effect) function.
statement error
CREATE INDEX bad_volatile ON bad USING inverted(id, (random()));
----
db error: ERROR: Index keys cannot contain expressions with side effects.


# --- Unsupported return types are rejected gracefully --------------------

statement ok
CREATE TABLE bad_types(id INTEGER PRIMARY KEY, a INTEGER, s VARCHAR, k VARCHAR, v VARCHAR);

statement error
CREATE INDEX bad_struct ON bad_types USING inverted(id, ({'x': a, 'y': s}));
----
db error: ERROR: Failed to create index: Column 'main.struct_pack(x := a, y := s)' has unsupported type STRUCT(x INTEGER, y VARCHAR) and can not be indexed


statement error
CREATE INDEX bad_map ON bad_types USING inverted(id, (map([k], [v])));
----
db error: ERROR: Failed to create index: Column '"map"(main.list_value(k), main.list_value(v))' has unsupported type MAP(VARCHAR, VARCHAR) and can not be indexed


statement error
CREATE INDEX bad_list_struct ON bad_types USING inverted(id, ([{'x': a}]));
----
db error: ERROR: Failed to create index: Column 'main.list_value(main.struct_pack(x := a))' has unsupported type STRUCT(x INTEGER)[] and can not be indexed


statement error
CREATE INDEX bad_list_map ON bad_types USING inverted(id, ([map([k], [v])]));
----
db error: ERROR: Failed to create index: Column 'main.list_value("map"(main.list_value(k), main.list_value(v)))' has unsupported type MAP(VARCHAR, VARCHAR)[] and can not be indexed


statement ok
CREATE TABLE bad_scalars(
    id INTEGER PRIMARY KEY,
    a INTEGER,
    dc DECIMAL(10, 2),
    hi HUGEINT,
    iv INTERVAL,
    tm TIME,
    uu UUID,
    ts TIMESTAMP);


statement error
CREATE INDEX bad_decimal ON bad_scalars USING inverted(id, (dc + 1));
----
db error: ERROR: Failed to create index: Column '(dc + 1)' has unsupported type DECIMAL(13,2) and can not be indexed


statement error
CREATE INDEX bad_hugeint ON bad_scalars USING inverted(id, (hi + 1));
----
db error: ERROR: Failed to create index: Column '(hi + 1)' has unsupported type HUGEINT and can not be indexed


statement error
CREATE INDEX bad_interval ON bad_scalars USING inverted(id, (iv));
----
db error: ERROR: Failed to create index: Column 'iv' has unsupported type INTERVAL and can not be indexed


statement error
CREATE INDEX bad_uuid ON bad_scalars USING inverted(id, (uu));
----
db error: ERROR: Failed to create index: Column 'uu' has unsupported type UUID and can not be indexed


statement error
CREATE INDEX bad_union ON bad_scalars
USING inverted(id, (union_value(num := a)));
----
db error: ERROR: Failed to create index: Column 'union_value(num := a)' has unsupported type UNION(num INTEGER) and can not be indexed


statement error
CREATE INDEX bad_list_list ON bad_scalars USING inverted(id, ([[a]]));
----
db error: ERROR: Failed to create index: Column 'main.list_value(main.list_value(a))' has unsupported type INTEGER[][] and can not be indexed


# --- @@ on indexed expressions (forces filter pushdown) -------------------

# Varchar expression: ts_like / ts_phrase / ts_any / TERM_EQ via `=`.
statement ok
CREATE TABLE tx_v(id INTEGER PRIMARY KEY, s1 VARCHAR, s2 VARCHAR);

statement ok
CREATE INDEX tx_v_idx ON tx_v USING inverted(id, (s1 || s2));

statement ok
INSERT INTO tx_v VALUES
    (1, 'foo', 'bar'),
    (2, 'hello', 'world'),
    (3, 'foo', 'baz');

statement ok
VACUUM (REFRESH_TABLE) tx_v;

# TERM_EQ
query
SELECT id FROM tx_v_idx WHERE (s1 || s2) @@ 'foobar'::tsquery;
----
id
1

# ts_like with wildcard
query
SELECT id FROM tx_v_idx WHERE (s1 || s2) @@ ts_like('foo%') ORDER BY id;
----
id
1
3

# ts_any
query
SELECT id FROM tx_v_idx WHERE (s1 || s2) @@ ts_any(['foobar', 'helloworld']) ORDER BY id;
----
id
1
2


# Same expression with `=` (TERM_EQ) — also pushes down.
query
SELECT id FROM tx_v_idx WHERE s1 || s2 = 'helloworld';
----
id
2


# Numeric expression: TERM_EQ and range.
statement ok
CREATE TABLE tx_n(id INTEGER PRIMARY KEY, a INTEGER, b INTEGER);

statement ok
CREATE INDEX tx_n_idx ON tx_n USING inverted(id, (a + b));

statement ok
INSERT INTO tx_n VALUES (1, 10, 20), (2, 5, 5), (3, 7, 13), (4, 50, 50);

statement ok
VACUUM (REFRESH_TABLE) tx_n;

# TERM_EQ
query
SELECT id FROM tx_n_idx WHERE a + b = 30;
----
id
1

# Range >
query
SELECT id FROM tx_n_idx WHERE a + b > 15 ORDER BY id;
----
id
1
3
4

# Range >= ... AND <=
query
SELECT id FROM tx_n_idx WHERE a + b >= 10 AND a + b <= 30 ORDER BY id;
----
id
1
2
3


# Boolean expression: TERM_EQ on true/false.
statement ok
CREATE TABLE tx_b(id INTEGER PRIMARY KEY, a INTEGER, b INTEGER);

statement ok
CREATE INDEX tx_b_idx ON tx_b USING inverted(id, (a > b));

statement ok
INSERT INTO tx_b VALUES (1, 10, 5), (2, 3, 7), (3, 4, 4);

statement ok
VACUUM (REFRESH_TABLE) tx_b;

query
SELECT id FROM tx_b_idx WHERE (a > b) = true;
----
id
1

query
SELECT id FROM tx_b_idx WHERE (a > b) = false ORDER BY id;
----
id
2
3


# Mixed: direct column `a` and expression `(a||b)` both indexed. `@@` can
# target either side and pushes down independently.
statement ok
CREATE TABLE tx_mix(id INTEGER PRIMARY KEY, a VARCHAR, b VARCHAR);

statement ok
CREATE INDEX tx_mix_idx ON tx_mix USING inverted(
    id, a, b, (a || b));

statement ok
INSERT INTO tx_mix VALUES
    (1, 'foo', 'bar'),
    (2, 'hello', 'world'),
    (3, 'foo', 'baz');

statement ok
VACUUM (REFRESH_TABLE) tx_mix;

# Direct-column @@.
query
SELECT id FROM tx_mix_idx WHERE a @@ ts_like('foo') ORDER BY id;
----
id
1
3

# Expression @@ — different rows.
query
SELECT id FROM tx_mix_idx WHERE (a || b) @@ ts_like('foob%') ORDER BY id;
----
id
1
3

# Conjunction of direct and expression pushdowns.
query
SELECT id FROM tx_mix_idx
WHERE a @@ ts_like('foo') AND (a || b) @@ ts_like('foobaz');
----
id
3


# EXPLAIN binds successfully for an expression-index pushdown.
query
EXPLAIN SELECT id FROM tx_n_idx WHERE a + b = 30;
----
QUERY PLAN
┌───────────────────────────┐
│       IRESEARCH_SCAN      │
│    ────────────────────   │
│      Index: tx_n_idx      │
│       Lookup: table       │
│                           │
│          Filter:          │
│  ┌─────────────────────┐  │
│  │┌───────────────────┐│  │
│  ││        Term       ││  │
│  ││    ────────────   ││  │
│  ││ (a + b)(numeric) =││  │
│  ││  \\x0\\x80\\x0\\x0\\x1e││  │
│  │└───────────────────┘│  │
│  └─────────────────────┘  │
│                           │
│      Projections: id      │
│                           │
│           ~1 row          │
└───────────────────────────┘

query
EXPLAIN SELECT id FROM tx_v_idx WHERE (s1 || s2) @@ 'foobar'::tsquery;
----
