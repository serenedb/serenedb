----
QUERY PLAN
┌───────────────────────────┐
│       IRESEARCH_SCAN      │
│    ────────────────────   │
│      Index: tx_b_idx      │
│       Lookup: table       │
│                           │
│          Filter:          │
│  ┌─────────────────────┐  │
│  │┌───────────────────┐│  │
│  ││        Term       ││  │
│  ││    ────────────   ││  │
│  ││  (a > b)(bool) =  ││  │
│  ││        \\xff       ││  │
│  │└───────────────────┘│  │
│  └─────────────────────┘  │
│                           │
│      Projections: id      │
│                           │
│           ~1 row          │
└───────────────────────────┘


# Strange cases: outer CAST inside the indexed expression. `(a + b)::json`
# pins the return type to JSON, so the index goes through the JSON multi-
# field aux dispatch and downstream cast-to-int filters still match.

statement ok
CREATE TABLE strange_json(id INTEGER PRIMARY KEY, a INTEGER, b INTEGER);

statement ok
CREATE INDEX strange_json_idx ON strange_json
USING inverted(id, ((a + b)::json));

statement ok
INSERT INTO strange_json VALUES (1, 10, 20), (2, 5, 5), (3, 7, 8);

statement ok
VACUUM (REFRESH_TABLE) strange_json;

query
SELECT id FROM strange_json_idx WHERE ((a + b)::json) = '30'::json;
----
id
1

query
SELECT id FROM strange_json_idx WHERE ((a + b)::json) = '10'::json;
----
id
2


# --- Smoke: one indexed expression per supported return type. INTEGER,
# VARCHAR and BOOLEAN are exercised above; this section covers the
# remaining types in the ValidateInvertedIndexColumns allow-list:
# TINYINT, SMALLINT, BIGINT, FLOAT, DOUBLE, DATE, TIMESTAMP_TZ.

statement ok
CREATE TABLE types_smoke(id INTEGER PRIMARY KEY, a INTEGER);

statement ok
CREATE INDEX types_smoke_idx ON types_smoke USING inverted(
    id,
    ((a + 1)::TINYINT),
    ((a + 1)::SMALLINT),
    ((a + 1)::BIGINT),
    ((a + 1)::FLOAT),
    ((a + 1)::DOUBLE),
    (DATE '2020-01-01' + (a + 1)),
    (to_timestamp(a + 1)));

statement ok
INSERT INTO types_smoke VALUES (1, 1), (2, 2);

statement ok
VACUUM (REFRESH_TABLE) types_smoke;

query
SELECT id FROM types_smoke_idx WHERE (a + 1)::TINYINT = 2::TINYINT;
----
id
1

query
SELECT id FROM types_smoke_idx WHERE (a + 1)::SMALLINT = 3::SMALLINT;
----
id
2

query
SELECT id FROM types_smoke_idx WHERE (a + 1)::BIGINT = 2::BIGINT;
----
id
1

query
SELECT id FROM types_smoke_idx WHERE (a + 1)::FLOAT = 3::FLOAT;
----
id
2

query
SELECT id FROM types_smoke_idx WHERE (a + 1)::DOUBLE = 2::DOUBLE;
----
id
1

query
SELECT id FROM types_smoke_idx WHERE DATE '2020-01-01' + (a + 1) = DATE '2020-01-04';
----
id
2

query
SELECT id FROM types_smoke_idx WHERE to_timestamp(a + 1) = to_timestamp(2);
----
id
1


# --- SQLNULL-typed indexed expression: every row's value is NULL by
# construction. The writer must short-circuit to the null field instead
# of asserting on a missing payload.

statement ok
CREATE TABLE null_expr(id INT PRIMARY KEY, a INT);

statement ok
CREATE INDEX null_expr_idx ON null_expr USING inverted(
    id, (CASE WHEN a > 0 THEN NULL ELSE NULL END));

statement ok
INSERT INTO null_expr VALUES (1, 1), (2, -1);

statement ok
VACUUM (REFRESH_TABLE) null_expr;

query
SELECT id FROM null_expr_idx ORDER BY id;
----
id
1
2

query
SELECT id FROM null_expr_idx
WHERE (CASE WHEN a > 0 THEN NULL ELSE NULL END) IS NULL ORDER BY id;
----
id
1
2


# --- SQLNULL-typed indexed column: column's declared type is NULL, so
# every value is structurally NULL. Same writer short-circuit.

statement ok
CREATE TABLE null_col(id INT PRIMARY KEY, a "NULL");

statement ok
CREATE INDEX null_col_idx ON null_col USING inverted(id, a);

statement ok
INSERT INTO null_col VALUES (1, NULL), (2, NULL);

statement ok
VACUUM (REFRESH_TABLE) null_col;

query
SELECT id FROM null_col_idx ORDER BY id;
----
id
1
2

query
SELECT id FROM null_col_idx WHERE a IS NULL ORDER BY id;
----
id
1
2


# --- INCLUDE-style storage on an indexed expression: `(expr) included` persists the evaluated value in the columnstore.

statement ok
CREATE TABLE inc_e_num(id INT PRIMARY KEY, a INT, b INT);

statement ok
CREATE INDEX inc_e_num_idx ON inc_e_num USING inverted(id, (a + b) included ());

statement ok
INSERT INTO inc_e_num VALUES (1, 10, 20), (2, 5, 5), (3, 100, 1);

statement ok
VACUUM (REFRESH_TABLE) inc_e_num;

query
SELECT id, a + b AS s FROM inc_e_num_idx WHERE id = 1;
----
id	s
1	30

query
SELECT id, a + b AS s FROM inc_e_num_idx ORDER BY id;
----
id	s
1	30
2	10
3	101


statement ok
UPDATE inc_e_num SET a = 50 WHERE id = 1;

statement ok
VACUUM (REFRESH_TABLE) inc_e_num;

query
SELECT id, a + b AS s FROM inc_e_num_idx ORDER BY id;
----
id	s
1	70
2	10
3	101


statement ok
CREATE TABLE inc_e_str(id INT PRIMARY KEY, a VARCHAR, b VARCHAR);

statement ok
CREATE INDEX inc_e_str_idx ON inc_e_str USING inverted(
    id, (LOWER(a) || '-' || LOWER(b)) included ());

statement ok
INSERT INTO inc_e_str VALUES (1, 'FOO', 'Bar'), (2, 'X', 'Y');

statement ok
VACUUM (REFRESH_TABLE) inc_e_str;

query
SELECT id, LOWER(a) || '-' || LOWER(b) AS s FROM inc_e_str_idx ORDER BY id;
----
id	s
1	foo-bar
2	x-y


statement ok
CREATE TABLE inc_e_zstd(id INT PRIMARY KEY, a VARCHAR, b VARCHAR);

statement ok
CREATE INDEX inc_e_zstd_idx ON inc_e_zstd USING inverted(
    id, (a || b) included (compression='zstd'));

statement ok
INSERT INTO inc_e_zstd VALUES (1, 'foo', 'bar'), (2, 'baz', 'qux');

statement ok
VACUUM (REFRESH_TABLE) inc_e_zstd;

query
SELECT id, a || b AS s FROM inc_e_zstd_idx ORDER BY id;
----
id	s
1	foobar
2	bazqux

statement error
CREATE INDEX inc_e_zstd_bad ON inc_e_num USING inverted(
    id, (a + b) included (compression='zstd'));
----
db error: ERROR: Failed to create index: Column '(a + b)': compression 'ZSTD' is not supported for type INTEGER


statement ok
CREATE TABLE inc_e_rgs(id INT PRIMARY KEY, a INT);

statement ok
CREATE INDEX inc_e_rgs_idx ON inc_e_rgs USING inverted(
    id, (a * 2) included (compression='bitpacking', row_group_size='8'));

statement ok
INSERT INTO inc_e_rgs VALUES (1, 1), (2, 5), (3, 12);

statement ok
VACUUM (REFRESH_TABLE) inc_e_rgs;

query
SELECT id, a * 2 AS s FROM inc_e_rgs_idx ORDER BY id;
----
id	s
1	2
2	10
3	24


statement error
CREATE INDEX inc_e_bad ON inc_e_num USING inverted(
    id, (a + b) included (bogus='value'));
----
db error: ERROR: Failed to create index: Column '(a + b)': unknown included option 'bogus'. Accepted options: compression (string, default 'auto'), row_group_size (int >= 1), hyperloglog (bool, default false)


statement error
CREATE INDEX inc_e_dict_with_opts ON inc_e_num USING inverted(
    id, (a + b) verbatim_dict (compression='zstd'));
----
db error: ERROR: Failed to create index: Unknown built-in opclass 'verbatim_dict' on '(a + b)' (known: included, hnsw)


# --- HNSW on an indexed expression: `(expr) hnsw(metric='l2', m=..., ef_construction=...)` builds an ANN graph over the expression's value.

statement ok
CREATE TABLE hnsw_e(id INT PRIMARY KEY, x FLOAT, y FLOAT, z FLOAT);

statement ok
CREATE INDEX hnsw_e_idx ON hnsw_e USING inverted(
    id,
    (array_value(x, y, z)) hnsw(metric='l2', m=8, ef_construction=16));

statement ok
INSERT INTO hnsw_e VALUES
    (1, 1, 2, 3),
    (2, 10, 10, 10),
    (3, 5, 5, 5),
    (4, 0, 0, 0);

statement ok
VACUUM (REFRESH_TABLE) hnsw_e;

query
SELECT id FROM hnsw_e_idx ORDER BY array_value(x, y, z) <-> [1,2,3]::FLOAT[3] LIMIT 2;
----
id
1
4

query
EXPLAIN SELECT id FROM hnsw_e_idx ORDER BY array_value(x, y, z) <-> [1,2,3]::FLOAT[3] LIMIT 2;
----
QUERY PLAN
┌───────────────────────────┐
│           TOP_N           │
│    ────────────────────   │
│           Top: 2          │
│      Order By: #1 ASC     │
│                           │
│          ~2 rows          │
└─────────────┬─────────────┘
┌─────────────┴─────────────┐
│       IRESEARCH_SCAN      │
│    ────────────────────   │
│           Index:          │
│      hnsw_e_idx (ANN)     │
│                           │
│       Lookup: table       │
│           Top: 2          │
│          Dims: 3          │
│                           │
│        Projections:       │
│             id            │
│  sdb_inverted_index_score │
│                           │
│          ~4 rows          │
└───────────────────────────┘


# Wrong dimensionality of the query vector should disqualify the ANN scan
# (validator inside TryAnnTopk). The query still returns correct results.

statement ok
CREATE TABLE hnsw_e2(id INT PRIMARY KEY, x FLOAT, y FLOAT, z FLOAT);

statement ok
CREATE INDEX hnsw_e2_idx ON hnsw_e2 USING inverted(
    id, (array_value(x, y, z)) hnsw(metric='l2', m=8, ef_construction=16));

statement ok
INSERT INTO hnsw_e2 VALUES (1, 1, 0, 0), (2, 0, 1, 0), (3, 0, 0, 1);

statement ok
VACUUM (REFRESH_TABLE) hnsw_e2;

# `hnsw` requires options.

statement error
CREATE INDEX hnsw_e_no_opts ON hnsw_e USING inverted(
    id, (array_value(x, y, z)) hnsw);
----
db error: ERROR: Unknown opclass 'hnsw' on column 'array_value(x, y, z)': no text dictionary by that name in schema 'public'
HINT: 'hnsw' is a built-in opclass; use the options form 'hnsw (...)'


# ARRAY of non-FLOAT child type is rejected.

statement ok
CREATE TABLE hnsw_e3(id INT PRIMARY KEY, a INT, b INT, c INT);

statement error
CREATE INDEX hnsw_e3_idx ON hnsw_e3 USING inverted(
    id, (array_value(a, b, c)) hnsw(metric='l2', m=8, ef_construction=16));
----
db error: ERROR: Failed to create index: Column 'array_value(a, b, c)' must be ARRAY(FLOAT, N) to use the 'hnsw' opclass, not INTEGER[3]


# Non-ARRAY return type rejected when hnsw is requested.

statement error
CREATE INDEX hnsw_e_scalar ON hnsw_e USING inverted(
    id, (x + y + z) hnsw(metric='l2', m=8, ef_construction=16));
----
db error: ERROR: Failed to create index: Column '((x + y) + z)' must be ARRAY(FLOAT, N) to use the 'hnsw' opclass, not FLOAT


# --- INCLUDE columns alongside an indexed expression ---------------------
# The inverted index pushes the (a+b)=N filter through the expression
# field, then the INCLUDE-only `payload` column is retrieved from the
# index for projection. INCLUDE columns must not affect the expression
# write path or the filter dispatch.

statement ok
CREATE TABLE inc_expr(id INT PRIMARY KEY, a INT, b INT, payload VARCHAR);

statement ok
INSERT INTO inc_expr VALUES (1, 10, 20, 'r1'), (2, 5, 5, 'r2'), (3, 100, 1, 'r3');

statement ok
CREATE INDEX inc_expr_idx ON inc_expr
  USING inverted(id, (a + b))
  INCLUDE (payload);

statement ok
VACUUM (REFRESH_TABLE) inc_expr;

query
SELECT id, payload FROM inc_expr_idx WHERE a + b = 30 ORDER BY id;
----
id	payload
1	r1

query
SELECT id, payload FROM inc_expr_idx WHERE a + b = 10 ORDER BY id;
----
id	payload
2	r2

query
SELECT id, payload FROM inc_expr_idx WHERE a + b = 101 ORDER BY id;
----
id	payload
3	r3


# INCLUDE column with an explicit `included` opclass + compression option.
statement ok
CREATE TABLE inc_expr2(id INT PRIMARY KEY, a INT, b INT, big BIGINT);

statement ok
INSERT INTO inc_expr2 VALUES (1, 1, 2, 1000), (2, 2, 2, 2000), (3, 5, 5, 3000);

statement ok
CREATE INDEX inc_expr2_idx ON inc_expr2
  USING inverted(id, (a + b))
  INCLUDE (big included (compression = 'uncompressed'));

statement ok
VACUUM (REFRESH_TABLE) inc_expr2;

query
SELECT id, big FROM inc_expr2_idx WHERE a + b = 4 ORDER BY id;
----
id	big
2	2000

query
SELECT id, big FROM inc_expr2_idx WHERE a + b = 10 ORDER BY id;
----
id	big
3	3000


# Multi-column expression + INCLUDE on a wider table.
statement ok
CREATE TABLE inc_expr3(id INT PRIMARY KEY, s1 VARCHAR, s2 VARCHAR, label VARCHAR);

statement ok
INSERT INTO inc_expr3 VALUES (1, 'foo', 'bar', 'L1'), (2, 'baz', 'qux', 'L2'), (3, 'foo', 'qux', 'L3');

statement ok
CREATE INDEX inc_expr3_idx ON inc_expr3
  USING inverted(id, (s1 || s2))
  INCLUDE (label);

statement ok
VACUUM (REFRESH_TABLE) inc_expr3;

query
SELECT id, label FROM inc_expr3_idx WHERE s1 || s2 = 'fooqux' ORDER BY id;
----
id	label
3	L3


# --- User-defined functions in indexed expressions -----------------------
# SereneDB accepts user-defined scalar macros / functions in indexed
# expressions. They inline at bind time, so the persisted indexed expression
# is the inlined built-in form.

statement ok
CREATE TABLE vedernikoff_t(id INT PRIMARY KEY, a INT, b INT);

statement count 2
INSERT INTO vedernikoff_t VALUES (1, 10, 20), (2, 5, 5);

statement ok
CREATE MACRO clickclack(x) AS x + 1;

statement ok
CREATE INDEX vedernikoff_macro_idx ON vedernikoff_t USING inverted(id, (clickclack(a)));


statement ok
CREATE FUNCTION babsky(x) AS x + 2;

statement ok
CREATE INDEX vedernikoff_fn_idx ON vedernikoff_t USING inverted(id, (babsky(b)));


# Macro buried inside a built-in call.
statement ok
CREATE INDEX vedernikoff_nested_idx ON vedernikoff_t USING inverted(id, (clickclack(a) + b));


statement ok
VACUUM (REFRESH_TABLE) vedernikoff_t;


# clickclack(10) = 11, clickclack(5) = 6 -- query through the macro.
query
SELECT id FROM vedernikoff_macro_idx WHERE clickclack(a) = 11 ORDER BY id;
----
id
1


# Same index reached via the inlined form.
query
SELECT id FROM vedernikoff_macro_idx WHERE a + 1 = 11 ORDER BY id;
----
id
1


# Built-in operators in the same place are still accepted.
statement ok
CREATE TABLE kostya_ok(id INT PRIMARY KEY, a INT, b INT);

statement ok
CREATE INDEX kostya_ok_idx ON kostya_ok USING inverted(id, (a + b));


# --- Geo-analyzer validation runs for indexed expressions ----------------
# The geojson / geopoint analyzers require a JSON or GEOMETRY value type.
# A geo dict on an expression whose return type is anything else is rejected
# with the same error that a non-JSON/non-GEOMETRY column would produce.

statement ok
CREATE TEXT SEARCH DICTIONARY geo_expr_dict(template = 'geojson');

statement ok
CREATE TABLE geo_expr_bad(id INT PRIMARY KEY, s VARCHAR);

statement error
CREATE INDEX geo_expr_bad_idx ON geo_expr_bad USING inverted(
    id, (LOWER(s)) geo_expr_dict);
----
db error: ERROR: Failed to create index: Column 'lower(s)' uses a geo analyzer; must be JSON (GeoJSON) or GEOMETRY


# Positive case: a JSON-typed expression is accepted.
statement ok
CREATE TABLE geo_expr_ok(id INT PRIMARY KEY, raw VARCHAR);

statement ok
CREATE INDEX geo_expr_ok_idx ON geo_expr_ok USING inverted(
    id, (raw::JSON) geo_expr_dict);
