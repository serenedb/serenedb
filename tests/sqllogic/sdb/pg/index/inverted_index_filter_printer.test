# Or-intersection anchoring: every branch of the positive disjunction
# requires a posting from `a`, so the negation needs no a(null) marker
# exclude -- NOT (a = 7) claims as a bare term exclusion.
query
EXPLAIN SELECT id FROM bigfilter_idx
WHERE (a < 10 OR a > 20)
  AND NOT (a = 7)
  AND t @@ ts_phrase('beta');
----
