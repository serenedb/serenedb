query
EXPLAIN SELECT id FROM bigfilter_idx
WHERE (a > 0 AND a < 100)
  AND ((b = 1 OR c = 2) OR (t @@ ts_phrase('gamma') AND a = 5))
  AND c IN (3, 6, 9, 12)
  AND NOT b = 99;
