statement ok
CREATE TABLE bigfilter (id INTEGER PRIMARY KEY, a INTEGER, b INTEGER, c INTEGER, t VARCHAR);

statement ok
CREATE TEXT SEARCH DICTIONARY bigfilter_text(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true
);

statement ok
CREATE INDEX bigfilter_idx ON bigfilter USING inverted(id, a, b, c, t bigfilter_text);

statement ok
INSERT INTO bigfilter VALUES
  (1, 1, 2, 3, 'alpha beta gamma'),
  (2, 4, 5, 6, 'beta gamma delta'),
  (3, 7, 8, 9, 'gamma delta epsilon'),
  (4, 10, 11, 12, 'delta epsilon alpha'),
  (5, 13, 14, 15, 'epsilon alpha beta');

statement ok
VACUUM (REFRESH_TABLE) bigfilter;


query
EXPLAIN SELECT id FROM bigfilter_idx
WHERE (a = 1 OR b = 2 OR c = 3)
  AND (a = 4 OR b = 5)
  AND (a = 7 OR c = 8 OR b = 9 OR a = 10)
  AND t @@ ts_phrase('alpha');
