EXPLAIN SELECT id FROM bigfilter_idx
WHERE a = 1
  AND b = 2
  AND c = 3
  AND a < 50
  AND b > 0
  AND t @@ ts_phrase('delta')
  AND (a = 4 OR b = 5 OR c = 6)
  AND NOT (a = 7 OR b = 8);
