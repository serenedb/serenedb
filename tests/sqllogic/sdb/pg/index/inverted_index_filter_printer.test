query I
SELECT id FROM bigfilter_idx
WHERE (a < 10 OR a > 20)
  AND NOT (a = 7)
  AND t @@ ts_phrase('beta')
ORDER BY id;
----
id
1
2


# Contradictory same-field bounds merge to Empty (the pre-fix merge
# produced an inverted Granular Range that mis-matched rows). The
# contradiction only appears after De Morgan, so DuckDB cannot fold it.
query I
SELECT id FROM bigfilter_idx WHERE NOT (a <= 7 OR a > 2) ORDER BY id
----
id


