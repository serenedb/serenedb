query
EXPLAIN SELECT id FROM bigfilter_idx
WHERE (a = 1 OR b = 2 OR c = 3 OR a = 4 OR b = 5)
  AND NOT (c = 6 OR a = 7 OR b = 8)
  AND t @@ ts_phrase('beta');
