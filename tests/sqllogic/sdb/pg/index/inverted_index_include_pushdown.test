id
1
2


# --- Each inverted+INCLUDE column individually serves its own filter ---

query I
SELECT id FROM logs_idx
WHERE service = 'frontend'
ORDER BY id;
----
id
1
3
4


query I
SELECT id FROM logs_idx
WHERE sev >= 13
ORDER BY id;
----
id
1
2
4


# Cleanup
statement ok
DROP INDEX logs_idx

statement ok
DROP TABLE logs

statement ok
DROP TEXT SEARCH DICTIONARY en_inc
