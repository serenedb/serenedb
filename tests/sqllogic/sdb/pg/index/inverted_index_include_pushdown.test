hash-threshold 100

# A column listed in BOTH the inverted clause AND INCLUDE keeps its
# posting list (for filter pushdown) AND its columnstore copy (for fast
# projection). Filters on it should push into the IRESEARCH_SCAN filter
# instead of sitting in a residual FILTER node above the scan.
#
# An INCLUDE-only column (not in the inverted clause) carries only the
# columnstore copy; the optimizer must NOT push filters on it.

statement ok
CREATE TEXT SEARCH DICTIONARY en_inc(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'lower',
    stemming = false,
    accent = false,
    frequency = true,
    position = true
)


statement ok
CREATE TABLE logs (
    id INT PRIMARY KEY,
    body VARCHAR,
    service VARCHAR,
    sev INT,
    tag VARCHAR
)


statement count 1
INSERT INTO logs VALUES (1, 'connection refused', 'frontend', 13, 'a')

statement count 1
INSERT INTO logs VALUES (2, 'connection refused', 'backend', 13, 'a')

statement count 1
INSERT INTO logs VALUES (3, 'connection refused', 'frontend', 5, 'b')

statement count 1
INSERT INTO logs VALUES (4, 'ok', 'frontend', 13, 'b')


# `service` and `sev` appear in BOTH inverted(...) AND INCLUDE(...).
# `tag` is INCLUDE-only.
statement ok
CREATE INDEX logs_idx ON logs
    USING inverted(id, body en_inc, service, sev)
    INCLUDE (service, sev, tag)


statement ok
VACUUM (REFRESH_TABLE) logs


# --- inverted+INCLUDE columns: equality and range filters push down ---

# Compound predicate -- all three filters land inside the IRESEARCH_SCAN
# filter; no residual FILTER node above the scan.
query
EXPLAIN SELECT id FROM logs_idx
WHERE body @@ 'connection' AND service = 'frontend' AND sev >= 13;
----
QUERY PLAN
в•ӯв”Җ IRESEARCH_SCAN в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®
в”Ӯ Index: logs_idx                                                              в”Ӯ
в”Ӯ Lookup: table                                                                в”Ӯ
в”Ӯ Index Filter:                                                                в”Ӯ
в”Ӯ в•ӯв”Җ And в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®                                                      в”Ӯ
в”Ӯ в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ                                                      в”Ӯ
в”Ӯ            в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®             в”Ӯ
в”Ӯ в•ӯв”Җ Term в”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®  в•ӯв”Җ Granular Range в”Җв”Җв”Җв”Җв•®  в•ӯв”Җ Term в”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•® в”Ӯ
в”Ӯ в”Ӯ Field: body(string) в”Ӯ  в”Ӯ Field: sev(numeric) в”Ӯ  в”Ӯ Field: service(string) в”Ӯ в”Ӯ
в”Ӯ в”Ӯ Value: connection   в”Ӯ  в”Ӯ Range: >=13         в”Ӯ  в”Ӯ Value: frontend        в”Ӯ в”Ӯ
в”Ӯ в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ  в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ  в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ в”Ӯ
в”Ӯ Projections: id                                                              в”Ӯ
в”Ӯ ~1 row                                                                       в”Ӯ
в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ


# Result matches the brute-force interpretation.
query
SELECT id FROM logs_idx
WHERE body @@ 'connection' AND service = 'frontend' AND sev >= 13
ORDER BY id;
----
id
1


# --- INCLUDE-only column stays as residual FILTER ---

# `tag` has no posting list (INCLUDE-only), so the optimizer cannot push
# `tag = 'a'` into the iresearch filter -- it stays as a residual FILTER.
query
EXPLAIN SELECT id FROM logs_idx
WHERE body @@ 'connection' AND tag = 'a';
----
QUERY PLAN
в•ӯв”Җ PROJECTION в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®
в”Ӯ Projections: id          в”Ӯ
в”Ӯ ~1 row                   в”Ӯ
в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ
в•ӯв”Җ IRESEARCH_SCAN в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®
в”Ӯ Index: logs_idx          в”Ӯ
в”Ӯ Lookup: table            в”Ӯ
в”Ӯ Index Filter:            в”Ӯ
в”Ӯ в•ӯв”Җ Term в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®  в”Ӯ
в”Ӯ в”Ӯ Field: body(string) в”Ӯ  в”Ӯ
в”Ӯ в”Ӯ Value: connection   в”Ӯ  в”Ӯ
в”Ӯ в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ  в”Ӯ
в”Ӯ Column Filter: tag = 'a' в”Ӯ
в”Ӯ Projections: tag (i),    в”Ӯ
в”Ӯ              id (l)      в”Ӯ
в”Ӯ ~1 row                   в”Ӯ
в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ


query
SELECT id FROM logs_idx
WHERE body @@ 'connection' AND tag = 'a'
ORDER BY id;
----
id
1
2


# --- Each inverted+INCLUDE column individually serves its own filter ---

query
SELECT id FROM logs_idx
WHERE service = 'frontend'
ORDER BY id;
----
id
1
3
4


query
SELECT id FROM logs_idx
WHERE sev >= 13
ORDER BY id;
----
id
1
2
4


# Cleanup
statement ok
DROP INDEX logs_idx

statement ok
DROP TABLE logs

statement ok
DROP TEXT SEARCH DICTIONARY en_inc
