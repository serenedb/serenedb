в”Ӯ  в”Ӯв”Ӯ    в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ   в”Ӯв”Ӯ  в”Ӯ
в”Ӯ  в”Ӯв”Ӯ   body(string) =  в”Ӯв”Ӯ  в”Ӯ
в”Ӯ  в”Ӯв”Ӯ        alpha      в”Ӯв”Ӯ  в”Ӯ
в”Ӯ  в”Ӯв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳв”Ӯ  в”Ӯ
в”Ӯ  в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ  в”Ӯ
в”Ӯ                           в”Ӯ
в”Ӯ        Projections:       в”Ӯ
в”Ӯ          body (l)         в”Ӯ
в”Ӯ           pk (l)          в”Ӯ
в”Ӯ          tag (l)          в”Ӯ
в”Ӯ          note (i)         в”Ӯ
в”Ӯ         extra (i)         в”Ӯ
в”Ӯ          dual (i)         в”Ӯ
в”Ӯ                           в”Ӯ
в”Ӯ           ~1 row          в”Ӯ
в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ


query
SELECT pk, body, tag, note, extra, dual FROM m_idx
WHERE body @@ ts_phrase('alpha') ORDER BY pk;
----
pk	body	tag	note	extra	dual
1	alpha cat	100	note one	10	red apple


# ---- 4. Dual-purpose column: indexed AND INCLUDEd ----
# Filter pushes down to the posting list (no residual FILTER above the
# scan), AND projection comes from cs (`dual (i)`). This combines the
# two roles into one declaration.
query
EXPLAIN SELECT pk, dual FROM m_idx WHERE dual @@ ts_phrase('red');
----
QUERY PLAN
в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
в”Ӯ         PROJECTION        в”Ӯ
в”Ӯ    в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ   в”Ӯ
в”Ӯ             pk            в”Ӯ
в”Ӯ            dual           в”Ӯ
в”Ӯ                           в”Ӯ
в”Ӯ           ~1 row          в”Ӯ
в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ
в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
в”Ӯ       IRESEARCH_SCAN      в”Ӯ
в”Ӯ    в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ   в”Ӯ
в”Ӯ        Index: m_idx       в”Ӯ
в”Ӯ       Lookup: table       в”Ӯ
в”Ӯ                           в”Ӯ
в”Ӯ          Filter:          в”Ӯ
в”Ӯ  в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ  в”Ӯ
в”Ӯ  в”Ӯв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җв”Ӯ  в”Ӯ
в”Ӯ  в”Ӯв”Ӯ        Term       в”Ӯв”Ӯ  в”Ӯ
в”Ӯ  в”Ӯв”Ӯ    в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ   в”Ӯв”Ӯ  в”Ӯ
в”Ӯ  в”Ӯв”Ӯ dual(string) = redв”Ӯв”Ӯ  в”Ӯ
в”Ӯ  в”Ӯв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳв”Ӯ  в”Ӯ
в”Ӯ  в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ  в”Ӯ
в”Ӯ                           в”Ӯ
в”Ӯ        Projections:       в”Ӯ
в”Ӯ          dual (i)         в”Ӯ
в”Ӯ           pk (l)          в”Ӯ
в”Ӯ                           в”Ӯ
в”Ӯ           ~1 row          в”Ӯ
в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ


query
SELECT pk, dual FROM m_idx WHERE dual @@ ts_phrase('red') ORDER BY pk;
----
pk	dual
1	red apple
4	red leaf


# IS NULL on dual-purpose: the null-mangled term sits in the posting
# list (because dual has explicit text indexing). EXPLAIN should show
# `AND[Term(dual(null)=)]` inside the iresearch filter and NO residual
# FILTER node.
query
EXPLAIN SELECT pk, dual FROM m_idx WHERE dual IS NULL;
----
QUERY PLAN
