hash-threshold 100

# Exact distances for a quantized IVF index.
#
# A quantized index (sq8/sq4/pq) stores per-dimension codes AND the raw vectors.
# The projected distance (emb <-> q) must be the EXACT distance computed from the
# raw vectors, not the lossy dequantized one -- for every execution path:
#   - pure ORDER BY score LIMIT k        -> TopK scan (emit-side exact rerank)
#   - ORDER BY score, <tiebreak> LIMIT k -> Stream scan (compound order)
#   - projected score, no pushed LIMIT   -> Stream scan
# so a default (quantized) index returns the same distances as a quant='none'
# one. Vectors are chosen so every true distance is an exact integer.

statement ok
SET sdb_nprobe = 1000

# --- L2 + sq8: exact distances across TopK, Stream, and no-limit paths --------

statement ok
CREATE TABLE ed_l2 (pk INTEGER PRIMARY KEY, emb FLOAT[3])

statement ok
CREATE INDEX ed_l2_sq8 ON ed_l2 USING inverted(pk, emb ivf (metric = 'l2', quant = 'sq8'))

statement ok
CREATE TABLE ed_l2_n (pk INTEGER PRIMARY KEY, emb FLOAT[3])

statement ok
CREATE INDEX ed_l2_none ON ed_l2_n USING inverted(pk, emb ivf (metric = 'l2', quant = 'none'))

statement count 4
INSERT INTO ed_l2 VALUES
  (1, [3, 4, 0]::FLOAT[3]),
  (2, [6, 8, 0]::FLOAT[3]),
  (3, [0, 0, 12]::FLOAT[3]),
  (4, [9, 12, 0]::FLOAT[3])

statement count 4
INSERT INTO ed_l2_n VALUES
  (1, [3, 4, 0]::FLOAT[3]),
  (2, [6, 8, 0]::FLOAT[3]),
  (3, [0, 0, 12]::FLOAT[3]),
  (4, [9, 12, 0]::FLOAT[3])

statement ok
VACUUM (REFRESH_TABLE) ed_l2

statement ok
VACUUM (REFRESH_TABLE) ed_l2_n

# pure ORDER BY score LIMIT k (TopK scan): exact distances.
query
SELECT pk, emb <-> [0, 0, 0]::FLOAT[3] AS d FROM ed_l2_sq8 ORDER BY d LIMIT 3;
----
pk	d
1	5
2	10
3	12

# compound ORDER BY score, pk LIMIT k (Stream scan): exact distances.
query
SELECT pk, emb <-> [0, 0, 0]::FLOAT[3] AS d FROM ed_l2_sq8 ORDER BY d, pk LIMIT 3;
----
pk	d
1	5
2	10
3	12

# projected score, no pushed LIMIT (Stream scan): exact distances.
query
SELECT pk, emb <-> [0, 0, 0]::FLOAT[3] AS d FROM ed_l2_sq8 ORDER BY pk;
----
pk	d
1	5
2	10
3	12
4	15

# quant='none' reference: identical distances.
query
SELECT pk, emb <-> [0, 0, 0]::FLOAT[3] AS d FROM ed_l2_none ORDER BY d, pk LIMIT 3;
----
pk	d
1	5
2	10
3	12

# --- L2 + sq4: same exact distances from a coarser quantizer ------------------

statement ok
CREATE TABLE ed_l2_sq4t (pk INTEGER PRIMARY KEY, emb FLOAT[3])

statement ok
CREATE INDEX ed_l2_sq4 ON ed_l2_sq4t USING inverted(pk, emb ivf (metric = 'l2', quant = 'sq4'))

statement count 4
INSERT INTO ed_l2_sq4t VALUES
  (1, [3, 4, 0]::FLOAT[3]),
  (2, [6, 8, 0]::FLOAT[3]),
  (3, [0, 0, 12]::FLOAT[3]),
  (4, [9, 12, 0]::FLOAT[3])

statement ok
VACUUM (REFRESH_TABLE) ed_l2_sq4t

query
SELECT pk, emb <-> [0, 0, 0]::FLOAT[3] AS d FROM ed_l2_sq4 ORDER BY d, pk LIMIT 3;
----
pk	d
1	5
2	10
3	12

# --- InnerProduct + sq8: exact (negated) inner product -----------------------

statement ok
CREATE TABLE ed_ip (pk INTEGER PRIMARY KEY, emb FLOAT[3])

statement ok
CREATE INDEX ed_ip_sq8 ON ed_ip USING inverted(pk, emb ivf (metric = 'ip', quant = 'sq8'))

statement count 3
INSERT INTO ed_ip VALUES
  (1, [1, 0, 0]::FLOAT[3]),
  (2, [2, 0, 0]::FLOAT[3]),
  (3, [3, 0, 0]::FLOAT[3])

statement ok
VACUUM (REFRESH_TABLE) ed_ip

query
SELECT pk, emb <#> [1, 0, 0]::FLOAT[3] AS d FROM ed_ip_sq8 ORDER BY d, pk;
----
pk	d
3	-3
2	-2
1	-1

# --- Cosine + sq8: exact angular distance (0 aligned, 1 orthogonal) -----------

statement ok
CREATE TABLE ed_cos (pk INTEGER PRIMARY KEY, emb FLOAT[3])

statement ok
CREATE INDEX ed_cos_sq8 ON ed_cos USING inverted(pk, emb ivf (metric = 'cosine', quant = 'sq8'))

statement count 2
INSERT INTO ed_cos VALUES
  (1, [10, 0, 0]::FLOAT[3]),
  (2, [0, 5, 0]::FLOAT[3])

statement ok
VACUUM (REFRESH_TABLE) ed_cos

query
SELECT pk, emb <=> [2, 0, 0]::FLOAT[3] AS d FROM ed_cos_sq8 ORDER BY d, pk;
----
pk	d
1	0
2	1

statement ok
RESET sdb_nprobe
