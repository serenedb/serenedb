hash-threshold 100

# Residual Product-Quantization IVF vector index. One global codebook (M
# subquantizers, ksub=16 centroids, nbits=4) is trained on the reservoir
# sample's centroid-relative residuals and stored once in the .idx; each
# cluster's codes are packed into faiss SIMD fast-scan blocks. PQ is lossy +
# approximate, so determinism here comes from far-separated "landmark"
# vectors (queries can't miss them) plus an exhaustive nprobe. PQ training
# needs >= 16 points, so the table is padded with filler rows. quant='pq'
# supports metric l2, ip, and cosine; pq_m must divide the dimension.

statement ok
SET sdb_nprobe = 1000

# ===========================================================================
# 1. L2 + PQ (d=8, pq_m=4 -> dsub=2): far-separated landmarks among filler.
# ===========================================================================

statement ok
CREATE TABLE pq_l2 (pk INTEGER PRIMARY KEY, emb FLOAT[8])

statement ok
CREATE INDEX pq_l2_idx ON pq_l2
  USING inverted(pk, emb ivf (metric = 'l2', quant = 'pq', pq_m = 4))

# 300 bounded filler rows near the origin to train the codebook.
statement ok
INSERT INTO pq_l2
SELECT g,
  ARRAY[ (g % 37)::float, ((g * 7) % 37)::float, ((g * 11) % 37)::float,
         ((g * 13) % 37)::float, ((g * 17) % 37)::float, ((g * 19) % 37)::float,
         ((g * 23) % 37)::float, ((g * 29) % 37)::float ]::FLOAT[8]
FROM generate_series(1, 300) g

# three landmarks, each isolated on a different axis, far from all filler.
statement count 3
INSERT INTO pq_l2 VALUES
  (1001, [1000, 0, 0, 0, 0, 0, 0, 0]::FLOAT[8]),
  (1002, [0, 1000, 0, 0, 0, 0, 0, 0]::FLOAT[8]),
  (1003, [0, 0, 0, 0, 0, 0, 0, 1000]::FLOAT[8])

statement ok
VACUUM (REFRESH_TABLE) pq_l2

query
SELECT count(*) FROM pq_l2_idx;
----
count
303

query
SELECT pk FROM pq_l2_idx
  ORDER BY emb <-> [1000, 0, 0, 0, 0, 0, 0, 0]::FLOAT[8] LIMIT 1;
----
pk
1001

query
SELECT pk FROM pq_l2_idx
  ORDER BY emb <-> [0, 1000, 0, 0, 0, 0, 0, 0]::FLOAT[8] LIMIT 1;
----
pk
1002

query
SELECT pk FROM pq_l2_idx
  ORDER BY emb <-> [0, 0, 0, 0, 0, 0, 0, 1000]::FLOAT[8] LIMIT 1;
----
pk
1003

# hybrid: an inner filter routes through the exact raw reranker.
query
SELECT pk FROM pq_l2_idx
  WHERE pk >= 1001 ORDER BY emb <-> [0, 0, 0, 0, 0, 0, 0, 1000]::FLOAT[8] LIMIT 1;
----
pk
1003

# ===========================================================================
# 2. InnerProduct + PQ.
# ===========================================================================

statement ok
CREATE TABLE pq_ip (pk INTEGER PRIMARY KEY, emb FLOAT[8])

statement ok
CREATE INDEX pq_ip_idx ON pq_ip
  USING inverted(pk, emb ivf (metric = 'ip', quant = 'pq', pq_m = 4))

statement ok
INSERT INTO pq_ip
SELECT g,
  ARRAY[ (g % 31)::float, ((g * 3) % 31)::float, ((g * 5) % 31)::float,
         ((g * 7) % 31)::float, ((g * 11) % 31)::float, ((g * 13) % 31)::float,
         ((g * 17) % 31)::float, ((g * 19) % 31)::float ]::FLOAT[8]
FROM generate_series(1, 300) g

# a landmark with a large component on axis 1: maximal inner product with a
# query that points along axis 1.
statement count 1
INSERT INTO pq_ip VALUES (2001, [500, 0, 0, 0, 0, 0, 0, 0]::FLOAT[8])

statement ok
VACUUM (REFRESH_TABLE) pq_ip

query
SELECT pk FROM pq_ip_idx
  ORDER BY emb <#> [100, 0, 0, 0, 0, 0, 0, 0]::FLOAT[8] LIMIT 1;
----
pk
2001

statement ok
RESET sdb_nprobe

# ===========================================================================
# 3. Guards: pq requires metric l2/ip/cosine; pq_m must divide the dimension.
# ===========================================================================

statement ok
CREATE TABLE pq_bad (pk INTEGER PRIMARY KEY, emb FLOAT[8])

statement error
CREATE INDEX pq_bad_m ON pq_bad USING inverted(pk, emb ivf (metric = 'l2', quant = 'pq', pq_m = 3));
----
db error: ERROR: Column 'emb': ivf option 'pq_m' (3) must divide the vector dimension 8


# ===========================================================================
# 3b. Cosine + PQ: cosine is folded into inner product over L2-normalized
#     residuals, so ranking is by angle regardless of magnitude. PQ only
#     resolves WELL-SEPARATED directions reliably (near-ties within one
#     cluster can flip under quantization noise), so this asserts cross-group
#     membership, not fragile within-group rank. Three ~100-row groups sit on
#     disjoint, near-orthogonal axis triples with varying magnitude (so cosine
#     must normalize). With LIMIT 100 the rerank pool (rerank_factor*k) covers
#     the whole table, so the top-100 is exact-cosine and deterministic: every
#     one of them is the group aligned with the query.
# ===========================================================================

statement ok
SET sdb_nprobe = 1000

statement ok
CREATE TABLE pq_cos (pk INTEGER PRIMARY KEY, emb FLOAT[8])

statement ok
CREATE INDEX pq_cos_idx ON pq_cos
  USING inverted(pk, emb ivf (metric = 'cosine', quant = 'pq', pq_m = 4))

# g % 3 == 0 -> x-axis group, == 1 -> dim4 group, == 2 -> dim7 group.
statement ok
INSERT INTO pq_cos
SELECT g,
  CASE WHEN g % 3 = 0 THEN ARRAY[(g % 5) + 10.0, 2, 2, 0, 0, 0, 0, 0]
       WHEN g % 3 = 1 THEN ARRAY[0, 0, 0, (g % 5) + 10.0, 2, 2, 0, 0]
       ELSE                 ARRAY[0, 0, 0, 0, 0, 0, (g % 5) + 10.0, 2] END::FLOAT[8]
FROM generate_series(1, 300) g

statement ok
VACUUM (REFRESH_TABLE) pq_cos

# all rows indexed
query
SELECT count(*) FROM pq_cos_idx;
----
count
300

# a +x query: the 100 nearest by cosine are exactly the x-axis group.
query
SELECT count(*) FROM (
  SELECT pk FROM pq_cos_idx
    ORDER BY emb <=> [7, 0, 0, 0, 0, 0, 0, 0]::FLOAT[8] LIMIT 100
) t WHERE pk % 3 = 0;
----
count
100

# a dim4 query: the 100 nearest are exactly the dim4 group.
query
SELECT count(*) FROM (
  SELECT pk FROM pq_cos_idx
    ORDER BY emb <=> [0, 0, 0, 7, 0, 0, 0, 0]::FLOAT[8] LIMIT 100
) t WHERE pk % 3 = 1;
----
count
100

# a dim7 query: the 100 nearest are exactly the dim7 group.
query
SELECT count(*) FROM (
  SELECT pk FROM pq_cos_idx
    ORDER BY emb <=> [0, 0, 0, 0, 0, 0, 7, 0]::FLOAT[8] LIMIT 100
) t WHERE pk % 3 = 2;
----
count
100

statement ok
RESET sdb_nprobe
