hash-threshold 100

# RaBitQ-quantized IVF vector index: ANN result correctness and correctness
# across INSERT / DELETE / UPDATE.
#
# RaBitQ stores a rotated sign-bit code (plus optional extra magnitude bits)
# per dimension in the postings .pay and scores them via the quantized
# QVectorIterator path; a kNN with a WHERE filter and any range query fall
# back to the exact raw reranker. Low bit counts are lossy, so most sections
# below use rabitq_bits = 8 with well-separated vectors so exact row
# order is deterministic; a dedicated section covers the default (1-bit)
# quantizer with a coarser separation. quant='rabitq' supports only metric
# l2 and ip (unlike sq8/sq4/pq, which also support cosine).

# Exhaustive search: probe every cluster so kNN can't miss a true neighbour.
statement ok
SET sdb_nprobe = 1000

# ===========================================================================
# 1. L2 + RaBitQ (8 bits), single cluster (nlist=1): exercises the batched
#    ComputeBlock path with >4 docs in one cluster.
# ===========================================================================

statement ok
CREATE TABLE rabitq_l2 (pk INTEGER PRIMARY KEY, emb FLOAT[3], label VARCHAR)

statement ok
CREATE INDEX rabitq_l2_idx ON rabitq_l2
  USING inverted(pk, emb ivf (metric = 'l2', quant = 'rabitq', rabitq_bits = 8))
  INCLUDE (label)

statement count 6
INSERT INTO rabitq_l2 VALUES
  (1, [10, 0, 0]::FLOAT[3], 'x'),
  (2, [0, 10, 0]::FLOAT[3], 'y'),
  (3, [0, 0, 10]::FLOAT[3], 'z'),
  (4, [10, 10, 0]::FLOAT[3], 'xy'),
  (5, [10, 10, 10]::FLOAT[3], 'xyz'),
  (6, [20, 0, 0]::FLOAT[3], 'x2')

statement ok
VACUUM (REFRESH_TABLE) rabitq_l2

query
SELECT pk, label FROM rabitq_l2_idx
  ORDER BY emb <-> [11, 0, 0]::FLOAT[3] LIMIT 3;
----
pk	label
1	x
6	x2
4	xy

query
SELECT pk, label FROM rabitq_l2_idx
  ORDER BY emb <-> [10, 12, 1]::FLOAT[3] LIMIT 3;
----
pk	label
4	xy
5	xyz
2	y

query
SELECT count(*) FROM rabitq_l2_idx;
----
count
6

# ===========================================================================
# 2. L2 + RaBitQ (8 bits), multiple clusters (nlist=3): kNN merges across
#    per-cluster QVectorIterators (disjunction). nprobe is exhaustive.
# ===========================================================================

statement ok
CREATE TABLE rabitq_mc (pk INTEGER PRIMARY KEY, emb FLOAT[3])

statement ok
CREATE INDEX rabitq_mc_idx ON rabitq_mc
  USING inverted(pk, emb ivf (metric = 'l2', quant = 'rabitq', rabitq_bits = 8))

statement count 6
INSERT INTO rabitq_mc VALUES
  (1, [100, 0, 0]::FLOAT[3]),
  (2, [101, 0, 0]::FLOAT[3]),
  (3, [0, 100, 0]::FLOAT[3]),
  (4, [0, 101, 0]::FLOAT[3]),
  (5, [0, 0, 100]::FLOAT[3]),
  (6, [0, 0, 101]::FLOAT[3])

statement ok
VACUUM (REFRESH_TABLE) rabitq_mc

query
SELECT pk FROM rabitq_mc_idx ORDER BY emb <-> [100, 0, 0]::FLOAT[3] LIMIT 2;
----
pk
1
2

query
SELECT pk FROM rabitq_mc_idx ORDER BY emb <-> [0, 0, 100]::FLOAT[3] LIMIT 2;
----
pk
5
6

query
SELECT pk FROM rabitq_mc_idx ORDER BY emb <-> [0, 100, 0]::FLOAT[3] LIMIT 2;
----
pk
3
4

# ===========================================================================
# 3. DML correctness: INSERT / DELETE / UPDATE / multi-segment / COMPACT.
# ===========================================================================

statement ok
CREATE TABLE rabitq_dml (pk INTEGER PRIMARY KEY, emb FLOAT[3], label VARCHAR)

statement ok
CREATE INDEX rabitq_dml_idx ON rabitq_dml
  USING inverted(pk, emb ivf (metric = 'l2', quant = 'rabitq', rabitq_bits = 8))
  INCLUDE (label)

statement count 4
INSERT INTO rabitq_dml VALUES
  (1, [10, 0, 0]::FLOAT[3], 'a'),
  (2, [0, 10, 0]::FLOAT[3], 'b'),
  (3, [0, 0, 15]::FLOAT[3], 'c'),
  (4, [20, 0, 0]::FLOAT[3], 'd')

statement ok
VACUUM (REFRESH_TABLE) rabitq_dml

# baseline kNN
query
SELECT pk FROM rabitq_dml_idx ORDER BY emb <-> [9, 0, 0]::FLOAT[3] LIMIT 2;
----
pk
1
4

# DELETE: deleted row must drop out after refresh; survivors still correct.
statement ok
DELETE FROM rabitq_dml WHERE pk = 1

statement ok
VACUUM (REFRESH_TABLE) rabitq_dml

query
SELECT pk FROM rabitq_dml_idx ORDER BY emb <-> [9, 0, 0]::FLOAT[3] LIMIT 3;
----
pk
4
2
3

query
SELECT count(*) FROM rabitq_dml_idx;
----
count
3

# UPDATE indexed vector: pk=4 moves from [20,0,0] to [0,0,100].
statement ok
UPDATE rabitq_dml SET emb = [0, 0, 100]::FLOAT[3] WHERE pk = 4

statement ok
VACUUM (REFRESH_TABLE) rabitq_dml

# now nearest to its new position
query
SELECT pk FROM rabitq_dml_idx ORDER BY emb <-> [0, 0, 99]::FLOAT[3] LIMIT 1;
----
pk
4

# and no longer nearest to its old position
query
SELECT pk FROM rabitq_dml_idx ORDER BY emb <-> [21, 0, 0]::FLOAT[3] LIMIT 1;
----
pk
2

# multi-segment: a second refreshed batch creates a new segment; kNN merges.
statement count 2
INSERT INTO rabitq_dml VALUES
  (5, [30, 0, 0]::FLOAT[3], 'e'),
  (6, [0, 30, 0]::FLOAT[3], 'f')

statement ok
VACUUM (REFRESH_TABLE) rabitq_dml

query
SELECT pk FROM rabitq_dml_idx ORDER BY emb <-> [29, 0, 0]::FLOAT[3] LIMIT 1;
----
pk
5

# COMPACT after deletes across segments: physical removal, results stable.
statement ok
DELETE FROM rabitq_dml WHERE pk IN (2, 5)

statement ok
VACUUM (COMPACT_TABLE) rabitq_dml

query
SELECT pk FROM rabitq_dml_idx ORDER BY emb <-> [0, 0, 99]::FLOAT[3] LIMIT 1;
----
pk
4

query
SELECT count(*) FROM rabitq_dml_idx;
----
count
3

# ===========================================================================
# 4. InnerProduct + RaBitQ (8 bits) (the other RaBitQ-supported metric).
# ===========================================================================

statement ok
CREATE TABLE rabitq_ip (pk INTEGER PRIMARY KEY, emb FLOAT[3])

statement ok
CREATE INDEX rabitq_ip_idx ON rabitq_ip
  USING inverted(pk, emb ivf (metric = 'ip', quant = 'rabitq', rabitq_bits = 8))

statement count 4
INSERT INTO rabitq_ip VALUES
  (1, [1, 0, 0]::FLOAT[3]),
  (2, [0, 1, 0]::FLOAT[3]),
  (3, [2, 0, 0]::FLOAT[3]),
  (4, [3, 0, 0]::FLOAT[3])

statement ok
VACUUM (REFRESH_TABLE) rabitq_ip

# highest inner product with [1,0,0] first: 4 (3), 3 (2), 1 (1)
query
SELECT pk FROM rabitq_ip_idx ORDER BY emb <#> [1, 0, 0]::FLOAT[3] LIMIT 3;
----
pk
4
3
1

# ===========================================================================
# 5. Hybrid (indexed scalar filter + kNN) and range query on a RaBitQ index.
#    Both route through the exact raw reranker, not the quantized path.
# ===========================================================================

statement ok
CREATE TABLE rabitq_hyb (pk INTEGER PRIMARY KEY, emb FLOAT[3], cat INTEGER)

statement ok
CREATE INDEX rabitq_hyb_idx ON rabitq_hyb
  USING inverted(pk, cat, emb ivf (metric = 'l2', quant = 'rabitq', rabitq_bits = 8))

statement count 4
INSERT INTO rabitq_hyb VALUES
  (1, [10, 0, 0]::FLOAT[3], 1),
  (2, [0, 10, 0]::FLOAT[3], 2),
  (3, [0, 0, 10]::FLOAT[3], 1),
  (4, [20, 0, 0]::FLOAT[3], 2)

statement ok
VACUUM (REFRESH_TABLE) rabitq_hyb

# hybrid: filter cat=1, then nearest to [11,0,0] among {1,3}
query
SELECT pk FROM rabitq_hyb_idx
  WHERE cat = 1 ORDER BY emb <-> [11, 0, 0]::FLOAT[3] LIMIT 2;
----
pk
1
3

# range: within distance 3 of [11,0,0] -> only pk=1 (distance 1)
query
SELECT pk FROM rabitq_hyb_idx
  WHERE emb <-> [11, 0, 0]::FLOAT[3] < 3 ORDER BY pk;
----
pk
1

# wider radius -> pk=1 (1) and pk=4 (9)
query
SELECT pk FROM rabitq_hyb_idx
  WHERE emb <-> [11, 0, 0]::FLOAT[3] < 10 ORDER BY pk;
----
pk
1
4

# ===========================================================================
# 6. Quantizer edge cases: identical vectors (zero residual), all-zero
#    vector, single-doc remainder.
# ===========================================================================

statement ok
CREATE TABLE rabitq_edge (pk INTEGER PRIMARY KEY, emb FLOAT[3])

statement ok
CREATE INDEX rabitq_edge_idx ON rabitq_edge
  USING inverted(pk, emb ivf (metric = 'l2', quant = 'rabitq', rabitq_bits = 8))

statement count 5
INSERT INTO rabitq_edge VALUES
  (1, [5, 5, 5]::FLOAT[3]),
  (2, [5, 5, 5]::FLOAT[3]),
  (3, [5, 5, 5]::FLOAT[3]),
  (4, [0, 0, 0]::FLOAT[3]),
  (5, [100, 0, 0]::FLOAT[3])

statement ok
VACUUM (REFRESH_TABLE) rabitq_edge

# all-zero query vector finds the all-zero row
query
SELECT pk FROM rabitq_edge_idx ORDER BY emb <-> [0, 0, 0]::FLOAT[3] LIMIT 1;
----
pk
4

# the three identical vectors are exactly the top-3 nearest to their value
query
SELECT pk FROM (
  SELECT pk FROM rabitq_edge_idx ORDER BY emb <-> [5, 5, 5]::FLOAT[3] LIMIT 3
) sub ORDER BY pk;
----
pk
1
2
3

query
SELECT count(*) FROM rabitq_edge_idx;
----
count
5

statement ok
RESET sdb_nprobe

# ===========================================================================
# 7. Default rabitq_bits (1-bit, sign-only quantization): coarser, so use a
#    large separation gap that survives 1-bit rounding.
# ===========================================================================

statement ok
SET sdb_nprobe = 1000

statement ok
CREATE TABLE rabitq_default (pk INTEGER PRIMARY KEY, emb FLOAT[8])

statement ok
CREATE INDEX rabitq_default_idx ON rabitq_default
  USING inverted(pk, emb ivf (metric = 'l2', quant = 'rabitq'))

statement count 3
INSERT INTO rabitq_default VALUES
  (1, [1, 1, 1, 1, 1, 1, 1, 1]::FLOAT[8]),
  (2, [1000, 1000, 1000, 1000, 1000, 1000, 1000, 1000]::FLOAT[8]),
  (3, [-1000, -1000, -1000, -1000, -1000, -1000, -1000, -1000]::FLOAT[8])

statement ok
VACUUM (REFRESH_TABLE) rabitq_default

query
SELECT pk FROM rabitq_default_idx
  ORDER BY emb <-> [1, 1, 1, 1, 1, 1, 1, 1]::FLOAT[8] LIMIT 1;
----
pk
1

statement ok
RESET sdb_nprobe

# ===========================================================================
# 8. Option guards: rabitq_bits range and only-valid-with-quant='rabitq'.
# ===========================================================================

statement ok
CREATE TABLE rabitq_bad (pk INTEGER PRIMARY KEY, emb FLOAT[3])

statement error
CREATE INDEX rabitq_bad_cos ON rabitq_bad USING inverted(pk, emb ivf (metric = 'cosine', quant = 'rabitq'));
----
db error: ERROR: Column 'emb': ivf rabitq quantization does not support metric 'cosine'


statement error
CREATE INDEX rabitq_bad_l1 ON rabitq_bad USING inverted(pk, emb ivf (metric = 'l1', quant = 'rabitq'));
----
db error: ERROR: Column 'emb': ivf quantization supports only metric 'l2', 'ip', or 'cosine'


statement error
CREATE INDEX rabitq_bad_bits_range ON rabitq_bad USING inverted(pk, emb ivf (metric = 'l2', quant = 'rabitq', rabitq_bits = 10));
----
db error: ERROR: Column 'emb': ivf option 'rabitq_bits' (10) must be between 1 and 9


statement error
CREATE INDEX rabitq_bad_bits_wrong_quant ON rabitq_bad USING inverted(pk, emb ivf (metric = 'l2', quant = 'sq8', rabitq_bits = 4));
----
db error: ERROR: Column 'emb': ivf option 'rabitq_bits' is only valid with quant 'rabitq'
