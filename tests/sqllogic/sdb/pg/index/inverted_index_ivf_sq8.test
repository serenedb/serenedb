hash-threshold 100

# SQ8-quantized IVF vector index: ANN result correctness and correctness
# across INSERT / DELETE / UPDATE.
#
# SQ8 stores 8-bit per-dimension codes in the postings .pay and scores them
# via the quantized QVectorIterator path (pure kNN, no inner filter); a kNN
# with a WHERE filter and any range query fall back to the exact raw reranker.
# SQ8 is lossy and IVF is approximate, so determinism comes from well-separated
# vectors plus an exhaustive nprobe; assertions check row identity/order only,
# never the distance score. quant='sq8' supports only metric l2 and ip.

# Exhaustive search: probe every cluster so kNN can't miss a true neighbour.
statement ok
SET sdb_nprobe = 1000

# ===========================================================================
# 1. L2 + SQ8, single cluster (nlist=1): exercises the batched ComputeBlock
#    (groups of 4 + remainder) with >4 docs in one cluster.
# ===========================================================================

statement ok
CREATE TABLE sq8_l2 (pk INTEGER PRIMARY KEY, emb FLOAT[3], label VARCHAR)

statement ok
CREATE INDEX sq8_l2_idx ON sq8_l2
  USING inverted(pk, emb ivf (metric = 'l2', quant = 'sq8'))
  INCLUDE (label)

statement count 6
INSERT INTO sq8_l2 VALUES
  (1, [10, 0, 0]::FLOAT[3], 'x'),
  (2, [0, 10, 0]::FLOAT[3], 'y'),
  (3, [0, 0, 10]::FLOAT[3], 'z'),
  (4, [10, 10, 0]::FLOAT[3], 'xy'),
  (5, [10, 10, 10]::FLOAT[3], 'xyz'),
  (6, [20, 0, 0]::FLOAT[3], 'x2')

statement ok
VACUUM (REFRESH_TABLE) sq8_l2

query
SELECT pk, label FROM sq8_l2_idx
  ORDER BY emb <-> [11, 0, 0]::FLOAT[3] LIMIT 3;
----
pk	label
1	x
6	x2
4	xy

query
SELECT pk, label FROM sq8_l2_idx
  ORDER BY emb <-> [10, 12, 1]::FLOAT[3] LIMIT 3;
----
pk	label
4	xy
5	xyz
2	y

query
SELECT count(*) FROM sq8_l2_idx;
----
count
6

# ===========================================================================
# 1b. L2 + SQ8, single cluster, LIMIT covers the whole cluster: the exact
#     rerank pass (rerank_pool = rerank_factor * k) pulls in every doc as one
#     contiguous run, exercising IvfVectorReader::ReadDocBatch's multi-row
#     batched Scan (not just the single-doc path).
# ===========================================================================

statement ok
CREATE TABLE sq8_rerank_run (pk INTEGER PRIMARY KEY, emb FLOAT[3])

statement ok
CREATE INDEX sq8_rerank_run_idx ON sq8_rerank_run
  USING inverted(pk, emb ivf (metric = 'l2', quant = 'sq8'))

statement count 6
INSERT INTO sq8_rerank_run VALUES
  (1, [10, 0, 0]::FLOAT[3]),
  (2, [20, 0, 0]::FLOAT[3]),
  (3, [30, 0, 0]::FLOAT[3]),
  (4, [40, 0, 0]::FLOAT[3]),
  (5, [50, 0, 0]::FLOAT[3]),
  (6, [60, 0, 0]::FLOAT[3])

statement ok
VACUUM (REFRESH_TABLE) sq8_rerank_run

query
SELECT pk FROM sq8_rerank_run_idx ORDER BY emb <-> [0, 0, 0]::FLOAT[3] LIMIT 6;
----
pk
1
2
3
4
5
6

# ===========================================================================
# 2. L2 + SQ8, multiple clusters (nlist=3): kNN merges across per-cluster
#    QVectorIterators (disjunction). nprobe is exhaustive.
# ===========================================================================

statement ok
CREATE TABLE sq8_mc (pk INTEGER PRIMARY KEY, emb FLOAT[3])

statement ok
CREATE INDEX sq8_mc_idx ON sq8_mc
  USING inverted(pk, emb ivf (metric = 'l2', quant = 'sq8'))

statement count 6
INSERT INTO sq8_mc VALUES
  (1, [100, 0, 0]::FLOAT[3]),
  (2, [101, 0, 0]::FLOAT[3]),
  (3, [0, 100, 0]::FLOAT[3]),
  (4, [0, 101, 0]::FLOAT[3]),
  (5, [0, 0, 100]::FLOAT[3]),
  (6, [0, 0, 101]::FLOAT[3])

statement ok
VACUUM (REFRESH_TABLE) sq8_mc

query
SELECT pk FROM sq8_mc_idx ORDER BY emb <-> [100, 0, 0]::FLOAT[3] LIMIT 2;
----
pk
1
2

query
SELECT pk FROM sq8_mc_idx ORDER BY emb <-> [0, 0, 100]::FLOAT[3] LIMIT 2;
----
pk
5
6

query
SELECT pk FROM sq8_mc_idx ORDER BY emb <-> [0, 100, 0]::FLOAT[3] LIMIT 2;
----
pk
3
4

# ===========================================================================
# 3. DML correctness: INSERT / DELETE / UPDATE / multi-segment / COMPACT.
# ===========================================================================

statement ok
CREATE TABLE sq8_dml (pk INTEGER PRIMARY KEY, emb FLOAT[3], label VARCHAR)

statement ok
CREATE INDEX sq8_dml_idx ON sq8_dml
  USING inverted(pk, emb ivf (metric = 'l2', quant = 'sq8'))
  INCLUDE (label)

statement count 4
INSERT INTO sq8_dml VALUES
  (1, [10, 0, 0]::FLOAT[3], 'a'),
  (2, [0, 10, 0]::FLOAT[3], 'b'),
  (3, [0, 0, 15]::FLOAT[3], 'c'),
  (4, [20, 0, 0]::FLOAT[3], 'd')

statement ok
VACUUM (REFRESH_TABLE) sq8_dml

# baseline kNN
query
SELECT pk FROM sq8_dml_idx ORDER BY emb <-> [9, 0, 0]::FLOAT[3] LIMIT 2;
----
pk
1
4

# DELETE: deleted row must drop out after refresh; survivors still correct.
statement ok
DELETE FROM sq8_dml WHERE pk = 1

statement ok
VACUUM (REFRESH_TABLE) sq8_dml

query
SELECT pk FROM sq8_dml_idx ORDER BY emb <-> [9, 0, 0]::FLOAT[3] LIMIT 3;
----
pk
4
2
3

query
SELECT count(*) FROM sq8_dml_idx;
----
count
3

# UPDATE indexed vector: pk=4 moves from [20,0,0] to [0,0,100].
statement ok
UPDATE sq8_dml SET emb = [0, 0, 100]::FLOAT[3] WHERE pk = 4

statement ok
VACUUM (REFRESH_TABLE) sq8_dml

# now nearest to its new position
query
SELECT pk FROM sq8_dml_idx ORDER BY emb <-> [0, 0, 99]::FLOAT[3] LIMIT 1;
----
pk
4

# and no longer nearest to its old position
query
SELECT pk FROM sq8_dml_idx ORDER BY emb <-> [21, 0, 0]::FLOAT[3] LIMIT 1;
----
pk
2

# multi-segment: a second refreshed batch creates a new segment; kNN merges.
statement count 2
INSERT INTO sq8_dml VALUES
  (5, [30, 0, 0]::FLOAT[3], 'e'),
  (6, [0, 30, 0]::FLOAT[3], 'f')

statement ok
VACUUM (REFRESH_TABLE) sq8_dml

query
SELECT pk FROM sq8_dml_idx ORDER BY emb <-> [29, 0, 0]::FLOAT[3] LIMIT 1;
----
pk
5

# COMPACT after deletes across segments: physical removal, results stable.
statement ok
DELETE FROM sq8_dml WHERE pk IN (2, 5)

statement ok
VACUUM (COMPACT_TABLE) sq8_dml

query
SELECT pk FROM sq8_dml_idx ORDER BY emb <-> [0, 0, 99]::FLOAT[3] LIMIT 1;
----
pk
4

query
SELECT count(*) FROM sq8_dml_idx;
----
count
3

# ===========================================================================
# 4. InnerProduct + SQ8 (the other SQ8-supported metric).
# ===========================================================================

statement ok
CREATE TABLE sq8_ip (pk INTEGER PRIMARY KEY, emb FLOAT[3])

statement ok
CREATE INDEX sq8_ip_idx ON sq8_ip
  USING inverted(pk, emb ivf (metric = 'ip', quant = 'sq8'))

statement count 4
INSERT INTO sq8_ip VALUES
  (1, [1, 0, 0]::FLOAT[3]),
  (2, [0, 1, 0]::FLOAT[3]),
  (3, [2, 0, 0]::FLOAT[3]),
  (4, [3, 0, 0]::FLOAT[3])

statement ok
VACUUM (REFRESH_TABLE) sq8_ip

# highest inner product with [1,0,0] first: 4 (3), 3 (2), 1 (1)
query
SELECT pk FROM sq8_ip_idx ORDER BY emb <#> [1, 0, 0]::FLOAT[3] LIMIT 3;
----
pk
4
3
1

# ===========================================================================
# 5. Hybrid (indexed scalar filter + kNN) and range query on an SQ8 index.
#    Both route through the exact raw reranker, not the quantized path.
# ===========================================================================

statement ok
CREATE TABLE sq8_hyb (pk INTEGER PRIMARY KEY, emb FLOAT[3], cat INTEGER)

statement ok
CREATE INDEX sq8_hyb_idx ON sq8_hyb
  USING inverted(pk, cat, emb ivf (metric = 'l2', quant = 'sq8'))

statement count 4
INSERT INTO sq8_hyb VALUES
  (1, [10, 0, 0]::FLOAT[3], 1),
  (2, [0, 10, 0]::FLOAT[3], 2),
  (3, [0, 0, 10]::FLOAT[3], 1),
  (4, [20, 0, 0]::FLOAT[3], 2)

statement ok
VACUUM (REFRESH_TABLE) sq8_hyb

# hybrid: filter cat=1, then nearest to [11,0,0] among {1,3}
query
SELECT pk FROM sq8_hyb_idx
  WHERE cat = 1 ORDER BY emb <-> [11, 0, 0]::FLOAT[3] LIMIT 2;
----
pk
1
3

# range: within distance 3 of [11,0,0] -> only pk=1 (distance 1)
query
SELECT pk FROM sq8_hyb_idx
  WHERE emb <-> [11, 0, 0]::FLOAT[3] < 3 ORDER BY pk;
----
pk
1

# wider radius -> pk=1 (1) and pk=4 (9)
query
SELECT pk FROM sq8_hyb_idx
  WHERE emb <-> [11, 0, 0]::FLOAT[3] < 10 ORDER BY pk;
----
pk
1
4

# ===========================================================================
# 6. Quantizer edge cases: identical vectors (per-dim vmin==vmax), all-zero
#    vector, single-doc remainder.
# ===========================================================================

statement ok
CREATE TABLE sq8_edge (pk INTEGER PRIMARY KEY, emb FLOAT[3])

statement ok
CREATE INDEX sq8_edge_idx ON sq8_edge
  USING inverted(pk, emb ivf (metric = 'l2', quant = 'sq8'))

statement count 5
INSERT INTO sq8_edge VALUES
  (1, [5, 5, 5]::FLOAT[3]),
  (2, [5, 5, 5]::FLOAT[3]),
  (3, [5, 5, 5]::FLOAT[3]),
  (4, [0, 0, 0]::FLOAT[3]),
  (5, [100, 0, 0]::FLOAT[3])

statement ok
VACUUM (REFRESH_TABLE) sq8_edge

# all-zero query vector finds the all-zero row
query
SELECT pk FROM sq8_edge_idx ORDER BY emb <-> [0, 0, 0]::FLOAT[3] LIMIT 1;
----
pk
4

# the three identical vectors are exactly the top-3 nearest to their value
query
SELECT pk FROM (
  SELECT pk FROM sq8_edge_idx ORDER BY emb <-> [5, 5, 5]::FLOAT[3] LIMIT 3
) sub ORDER BY pk;
----
pk
1
2
3

query
SELECT count(*) FROM sq8_edge_idx;
----
count
5

statement ok
RESET sdb_nprobe

# ===========================================================================
# 7. Guard: SQ8 is only valid with metric l2 or ip; cosine/l1 + sq8 must be
#    rejected at CREATE INDEX rather than crashing at query time.
# ===========================================================================

statement ok
CREATE TABLE sq8_bad (pk INTEGER PRIMARY KEY, emb FLOAT[3])

statement error
CREATE INDEX sq8_bad_cos ON sq8_bad USING inverted(pk, emb ivf (metric = 'cosine', quant = 'sq8'));
----
db error: ERROR: Column 'emb': ivf quantization supports only metric 'l2' or 'ip'


statement error
CREATE INDEX sq8_bad_l1 ON sq8_bad USING inverted(pk, emb ivf (metric = 'l1', quant = 'sq8'));
----
db error: ERROR: Column 'emb': ivf quantization supports only metric 'l2' or 'ip'


# ===========================================================================
# 8. Multiple clusters (nlist=4) combined with live tombstones: INSERT /
#    DELETE / UPDATE / multi-segment / COMPACT against a multi-cluster
#    index. Every existing DML section above uses nlist=1 (single cluster,
#    no cross-cluster merge); every existing nlist>1 section above has no
#    deletions. This is the one combination that wasn't covered by either:
#    the kNN disjunction across per-cluster QVectorIterators has to keep
#    producing correct results while some segments carry a docs_mask
#    (tombstones), which routes the merged iterator through a different
#    consumer (MaskDocIterator) than the plain no-mask case.
# ===========================================================================

statement ok
CREATE TABLE sq8_mc_dml (pk INTEGER PRIMARY KEY, emb FLOAT[3], label VARCHAR)

statement ok
CREATE INDEX sq8_mc_dml_idx ON sq8_mc_dml
  USING inverted(pk, emb ivf (metric = 'l2', quant = 'sq8'))
  INCLUDE (label)

statement count 8
INSERT INTO sq8_mc_dml VALUES
  (1, [100, 0, 0]::FLOAT[3], 'a'),
  (2, [102, 0, 0]::FLOAT[3], 'b'),
  (3, [0, 90, 0]::FLOAT[3], 'c'),
  (4, [0, 95, 0]::FLOAT[3], 'd'),
  (5, [0, 0, 80]::FLOAT[3], 'e'),
  (6, [0, 0, 85]::FLOAT[3], 'f'),
  (7, [-70, 0, 0]::FLOAT[3], 'g'),
  (8, [-75, 0, 0]::FLOAT[3], 'h')

statement ok
VACUUM (REFRESH_TABLE) sq8_mc_dml

# baseline kNN across all 4 clusters
query
SELECT pk FROM sq8_mc_dml_idx ORDER BY emb <-> [100, 0, 0]::FLOAT[3] LIMIT 2;
----
pk
1
2

# DELETE: deleted row must drop out after refresh; disjunction merge across
# the remaining clusters (now via MaskDocIterator) still correct.
statement ok
DELETE FROM sq8_mc_dml WHERE pk = 1

statement ok
VACUUM (REFRESH_TABLE) sq8_mc_dml

query
SELECT pk FROM sq8_mc_dml_idx ORDER BY emb <-> [100, 0, 0]::FLOAT[3] LIMIT 2;
----
pk
2
5

query
SELECT count(*) FROM sq8_mc_dml_idx;
----
count
7

# UPDATE indexed vector: pk=7 moves cluster, from [-70,0,0] to [0,0,-90].
statement ok
UPDATE sq8_mc_dml SET emb = [0, 0, -90]::FLOAT[3] WHERE pk = 7

statement ok
VACUUM (REFRESH_TABLE) sq8_mc_dml

query
SELECT pk FROM sq8_mc_dml_idx ORDER BY emb <-> [0, 0, -89]::FLOAT[3] LIMIT 1;
----
pk
7

query
SELECT pk FROM sq8_mc_dml_idx ORDER BY emb <-> [-71, 0, 0]::FLOAT[3] LIMIT 1;
----
pk
8

# multi-segment: a second refreshed batch creates a new segment; kNN merges
# across per-cluster disjunctions from both segments.
statement count 2
INSERT INTO sq8_mc_dml VALUES
  (9, [200, 0, 0]::FLOAT[3], 'i'),
  (10, [0, 200, 0]::FLOAT[3], 'j')

statement ok
VACUUM (REFRESH_TABLE) sq8_mc_dml

query
SELECT pk FROM sq8_mc_dml_idx ORDER BY emb <-> [199, 0, 0]::FLOAT[3] LIMIT 1;
----
pk
9

# COMPACT after deletes across segments/clusters: physical removal, results
# stable (back to the plain no-mask disjunction path after compaction).
statement ok
DELETE FROM sq8_mc_dml WHERE pk IN (2, 9)

statement ok
VACUUM (COMPACT_TABLE) sq8_mc_dml

query
SELECT pk FROM sq8_mc_dml_idx ORDER BY emb <-> [100, 0, 0]::FLOAT[3] LIMIT 1;
----
pk
5

query
SELECT count(*) FROM sq8_mc_dml_idx;
----
count
7

# hybrid: WHERE filter combined with kNN on the multi-cluster index.
query
SELECT pk, label FROM sq8_mc_dml_idx
  WHERE label IN ('c', 'd', 'e', 'f') ORDER BY emb <-> [0, 0, 89]::FLOAT[3] LIMIT 2;
----
pk	label
6	f
5	e

# ===========================================================================
# 9. Tombstone the whole nearest cluster (both x-axis rows) as a docs_mask
#    overlay -- DELETE without COMPACT. With a live docs_mask the top-k scan
#    must return the seekable disjunction wrapped in a MaskDocIterator, not
#    the collect-only DisjointClusterUnion fast path (valid only when
#    docs_mask == nullptr); the survivors come from the other clusters.
# ===========================================================================

statement ok
CREATE TABLE sq8_del_mask (pk INTEGER PRIMARY KEY, emb FLOAT[3])

statement ok
CREATE INDEX sq8_del_mask_idx ON sq8_del_mask
  USING inverted(pk, emb ivf (metric = 'l2', quant = 'sq8'))

statement count 6
INSERT INTO sq8_del_mask VALUES
  (1, [100, 0, 0]::FLOAT[3]),
  (2, [102, 0, 0]::FLOAT[3]),
  (3, [0, 0, 40]::FLOAT[3]),
  (4, [0, 60, 0]::FLOAT[3]),
  (5, [0, 0, 90]::FLOAT[3]),
  (6, [-80, 0, 0]::FLOAT[3])

statement ok
VACUUM (REFRESH_TABLE) sq8_del_mask

statement ok
SET sdb_nprobe = 1000

# baseline: the two x-axis rows are the nearest to [100, 0, 0].
query
SELECT pk FROM sq8_del_mask_idx ORDER BY emb <-> [100, 0, 0]::FLOAT[3] LIMIT 2;
----
pk
1
2

statement ok
DELETE FROM sq8_del_mask WHERE pk IN (1, 2)

statement ok
VACUUM (REFRESH_TABLE) sq8_del_mask

# top-k skips both tombstoned rows and returns the cross-cluster survivors in
# order (pk=3 at [0,0,40], then pk=4 at [0,60,0]); must not assert.
query
SELECT pk FROM sq8_del_mask_idx ORDER BY emb <-> [100, 0, 0]::FLOAT[3] LIMIT 2;
----
pk
3
4

query
SELECT count(*) FROM sq8_del_mask_idx;
----
count
4
