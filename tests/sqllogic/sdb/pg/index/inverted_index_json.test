# Same JSON path indexed once, but two tokenizers are in flight at the
# same time: the user-configured keyword tokenizer for string
# leaves, and the built-in NumericTokenizer for integer/float leaves.
# Both work without re-declaring the path -- the sink dispatches per leaf
# type to the matching pre-emitted iresearch field.

statement ok
CREATE TABLE mixed_tok (id INTEGER PRIMARY KEY, content JSON);

statement ok
CREATE INDEX mixed_tok_idx ON mixed_tok USING inverted(
    id, (content->'val') verbatim_dict);

statement ok
INSERT INTO mixed_tok VALUES
    (1, '{"val":"hello"}'::json),
    (2, '{"val":42}'::json),
    (3, '{"val":"world"}'::json),
    (4, '{"val":7}'::json);

statement ok
VACUUM (REFRESH_TABLE) mixed_tok;

# Keyword tokenizer side: exact-match string lookup hits the string-mangled
# field.
query
SELECT id FROM mixed_tok_idx WHERE content->>'val' = 'hello';
----
id
1

# Numeric tokenizer side: integer cast routes to the numeric-mangled field
# without ever evaluating the cast on string-leaf rows.
query
SELECT id FROM mixed_tok_idx WHERE (content->'val')::int = 42;
----
id
2

# Range filter on the numeric side.
query
SELECT id FROM mixed_tok_idx WHERE (content->'val')::double > 10 ORDER BY id;
----
id
2



# --- JSON path under a text dictionary (frequency+position features) ----
#
# Text dicts add Freq+Pos to the string-leaf field. Pre-PR the JSON path
# wrote every leaf (numeric/bool/string/null) into a single iresearch field
# with the analyzer's features, which made the numeric/bool/null writes
# slot-incompatible with the text's Freq+Pos request and silently dropped
# them. The per-kind field_id split puts each leaf in its own term-dict
# slot, so the numeric/bool/null leaves can keep IndexFeatures::None
# alongside the string leaf's Freq+Pos.

statement ok
CREATE TEXT SEARCH DICTIONARY en_text(
    template = 'text', locale = 'en_US.UTF-8', case = 'none',
    stemming = false, accent = false, frequency = true, position = true);

statement ok
CREATE TABLE json_text (id INTEGER PRIMARY KEY, content JSON);

statement ok
CREATE INDEX json_text_idx ON json_text USING inverted(
    id, (content->'v') en_text);

statement ok
INSERT INTO json_text VALUES
    (1, '{"v":42}'::json),
    (2, '{"v":"the quick brown fox"}'::json),
    (3, '{"v":true}'::json),
    (4, '{"v":null}'::json),
    (5, '{"v":3.14}'::json);

statement ok
VACUUM (REFRESH_TABLE) json_text;

# Numeric / bool / null leaves are stored under their own field_ids with
# IndexFeatures::None, and routed by the typed-cast filter at read time.
query
SELECT id FROM json_text_idx WHERE (content->'v')::int = 42;
----
id
1

query
SELECT id FROM json_text_idx WHERE (content->'v')::double > 3 ORDER BY id;
----
id
1
5

query
SELECT id FROM json_text_idx WHERE (content->'v')::bool = true;
----
id
3

# String leaf is text-tokenized through the en_text analyzer; ts_tokenize
# emits the same tokens, so terms / phrases work.
query
SELECT id FROM json_text_idx WHERE (content->'v') @@ ts_tokenize('quick', 'en_text');
----
id
2

query
SELECT id FROM json_text_idx WHERE (content->'v') @@ ts_tokenize('brown fox', 'en_text');
----
id
2

# Negative-feature assertion: the numeric / bool / null leaves were created
# with IndexFeatures::None, so a phrase query (which requires Pos) routed
# against the string leaf only matches docs whose string value carries the
# phrase. Row 2 is the only string-leaf row; the numeric / bool / null
# rows do not match. If a regression re-introduces the pre-PR shape where
# every leaf is written through the analyzer's feature mask, the phrase
# would silently widen its match set (positions land on numeric/bool
# leaves and coincidental adjacency starts matching).
query
SELECT id FROM json_text_idx WHERE (content->'v') @@ ts_phrase('quick brown fox');
----
id
2



# --- Same expression listed twice with different tokenizers is rejected.
# The catalog stores a single tokenizer per indexed expression; without an
# explicit check this would silently dedup on serialization and drop one
# tokenizer's data on the floor. Block at CREATE INDEX so the user sees
# exactly which expression was listed twice.

statement ok
CREATE TABLE dup_expr_err (id INTEGER PRIMARY KEY, content JSON);

statement error
CREATE INDEX dup_expr_err_idx ON dup_expr_err
USING inverted(id, (content->'v') verbatim_dict, (content->'v') en_text);
----
db error: ERROR: Failed to create index: Expression '("content" -> 'v')' is listed more than once with a tokenizer opclass; the catalog stores a single tokenizer per indexed expression. Stack `included(...)` on the same expression instead, or remove the duplicate.



# --- #> and #>> operators ------------------------------------------------

# Single-segment text[] path with #>>.  Index expression and query
# expression must use the same operator -- canonical bytes differ across
# forms today.
statement ok
CREATE TABLE hashpath_single (id INTEGER PRIMARY KEY, content JSON);

statement ok
CREATE INDEX hashpath_single_idx ON hashpath_single
USING inverted(id, (content #>> '{host}') verbatim_dict);

statement ok
INSERT INTO hashpath_single VALUES
    (1, '{"host":"server-01","status":"ok"}'::json),
    (2, '{"host":"server-02","status":"ok"}'::json),
    (3, '{"host":"server-03","status":"err"}'::json);

statement ok
VACUUM (REFRESH_TABLE) hashpath_single;

query
SELECT id FROM hashpath_single_idx
WHERE content #>> '{host}' @@ ts_like('server-0_') ORDER BY id;
----
id
1
2
3

query
SELECT id FROM hashpath_single_idx
WHERE content #>> '{host}' @@ ts_like('server-02');
----
id
2



# Multi-segment text[] path with #>>.  Same key sequence as
# `content -> 'a' -> 'b' ->> 'c'` semantically, but bytes differ so we
# index/query using the same #>> form throughout.
statement ok
CREATE TABLE hashpath_multi (id INTEGER PRIMARY KEY, content JSON);

statement ok
CREATE INDEX hashpath_multi_idx ON hashpath_multi
USING inverted(id, (content #>> '{user, name}') verbatim_dict);

statement ok
INSERT INTO hashpath_multi VALUES
    (1, '{"user":{"name":"alice","age":30}}'::json),
    (2, '{"user":{"name":"bob","age":25}}'::json),
    (3, '{"user":{"name":"alice","age":40}}'::json);

statement ok
VACUUM (REFRESH_TABLE) hashpath_multi;

query
SELECT id FROM hashpath_multi_idx
WHERE content #>> '{user, name}' @@ ts_like('alice') ORDER BY id;
----
id
1
3



# #> returning JSON, chained with ->> to extract a text leaf.  Combination
# form: outer JSON-extract is `->>` (text out), inner is `#>` (json out).
statement ok
CREATE TABLE hashpath_chain (id INTEGER PRIMARY KEY, content JSON);

statement ok
CREATE INDEX hashpath_chain_idx ON hashpath_chain
USING inverted(id, ((content #> '{user}')->>'name') verbatim_dict);

statement ok
INSERT INTO hashpath_chain VALUES
    (1, '{"user":{"name":"carol","role":"admin"}}'::json),
    (2, '{"user":{"name":"dave","role":"user"}}'::json),
    (3, '{"user":{"name":"carol","role":"user"}}'::json);

statement ok
VACUUM (REFRESH_TABLE) hashpath_chain;

query
SELECT id FROM hashpath_chain_idx
WHERE (content #> '{user}')->>'name' @@ ts_like('carol') ORDER BY id;
----
id
1
3



# Inverted combination: outer `#>>` on the result of an inner `->`.
statement ok
CREATE TABLE chain_to_hash (id INTEGER PRIMARY KEY, content JSON);

statement ok
CREATE INDEX chain_to_hash_idx ON chain_to_hash
USING inverted(id, ((content -> 'user') #>> '{name}') verbatim_dict);

statement ok
INSERT INTO chain_to_hash VALUES
    (1, '{"user":{"name":"eve"}}'::json),
    (2, '{"user":{"name":"frank"}}'::json);

statement ok
VACUUM (REFRESH_TABLE) chain_to_hash;

query
SELECT id FROM chain_to_hash_idx
WHERE (content -> 'user') #>> '{name}' @@ ts_like('eve');
----
id
1


# UPDATE re-indexes the JSON leaf: old token gone, new token searchable.
statement ok
CREATE TABLE dml_t (id INTEGER PRIMARY KEY, content JSON);

statement ok
CREATE INDEX dml_idx ON dml_t USING inverted(id, (content->>'host') verbatim_dict);

statement ok
INSERT INTO dml_t VALUES
    (1, '{"host":"alpha"}'::json),
    (2, '{"host":"beta"}'::json);

statement ok
VACUUM (REFRESH_TABLE) dml_t;

statement ok
UPDATE dml_t SET content = '{"host":"gamma"}'::json WHERE id = 1;

statement ok
VACUUM (REFRESH_TABLE) dml_t;

query
SELECT id FROM dml_idx WHERE content->>'host' = 'alpha';
----
id

query
SELECT id FROM dml_idx WHERE content->>'host' = 'gamma';
----
id
1


# DELETE removes the row's JSON leaf from the index.
statement ok
DELETE FROM dml_t WHERE id = 2;

statement ok
VACUUM (REFRESH_TABLE) dml_t;

query
SELECT id FROM dml_idx WHERE content->>'host' = 'beta';
----
id

query
SELECT id FROM dml_idx WHERE content->>'host' = 'gamma';
----
id
1


# --- INCLUDE columns alongside a JSON-path indexed expression ------------
# The JSON path is treated as a regular indexed expression in the catalog;
# INCLUDE columns must coexist with it the same way they coexist with any
# other indexed-expression entry.

statement ok
CREATE TABLE jp_inc(id INTEGER PRIMARY KEY, doc JSON, label VARCHAR);

statement ok
INSERT INTO jp_inc VALUES
  (1, '{"host":"a","val":10}', 'first'),
  (2, '{"host":"b","val":20}', 'second'),
  (3, '{"host":"a","val":30}', 'third');

statement ok
CREATE INDEX jp_inc_idx ON jp_inc
  USING inverted(id, (doc->>'host') verbatim_dict)
  INCLUDE (label);

statement ok
VACUUM (REFRESH_TABLE) jp_inc;

query
SELECT id, label FROM jp_inc_idx WHERE doc->>'host' = 'a' ORDER BY id;
----
id	label
1	first
3	third

query
SELECT id, label FROM jp_inc_idx WHERE doc->>'host' = 'b' ORDER BY id;
----
id	label
2	second


# JSON-typed expression (no `->>`) with INCLUDE: the multi-field aux
# dispatch indexes each leaf type into its own mangled sub-field while
# `label` is stored as an INCLUDE column.

statement ok
CREATE TABLE jp_inc2(id INTEGER PRIMARY KEY, doc JSON, label VARCHAR);

statement ok
INSERT INTO jp_inc2 VALUES
  (1, '{"val":42}', 'a'),
  (2, '{"val":99}', 'b'),
  (3, '{"val":42}', 'c');

statement ok
CREATE INDEX jp_inc2_idx ON jp_inc2
  USING inverted(id, (doc->'val') verbatim_dict)
  INCLUDE (label);

statement ok
VACUUM (REFRESH_TABLE) jp_inc2;

query
SELECT id, label FROM jp_inc2_idx WHERE (doc->'val')::int = 42 ORDER BY id;
----
id	label
1	a
3	c

query
SELECT id, label FROM jp_inc2_idx WHERE (doc->'val')::int = 99 ORDER BY id;
----
id	label
2	b


# Mixed-leaf-type rows + INCLUDE column projection. The index splits the
# JSON value by leaf type into separate sub-fields; cast-typed filters
# from the query side must each retrieve their row through the matching
# sub-field, with the INCLUDE column projected alongside.

statement ok
CREATE TABLE jp_inc_mixed(id INTEGER PRIMARY KEY, doc JSON, label VARCHAR);

statement ok
INSERT INTO jp_inc_mixed VALUES
  (1, '{"val":42}',      'int-row'),
  (2, '{"val":"hello"}', 'str-row'),
  (3, '{"val":3.14}',    'flt-row'),
  (4, '{"val":true}',    'bool-row');

statement ok
CREATE INDEX jp_inc_mixed_idx ON jp_inc_mixed
  USING inverted(id, (doc->'val') verbatim_dict)
  INCLUDE (label);

statement ok
VACUUM (REFRESH_TABLE) jp_inc_mixed;

query
SELECT id, label FROM jp_inc_mixed_idx ORDER BY id;
----
id	label
1	int-row
2	str-row
3	flt-row
4	bool-row


# `included` opclass with a compression option for the INCLUDE column,
# combined with a JSON-path indexed expression.

statement ok
CREATE TABLE jp_inc3(id INTEGER PRIMARY KEY, doc JSON, big BIGINT);

statement ok
INSERT INTO jp_inc3 VALUES
  (1, '{"host":"x"}', 1000),
  (2, '{"host":"y"}', 2000),
  (3, '{"host":"x"}', 3000);

statement ok
CREATE INDEX jp_inc3_idx ON jp_inc3
  USING inverted(id, (doc->>'host') verbatim_dict)
  INCLUDE (big included (compression = 'uncompressed'));

statement ok
VACUUM (REFRESH_TABLE) jp_inc3;

query
SELECT id, big FROM jp_inc3_idx WHERE doc->>'host' = 'x' ORDER BY id;
----
id	big
1	1000
3	3000

query
SELECT id, big FROM jp_inc3_idx WHERE doc->>'host' = 'y' ORDER BY id;
----
id	big
2	2000
