query
SELECT pk FROM g11_c_expr_st WHERE t16 * 2::SMALLINT @@ ts_between(150::SMALLINT, 250::SMALLINT, true, true) ORDER BY pk;
----
pk
2


# (d) UTINYINT / USMALLINT / UINTEGER scalar via expression -- view-backed.
statement count 2
COPY (SELECT * FROM (VALUES
  (1, 5::UTINYINT,   500::USMALLINT,   5000::UINTEGER,       'a'),
  (2, 250::UTINYINT, 60000::USMALLINT, 4000000000::UINTEGER, 'b')
) AS t(pk, u8, u16, u32, tag))
TO '${__TEST_DIR__}/sdb_g11_unsigned.parquet' (FORMAT parquet);

statement ok
CREATE VIEW g11_d_v AS SELECT * FROM read_parquet('${__TEST_DIR__}/sdb_g11_unsigned.parquet');

statement ok
CREATE INDEX g11_d_u8_expr_st  ON g11_d_v USING inverted(pk, (u8  + 1::UTINYINT))  INCLUDE (tag);

statement ok
CREATE INDEX g11_d_u16_expr_st ON g11_d_v USING inverted(pk, (u16 + 1::USMALLINT)) INCLUDE (tag);

statement ok
CREATE INDEX g11_d_u32_expr_st ON g11_d_v USING inverted(pk, (u32 + 1::UINTEGER))  INCLUDE (tag);

query
SELECT pk FROM g11_d_u8_expr_st  WHERE u8  + 1::UTINYINT  @@ ts_between(100::UTINYINT,  255::UTINYINT,  true, true) ORDER BY pk;
----
pk
2

query
SELECT pk FROM g11_d_u16_expr_st WHERE u16 + 1::USMALLINT @@ ts_between(50000::USMALLINT, 65535::USMALLINT, true, true) ORDER BY pk;
----
pk
2

query
SELECT pk FROM g11_d_u32_expr_st WHERE u32 + 1::UINTEGER  @@ ts_between(1000::UINTEGER, 10000::UINTEGER, true, true) ORDER BY pk;
----
pk
1


# (e) TIME / TIMESTAMP_MS / TIMESTAMP_NS scalar via expression -- view-backed.
statement count 2
COPY (SELECT * FROM (VALUES
  (1, TIME '01:23:45',
      TIMESTAMP_MS '2024-01-01 00:00:00',
      TIMESTAMP_NS '2024-01-01 00:00:00',
      'a'),
  (2, TIME '23:00:00',
      TIMESTAMP_MS '2024-06-15 12:00:00',
      TIMESTAMP_NS '2024-06-15 12:00:00',
      'b')
) AS t(pk, tt, ts_ms, ts_ns, tag))
TO '${__TEST_DIR__}/sdb_g11_temporal.parquet' (FORMAT parquet);

statement ok
CREATE VIEW g11_e_v AS SELECT * FROM read_parquet('${__TEST_DIR__}/sdb_g11_temporal.parquet');

statement ok
CREATE INDEX g11_e_tt_expr_st    ON g11_e_v USING inverted(pk, (tt    + INTERVAL '1 second')) INCLUDE (tag);

statement ok
CREATE INDEX g11_e_ts_ms_expr_st ON g11_e_v USING inverted(pk, (ts_ms + INTERVAL '1 hour'))   INCLUDE (tag);

statement ok
CREATE INDEX g11_e_ts_ns_expr_st ON g11_e_v USING inverted(pk, (ts_ns + INTERVAL '1 hour'))   INCLUDE (tag);

query
SELECT pk FROM g11_e_tt_expr_st
WHERE tt + INTERVAL '1 second' @@ ts_between(TIME '00:00:00', TIME '12:00:00', true, true) ORDER BY pk;
----
pk
1

query
SELECT pk FROM g11_e_ts_ms_expr_st
WHERE ts_ms + INTERVAL '1 hour' @@ ts_between(TIMESTAMP_MS '2024-03-01', TIMESTAMP_MS '2024-12-31', true, true) ORDER BY pk;
----
pk
2

query
SELECT pk FROM g11_e_ts_ns_expr_st
WHERE ts_ns + INTERVAL '1 hour' @@ ts_between(TIMESTAMP_NS '2024-03-01', TIMESTAMP_NS '2024-12-31', true, true) ORDER BY pk;
----
pk
2


