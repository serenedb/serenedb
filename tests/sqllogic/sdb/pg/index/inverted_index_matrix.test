   [TIMESTAMP_MS '2024-01-01 00:00:00', TIMESTAMP_MS '2024-02-01 00:00:00'],
   [TIMESTAMP_NS '2024-01-01 00:00:00', TIMESTAMP_NS '2024-02-01 00:00:00'],
   '01:23:45+02'::TIMETZ,
