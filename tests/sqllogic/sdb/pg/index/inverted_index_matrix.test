# ============================================================================
# Indexes with no user-indexed columns -- only the implicit PK-blob field
# (added by every inverted index so DELETE-from-index can locate rows).
# `USING inverted INCLUDE (...)` is the canonical syntax for this.
# ============================================================================

statement ok
CREATE TABLE m_pk_only(pk INTEGER PRIMARY KEY, v VARCHAR, n INTEGER);

statement ok
CREATE INDEX m_pk_only_one  ON m_pk_only USING inverted INCLUDE (v);

statement ok
CREATE INDEX m_pk_only_many ON m_pk_only USING inverted INCLUDE (v, n);

statement ok
INSERT INTO m_pk_only VALUES (1, 'alpha', 10), (2, 'beta', 20), (3, 'gamma', 30);

statement ok
VACUUM (REFRESH_TABLE) m_pk_only;

query
SELECT count(*) FROM m_pk_only_one;
----
count
3

query
SELECT pk, v FROM m_pk_only_one ORDER BY pk;
----
pk	v
1	alpha
2	beta
3	gamma

query
SELECT pk, v, n FROM m_pk_only_many ORDER BY pk;
----
pk	v	n
1	alpha	10
2	beta	20
3	gamma	30


# ============================================================================
# Width fan-out — TINYINT (i8) and SMALLINT (i16) join the I32/I64 family but
# share the same encoder; flush a sign-extension regression with their own
# rows.  UTINYINT / USMALLINT / UINTEGER / HUGEINT / UUID / DECIMAL / TIME /
# TIMESTAMP_MS / TIMESTAMP_NS / INTERVAL are catalog-accepted but rocksdb
# refuses to serialize them today, so they're left out.
# ============================================================================

statement ok
CREATE TABLE m_narrow(pk INTEGER PRIMARY KEY, t8 TINYINT, t16 SMALLINT);

statement ok
CREATE INDEX m_narrow_t8  ON m_narrow USING inverted(pk, t8) INCLUDE (t8);

statement ok
CREATE INDEX m_narrow_t16 ON m_narrow USING inverted(pk, t16);

statement ok
INSERT INTO m_narrow VALUES (1, -10::TINYINT, -100::SMALLINT), (2, 10::TINYINT, 100::SMALLINT);

statement ok
VACUUM (REFRESH_TABLE) m_narrow;

query
SELECT pk FROM m_narrow_t8 WHERE t8 @@ ts_between(-50::TINYINT, -5::TINYINT, true, true);
----
pk
1

query
SELECT pk FROM m_narrow_t16 WHERE t16 @@ ts_between(-200::SMALLINT, 50::SMALLINT, true, true);
----
pk
1


