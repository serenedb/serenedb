statement ok
CREATE INDEX g17_b_col_at_st  ON g17_b USING inverted(pk, b any_text_dict)  INCLUDE (b);

statement ok
CREATE INDEX g17_b_expr_at_ns ON g17_b USING inverted(pk, (decode(encode(b, 'hex'), 'hex')) any_text_dict);

statement ok
