CREATE INDEX m_i_list_col_ns    ON m_i USING inverted(pk, ns);

statement ok
CREATE INDEX m_i_array_col_st   ON m_i USING inverted(pk, na) INCLUDE (na);

statement ok
CREATE INDEX m_i_array_col_ns   ON m_i USING inverted(pk, na);

statement ok
CREATE INDEX m_i_expr_ns        ON m_i USING inverted(pk, (n * 2));

statement ok
INSERT INTO m_i VALUES
    (1, 10, [10, 20, 30],    [10, 20, 30]),
