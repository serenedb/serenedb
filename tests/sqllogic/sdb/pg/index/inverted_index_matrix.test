# ============================================================================
# geopoint analyzer  --  JSON-only geo class
# ----------------------------------------------------------------------------
# Fourth geo class alongside geo_s2_dict / geo_src_dict / geojson_shape: the
# geopoint analyzer reads coordinates from configured JSON keys (latitude /
# longitude). Acceptance is JSON-only -- GEOMETRY columns are explicitly
# rejected (geopoint's JSON-path config is meaningless on WKB), and any
# non-JSON / non-GEOMETRY scalar (VARCHAR, BLOB, INTEGER) trips the generic
# geo-analyzer column-type check in ValidateTokenizerVsColumn.
# ============================================================================

statement ok
CREATE TEXT SEARCH DICTIONARY geopoint_dict(template = 'geopoint', latitude = 'lat', longitude = 'lng');

statement ok
CREATE TABLE g4_j(pk INTEGER PRIMARY KEY, j JSON);

statement ok
