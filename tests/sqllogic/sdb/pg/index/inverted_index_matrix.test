# Implicit (no opclass) path still accepts numeric / temporal / boolean columns.
statement ok
CREATE INDEX m_reject_imp ON m_reject USING inverted(pk, i, bi, bo, dt, ts);


# ============================================================================
# any-class text-family analyzer  --  scalar / LIST / ARRAY accepted shapes,
# expression source, and validator rejections (INTEGER scalar, JSON inside
# LIST, GEOMETRY scalar).
# ============================================================================

statement ok
CREATE TEXT SEARCH DICTIONARY any_text_dict(template = 'text', locale = 'en_US.UTF-8', case = 'none', stemming = false, accent = false, frequency = true, position = true);

statement ok
CREATE TABLE g1_v(pk INTEGER PRIMARY KEY, v VARCHAR);

statement ok
CREATE INDEX g1_v_col_text_st ON g1_v USING inverted(pk, v any_text_dict) INCLUDE (v);

