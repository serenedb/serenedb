# ============================================================================
# g16: implicit-rejection (no opclass) for the unsupported-leaf types g5
#      didn't cover -- UBIGINT, UHUGEINT, BIT, ENUM, VARIANT -- plus LIST
#      and ARRAY whose child is itself an unsupported leaf (HUGEINT, DECIMAL,
#      INTERVAL, UUID). All paths land on term_dict::Validate's unsupported()
#      branch (server/catalog/inverted_index.cpp:251-255 / 264-265 / 270-271),
#      which produces the verbatim "has unsupported type X and can not be
#      indexed" message. BIGNUM is omitted: the inventory provides no
#      reachability recipe, so we don't gamble on CREATE TABLE accepting it.
# ============================================================================

statement ok
CREATE TYPE g16_enum_t AS ENUM ('alpha', 'beta', 'gamma');


statement ok
CREATE TABLE g16_t(pk INTEGER PRIMARY KEY,
                   ub UBIGINT,
                   uh UHUGEINT,
                   bi BIT,
                   en g16_enum_t,
                   vr VARIANT,
                   lh HUGEINT[],
                   ld DECIMAL(10,2)[],
                   li INTERVAL[],
                   lu UUID[],
                   ah HUGEINT[2],
                   ad DECIMAL(10,2)[2]);


# (a) implicit (no opclass) on UBIGINT: term_dict classifies UBIGINT as
#     Unsupported (Classify default arm), so Validate rejects.
statement error
CREATE INDEX g16_imp_ub ON g16_t USING inverted(pk, ub);
----
db error: ERROR: Failed to create index: Column 'ub' has unsupported type UBIGINT and can not be indexed


# (b) implicit (no opclass) on UHUGEINT: 128-bit unsigned, Unsupported.
statement error
CREATE INDEX g16_imp_uh ON g16_t USING inverted(pk, uh);
----
db error: ERROR: Failed to create index: Column 'uh' has unsupported type UHUGEINT and can not be indexed


# (c) implicit (no opclass) on BIT: bitstring is Unsupported.
statement error
CREATE INDEX g16_imp_bi ON g16_t USING inverted(pk, bi);
----
db error: ERROR: Failed to create index: Column 'bi' has unsupported type BIT and can not be indexed


# (d) implicit (no opclass) on ENUM: the type's alias (from CREATE TYPE) is
#     what ToString surfaces, so the error names the user-visible type name.
statement error
CREATE INDEX g16_imp_en ON g16_t USING inverted(pk, en);
----
db error: ERROR: Failed to create index: Column 'en' has unsupported type g16_enum_t and can not be indexed


# (e) implicit (no opclass) on VARIANT: STRUCT-backed catch-all type, Unsupported.
statement error
CREATE INDEX g16_imp_vr ON g16_t USING inverted(pk, vr);
----
db error: ERROR: Failed to create index: Column 'vr' has unsupported type VARIANT and can not be indexed


# (f) implicit (no opclass) on LIST<HUGEINT>: container path in Validate
#     inspects the child kind; HUGEINT is Unsupported, so the list is rejected
#     with the rendered "<child>[]" type string.
statement error
CREATE INDEX g16_imp_lh ON g16_t USING inverted(pk, lh);
----
db error: ERROR: Failed to create index: Column 'lh' has unsupported type HUGEINT[] and can not be indexed


# (g) implicit (no opclass) on LIST<DECIMAL(10,2)>: same container path.
statement error
CREATE INDEX g16_imp_ld ON g16_t USING inverted(pk, ld);
----
db error: ERROR: Failed to create index: Column 'ld' has unsupported type DECIMAL(10,2)[] and can not be indexed


# (h) implicit (no opclass) on LIST<INTERVAL>.
statement error
CREATE INDEX g16_imp_li ON g16_t USING inverted(pk, li);
----
db error: ERROR: Failed to create index: Column 'li' has unsupported type INTERVAL[] and can not be indexed


# (i) implicit (no opclass) on LIST<UUID>.
statement error
CREATE INDEX g16_imp_lu ON g16_t USING inverted(pk, lu);
----
db error: ERROR: Failed to create index: Column 'lu' has unsupported type UUID[] and can not be indexed


# (j) implicit (no opclass) on ARRAY<HUGEINT,2>: the container branch renders
#     fixed-size arrays as "<child>[N]" (types.cpp:474).
statement error
CREATE INDEX g16_imp_ah ON g16_t USING inverted(pk, ah);
----
db error: ERROR: Failed to create index: Column 'ah' has unsupported type HUGEINT[2] and can not be indexed


# (k) implicit (no opclass) on ARRAY<DECIMAL(10,2),2>: same array path.
statement error
CREATE INDEX g16_imp_ad ON g16_t USING inverted(pk, ad);
----
db error: ERROR: Failed to create index: Column 'ad' has unsupported type DECIMAL(10,2)[2] and can not be indexed





# ============================================================================
# g17 -- Tokenizer-completeness for LIST/ARRAY columns + expression-source
# LIST/ARRAY across all tokenizers.
#
# Two gaps filled in one section:
#
#  (1) Column-source LIST/ARRAY coverage was uneven. kw_dict already had a
#      full grid (m_vla, m_bla, g7_*), but ng_dict and any_text_dict only
#      covered LIST<VARCHAR> + a BLOB scalar slice. g17 adds the missing
#      ng_dict-on-ARRAY<VARCHAR,3>/LIST<BLOB>/ARRAY<BLOB,3>, JSON-scalar
#      cells for both ng_dict and any_text_dict (JSON is a VARCHAR alias,
#      so the tokenizer validator accepts it), and BLOB-scalar-with-INCLUDE
#      sidecars under each tokenizer.
#
#  (2) Expression-source LIST/ARRAY was zero across the board. No prior
#      test placed a parenthesized identity expression on VARCHAR[],
#      VARCHAR[N], BLOB[], BLOB[N] under kw_dict / ng_dict / any_text_dict /
#      implicit. g17 builds that entire matrix, plus implicit-path
#      expression-source LIST<JSON>.
#
# Reuses existing dicts (kw_dict, ng_dict, any_text_dict) -- no new dict
# declarations. All cells in g17 are validator-positive; the negative cells
# (LIST<JSON> + tokenizer, LIST<GEOMETRY>) are already pinned by m_jl_*,
# g1_reject_*, m_gl_*, g7_gl, and g7_ga.
# ============================================================================

statement ok
CREATE TABLE g17_v(pk INTEGER PRIMARY KEY, v VARCHAR);

statement ok
CREATE TABLE g17_b(pk INTEGER PRIMARY KEY, b BLOB);

statement ok
CREATE TABLE g17_j(pk INTEGER PRIMARY KEY, j JSON);

statement ok
CREATE TABLE g17_vla(pk INTEGER PRIMARY KEY, vs VARCHAR[], va VARCHAR[3]);

statement ok
CREATE TABLE g17_bla(pk INTEGER PRIMARY KEY, bs BLOB[], ba BLOB[3]);

statement ok
CREATE TABLE g17_jl(pk INTEGER PRIMARY KEY, js JSON[]);


# --- (f) ng_dict on VARCHAR expression source (no INCLUDE) ------------------

statement ok
CREATE INDEX g17_v_expr_ng ON g17_v USING inverted(pk, (upper(v)) ng_dict);

statement ok
INSERT INTO g17_v VALUES (1, 'alpha'), (2, 'beta');

statement ok
VACUUM (REFRESH_TABLE) g17_v;

query
SELECT count(*) FROM g17_v_expr_ng;
----
count
2


# --- (e) ng_dict on BLOB scalar WITH INCLUDE --------------------------------
# --- (h) any_text_dict on BLOB scalar WITH INCLUDE --------------------------
