# LIST<GEOMETRY> and ARRAY<GEOMETRY> rejected by the explicit special-case
# in term_dict::Validate (inverted_index.cpp:262), even though scalar
# GEOMETRY classifies as String-kind and is accepted on its own.

statement ok
CREATE TABLE g7_gl(pk INTEGER PRIMARY KEY,
                   gs GEOMETRY('OGC:CRS84')[],
                   ga GEOMETRY('OGC:CRS84')[3]);

statement error
CREATE INDEX g7_gl_imp ON g7_gl USING inverted(pk, gs);
----
db error: ERROR: Failed to create index: Column 'gs' has unsupported type GEOMETRY('OGC:CRS84')[] and can not be indexed


statement error
CREATE INDEX g7_ga_imp ON g7_gl USING inverted(pk, ga);
----
