statement ok
CREATE TABLE m_g(pk INTEGER PRIMARY KEY, g GEOMETRY('OGC:CRS84'));

statement ok
CREATE INDEX m_g_col_s2_st   ON m_g USING inverted(pk, g geo_s2_dict)  INCLUDE (g);

statement ok
CREATE INDEX m_g_col_src_ns  ON m_g USING inverted(pk, g geo_src_dict);

statement ok
CREATE INDEX m_g_expr_s2_ns  ON m_g USING inverted(pk, (g) geo_s2_dict);

statement ok
CREATE INDEX m_g_expr_src_ns ON m_g USING inverted(pk, (g) geo_src_dict);

statement ok
INSERT INTO m_g VALUES
    (1, 'POINT(0 0)'::GEOMETRY('OGC:CRS84')),
    (2, 'POINT(10 20)'::GEOMETRY('OGC:CRS84')),
    (3, 'POINT(-5 47)'::GEOMETRY('OGC:CRS84'));

