  (2,
   [TIMESTAMPTZ '2024-06-15 12:00:00+00', TIMESTAMPTZ '2024-07-15 12:00:00+00'],
   [TIME '23:00:00', TIME '23:30:00'],
   [TIMESTAMP_MS '2024-06-15 12:00:00', TIMESTAMP_MS '2024-07-15 12:00:00'],
   [TIMESTAMP_NS '2024-06-15 12:00:00', TIMESTAMP_NS '2024-07-15 12:00:00'],
   '23:00:00+05'::TIMETZ,
   '23:00:00.987654321'::TIME_NS)
) AS t(pk, list_tstz, list_tt, list_tsms, list_tsns, ttz, tns))
TO '${__TEST_DIR__}/sdb_g19_temporal.parquet' (FORMAT parquet);

