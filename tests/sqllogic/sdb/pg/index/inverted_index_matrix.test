# ============================================================================
# g12 -- geopoint analyzer: cells omitted by g4
# ----------------------------------------------------------------------------
# g4 covered geopoint on JSON scalar (col, expr) + the three primary
# rejections (GEOMETRY scalar, VARCHAR, BLOB, INTEGER). Cells still missing:
#   (a) JSON scalar + INCLUDE(col)              -- accept (mirrors g4 explicitly)
#   (b) JSON-returning expression + INCLUDE     -- accept (sidecar on tag)
#   (c) LIST<JSON>                              -- reject (falls through
#       IsJSONType() in ValidateTokenizerVsColumn; LIST itself is not JSON)
#   (d) ARRAY<JSON, 2>                          -- reject (same reason)
#   (e) LIST<GEOMETRY>                          -- reject EARLY in
#       term_dict::Validate (LIST<GEOMETRY> child trips the
#       `child == GEOMETRY` short-circuit before the geo-analyzer validator
#       sees the type) -- same wording as m_gl_geo_list / m_gl_kw_list.
#   (f) VARCHAR (non-JSON)                      -- reject, generic geo error
#   (g) BLOB scalar                             -- reject, generic geo error
#   (h) INTEGER scalar                          -- reject, generic geo error
#   (i) GEOMETRY scalar (CRS84)                 -- reject, geopoint-specific
#                                                  "JSON-only" message
# Probe lane mirrors g4_j_col_geo_st: `<->` distance to a GeoJSON Point
# literal (ts_within / ts_distance are not exposed as standalone functions;
# the `<->` operator is the established geopoint accept-verification path).
# geopoint_dict is reused from line 1979 -- not redeclared.
# ============================================================================

# ---- (a) JSON scalar column WITH INCLUDE on the same JSON column ----------
statement ok
CREATE TABLE g12_j(pk INTEGER PRIMARY KEY, j JSON, tag VARCHAR);

statement ok
CREATE INDEX g12_j_col_geo_st ON g12_j USING inverted(pk, j geopoint_dict) INCLUDE (j);

# ---- (b) JSON-returning expression `((j))` WITH INCLUDE on a sidecar col --
statement ok
CREATE INDEX g12_j_expr_geo_st ON g12_j USING inverted(pk, ((j)) geopoint_dict) INCLUDE (tag);

statement ok
INSERT INTO g12_j VALUES
    (1, '{"name":"a","lat":55.703900,"lng":37.615895}', 'north'),
    (2, '{"name":"b","lat":55.704831,"lng":37.616297}', 'south');

statement ok
VACUUM (REFRESH_TABLE) g12_j;

query
SELECT count(*) FROM g12_j_col_geo_st;
----
count
2

query
SELECT pk, tag FROM g12_j_col_geo_st
WHERE j <-> '{"type":"Point","coordinates":[37.616,55.704]}' < 500.0
ORDER BY pk;
