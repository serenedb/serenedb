# ============================================================================
# Mixed-tokenizer multi-column inverted indexes  --  combos omitted from g10.
# ----------------------------------------------------------------------------
# Each subsection builds one mixed-opclass inverted index, inserts two rows,
# and verifies (i) a single-column probe routes through the per-column codec
# and (ii) a multi-predicate AND probe intersects posting lists across the
# heterogeneous opclasses on one index. All dicts are reused from the
# top-of-file and g1/g4 declarations.
# ============================================================================

# --- (a) kw_dict + ng_dict on two VARCHAR columns, no INCLUDE ---------------

statement ok
CREATE TABLE g13_a(pk INTEGER PRIMARY KEY,
                   v  VARCHAR,
                   v2 VARCHAR);

statement ok
CREATE INDEX g13_a_mix ON g13_a
    USING inverted(pk, v kw_dict, v2 ng_dict);

statement ok
INSERT INTO g13_a VALUES
    (1, 'alpha', 'wonderful'),
    (2, 'beta',  'magnificent');

statement ok
VACUUM (REFRESH_TABLE) g13_a;

query
SELECT pk FROM g13_a_mix WHERE v @@ ts_like('alpha') ORDER BY pk;
----
pk
1

query
SELECT pk FROM g13_a_mix WHERE v2 @@ ts_ngram('mag', 0.5) ORDER BY pk;
----
pk
2

query
SELECT pk FROM g13_a_mix
WHERE v @@ ts_like('alpha') AND v2 @@ ts_ngram('won', 0.5)
ORDER BY pk;
----
pk
1

