# ANN range — radius wide enough to include the (1,0,0) row at distance 0
# and exclude the orthogonal vectors at distance sqrt(2)~1.414... < 1.5
# but stays away from the third row at sqrt(2).
query
SELECT pk FROM m_vec_hnsw_st
WHERE emb <-> [1.0::FLOAT, 0.0::FLOAT, 0.0::FLOAT]::FLOAT[3] < 0.5
ORDER BY pk;
----
pk
1

query
SELECT pk FROM m_vec_hnsw_expr_ns
WHERE (emb) <-> [1.0::FLOAT, 0.0::FLOAT, 0.0::FLOAT]::FLOAT[3] < 0.5
ORDER BY pk;
----
pk
1

# Lock in that both column and expression HNSW reach the ANN scan operator
# (not a brute-force fallback). top-K ⇒ IRESEARCH_SCAN (ANN),
# distance < radius ⇒ IRESEARCH_SCAN (ANN range).
query
EXPLAIN SELECT pk FROM m_vec_hnsw_st
  ORDER BY emb <-> [1.0::FLOAT, 0.0::FLOAT, 0.0::FLOAT]::FLOAT[3] LIMIT 1;
----
QUERY PLAN
┌───────────────────────────┐
│           TOP_N           │
│    ────────────────────   │
│           Top: 1          │
│      Order By: #1 ASC     │
│                           │
│           ~1 row          │
└─────────────┬─────────────┘
┌─────────────┴─────────────┐
│       IRESEARCH_SCAN      │
│    ────────────────────   │
│           Index:          │
│    m_vec_hnsw_st (ANN)    │
│                           │
│       Lookup: table       │
│           Top: 1          │
│          Dims: 3          │
│                           │
│        Projections:       │
│             pk            │
│  sdb_inverted_index_score │
│                           │
│          ~3 rows          │
└───────────────────────────┘

