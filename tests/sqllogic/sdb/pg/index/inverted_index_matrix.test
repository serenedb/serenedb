# ============================================================================
# g21 -- Geo + HNSW rejection completeness
#
# Closes the remaining gaps in the geo-tokenizer and hnsw validators:
#   - geo_s2_dict / geo_src_dict / geopoint_dict on ARRAY/LIST<JSON>: JSON is
#     a VARCHAR alias so term_dict accepts the container; the geo-tokenizer
#     validator then rejects it because col_id is ARRAY/LIST, not a JSON or
#     GEOMETRY scalar leaf;
#   - geo_s2_dict / geo_src_dict / geopoint_dict on ARRAY/LIST of GEOMETRY:
#     term_dict::Validate runs before the geo-tokenizer validator and
#     rejects LIST/ARRAY-of-GEOMETRY children with the generic
#     "unsupported type ... and can not be indexed" message; the geo-analyzer
#     branch never fires for these, so we assert the term_dict error;
#   - geo_s2_dict on scalar GEOMETRY without an OGC:CRS84 annotation (CRS84
#     validator's "no CRS attached" branch);
#   - geo_s2_dict / geo_src_dict / geopoint_dict on expression sources that
#     reduce to a non-geo type (VARCHAR / INTEGER / GEOMETRY-CRS84 for the
#     geopoint JSON-only branch);
#   - geo_src_dict on scalar BLOB (geo analyzer rejects non-GEOMETRY/non-JSON
#     leaves, even though text-tokenizers accept BLOB);
#   - hnsw on scalar DOUBLE (column-form, not just g5's FLOAT-scalar) and on
#     expression sources of every wrong shape (scalar FLOAT/VARCHAR,
#     LIST<FLOAT>, ARRAY<DOUBLE,3>, ARRAY<INTEGER,3>).
# Parenthesized single-column-ref expressions parse as COLUMN_REF, so the
# error message renders the bare column name (e.g. (v) -> Column 'v'); only
# the index identifiers carry the col/expr distinction.
# ============================================================================

statement ok
CREATE TABLE g21_t(pk INTEGER PRIMARY KEY,
                   arr_g GEOMETRY('OGC:CRS84')[3], arr_j JSON[3],
                   list_g GEOMETRY('OGC:CRS84')[], list_j JSON[],
                   g_nocrs GEOMETRY,
                   b BLOB, v VARCHAR, n INTEGER, dbl DOUBLE,
                   f_scalar FLOAT,
                   emb_list FLOAT[],
                   arr_d DOUBLE[3], arr_i INTEGER[3],
                   g_crs84 GEOMETRY('OGC:CRS84'));

# --- geo_s2_dict rejections -------------------------------------------------

# (a) ARRAY<GEOMETRY-CRS84>: term_dict::Validate runs first and rejects
# LIST/ARRAY-of-GEOMETRY before the geo-tokenizer is consulted.
statement error
CREATE INDEX g21_s2_col_arr_g ON g21_t USING inverted(pk, arr_g geo_s2_dict);
----
db error: ERROR: Failed to create index: Column 'arr_g' has unsupported type GEOMETRY('OGC:CRS84')[3] and can not be indexed


# (b) ARRAY<JSON>: JSON is VARCHAR-aliased so term_dict accepts the container;
# the geo-tokenizer validator then rejects it because col_id is ARRAY.
statement error
CREATE INDEX g21_s2_col_arr_j ON g21_t USING inverted(pk, arr_j geo_s2_dict);
----
db error: ERROR: Failed to create index: Column 'arr_j' uses a geo analyzer; must be JSON (GeoJSON) or GEOMETRY


# (c) Scalar GEOMETRY with no CRS attached -> CRS84 validator's no-CRS branch.
statement error
CREATE INDEX g21_s2_col_nocrs ON g21_t USING inverted(pk, g_nocrs geo_s2_dict);
----
db error: ERROR: Failed to create index: Column 'g_nocrs': GEOMETRY type has no CRS attached; declare it with ::GEOMETRY('OGC:CRS84')


# (d) Expression-source scalar VARCHAR -> geo-tokenizer rejects non-geo leaf.
statement error
CREATE INDEX g21_s2_expr_v ON g21_t USING inverted(pk, (v) geo_s2_dict);
----
db error: ERROR: Failed to create index: Column 'v' uses a geo analyzer; must be JSON (GeoJSON) or GEOMETRY


# (e) Expression-source scalar INTEGER -> same.
statement error
CREATE INDEX g21_s2_expr_n ON g21_t USING inverted(pk, (n) geo_s2_dict);
----
db error: ERROR: Failed to create index: Column 'n' uses a geo analyzer; must be JSON (GeoJSON) or GEOMETRY


# --- geo_src_dict rejections ------------------------------------------------

# (f) ARRAY<GEOMETRY-CRS84>: term_dict rejects ARRAY-of-GEOMETRY first.
statement error
CREATE INDEX g21_src_col_arr_g ON g21_t USING inverted(pk, arr_g geo_src_dict);
----
db error: ERROR: Failed to create index: Column 'arr_g' has unsupported type GEOMETRY('OGC:CRS84')[3] and can not be indexed


# (g) LIST<GEOMETRY-CRS84>: term_dict rejects LIST-of-GEOMETRY first.
statement error
CREATE INDEX g21_src_col_list_g ON g21_t USING inverted(pk, list_g geo_src_dict);
----
db error: ERROR: Failed to create index: Column 'list_g' has unsupported type GEOMETRY('OGC:CRS84')[] and can not be indexed


# (h) LIST<JSON>: JSON is VARCHAR-aliased, so term_dict accepts; geo-tokenizer
# then rejects the LIST container.
statement error
CREATE INDEX g21_src_col_list_j ON g21_t USING inverted(pk, list_j geo_src_dict);
----
db error: ERROR: Failed to create index: Column 'list_j' uses a geo analyzer; must be JSON (GeoJSON) or GEOMETRY


# (i) Scalar BLOB: text-tokenizers accept BLOB, but geo analyzers reject it.
statement error
CREATE INDEX g21_src_col_b ON g21_t USING inverted(pk, b geo_src_dict);
----
db error: ERROR: Failed to create index: Column 'b' uses a geo analyzer; must be JSON (GeoJSON) or GEOMETRY


# (j) Expression-source scalar VARCHAR.
statement error
CREATE INDEX g21_src_expr_v ON g21_t USING inverted(pk, (v) geo_src_dict);
----
db error: ERROR: Failed to create index: Column 'v' uses a geo analyzer; must be JSON (GeoJSON) or GEOMETRY


# --- geopoint_dict rejections -----------------------------------------------

# (k) ARRAY<GEOMETRY-CRS84>: term_dict rejects ARRAY-of-GEOMETRY first.
statement error
CREATE INDEX g21_gp_col_arr_g ON g21_t USING inverted(pk, arr_g geopoint_dict);
----
db error: ERROR: Failed to create index: Column 'arr_g' has unsupported type GEOMETRY('OGC:CRS84')[3] and can not be indexed


# (l) ARRAY<JSON>: term_dict accepts; geo-tokenizer then rejects the container.
statement error
CREATE INDEX g21_gp_col_arr_j ON g21_t USING inverted(pk, arr_j geopoint_dict);
----
db error: ERROR: Failed to create index: Column 'arr_j' uses a geo analyzer; must be JSON (GeoJSON) or GEOMETRY


# (m) Expression-source GEOMETRY('OGC:CRS84'): CRS84 passes, then the
# geopoint-specific JSON-only message fires.
statement error
CREATE INDEX g21_gp_expr_g_crs84 ON g21_t USING inverted(pk, (g_crs84) geopoint_dict);
----
db error: ERROR: Failed to create index: Column 'g_crs84' is GEOMETRY but the analyzer is geopoint; geopoint's latitude/longitude paths are JSON-only -- use a geojson analyzer for GEOMETRY columns


# (n) Expression-source scalar VARCHAR: geo-tokenizer rejection.
statement error
CREATE INDEX g21_gp_expr_v ON g21_t USING inverted(pk, (v) geopoint_dict);
----
db error: ERROR: Failed to create index: Column 'v' uses a geo analyzer; must be JSON (GeoJSON) or GEOMETRY


# --- hnsw rejections --------------------------------------------------------

# (o) Column-form scalar DOUBLE: must be ARRAY(FLOAT, N).
statement error
CREATE INDEX g21_hnsw_col_dbl ON g21_t USING inverted(pk, dbl hnsw (metric = 'l2'));
----
db error: ERROR: Failed to create index: Column 'dbl' must be ARRAY(FLOAT, N) to use the 'hnsw' opclass, not DOUBLE


# (p) Expression-source scalar FLOAT: still not ARRAY.
statement error
CREATE INDEX g21_hnsw_expr_f ON g21_t USING inverted(pk, (f_scalar) hnsw (metric = 'l2'));
----
db error: ERROR: Failed to create index: Column 'f_scalar' must be ARRAY(FLOAT, N) to use the 'hnsw' opclass, not FLOAT


# (q) Expression-source scalar VARCHAR: not ARRAY at all.
statement error
CREATE INDEX g21_hnsw_expr_v ON g21_t USING inverted(pk, (v) hnsw (metric = 'l2'));
----
db error: ERROR: Failed to create index: Column 'v' must be ARRAY(FLOAT, N) to use the 'hnsw' opclass, not VARCHAR


# (r) Expression-source LIST<FLOAT>: variable-length, not fixed ARRAY.
statement error
CREATE INDEX g21_hnsw_expr_emb_list ON g21_t USING inverted(pk, (emb_list) hnsw (metric = 'l2'));
----
db error: ERROR: Failed to create index: Column 'emb_list' must be ARRAY(FLOAT, N) to use the 'hnsw' opclass, not FLOAT[]


# (s) Expression-source ARRAY<DOUBLE,3>: element type must be FLOAT.
statement error
CREATE INDEX g21_hnsw_expr_arr_d ON g21_t USING inverted(pk, (arr_d) hnsw (metric = 'l2'));
----
db error: ERROR: Failed to create index: Column 'arr_d' must be ARRAY(FLOAT, N) to use the 'hnsw' opclass, not DOUBLE[3]


# (t) Expression-source ARRAY<INTEGER,3>: element type must be FLOAT.
statement error
CREATE INDEX g21_hnsw_expr_arr_i ON g21_t USING inverted(pk, (arr_i) hnsw (metric = 'l2'));
----
db error: ERROR: Failed to create index: Column 'arr_i' must be ARRAY(FLOAT, N) to use the 'hnsw' opclass, not INTEGER[3]




# ============================================================================
# g22 -- INCLUDE_ONLY column-scalar coverage for missing types.
#
# included::Validate (server/catalog/inverted_index.cpp:282-333) accepts a
# wide whitelist that g6 sampled but did not exhaust. This block pins
# INCLUDE-only acceptance for the remaining accepted leaves and the
# container shapes that g7 / g9 didn't put in INCLUDE position:
#
#   direct table (g22_t):
#     - BIT
#     - ENUM (user-defined)
#     - VARCHAR[]      LIST<VARCHAR>
#     - INTEGER[]      LIST<INTEGER>
#     - VARCHAR[3]     ARRAY<VARCHAR,3>
#     - INTEGER[3]     ARRAY<INTEGER,3>
#     - GEOMETRY('OGC:CRS84')[3]   ARRAY<GEOMETRY,3>
#     - LIST<MAP(VARCHAR,INTEGER)>
#     - LIST<STRUCT(a INTEGER)>
#     - LIST<VARIANT>
#
#   view-backed (g22_v_unsup) -- rocksdb refuses to serialize these as
#   live-table columns, but a parquet-fed view bypasses that and the index
#   still accepts them on the INCLUDE side:
#     - UBIGINT
#     - UHUGEINT
#     - TIME
#     - TIME_NS
#     - TIME_TZ
#
# Each cell is one CREATE INDEX ... USING inverted INCLUDE (col) on a
# pk-only indexed position (the canonical INCLUDE-only spelling, mirroring
# m_pk_only / m_unsup_inc). 2 rows are inserted; count(*) verifies the
# index materialized.
# ============================================================================

statement ok
CREATE TYPE g22_enum_t AS ENUM ('x','y','z');

statement ok
CREATE TABLE g22_t(pk INTEGER PRIMARY KEY,
                   vl VARCHAR[],
                   il INTEGER[],
                   va VARCHAR[3],
                   ia INTEGER[3],
                   ga GEOMETRY('OGC:CRS84')[3],
                   lm MAP(VARCHAR, INTEGER)[],
                   ls STRUCT(a INTEGER)[],
                   lv VARIANT[]);

# BIT and ENUM scalars are rocksdb-incompatible; INCLUDE-only coverage for
# them lives in g16 (implicit-rejection block) and m_unsup-style view-backed
# follow-ups elsewhere. Skipping direct-table INCLUDE-only here.

statement ok
CREATE INDEX g22_inc_vl ON g22_t USING inverted INCLUDE (vl);

statement ok
CREATE INDEX g22_inc_il ON g22_t USING inverted INCLUDE (il);

statement ok
CREATE INDEX g22_inc_va ON g22_t USING inverted INCLUDE (va);

statement ok
CREATE INDEX g22_inc_ia ON g22_t USING inverted INCLUDE (ia);

statement ok
CREATE INDEX g22_inc_ga ON g22_t USING inverted INCLUDE (ga);

statement ok
CREATE INDEX g22_inc_lm ON g22_t USING inverted INCLUDE (lm);

statement ok
CREATE INDEX g22_inc_ls ON g22_t USING inverted INCLUDE (ls);

statement ok
CREATE INDEX g22_inc_lv ON g22_t USING inverted INCLUDE (lv);

statement ok
INSERT INTO g22_t VALUES
    (1, ['alpha','beta'], [10, 20],
        ['p','q','r'], [1, 2, 3],
        ['POINT(0 0)'::GEOMETRY('OGC:CRS84'),
         'POINT(1 1)'::GEOMETRY('OGC:CRS84'),
         'POINT(2 2)'::GEOMETRY('OGC:CRS84')],
        [MAP {'k1': 1}, MAP {'k2': 2}],
        [ROW(10)::STRUCT(a INTEGER), ROW(20)::STRUCT(a INTEGER)],
        [42::VARIANT, 'hello'::VARIANT]),
    (2, ['gamma'], [30],
        ['s','t','u'], [4, 5, 6],
        ['POINT(3 3)'::GEOMETRY('OGC:CRS84'),
         'POINT(4 4)'::GEOMETRY('OGC:CRS84'),
         'POINT(5 5)'::GEOMETRY('OGC:CRS84')],
        [MAP {'k3': 3}],
        [ROW(30)::STRUCT(a INTEGER)],
        ['world'::VARIANT]);

statement ok
VACUUM (REFRESH_TABLE) g22_t;

query
SELECT count(*) FROM g22_inc_vl;
----
count
