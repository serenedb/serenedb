# ============================================================================
# Implicit role (no opclass) -- column listed in the indexed position with
# no opclass attached. term_dict::Validate (inverted_index.cpp) accepts
# every String-kind scalar (VARCHAR / BLOB / JSON-alias-VARCHAR / GEOMETRY)
# and any LIST / ARRAY of supported elements, but special-cases LIST or
# ARRAY of GEOMETRY as unsupported (line 262). Verifies each accepted
# index with a @@ probe (or count(*) when ts_* rejects the type); rejected
# cases use the implicit validator regex.
#
# Note: under the implicit role FillEntryFromTokenizer is never invoked,
# so HasJsonLeafFields() stays false and the sink routes JSON columns
# through WriteScalarBatch<VARCHAR>. JSON values are indexed as raw text
# (quotes and all), unlike the kw_dict path in m_j_prim.
# ============================================================================

statement ok
CREATE TABLE g7_j(pk INTEGER PRIMARY KEY, j JSON);

statement ok
CREATE INDEX g7_j_imp ON g7_j USING inverted(pk, j);

statement ok
INSERT INTO g7_j VALUES (1, '"alpha"'), (2, '"beta"'), (3, '42');

statement ok
VACUUM (REFRESH_TABLE) g7_j;

query
SELECT pk FROM g7_j_imp WHERE j @@ ts_like('"alpha"') ORDER BY pk;
----
pk
1


statement ok
