# ============================================================================
# Types whose ROCKSDB row serializer refuses but which the catalog accepts
# via term_dict (or via INCLUDE). Reached through a parquet-backed view so
# the row store is bypassed entirely:
#   UTINYINT, USMALLINT, UINTEGER  -- catalog NumericI32 / NumericI64 family
#   TIME, TIME_NS, TIME_TZ, TIMESTAMP_MS, TIMESTAMP_NS, TIMESTAMP_TZ
#                                  -- catalog NumericI64 family (temporal)
#   UUID, DECIMAL, INTERVAL, HUGEINT
#                                  -- term_dict rejects -> INCLUDE-only
# ============================================================================

statement count 2
COPY (SELECT * FROM (VALUES
  (1, 5::UTINYINT,   500::USMALLINT,   5000::UINTEGER,
      TIME '01:23:45',
      TIMESTAMP_MS '2024-01-01 00:00:00',
      TIMESTAMP_NS '2024-01-01 00:00:00',
      TIMESTAMPTZ  '2024-01-01 00:00:00+00',
      'a0eebc99-9c0b-4ef8-bb6d-6bb9bd380a11'::UUID,
      12.34::DECIMAL(10,2),
      INTERVAL 5 DAY,
      100::HUGEINT),
  (2, 250::UTINYINT, 60000::USMALLINT, 4000000000::UINTEGER,
      TIME '23:00:00',
      TIMESTAMP_MS '2024-06-15 12:00:00',
      TIMESTAMP_NS '2024-06-15 12:00:00',
      TIMESTAMPTZ  '2024-06-15 12:00:00+00',
      'b0eebc99-9c0b-4ef8-bb6d-6bb9bd380a22'::UUID,
      56.78::DECIMAL(10,2),
      INTERVAL 10 DAY,
      200::HUGEINT)
) AS t(pk, u8, u16, u32, tt, ts_ms, ts_ns, ts_tz, u, d, iv, h))
TO '${__TEST_DIR__}/sdb_matrix_unsup.parquet' (FORMAT parquet);

statement ok
CREATE VIEW m_unsup AS SELECT * FROM read_parquet('${__TEST_DIR__}/sdb_matrix_unsup.parquet');

statement ok
CREATE INDEX m_unsup_u8    ON m_unsup USING inverted(pk, u8);

statement ok
CREATE INDEX m_unsup_u16   ON m_unsup USING inverted(pk, u16);

statement ok
CREATE INDEX m_unsup_u32   ON m_unsup USING inverted(pk, u32);

statement ok
CREATE INDEX m_unsup_tt    ON m_unsup USING inverted(pk, tt);

statement ok
CREATE INDEX m_unsup_ts_ms ON m_unsup USING inverted(pk, ts_ms);

statement ok
CREATE INDEX m_unsup_ts_ns ON m_unsup USING inverted(pk, ts_ns);

statement ok
CREATE INDEX m_unsup_ts_tz ON m_unsup USING inverted(pk, ts_tz);

# INCLUDE-only sidecar for term_dict-rejected types (UUID / DECIMAL / INTERVAL
# / HUGEINT are accepted by the included opclass but not by term_dict).
statement ok
CREATE INDEX m_unsup_inc ON m_unsup USING inverted INCLUDE (u, d, iv, h);

