# ============================================================================
# g18 -- Geo non-CRS84 rejection for geo_src_dict and geopoint_dict
#
# ValidateTokenizerVsColumn (server/catalog/index.cpp) runs ValidateGeometryCRS84
# *first* inside the GEOMETRY branch, before the geopoint-on-GEOMETRY check.
# So for geopoint_dict on a GEOMETRY column the JSON-only error is only
# reachable when the CRS already passes CRS84 validation -- g4 already pins
# that case on a valid GEOMETRY('OGC:CRS84') column. Here we pin the two CRS84
# rejection branches:
#   no CRS attached          -> "GEOMETRY type has no CRS attached..."
#   recognized but non-CRS84 -> "GEOMETRY type has invalid CRS '...'"
# for both geo_src_dict (a/b) and geopoint_dict (c1/c2). DuckDB's BindGeometryType
# rejects unrecognized short CRS identifiers at type creation, so the only SQL
# path to a recognized-but-non-CRS84 GEOMETRY type is a full WKT2 definition;
# the Pseudo-Mercator WKT2 below resolves to identifier 'DUCKDB:1337'.
# ============================================================================

statement ok
CREATE TABLE g18_t(pk INTEGER PRIMARY KEY,
                   g_nocrs GEOMETRY,
