# ============================================================================
# g14 -- INCLUDE-only with EXPRESSION source.
#
# g6 covered column-named INCLUDE sources across every accepted scalar type.
# This block pins what happens when the INCLUDE list element is a
# parenthesized expression rather than a bare column identifier.
#
# Grammar: CreateIndex's IncludeClause is
#     IncludeClause  <- 'INCLUDE' Parens(List(IncludedColumn))
#     IncludedColumn <- ColId IndexOpclass?
# (third_party/duckdb/src/parser/peg/grammar/statements/create_index.gram).
# An IncludedColumn is a bare identifier with an optional opclass -- no
# Parens, no Expr. Every expression form below therefore fails at parse
# time with the same token-level error pointing at the leading '(' that
# opens the would-be expression. The error never reaches the catalog
# binder, so there is no "tokenizer" / "unsupported type" wording -- only
# the syntactic rejection.
# ============================================================================

statement ok
CREATE TABLE g14_t(pk INTEGER PRIMARY KEY,
                   v  VARCHAR,
                   n  INTEGER,
                   d  DATE,
                   ts TIMESTAMP,
                   bo BOOLEAN,
                   f  FLOAT,
                   j  JSON,
                   g  GEOMETRY('OGC:CRS84'));

# (a) VARCHAR expression -- upper(v)
statement error
CREATE INDEX g14_inc_expr_v ON g14_t USING inverted(pk) INCLUDE ((upper(v)));
----
db error: ERROR: syntax error at or near "("


# (b) INTEGER expression -- n * 2
statement error
CREATE INDEX g14_inc_expr_n ON g14_t USING inverted(pk) INCLUDE ((n * 2));
----
db error: ERROR: syntax error at or near "("


# (c) DATE expression -- d + INTERVAL '1 day'
statement error
CREATE INDEX g14_inc_expr_d ON g14_t USING inverted(pk)
    INCLUDE ((d + INTERVAL '1 day'));
----
db error: ERROR: syntax error at or near "("


# (d) TIMESTAMP expression -- ts + INTERVAL '1 hour'
statement error
CREATE INDEX g14_inc_expr_ts ON g14_t USING inverted(pk)
    INCLUDE ((ts + INTERVAL '1 hour'));
----
db error: ERROR: syntax error at or near "("


# (e) BOOLEAN expression -- NOT bo
statement error
CREATE INDEX g14_inc_expr_bo ON g14_t USING inverted(pk) INCLUDE ((NOT bo));
----
db error: ERROR: syntax error at or near "("


# (f) FLOAT expression -- f * 1.0::FLOAT (constant-fold-resistant cast)
statement error
CREATE INDEX g14_inc_expr_f ON g14_t USING inverted(pk)
    INCLUDE ((f * 1.0::FLOAT));
----
db error: ERROR: syntax error at or near "("


# (g) JSON-extract expression -- j->>'type'
statement error
CREATE INDEX g14_inc_expr_j ON g14_t USING inverted(pk) INCLUDE ((j->>'type'));
----
db error: ERROR: syntax error at or near "("


# (h) GEOMETRY-identity expression -- (g). Even a trivial parenthesized
# identity is rejected by the IncludedColumn grammar (no Parens
# alternative), confirming the rejection is syntactic and independent of
# the inner expression's shape or type.
statement error
CREATE INDEX g14_inc_expr_g ON g14_t USING inverted(pk) INCLUDE ((g));
----
db error: ERROR: syntax error at or near "("


# ============================================================================
# g15 -- Text-tokenizer rejection coverage across the full unusual-type matrix.
#
# Every type the AREA lists is declared as a column of one table g15_t, and
# every (column, text-tokenizer) pair is exercised with a single
# statement-error block. The two-stage validator in
# server/catalog/index.cpp:ValidateInvertedIndexColumns runs in this order:
#
#   (1) term_dict::Validate (line 399) -- rejects types that Classify (in
#       server/catalog/inverted_index.h:64) maps to Kind::Unsupported.
#       Wording: "has unsupported type X and can not be indexed".
#       For this block: UBIGINT, HUGEINT, UHUGEINT, DECIMAL(10,2), INTERVAL,
#       UUID, STRUCT(a INTEGER), MAP(VARCHAR, INTEGER), VARIANT.
#
#   (2) ValidateTokenizerVsColumn (line 704) -- rejects types that are
#       Supported by term_dict but are not VARCHAR / BLOB / LIST / ARRAY of
#       VARCHAR / BLOB; the keyword / ngram / text analyzers can only consume
#       string-shaped bytes. Wording:
#       "uses a tokenizer; must be VARCHAR, BLOB, or a LIST/ARRAY of
#        VARCHAR/BLOB (got X)".
#       For this block: TIME, TIME_NS, TIME WITH TIME ZONE,
#       TIMESTAMP_MS, TIMESTAMP_NS, TIMESTAMP WITH TIME ZONE,
#       TINYINT, SMALLINT, UTINYINT, USMALLINT, UINTEGER, FLOAT,
#       GEOMETRY('OGC:CRS84').
#
# kw_dict / ng_dict / any_text_dict are already declared at the top of this
# file (lines 28, 31-32, 1583) -- not redeclared.
#
# No rows are inserted: the entire block tests CREATE INDEX rejection, so
# rocksdb-incompatible types (UTINYINT / USMALLINT / UINTEGER / TIME
# variants / TIMESTAMP_MS / TIMESTAMP_NS / TIMESTAMPTZ) can sit in a regular
# table without ever reaching the storage path.
# ============================================================================

statement ok
CREATE TABLE g15_t(pk    INTEGER PRIMARY KEY,
                   u64   UBIGINT,
                   h     HUGEINT,
                   uh    UHUGEINT,
                   d     DECIMAL(10,2),
                   iv    INTERVAL,
                   uu    UUID,
                   st    STRUCT(a INTEGER),
                   mp    MAP(VARCHAR, INTEGER),
                   vr    VARIANT,
                   tt    TIME,
                   ttns  TIME_NS,
                   tttz  TIMETZ,
                   tsms  TIMESTAMP_MS,
                   tsns  TIMESTAMP_NS,
                   tstz  TIMESTAMPTZ,
                   t8    TINYINT,
                   t16   SMALLINT,
                   u8    UTINYINT,
                   u16   USMALLINT,
                   u32   UINTEGER,
                   f     FLOAT,
                   g     GEOMETRY('OGC:CRS84'));

