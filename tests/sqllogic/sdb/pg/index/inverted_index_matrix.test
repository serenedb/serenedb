# ============================================================================
# Vector  --  HNSW (array only) + text-tokenized FLOAT array
# ============================================================================

statement ok
CREATE TABLE m_vec(pk INTEGER PRIMARY KEY, emb FLOAT[3], fs FLOAT[]);

statement ok
CREATE INDEX m_vec_hnsw_st   ON m_vec
    USING inverted(pk, emb hnsw (metric = 'l2')) INCLUDE (emb);

statement ok
CREATE INDEX m_vec_hnsw_ns   ON m_vec
    USING inverted(pk, emb hnsw (metric = 'cosine'));

statement ok
CREATE INDEX m_vec_hnsw_expr_ns ON m_vec
    USING inverted(pk, (emb) hnsw (metric = 'l2'));

statement ok
CREATE INDEX m_vec_hnsw_expr_st ON m_vec
    USING inverted(pk, (emb) hnsw (metric = 'l2')) INCLUDE (emb);

statement ok
CREATE INDEX m_vec_floats_st ON m_vec USING inverted(pk, fs) INCLUDE (fs);

statement ok
CREATE INDEX m_vec_floats_ns ON m_vec USING inverted(pk, fs);

statement ok
CREATE INDEX m_vec_floats_expr_ns ON m_vec USING inverted(pk, (fs));

