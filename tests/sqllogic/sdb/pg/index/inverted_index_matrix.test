# ============================================================================
# g19 -- IMPLICIT (no opclass) role: close remaining rejection / accept gaps.
#
# This section completes the term_dict::Validate coverage matrix for the
# implicit (opclass-less) role. Three buckets:
#
#   (1) LIST<unsupported> / ARRAY<unsupported> rejections that g16 didn't
#       reach: UBIGINT, UHUGEINT, BIT, ENUM, STRUCT(a INTEGER),
#       MAP(VARCHAR, INTEGER), VARIANT, UUID, INTERVAL, GEOMETRY('OGC:CRS84').
#       The GEOMETRY-list/array cases are also pinned by g7_gl / g7_ga; we
#       repeat them here under the g19_ prefix for self-contained matrix
#       completeness.
#
#   (2) Scalar BIT / ENUM / VARIANT under the g19_ prefix (g16 already pins
#       the same payload; duplicated intentionally so this section reads as
#       a self-contained implicit-role grid).
#
#   (3) Accept paths the implicit/column and implicit/expression matrices
#       didn't pin: LIST<TIMESTAMPTZ/TIME/TIMESTAMP_MS/TIMESTAMP_NS>,
#       ARRAY<TIMESTAMP/BIGINT/JSON/BLOB/FLOAT/DOUBLE,3>, plus
#       expression-source scalar TIMETZ / TIME_NS / BLOB / JSON / VARCHAR
#       and expression-source ARRAY<JSON,3> / ARRAY<BLOB,3>.
#       UTINYINT expression scalar is already covered by g11_d_u8_expr_st,
#       so it is not repeated here.
#
#   (4) Nested LIST<LIST<INTEGER>> via expression: term_dict::Validate
#       recurses one level only -- inner LIST classifies as Unsupported, so
#       the outer LIST is rejected. ([[pk]] is the literal short form
#       DuckDB lowers to main.list_value(main.list_value(pk)).)
#
# Storage strategy: term_dict-rejected columns (UBIGINT / UHUGEINT /
# BIT / ENUM / STRUCT / MAP / VARIANT / UUID[] / INTERVAL[] / GEOMETRY[])
# never receive INSERTs -- CREATE INDEX rejection runs before any row store
# path. Rocksdb-incompatible accept-paths (TIMESTAMPTZ / TIME / TIMESTAMP_MS
# / TIMESTAMP_NS LIST, TIMETZ / TIME_NS scalar expression) are routed
# through a parquet-backed view so the rocksdb row store is bypassed --
# same recipe as m_unsup, g6_v_unsup, g11_a_v / g11_d_v / g11_e_v.
# Rocksdb-compatible accept-paths (TIMESTAMP / BIGINT / JSON / BLOB / FLOAT
# / DOUBLE ARRAY, BLOB / JSON / VARCHAR scalar expression) live on a
# dedicated table to keep INSERTs clear of the rocksdb-incompatible columns
# on g19_t.
# ============================================================================

statement ok
CREATE TYPE g19_enum_t AS ENUM ('alpha', 'beta', 'gamma');

statement ok
CREATE TABLE g19_t(pk           INTEGER PRIMARY KEY,
                   list_ubig    UBIGINT[],
                   list_uhuge   UHUGEINT[],
                   list_bit     BIT[],
                   list_enum    g19_enum_t[],
                   list_struct  STRUCT(a INTEGER)[],
                   list_map     MAP(VARCHAR, INTEGER)[],
                   list_variant VARIANT[],
                   arr_ubig     UBIGINT[3],
                   arr_uhuge    UHUGEINT[3],
                   arr_uuid     UUID[3],
                   arr_intv     INTERVAL[3],
                   arr_geom     GEOMETRY('OGC:CRS84')[3],
                   bit_s        BIT,
                   enum_s       g19_enum_t,
                   vr           VARIANT);


