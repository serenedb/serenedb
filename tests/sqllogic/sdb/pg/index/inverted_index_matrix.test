# ============================================================================
# Validator branches: explicit statement-error pins for opclass acceptance
# rules that aren't covered elsewhere in the matrix. Each rejection uses the
# inventory regex so the exact error message stays observable.
#   (a) GEOMETRY without OGC:CRS84 + geo_s2_dict       -> CRS84 validator
#   (b) hnsw on scalar FLOAT                            -> hnsw validator
#   (c) hnsw on LIST<FLOAT>                             -> hnsw validator
#   (d) hnsw on ARRAY<DOUBLE,3>                         -> hnsw validator
#   (e) hnsw on ARRAY<INTEGER,3>                        -> hnsw validator
#   (f) hnsw on scalar VARCHAR                          -> hnsw validator
#   (g) implicit (no opclass) on UUID                   -> term_dict Unsupported
#   (h) implicit (no opclass) on DECIMAL(10,2)          -> term_dict Unsupported
#   (i) implicit (no opclass) on INTERVAL               -> term_dict Unsupported
#   (j) implicit (no opclass) on HUGEINT                -> term_dict Unsupported
# ============================================================================

statement ok
CREATE TABLE g5_reject(pk INTEGER PRIMARY KEY,
                       g_nocrs GEOMETRY,
                       f FLOAT,
                       fl FLOAT[],
                       da DOUBLE[3],
                       ia INTEGER[3],
                       v VARCHAR,
                       u UUID,
                       d DECIMAL(10,2),
                       iv INTERVAL,
                       h HUGEINT);

# (a) GEOMETRY without OGC:CRS84 annotation: CRS84 validator rejects.
statement error
CREATE INDEX g5_reject_s2_nocrs ON g5_reject USING inverted(pk, g_nocrs geo_s2_dict);
----
db error: ERROR: Failed to create index: Column 'g_nocrs': GEOMETRY type has no CRS attached; declare it with ::GEOMETRY('OGC:CRS84')


# (b) hnsw on scalar FLOAT: must be ARRAY(FLOAT, N).
statement error
CREATE INDEX g5_reject_hnsw_f ON g5_reject USING inverted(pk, f hnsw (metric = 'l2'));
----
db error: ERROR: Failed to create index: Column 'f' must be ARRAY(FLOAT, N) to use the 'hnsw' opclass, not FLOAT


# (c) hnsw on LIST<FLOAT>: must be ARRAY(FLOAT, N), not a variable-length list.
statement error
CREATE INDEX g5_reject_hnsw_fl ON g5_reject USING inverted(pk, fl hnsw (metric = 'l2'));
----
db error: ERROR: Failed to create index: Column 'fl' must be ARRAY(FLOAT, N) to use the 'hnsw' opclass, not FLOAT[]


# (d) hnsw on ARRAY<DOUBLE,3>: element type must be FLOAT, not DOUBLE.
statement error
CREATE INDEX g5_reject_hnsw_da ON g5_reject USING inverted(pk, da hnsw (metric = 'l2'));
----
db error: ERROR: Failed to create index: Column 'da' must be ARRAY(FLOAT, N) to use the 'hnsw' opclass, not DOUBLE[3]


# (e) hnsw on ARRAY<INTEGER,3>: element type must be FLOAT, not INTEGER.
statement error
CREATE INDEX g5_reject_hnsw_ia ON g5_reject USING inverted(pk, ia hnsw (metric = 'l2'));
----
db error: ERROR: Failed to create index: Column 'ia' must be ARRAY(FLOAT, N) to use the 'hnsw' opclass, not INTEGER[3]


# (f) hnsw on scalar VARCHAR: not ARRAY at all.
statement error
CREATE INDEX g5_reject_hnsw_v ON g5_reject USING inverted(pk, v hnsw (metric = 'l2'));
----
db error: ERROR: Failed to create index: Column 'v' must be ARRAY(FLOAT, N) to use the 'hnsw' opclass, not VARCHAR


# (g) implicit (no opclass) on UUID: term_dict has no codec for UUID.
statement error
CREATE INDEX g5_reject_imp_u ON g5_reject USING inverted(pk, u);
----
db error: ERROR: Failed to create index: Column 'u' has unsupported type UUID and can not be indexed


# (h) implicit (no opclass) on DECIMAL(10,2): term_dict has no codec for DECIMAL.
statement error
CREATE INDEX g5_reject_imp_d ON g5_reject USING inverted(pk, d);
----
db error: ERROR: Failed to create index: Column 'd' has unsupported type DECIMAL(10,2) and can not be indexed


# (i) implicit (no opclass) on INTERVAL: term_dict has no codec for INTERVAL.
statement error
CREATE INDEX g5_reject_imp_iv ON g5_reject USING inverted(pk, iv);
----
