CREATE TABLE g11_j(pk INTEGER PRIMARY KEY, ll BIGINT[], tag VARCHAR);

statement ok
CREATE INDEX g11_j_expr_st ON g11_j USING inverted(pk, ((ll))) INCLUDE (tag);

statement ok
