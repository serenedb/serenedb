# (k) DOUBLE list via expression: identity-wrap a DOUBLE[].
statement ok
CREATE TABLE g11_k(pk INTEGER PRIMARY KEY, dbl DOUBLE[], tag VARCHAR);

statement ok
CREATE INDEX g11_k_expr_st ON g11_k USING inverted(pk, ((dbl))) INCLUDE (tag);

statement ok
INSERT INTO g11_k VALUES
    (1, [1.5, 2.5], 'a'),
    (2, [4.5],      'b');

statement ok
VACUUM (REFRESH_TABLE) g11_k;

query
SELECT pk FROM g11_k_expr_st WHERE (dbl) @@ ts_between(2.0::DOUBLE, 3.0::DOUBLE, true, true) ORDER BY pk;
----
pk
1


# (l) JSON ->>'a' kw_dict via expression WITH INCLUDE(tag).
statement ok
CREATE TABLE g11_l(pk INTEGER PRIMARY KEY, j JSON, tag VARCHAR);

statement ok
CREATE INDEX g11_l_expr_st ON g11_l USING inverted(pk, (j->>'type') kw_dict) INCLUDE (tag);

statement ok
INSERT INTO g11_l VALUES
    (1, '{"type":"Point","coordinates":[0.0, 0.0]}',           'a'),
    (2, '{"type":"LineString","coordinates":[[0,0],[1,1]]}',   'b');

statement ok
VACUUM (REFRESH_TABLE) g11_l;

query
SELECT pk FROM g11_l_expr_st WHERE j->>'type' @@ ts_like('Point') ORDER BY pk;
----
pk
1


# (m) GEOMETRY geo_src_dict via expression WITH INCLUDE(tag).
statement ok
CREATE TABLE g11_m(pk INTEGER PRIMARY KEY, g GEOMETRY('OGC:CRS84'), tag VARCHAR);

statement ok
CREATE INDEX g11_m_expr_st ON g11_m USING inverted(pk, (g) geo_src_dict) INCLUDE (tag);

statement ok
INSERT INTO g11_m VALUES
    (1, 'POINT(0 0)'::GEOMETRY('OGC:CRS84'),   'a'),
    (2, 'POINT(10 20)'::GEOMETRY('OGC:CRS84'), 'b');

statement ok
VACUUM (REFRESH_TABLE) g11_m;

query
SELECT count(*) FROM g11_m_expr_st;
----
count
2


