statement ok
DROP TABLE g4_reject;

statement ok
DROP TABLE g12_j;

statement ok
DROP TABLE g12_jl;

statement ok
DROP TABLE g12_ja;

statement ok
DROP TABLE g12_gl;

statement ok
DROP TABLE g12_reject;

statement ok
DROP TABLE g18_t;

statement ok
DROP TEXT SEARCH DICTIONARY geo_s2_dict;

statement ok
DROP TEXT SEARCH DICTIONARY geo_src_dict;

statement ok
DROP TEXT SEARCH DICTIONARY geopoint_dict;
