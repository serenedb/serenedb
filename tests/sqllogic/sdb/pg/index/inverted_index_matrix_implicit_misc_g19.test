----
db error: ERROR: Failed to create index: Column 'list_bit' has unsupported type BIT[] and can not be indexed


statement error
CREATE INDEX g19_imp_list_enum ON g19_t USING inverted(pk, list_enum);
----
db error: ERROR: Failed to create index: Column 'list_enum' has unsupported type g19_enum_t[] and can not be indexed


statement error
CREATE INDEX g19_imp_list_struct ON g19_t USING inverted(pk, list_struct);
----
db error: ERROR: Failed to create index: Column 'list_struct' has unsupported type STRUCT(a INTEGER)[] and can not be indexed


statement error
CREATE INDEX g19_imp_list_map ON g19_t USING inverted(pk, list_map);
----
db error: ERROR: Failed to create index: Column 'list_map' has unsupported type MAP(VARCHAR, INTEGER)[] and can not be indexed


statement error
CREATE INDEX g19_imp_list_variant ON g19_t USING inverted(pk, list_variant);
----
db error: ERROR: Failed to create index: Column 'list_variant' has unsupported type VARIANT[] and can not be indexed


# ----------------------------------------------------------------------------
# (b) ARRAY<unsupported-leaf> implicit rejections. Fixed-size arrays render
# as "<child>[N]" (types.cpp:474); the container branch path is the same as
# LIST.
# ----------------------------------------------------------------------------

statement error
CREATE INDEX g19_imp_arr_ubig ON g19_t USING inverted(pk, arr_ubig);
----
db error: ERROR: Failed to create index: Column 'arr_ubig' has unsupported type UBIGINT[3] and can not be indexed


statement error
CREATE INDEX g19_imp_arr_uhuge ON g19_t USING inverted(pk, arr_uhuge);
----
db error: ERROR: Failed to create index: Column 'arr_uhuge' has unsupported type UHUGEINT[3] and can not be indexed


statement error
CREATE INDEX g19_imp_arr_uuid ON g19_t USING inverted(pk, arr_uuid);
----
db error: ERROR: Failed to create index: Column 'arr_uuid' has unsupported type UUID[3] and can not be indexed


statement error
CREATE INDEX g19_imp_arr_intv ON g19_t USING inverted(pk, arr_intv);
----
db error: ERROR: Failed to create index: Column 'arr_intv' has unsupported type INTERVAL[3] and can not be indexed


# ARRAY<GEOMETRY('OGC:CRS84'),3>: rejected by the explicit GEOMETRY
# special-case at inverted_index.cpp:263 (the GEOMETRY child is String-kind
# and would otherwise be accepted, but the container branch carves it out).
# Also pinned by g7_ga; repeated under g19_ for self-contained coverage.
statement error
CREATE INDEX g19_imp_arr_geom ON g19_t USING inverted(pk, arr_geom);
----
db error: ERROR: Failed to create index: Column 'arr_geom' has unsupported type GEOMETRY('OGC:CRS84')[3] and can not be indexed


# ----------------------------------------------------------------------------
# (c) Scalar BIT / ENUM / VARIANT implicit rejections (also pinned by g16_*;
# replayed here as part of the g19_ self-contained implicit-role grid).
# ----------------------------------------------------------------------------

statement error
CREATE INDEX g19_imp_bit_s ON g19_t USING inverted(pk, bit_s);
----
db error: ERROR: Failed to create index: Column 'bit_s' has unsupported type BIT and can not be indexed


statement error
