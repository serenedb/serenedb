db error: ERROR: Failed to create index: Column 'vr' has unsupported type VARIANT and can not be indexed


# ----------------------------------------------------------------------------
# (d) Expression-source nested LIST<LIST<INTEGER>>: [[pk]] lowers to
# main.list_value(main.list_value(pk)) (already pinned by bad_list_list in
# inverted_index_expressions.test; replayed here under g19_ for completeness).
# ----------------------------------------------------------------------------

statement error
CREATE INDEX g19_imp_expr_nested ON g19_t USING inverted(pk, ([[pk]]));
----
db error: ERROR: Failed to create index: Column 'main.list_value(main.list_value(pk))' has unsupported type INTEGER[][] and can not be indexed


# ----------------------------------------------------------------------------
# (e) Rocksdb-compatible ARRAY<scalar,3> accept-paths (column source) and
# scalar / array expression accept-paths. Lives on a dedicated table so
# INSERTs don't have to step around the rocksdb-incompatible columns on
# g19_t. The implicit term_dict path accepts:
#   - TIMESTAMP[3] / BIGINT[3] / JSON[3] / BLOB[3] / FLOAT[3] / DOUBLE[3]
#     ARRAY columns (Classify maps each leaf to NumericI64 / String /
#     NumericF32 / NumericF64).
#   - BLOB / JSON / VARCHAR scalar expression (identity-wrapper via
#     coalesce keeps the binder from constant-folding the projection away).
#   - ARRAY<JSON,3> / ARRAY<BLOB,3> via identity expression.
# ----------------------------------------------------------------------------

statement ok
CREATE TABLE g19_acc_t(pk     INTEGER PRIMARY KEY,
                       arr_ts TIMESTAMP[3],
                       arr_bi BIGINT[3],
                       arr_j  JSON[3],
                       arr_b  BLOB[3],
                       arr_f  FLOAT[3],
                       arr_d  DOUBLE[3],
                       b      BLOB,
                       j      JSON,
                       v      VARCHAR);

statement ok
CREATE INDEX g19_acc_arr_ts ON g19_acc_t USING inverted(pk, arr_ts);

statement ok
CREATE INDEX g19_acc_arr_bi ON g19_acc_t USING inverted(pk, arr_bi);

statement ok
CREATE INDEX g19_acc_arr_j ON g19_acc_t USING inverted(pk, arr_j);

statement ok
CREATE INDEX g19_acc_arr_b ON g19_acc_t USING inverted(pk, arr_b);

statement ok
CREATE INDEX g19_acc_arr_f ON g19_acc_t USING inverted(pk, arr_f);

statement ok
CREATE INDEX g19_acc_arr_d ON g19_acc_t USING inverted(pk, arr_d);

statement ok
CREATE INDEX g19_acc_expr_b ON g19_acc_t USING inverted(pk, (coalesce(b, NULL::BLOB)));

statement ok
CREATE INDEX g19_acc_expr_j ON g19_acc_t USING inverted(pk, (coalesce(j, NULL::JSON)));

statement ok
CREATE INDEX g19_acc_expr_v ON g19_acc_t USING inverted(pk, (coalesce(v, NULL::VARCHAR)));

statement ok
CREATE INDEX g19_acc_expr_arr_j ON g19_acc_t USING inverted(pk, (arr_j));

statement ok
CREATE INDEX g19_acc_expr_arr_b ON g19_acc_t USING inverted(pk, (arr_b));

statement ok
INSERT INTO g19_acc_t VALUES
    (1,
     [TIMESTAMP '2024-01-01 00:00:00', TIMESTAMP '2024-02-01 00:00:00', TIMESTAMP '2024-03-01 00:00:00'],
     [10::BIGINT, 20::BIGINT, 30::BIGINT],
     ARRAY['"alpha"'::JSON, '"beta"'::JSON, '"gamma"'::JSON],
     ['aa'::BLOB, 'bb'::BLOB, 'cc'::BLOB],
     [1.0::FLOAT, 2.0::FLOAT, 3.0::FLOAT],
     [1.5::DOUBLE, 2.5::DOUBLE, 3.5::DOUBLE],
     'hello'::BLOB,
     '"jvalue1"'::JSON,
     'vvalue1'),
    (2,
     [TIMESTAMP '2024-06-01 00:00:00', TIMESTAMP '2024-07-01 00:00:00', TIMESTAMP '2024-08-01 00:00:00'],
     [40::BIGINT, 50::BIGINT, 60::BIGINT],
     ARRAY['"delta"'::JSON, '"epsilon"'::JSON, '"zeta"'::JSON],
     ['dd'::BLOB, 'ee'::BLOB, 'ff'::BLOB],
     [4.0::FLOAT, 5.0::FLOAT, 6.0::FLOAT],
     [4.5::DOUBLE, 5.5::DOUBLE, 6.5::DOUBLE],
     'world'::BLOB,
     '"jvalue2"'::JSON,
     'vvalue2');

statement ok
VACUUM (REFRESH_TABLE) g19_acc_t;

