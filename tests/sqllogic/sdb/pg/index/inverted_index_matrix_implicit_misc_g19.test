# ----------------------------------------------------------------------------
# (f) Rocksdb-incompatible accept-paths via parquet-backed view: the catalog
# accepts these types through term_dict (Classify -> NumericI64), but the
# rocksdb row store refuses TIMESTAMPTZ / TIME / TIMESTAMP_MS / TIMESTAMP_NS
# / TIMETZ / TIME_NS payloads. The parquet round-trip preserves the column
# types while bypassing rocksdb -- same shape as m_unsup / g11_a_v.
# ----------------------------------------------------------------------------

statement count 2
COPY (SELECT * FROM (VALUES
  (1,
   [TIMESTAMPTZ '2024-01-01 00:00:00+00', TIMESTAMPTZ '2024-02-01 00:00:00+00'],
   [TIME '01:23:45', TIME '02:34:56'],
   [TIMESTAMP_MS '2024-01-01 00:00:00', TIMESTAMP_MS '2024-02-01 00:00:00'],
   [TIMESTAMP_NS '2024-01-01 00:00:00', TIMESTAMP_NS '2024-02-01 00:00:00'],
   '01:23:45+02'::TIMETZ,
   '01:23:45.123456789'::TIME_NS),
  (2,
   [TIMESTAMPTZ '2024-06-15 12:00:00+00', TIMESTAMPTZ '2024-07-15 12:00:00+00'],
   [TIME '23:00:00', TIME '23:30:00'],
   [TIMESTAMP_MS '2024-06-15 12:00:00', TIMESTAMP_MS '2024-07-15 12:00:00'],
   [TIMESTAMP_NS '2024-06-15 12:00:00', TIMESTAMP_NS '2024-07-15 12:00:00'],
   '23:00:00+05'::TIMETZ,
   '23:00:00.987654321'::TIME_NS)
) AS t(pk, list_tstz, list_tt, list_tsms, list_tsns, ttz, tns))
TO '${__TEST_DIR__}/sdb_g19_temporal.parquet' (FORMAT parquet);

statement ok
CREATE VIEW g19_v AS SELECT * FROM read_parquet('${__TEST_DIR__}/sdb_g19_temporal.parquet');

statement ok
CREATE INDEX g19_acc_list_tstz ON g19_v USING inverted(pk, list_tstz);

statement ok
CREATE INDEX g19_acc_list_tt ON g19_v USING inverted(pk, list_tt);

statement ok
CREATE INDEX g19_acc_list_tsms ON g19_v USING inverted(pk, list_tsms);

statement ok
CREATE INDEX g19_acc_list_tsns ON g19_v USING inverted(pk, list_tsns);

statement ok
CREATE INDEX g19_acc_expr_ttz ON g19_v USING inverted(pk, (coalesce(ttz, ttz)));

statement ok
CREATE INDEX g19_acc_expr_tns ON g19_v USING inverted(pk, (coalesce(tns, tns)));

