control substitution on

statement ok
CREATE TEXT SEARCH DICTIONARY kw_dict(template = 'keyword');

statement ok
CREATE TEXT SEARCH DICTIONARY geo_s2_dict(template = 'geojson',
    coding = 's2point');

statement ok
CREATE TEXT SEARCH DICTIONARY geo_src_dict(template = 'geojson',
    coding = 'source');

statement ok
CREATE TEXT SEARCH DICTIONARY geopoint_dict(template = 'geopoint', latitude = 'lat', longitude = 'lng');


# ============================================================================
# Implicit role (no opclass) -- column listed in the indexed position with
# no opclass attached. term_dict::Validate (inverted_index.cpp) accepts
# every String-kind scalar (VARCHAR / BLOB / JSON-alias-VARCHAR / GEOMETRY)
# and any LIST / ARRAY of supported elements, but special-cases LIST or
# ARRAY of GEOMETRY as unsupported (line 262). Verifies each accepted
# index with a @@ probe (or count(*) when ts_* rejects the type); rejected
# cases use the implicit validator regex.
#
# Note: under the implicit role FillEntryFromTokenizer is never invoked,
# so HasJsonLeafFields() stays false and the sink routes JSON columns
# through WriteScalarBatch<VARCHAR>. JSON values are indexed as raw text
# (quotes and all), unlike the kw_dict path in m_j_prim.
# ============================================================================

statement ok
CREATE TABLE g7_j(pk INTEGER PRIMARY KEY, j JSON);

statement ok
CREATE INDEX g7_j_imp ON g7_j USING inverted(pk, j);

statement ok
INSERT INTO g7_j VALUES (1, '"alpha"'), (2, '"beta"'), (3, '42');

statement ok
VACUUM (REFRESH_TABLE) g7_j;

query
SELECT pk FROM g7_j_imp WHERE j @@ ts_like('"alpha"') ORDER BY pk;
----
pk
1


statement ok
CREATE TABLE g7_b(pk INTEGER PRIMARY KEY, b BLOB);

statement ok
CREATE INDEX g7_b_imp ON g7_b USING inverted(pk, b);

statement ok
INSERT INTO g7_b VALUES
    (1, '\x68656c6c6f'::BLOB),
    (2, '\xdeadbeef'::BLOB);

statement ok
VACUUM (REFRESH_TABLE) g7_b;

query
SELECT pk FROM g7_b_imp WHERE b @@ ts_like('\xdeadbeef'::BLOB) ORDER BY pk;
----
pk
2


# GEOMETRY scalar with no opclass: rejected by the term_dict (implicit)
# validator. GEOMETRY indexing requires a geo opclass (geo_s2_dict /
# geo_src_dict / geopoint_dict) -- raw WKB bytes have no usable index codec
# without the geo analyzer attached.
statement ok
CREATE TABLE g7_g(pk INTEGER PRIMARY KEY, g GEOMETRY('OGC:CRS84'));

statement error
CREATE INDEX g7_g_imp ON g7_g USING inverted(pk, g);
----
db error: ERROR: Column 'g' has unsupported type GEOMETRY('OGC:CRS84') and can not be indexed


