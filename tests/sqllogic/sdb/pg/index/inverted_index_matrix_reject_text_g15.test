control substitution on

statement ok
CREATE TEXT SEARCH DICTIONARY kw_dict(template = 'keyword');

statement ok
CREATE TEXT SEARCH DICTIONARY ng_dict(template = 'ngram', mingram = 2,
    maxgram = 3, preserveoriginal = false, frequency = true, position = true);

statement ok
CREATE TEXT SEARCH DICTIONARY any_text_dict(template = 'text', locale = 'en_US.UTF-8', case = 'none', stemming = false, accent = false, frequency = true, position = true);


# ============================================================================
# g15 -- Text-tokenizer rejection coverage across the full unusual-type matrix.
#
# Every type the AREA lists is declared as a column of one table g15_t, and
# every (column, text-tokenizer) pair is exercised with a single
# statement-error block. The two-stage validator in
# server/catalog/index.cpp:ValidateInvertedIndexColumns runs in this order:
#
#   (1) term_dict::Validate (line 399) -- rejects types that Classify (in
#       server/catalog/inverted_index.h:64) maps to Kind::Unsupported.
#       Wording: "has unsupported type X and can not be indexed".
#       For this block: UBIGINT, HUGEINT, UHUGEINT, DECIMAL(10,2), INTERVAL,
#       UUID, STRUCT(a INTEGER), MAP(VARCHAR, INTEGER), VARIANT.
#
#   (2) ValidateTokenizerVsColumn (line 704) -- rejects types that are
#       Supported by term_dict but are not VARCHAR / BLOB / LIST / ARRAY of
#       VARCHAR / BLOB; the keyword / ngram / text analyzers can only consume
#       string-shaped bytes. Wording:
#       "uses a tokenizer; must be VARCHAR, BLOB, or a LIST/ARRAY of
#        VARCHAR/BLOB (got X)".
#       For this block: TIME, TIME_NS, TIME WITH TIME ZONE,
#       TIMESTAMP_MS, TIMESTAMP_NS, TIMESTAMP WITH TIME ZONE,
#       TINYINT, SMALLINT, UTINYINT, USMALLINT, UINTEGER, FLOAT,
#       GEOMETRY('OGC:CRS84').
#
# kw_dict / ng_dict / any_text_dict are already declared at the top of this
# file (lines 28, 31-32, 1583) -- not redeclared.
#
# No rows are inserted: the entire block tests CREATE INDEX rejection, so
# rocksdb-incompatible types (UTINYINT / USMALLINT / UINTEGER / TIME
# variants / TIMESTAMP_MS / TIMESTAMP_NS / TIMESTAMPTZ) can sit in a regular
# table without ever reaching the storage path.
# ============================================================================

statement ok
CREATE TABLE g15_t(pk    INTEGER PRIMARY KEY,
                   u64   UBIGINT,
                   h     HUGEINT,
                   uh    UHUGEINT,
                   d     DECIMAL(10,2),
                   iv    INTERVAL,
                   uu    UUID,
                   st    STRUCT(a INTEGER),
                   mp    MAP(VARCHAR, INTEGER),
                   vr    VARIANT,
                   tt    TIME,
                   ttns  TIME_NS,
                   tttz  TIMETZ,
                   tsms  TIMESTAMP_MS,
                   tsns  TIMESTAMP_NS,
                   tstz  TIMESTAMPTZ,
                   t8    TINYINT,
                   t16   SMALLINT,
                   u8    UTINYINT,
                   u16   USMALLINT,
                   u32   UINTEGER,
                   f     FLOAT,
                   g     GEOMETRY('OGC:CRS84'));

# ----------------------------------------------------------------------------
# kw_dict (keyword tokenizer)
# ----------------------------------------------------------------------------

# Unsupported-set rejections: term_dict::Validate fails first.
statement error
CREATE INDEX g15_kw_u64 ON g15_t USING inverted(pk, u64 kw_dict);
----
db error: ERROR: Column 'u64' has unsupported type UBIGINT and can not be indexed


