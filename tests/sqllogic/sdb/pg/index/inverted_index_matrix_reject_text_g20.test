control substitution on

statement ok
CREATE TEXT SEARCH DICTIONARY kw_dict(template = 'keyword');

statement ok
CREATE TEXT SEARCH DICTIONARY ng_dict(template = 'ngram', mingram = 2,
    maxgram = 3, preserveoriginal = false, frequency = true, position = true);

statement ok
CREATE TEXT SEARCH DICTIONARY any_text_dict(template = 'text', locale = 'en_US.UTF-8', case = 'none', stemming = false, accent = false, frequency = true, position = true);


# ============================================================================
# g20 -- Text-tokenizer (kw_dict / ng_dict / any_text_dict) rejection
# completeness for list/array of non-string children + scalar BIT/ENUM +
# expression-source scalar INTEGER / GEOMETRY('OGC:CRS84').
#
# Closes the remaining gaps in text-tokenizer rejection:
#
#   (1) LIST<UUID>, LIST<GEOMETRY('OGC:CRS84')>, ARRAY<GEOMETRY('OGC:CRS84'),3>:
#       term_dict::Validate rejects in the LIST/ARRAY container branch
#       (server/catalog/inverted_index.cpp:257-266). UUID has no Classify entry
#       (default arm -> Unsupported), and GEOMETRY children are caught by the
#       explicit special-case at inverted_index.cpp:263.
#       Wording: "has unsupported type X and can not be indexed".
#
#   (2) LIST<INTEGER>, LIST<BIGINT>, LIST<DOUBLE>, ARRAY<INTEGER,3>:
#       term_dict::Validate passes (children classify as Numeric{I32,I64,F64}),
#       so ValidateTokenizerVsColumn (server/catalog/index.cpp:447-469) fires
#       next. Wording: "uses a tokenizer; must be VARCHAR, BLOB, or a
#       LIST/ARRAY of VARCHAR/BLOB (got X)".
#
#   (3) ARRAY<JSON,3>: JSON's LogicalTypeId is VARCHAR (alias-tagged), so the
#       child satisfies is_string_leaf but the !IsJSONType() guard at
#       index.cpp:459 strips it back out. Same ValidateTokenizerVsColumn
#       wording as (2). m_jl pinned JSON[] for kw/ng; g1 pinned any_text on
#       LIST<JSON>; g20 adds ARRAY<JSON,3> across all three tokenizers.
#
#   (4) Scalar BIT, ENUM: term_dict::Classify default arm -> Unsupported.
#       term_dict::Validate fails first with the "has unsupported type"
#       wording. (BIT was already covered for implicit-path rejection in g16;
#       g20 nails the kw/ng/any_text branches.)
#
#   (5) Expression-source scalar INTEGER and GEOMETRY('OGC:CRS84'):
#       INTEGER classifies as NumericI32 (Supported) and GEOMETRY classifies
#       as String (Supported, opclass is non-empty), so both reach
#       ValidateTokenizerVsColumn -- which rejects because neither is
#       VARCHAR/BLOB nor a LIST/ARRAY of them. The error label is the
#       verbatim expression text for non-trivial expressions ('(n + 1)'); the
#       +1 keeps the expression from constant-folding away. DuckDB's parser
#       normalizes a single-identifier paren like `(g)` to a bare column
#       reference, so the error label collapses to 'g' (not '(g)').
#
# kw_dict / ng_dict / any_text_dict are already declared near the top of this
# file -- not redeclared. No rows are inserted: every cell is pure CREATE
# INDEX rejection, so rocksdb-incompatible types (BIT, ENUM) sit safely in a
# regular table without ever reaching the storage path.
# ============================================================================

statement ok
CREATE TYPE g20_enum_t AS ENUM ('a', 'b');


statement ok
CREATE TABLE g20_t(pk     INTEGER PRIMARY KEY,
                   list_i  INTEGER[],
                   list_bi BIGINT[],
                   list_d  DOUBLE[],
                   list_u  UUID[],
                   list_g  GEOMETRY('OGC:CRS84')[],
                   arr_i   INTEGER[3],
                   arr_g   GEOMETRY('OGC:CRS84')[3],
                   arr_j   JSON[3],
                   bit_s   BIT,
                   enum_s  g20_enum_t,
                   v       VARCHAR,
                   n       INTEGER,
                   g       GEOMETRY('OGC:CRS84'));


# ----------------------------------------------------------------------------
# kw_dict (keyword tokenizer)
# ----------------------------------------------------------------------------

# (a) kw_dict on LIST<INTEGER>: term_dict passes (NumericI32),
#     ValidateTokenizerVsColumn rejects.
statement error
CREATE INDEX g20_kw_li ON g20_t USING inverted(pk, list_i kw_dict);
----
db error: ERROR: Column 'list_i' uses a tokenizer; must be VARCHAR, BLOB, or a LIST/ARRAY of VARCHAR/BLOB (got INTEGER[])


# (b) kw_dict on LIST<BIGINT>: NumericI64 child, ValidateTokenizerVsColumn.
statement error
CREATE INDEX g20_kw_lbi ON g20_t USING inverted(pk, list_bi kw_dict);
----
db error: ERROR: Column 'list_bi' uses a tokenizer; must be VARCHAR, BLOB, or a LIST/ARRAY of VARCHAR/BLOB (got BIGINT[])


# (c) kw_dict on LIST<DOUBLE>: NumericF64 child, ValidateTokenizerVsColumn.
statement error
CREATE INDEX g20_kw_ld ON g20_t USING inverted(pk, list_d kw_dict);
----
db error: ERROR: Column 'list_d' uses a tokenizer; must be VARCHAR, BLOB, or a LIST/ARRAY of VARCHAR/BLOB (got DOUBLE[])


# (d) kw_dict on LIST<UUID>: UUID classifies Unsupported (default arm), so
#     term_dict::Validate fails in the container branch.
statement error
CREATE INDEX g20_kw_lu ON g20_t USING inverted(pk, list_u kw_dict);
----
db error: ERROR: Column 'list_u' has unsupported type UUID[] and can not be indexed


# (e) kw_dict on LIST<GEOMETRY('OGC:CRS84')>: explicit child-GEOMETRY guard
#     in term_dict::Validate fires regardless of CRS.
statement error
CREATE INDEX g20_kw_lg ON g20_t USING inverted(pk, list_g kw_dict);
----
db error: ERROR: Column 'list_g' has unsupported type GEOMETRY('OGC:CRS84')[] and can not be indexed


# (f) kw_dict on ARRAY<INTEGER,3>: NumericI32 child, ValidateTokenizerVsColumn.
statement error
CREATE INDEX g20_kw_ai ON g20_t USING inverted(pk, arr_i kw_dict);
----
db error: ERROR: Column 'arr_i' uses a tokenizer; must be VARCHAR, BLOB, or a LIST/ARRAY of VARCHAR/BLOB (got INTEGER[3])


# (g) kw_dict on ARRAY<GEOMETRY('OGC:CRS84'),3>: explicit child-GEOMETRY guard.
statement error
CREATE INDEX g20_kw_ag ON g20_t USING inverted(pk, arr_g kw_dict);
----
db error: ERROR: Column 'arr_g' has unsupported type GEOMETRY('OGC:CRS84')[3] and can not be indexed


# (h) kw_dict on ARRAY<JSON,3>: JSON child is VARCHAR-aliased; is_string_leaf
#     matches but the !IsJSONType() guard strips JSON back out, so
#     ValidateTokenizerVsColumn rejects.
statement error
CREATE INDEX g20_kw_aj ON g20_t USING inverted(pk, arr_j kw_dict);
----
db error: ERROR: Column 'arr_j' uses a tokenizer; must be VARCHAR, BLOB, or a LIST/ARRAY of VARCHAR/BLOB (got JSON[3])


# (i) kw_dict on scalar BIT: Classify default arm -> Unsupported,
#     term_dict::Validate fails on the scalar branch.
statement error
CREATE INDEX g20_kw_bit ON g20_t USING inverted(pk, bit_s kw_dict);
----
db error: ERROR: Column 'bit_s' has unsupported type BIT and can not be indexed


# (j) kw_dict on scalar ENUM: same path; the user-visible type alias
#     ('g20_enum_t') is what ToString surfaces.
statement error
CREATE INDEX g20_kw_en ON g20_t USING inverted(pk, enum_s kw_dict);
----
db error: ERROR: Column 'enum_s' has unsupported type g20_enum_t and can not be indexed


# (k) kw_dict on INTEGER expression source: term_dict accepts (NumericI32),
#     ValidateTokenizerVsColumn rejects; the column label is the verbatim
#     expression text. '+ 1' keeps it from constant-folding.
statement error
CREATE INDEX g20_kw_expr_n ON g20_t USING inverted(pk, (n + 1) kw_dict);
----
db error: ERROR: Column '(n + 1)' uses a tokenizer; must be VARCHAR, BLOB, or a LIST/ARRAY of VARCHAR/BLOB (got INTEGER)


# (l) kw_dict on GEOMETRY('OGC:CRS84') expression source: term_dict accepts
#     (String, non-empty opclass), ValidateTokenizerVsColumn rejects. The
#     DuckDB parser normalizes the single-identifier paren `(g)` to a bare
#     column reference, so the error label collapses to 'g'.
statement error
CREATE INDEX g20_kw_expr_g ON g20_t USING inverted(pk, (g) kw_dict);
----
db error: ERROR: Column 'g' uses a tokenizer; must be VARCHAR, BLOB, or a LIST/ARRAY of VARCHAR/BLOB (got GEOMETRY('OGC:CRS84'))


