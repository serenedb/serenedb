control substitution on

# ============================================================================
# DATE / TIMESTAMP scalar
# ============================================================================

statement ok
CREATE TABLE m_t(pk INTEGER PRIMARY KEY, d DATE, ts TIMESTAMP);

statement ok
CREATE INDEX m_t_date_col_st ON m_t USING inverted(pk, d)  INCLUDE (d);

statement ok
CREATE INDEX m_t_ts_col_ns   ON m_t USING inverted(pk, ts);

statement ok
CREATE INDEX m_t_date_expr_ns ON m_t USING inverted(pk, (d + INTERVAL '1 day'));

statement ok
CREATE INDEX m_t_ts_expr_ns   ON m_t USING inverted(pk, (ts + INTERVAL '1 hour'));

statement ok
INSERT INTO m_t VALUES
    (1, DATE '2024-01-01', TIMESTAMP '2024-01-01 00:00:00'),
    (2, DATE '2024-06-15', TIMESTAMP '2024-06-15 12:00:00');

statement ok
VACUUM (REFRESH_TABLE) m_t;

query
SELECT count(*) FROM m_t_date_col_st;
----
count
2

query
SELECT count(*) FROM m_t_ts_col_ns;
----
count
2

query
SELECT count(*) FROM m_t_date_expr_ns;
----
count
2

query
SELECT count(*) FROM m_t_ts_expr_ns;
----
count
2

# Drive DATE / TIMESTAMP via @@ on the term_dict path, both column and
# expression sources.
query
SELECT pk FROM m_t_date_col_st
WHERE d @@ ts_between(DATE '2024-03-01', DATE '2024-12-31', true, true) ORDER BY pk;
----
pk
2

query
SELECT pk FROM m_t_ts_col_ns
WHERE ts @@ ts_between(TIMESTAMP '2024-03-01', TIMESTAMP '2024-12-31', true, true) ORDER BY pk;
----
pk
2

query
SELECT pk FROM m_t_date_expr_ns
WHERE (d + INTERVAL '1 day') @@ ts_between(DATE '2024-03-01', DATE '2024-12-31', true, true) ORDER BY pk;
----
pk
2

query
SELECT pk FROM m_t_ts_expr_ns
WHERE (ts + INTERVAL '1 hour') @@ ts_between(TIMESTAMP '2024-03-01', TIMESTAMP '2024-12-31', true, true) ORDER BY pk;
----
pk
2


# ============================================================================
# Width fan-out — TINYINT (i8) and SMALLINT (i16) join the I32/I64 family but
# share the same encoder; flush a sign-extension regression with their own
# rows.  UTINYINT / USMALLINT / UINTEGER share the same numeric encoders and
# get no dedicated rows; HUGEINT / UUID / DECIMAL / INTERVAL classify as
# Unsupported and are rejected by the validator (see
# inverted_index_matrix_validator / inverted_index_unsupported_numeric).
# ============================================================================

statement ok
CREATE TABLE m_narrow(pk INTEGER PRIMARY KEY, t8 TINYINT, t16 SMALLINT);

statement ok
CREATE INDEX m_narrow_t8  ON m_narrow USING inverted(pk, t8) INCLUDE (t8);

statement ok
CREATE INDEX m_narrow_t16 ON m_narrow USING inverted(pk, t16);

statement ok
INSERT INTO m_narrow VALUES (1, -10::TINYINT, -100::SMALLINT), (2, 10::TINYINT, 100::SMALLINT);

statement ok
VACUUM (REFRESH_TABLE) m_narrow;

query
SELECT pk FROM m_narrow_t8 WHERE t8 @@ ts_between(-50::TINYINT, -5::TINYINT, true, true);
----
pk
1

query
SELECT pk FROM m_narrow_t16 WHERE t16 @@ ts_between(-200::SMALLINT, 50::SMALLINT, true, true);
----
pk
1


# ============================================================================
# FLOAT scalar (NumericF32) — every other numeric kind has scalar coverage.
# ============================================================================

statement ok
CREATE TABLE m_f(pk INTEGER PRIMARY KEY, n FLOAT);

statement ok
CREATE INDEX m_f_col_st ON m_f USING inverted(pk, n) INCLUDE (n);

statement ok
CREATE INDEX m_f_expr_ns ON m_f USING inverted(pk, (n * 2.0::FLOAT));

statement ok
INSERT INTO m_f VALUES (1, 1.5::FLOAT), (2, 2.5::FLOAT), (3, -0.5::FLOAT);

statement ok
VACUUM (REFRESH_TABLE) m_f;

query
SELECT pk FROM m_f_col_st WHERE n @@ ts_between(2.0::FLOAT, 3.0::FLOAT, true, true);
----
pk
2

query
SELECT pk FROM m_f_expr_ns WHERE n * 2.0::FLOAT @@ ts_between(4.0::FLOAT, 6.0::FLOAT, true, true);
----
pk
2


# ============================================================================
# TIMESTAMP WITH TIME ZONE — distinct logical type from TIMESTAMP.
# ============================================================================

statement ok
CREATE TABLE m_tz(pk INTEGER PRIMARY KEY, ts TIMESTAMPTZ);

statement ok
CREATE INDEX m_tz_col_ns ON m_tz USING inverted(pk, ts);

statement ok
INSERT INTO m_tz VALUES
    (1, TIMESTAMPTZ '2024-01-01 00:00:00+00'),
    (2, TIMESTAMPTZ '2024-06-15 12:00:00+00');

statement ok
VACUUM (REFRESH_TABLE) m_tz;

query
SELECT pk FROM m_tz_col_ns WHERE ts @@ ts_between(TIMESTAMPTZ '2024-03-01 00:00:00+00', TIMESTAMPTZ '2024-12-31 00:00:00+00', true, true);
----
pk
2


# ============================================================================
# DATE list / array — DATE classifies as NumericI32 so its list / array goes
# through the implicit numeric tokenizer.
# ============================================================================

statement ok
CREATE TABLE m_dla(pk INTEGER PRIMARY KEY, ds DATE[], da DATE[3]);

statement ok
CREATE INDEX m_dla_ds ON m_dla USING inverted(pk, ds);

statement ok
CREATE INDEX m_dla_da ON m_dla USING inverted(pk, da);

statement ok
INSERT INTO m_dla VALUES
    (1, [DATE '2024-01-01', DATE '2024-06-15'], [DATE '2024-01-01', DATE '2024-06-15', DATE '2024-12-31']),
    (2, [DATE '2025-01-01'],                    [DATE '2025-01-01', DATE '2025-06-15', DATE '2025-12-31']);

statement ok
VACUUM (REFRESH_TABLE) m_dla;

query
SELECT pk FROM m_dla_ds WHERE ds @@ ts_between(DATE '2024-01-01', DATE '2024-12-31', true, true);
----
pk
1

query
SELECT pk FROM m_dla_da WHERE da @@ ts_between(DATE '2025-03-01', DATE '2025-08-01', true, true);
----
pk
2


# ============================================================================
# TIME / TIMETZ / TIME_NS scalar — NumericI64 raw-unit encodings (micros,
# packed micros+offset, nanos).
# ============================================================================

statement ok
CREATE TABLE m_time(pk INTEGER PRIMARY KEY, t TIME, ttz TIMETZ, tns TIME_NS);

statement ok
CREATE INDEX m_time_t   ON m_time USING inverted(pk, t)   INCLUDE (t);

statement ok
CREATE INDEX m_time_ttz ON m_time USING inverted(pk, ttz) INCLUDE (ttz);

statement ok
CREATE INDEX m_time_tns ON m_time USING inverted(pk, tns) INCLUDE (tns);

statement ok
INSERT INTO m_time VALUES
    (1, TIME '06:00:00', TIMETZ '06:00:00+02', TIME_NS '06:00:00.000000001'),
    (2, TIME '18:30:00', TIMETZ '18:30:00+02', TIME_NS '18:30:00.999999999');

statement ok
VACUUM (REFRESH_TABLE) m_time;

query
SELECT pk FROM m_time_t WHERE t @@ ts_between(TIME '12:00:00', TIME '23:00:00', true, true);
----
pk
2

# Cross-unit: TIME_NS bounds against the micros-encoded TIME column (the bound
# is cast to the column's unit before tokenizing).
query
SELECT pk FROM m_time_t WHERE t @@ ts_between(TIME_NS '12:00:00', TIME_NS '23:00:00', true, true);
----
pk
2



query
SELECT pk FROM m_time_ttz WHERE ttz @@ ts_between(TIMETZ '12:00:00+02', TIMETZ '23:00:00+02', true, true);
----
pk
2

query
SELECT pk FROM m_time_tns WHERE tns @@ ts_between(TIME_NS '12:00:00', TIME_NS '23:00:00', true, true);
----
pk
2

# Stored (INCLUDE) values round-trip.
query
SELECT pk, t FROM m_time_t ORDER BY pk;
----
pk	t
1	06:00:00
2	18:30:00

# The binary wire carries micros, so sub-microsecond digits truncate there.
skipif pg-wire-extended
query
SELECT pk, tns FROM m_time_tns ORDER BY pk;
----
pk	tns
1	06:00:00.000000001
2	18:30:00.999999999

onlyif pg-wire-extended
query
SELECT pk, tns FROM m_time_tns ORDER BY pk;
----
pk	tns
1	06:00:00
2	18:30:00.999999


# ============================================================================
# TIMESTAMP_S / TIMESTAMP_MS / TIMESTAMP_NS scalar — raw-unit int64 encodings
# (seconds / millis / nanos). Cross-unit bounds are the critical probes: the
# bound is cast to the column's unit before tokenizing, so a micros-typed
# TIMESTAMP bound must land exactly on the stored unit's sub-second boundary.
# ============================================================================

statement ok
CREATE TABLE m_scaled(pk INTEGER PRIMARY KEY, ts_s TIMESTAMP_S, ts_ms TIMESTAMP_MS, ts_ns TIMESTAMP_NS);

statement ok
CREATE INDEX m_scaled_s  ON m_scaled USING inverted(pk, ts_s)  INCLUDE (ts_s);

statement ok
CREATE INDEX m_scaled_ms ON m_scaled USING inverted(pk, ts_ms) INCLUDE (ts_ms);

statement ok
CREATE INDEX m_scaled_ns ON m_scaled USING inverted(pk, ts_ns) INCLUDE (ts_ns);

statement ok
INSERT INTO m_scaled VALUES
    (1, TIMESTAMP_S '2024-01-01 00:00:00', TIMESTAMP_MS '2024-01-01 00:00:00.251',
        TIMESTAMP_NS '2024-01-01 00:00:00.000000001'),
    (2, TIMESTAMP_S '2024-06-15 12:00:00', TIMESTAMP_MS '2024-06-15 12:00:00.753',
        TIMESTAMP_NS '2024-06-15 12:00:00.123456789');

statement ok
VACUUM (REFRESH_TABLE) m_scaled;

query
SELECT pk FROM m_scaled_s WHERE ts_s @@ ts_between(TIMESTAMP_S '2024-03-01 00:00:00', TIMESTAMP_S '2024-12-31 00:00:00', true, true);
----
pk
2

query
SELECT pk FROM m_scaled_ms WHERE ts_ms @@ ts_between(TIMESTAMP_MS '2024-03-01 00:00:00', TIMESTAMP_MS '2024-12-31 00:00:00', true, true);
----
pk
2

query
SELECT pk FROM m_scaled_ns WHERE ts_ns @@ ts_between(TIMESTAMP_NS '2024-03-01 00:00:00', TIMESTAMP_NS '2024-12-31 00:00:00', true, true);
----
pk
2

# Cross-unit: DATE bounds against the seconds-encoded column.
query
SELECT pk FROM m_scaled_s WHERE ts_s @@ ts_between(DATE '2024-03-01', DATE '2024-12-31', true, true);
----
pk
2

# Cross-unit sub-second window: micros bounds land around the stored .753 ms.
query
SELECT pk FROM m_scaled_ms WHERE ts_ms @@ ts_between(TIMESTAMP '2024-06-15 12:00:00.700', TIMESTAMP '2024-06-15 12:00:00.800', true, true);
----
pk
2

query
SELECT pk FROM m_scaled_ms WHERE ts_ms @@ ts_between(TIMESTAMP '2024-06-15 12:00:00.754', TIMESTAMP '2024-06-15 12:00:00.800', true, true);
----
pk

# Cross-unit sub-micro window: micros bounds bracket the stored .123456789 ns.
query
SELECT pk FROM m_scaled_ns WHERE ts_ns @@ ts_between(TIMESTAMP '2024-06-15 12:00:00.123456', TIMESTAMP '2024-06-15 12:00:00.123457', true, true);
----
pk
2

query
SELECT pk, ts_ms FROM m_scaled_ms ORDER BY pk;
----
pk	ts_ms
1	2024-01-01 00:00:00.251
2	2024-06-15 12:00:00.753


# ============================================================================
# TIMESTAMPTZ_NS — ns-precision sibling of TIMESTAMPTZ. DuckDB has no
# micros<->nanos tz casts, so bounds must be TIMESTAMPTZ_NS-typed.
# ============================================================================

statement ok
CREATE TABLE m_tzns(pk INTEGER PRIMARY KEY, ts TIMESTAMPTZ_NS);

statement ok
CREATE INDEX m_tzns_col ON m_tzns USING inverted(pk, ts) INCLUDE (ts);

statement ok
INSERT INTO m_tzns VALUES
    (1, TIMESTAMPTZ_NS '2024-01-01 00:00:00.000000001+00'),
    (2, TIMESTAMPTZ_NS '2024-06-15 12:00:00.123456789+00');

statement ok
VACUUM (REFRESH_TABLE) m_tzns;

query
SELECT pk FROM m_tzns_col WHERE ts @@ ts_between(TIMESTAMPTZ_NS '2024-03-01 00:00:00+00', TIMESTAMPTZ_NS '2024-12-31 00:00:00+00', true, true);
----
pk
2


# --- teardown ---------------------------------------------------------------

statement ok
DROP TABLE m_time;

statement ok
DROP TABLE m_scaled;

statement ok
DROP TABLE m_tzns;

statement ok
DROP TABLE m_t;

statement ok
DROP TABLE m_narrow;

statement ok
DROP TABLE m_f;

statement ok
DROP TABLE m_tz;

statement ok
DROP TABLE m_dla;
