statement ok
CREATE INDEX g17_bla_bs_col_ng    ON g17_bla USING inverted(pk, bs ng_dict);

statement ok
CREATE INDEX g17_bla_ba_col_ng    ON g17_bla USING inverted(pk, ba ng_dict);

statement ok
CREATE INDEX g17_bla_bs_expr_kw   ON g17_bla USING inverted(pk, (bs) kw_dict);

statement ok
CREATE INDEX g17_bla_ba_expr_kw   ON g17_bla USING inverted(pk, (ba) kw_dict);

statement ok
CREATE INDEX g17_bla_bs_expr_ng   ON g17_bla USING inverted(pk, (bs) ng_dict);

