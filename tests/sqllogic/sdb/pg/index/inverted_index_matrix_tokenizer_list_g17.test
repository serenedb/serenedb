# --- (z) implicit (no opclass) LIST<JSON> expression source -----------------
# Mirrors g7_jl_imp on the column side; this is the expression-source twin.

statement ok
CREATE INDEX g17_jl_js_expr_imp ON g17_jl USING inverted(pk, (js));

statement ok
INSERT INTO g17_jl VALUES
    (1, ARRAY['"alpha"'::JSON, '"beta"'::JSON]),
    (2, ARRAY['"gamma"'::JSON]);

statement ok
VACUUM (REFRESH_TABLE) g17_jl;

query
