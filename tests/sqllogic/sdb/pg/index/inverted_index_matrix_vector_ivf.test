control substitution on

# ============================================================================
# Vector  --  IVF (array only) + text-tokenized FLOAT array
# ============================================================================

statement ok
CREATE TABLE m_vec(pk INTEGER PRIMARY KEY, emb FLOAT[3], fs FLOAT[]);

statement ok
CREATE INDEX m_vec_ivf_st   ON m_vec
    USING inverted(pk, emb ivf (metric = 'l2')) INCLUDE (emb);

statement ok
CREATE INDEX m_vec_ivf_ns   ON m_vec
    USING inverted(pk, emb ivf (metric = 'cosine'));

statement ok
CREATE INDEX m_vec_ivf_expr_ns ON m_vec
    USING inverted(pk, (emb) ivf (metric = 'l2'));

statement ok
CREATE INDEX m_vec_ivf_expr_st ON m_vec
    USING inverted(pk, (emb) ivf (metric = 'l2')) INCLUDE (emb);

statement ok
CREATE INDEX m_vec_floats_st ON m_vec USING inverted(pk, fs) INCLUDE (fs);

statement ok
CREATE INDEX m_vec_floats_ns ON m_vec USING inverted(pk, fs);

statement ok
CREATE INDEX m_vec_floats_expr_ns ON m_vec USING inverted(pk, (fs));

statement ok
INSERT INTO m_vec VALUES
    (1, [1.0::FLOAT, 0.0::FLOAT, 0.0::FLOAT], [1.0::FLOAT, 2.0::FLOAT, 3.0::FLOAT]),
    (2, [0.0::FLOAT, 1.0::FLOAT, 0.0::FLOAT], [4.0::FLOAT, 5.0::FLOAT]),
    (3, [0.0::FLOAT, 0.0::FLOAT, 1.0::FLOAT], [3.0::FLOAT, 3.0::FLOAT, 3.0::FLOAT]);

statement ok
VACUUM (REFRESH_TABLE) m_vec;

query
SELECT pk FROM m_vec_ivf_st
ORDER BY emb <-> [1.0::FLOAT, 0.0::FLOAT, 0.0::FLOAT]::FLOAT[3]
LIMIT 1;
----
pk
1

query
SELECT pk FROM m_vec_ivf_ns
ORDER BY emb <=> [1.0::FLOAT, 0.0::FLOAT, 0.0::FLOAT]::FLOAT[3]
LIMIT 1;
----
pk
1

query
SELECT count(*) FROM m_vec_ivf_ns;
----
count
3

query
SELECT pk FROM m_vec_floats_st
WHERE fs @@ ts_between(2.5::FLOAT, 3.5::FLOAT, true, true)
ORDER BY pk;
----
pk
1
3

query
SELECT pk FROM m_vec_ivf_expr_ns
ORDER BY (emb) <-> [1.0::FLOAT, 0.0::FLOAT, 0.0::FLOAT]::FLOAT[3]
LIMIT 1;
----
pk
1

query
SELECT pk FROM m_vec_ivf_expr_st
ORDER BY (emb) <-> [1.0::FLOAT, 0.0::FLOAT, 0.0::FLOAT]::FLOAT[3]
LIMIT 1;
----
pk
1

# ANN range — radius wide enough to include the (1,0,0) row at distance 0
# and exclude the orthogonal vectors at distance sqrt(2)~1.414... < 1.5
# but stays away from the third row at sqrt(2).
query
SELECT pk FROM m_vec_ivf_st
WHERE emb <-> [1.0::FLOAT, 0.0::FLOAT, 0.0::FLOAT]::FLOAT[3] < 0.5
ORDER BY pk;
----
pk
1

query
SELECT pk FROM m_vec_ivf_expr_ns
WHERE (emb) <-> [1.0::FLOAT, 0.0::FLOAT, 0.0::FLOAT]::FLOAT[3] < 0.5
ORDER BY pk;
----
pk
1

# Lock in that both column and expression IVF reach the ANN scan operator
# (not a brute-force fallback). top-K ⇒ IRESEARCH_SCAN with a VECTOR_KNN
# Filter node, distance < radius ⇒ IRESEARCH_SCAN with a VECTOR_RANGE node.
query
EXPLAIN SELECT pk FROM m_vec_ivf_st
  ORDER BY emb <-> [1.0::FLOAT, 0.0::FLOAT, 0.0::FLOAT]::FLOAT[3] LIMIT 1;
----
QUERY PLAN
╭─ TOP_N ────────────────────────────────╮
│ Top: 1                                 │
│ Order By: #1 ASC                       │
│ ~1 row                                 │
╰────────────────────┬───────────────────╯
╭─ IRESEARCH_SCAN ───┴───────────────────╮
│ Index: m_vec_ivf_st                    │
│ Lookup: table                          │
│ Index Filter:                          │
│ ╭─ Vector KNN ─╮                       │
│ │ Field: emb   │                       │
│ │ Metric: l2   │                       │
│ │ Dims: 3      │                       │
│ ╰──────────────╯                       │
│ Top: 1                                 │
│ Projections: pk,                       │
│              sdb_inverted_index_score  │
│ ~3 rows                                │
╰────────────────────────────────────────╯

query
EXPLAIN SELECT pk FROM m_vec_ivf_expr_ns
  ORDER BY (emb) <-> [1.0::FLOAT, 0.0::FLOAT, 0.0::FLOAT]::FLOAT[3] LIMIT 1;
----
QUERY PLAN
╭─ TOP_N ────────────────────────────────╮
│ Top: 1                                 │
│ Order By: #1 ASC                       │
│ ~1 row                                 │
╰────────────────────┬───────────────────╯
╭─ IRESEARCH_SCAN ───┴───────────────────╮
│ Index: m_vec_ivf_expr_ns               │
│ Lookup: table                          │
│ Index Filter:                          │
│ ╭─ Vector KNN ─╮                       │
│ │ Field: emb   │                       │
│ │ Metric: l2   │                       │
│ │ Dims: 3      │                       │
│ ╰──────────────╯                       │
│ Top: 1                                 │
│ Projections: pk,                       │
│              sdb_inverted_index_score  │
│ ~3 rows                                │
╰────────────────────────────────────────╯

query
EXPLAIN SELECT pk FROM m_vec_ivf_st
  WHERE emb <-> [1.0::FLOAT, 0.0::FLOAT, 0.0::FLOAT]::FLOAT[3] < 1.5;
----
QUERY PLAN
╭─ IRESEARCH_SCAN ────╮
│ Index: m_vec_ivf_st │
│ Lookup: table       │
│ Index Filter:       │
│ ╭─ Vector Range ─╮  │
│ │ Field: emb     │  │
│ │ Metric: l2     │  │
│ │ Dims: 3        │  │
│ │ Radius: < 1.5  │  │
│ ╰────────────────╯  │
│ Projections: pk     │
│ ~3 rows             │
╰─────────────────────╯

query
EXPLAIN SELECT pk FROM m_vec_ivf_expr_ns
  WHERE (emb) <-> [1.0::FLOAT, 0.0::FLOAT, 0.0::FLOAT]::FLOAT[3] < 1.5;
----
QUERY PLAN
╭─ IRESEARCH_SCAN ─────────╮
│ Index: m_vec_ivf_expr_ns │
│ Lookup: table            │
│ Index Filter:            │
│ ╭─ Vector Range ─╮       │
│ │ Field: emb     │       │
│ │ Metric: l2     │       │
│ │ Dims: 3        │       │
│ │ Radius: < 1.5  │       │
│ ╰────────────────╯       │
│ Projections: pk          │
│ ~3 rows                  │
╰──────────────────────────╯

query
SELECT pk FROM m_vec_floats_expr_ns
WHERE (fs) @@ ts_between(2.5::FLOAT, 3.5::FLOAT, true, true)
ORDER BY pk;
----
pk
1
3


# --- teardown ---------------------------------------------------------------

statement ok
DROP TABLE m_vec;
