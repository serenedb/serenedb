# ---------------------------------------------------------------------------
# Conjunction (AND) and disjunction (OR) filter shapes still produce the
# same top-K results with WAND on as without. The score_top_k pull-up
# happens regardless of the boolean filter shape.
# ---------------------------------------------------------------------------

query I
SELECT id FROM docs_wand_idx
WHERE body @@ ts_phrase('fox') AND body @@ ts_phrase('lazy')
ORDER BY BM25(docs_wand_idx.tableoid) DESC, id
LIMIT 3;
----
id
2


query I
SELECT id FROM docs_plain_idx
WHERE body @@ ts_phrase('fox') AND body @@ ts_phrase('lazy')
ORDER BY BM25(docs_plain_idx.tableoid) DESC, id
LIMIT 3;
----
id
2


query I
SELECT id FROM docs_wand_idx
WHERE body @@ ts_phrase('fox') OR body @@ ts_phrase('lazy')
ORDER BY BM25(docs_wand_idx.tableoid) DESC, id
LIMIT 4;
----
id
2
3
1
4


query I
SELECT id FROM docs_plain_idx
WHERE body @@ ts_phrase('fox') OR body @@ ts_phrase('lazy')
ORDER BY BM25(docs_plain_idx.tableoid) DESC, id
LIMIT 4;
----
id
2
3
1
4


# ---------------------------------------------------------------------------
# Multi-segment scenario: a second batch of inserts after VACUUM produces
# an additional segment so the threshold-feedback loop has to carry the
# heap minimum from segment 0 into segment 1 (see SetScoreThreshold round-
# trip in duckdb_search_full_scan.cpp). Top-K results must still match
# the non-WAND baseline over the union of both segments.
# ---------------------------------------------------------------------------

statement count 1
INSERT INTO docs_wand VALUES (6, 'fox fox fox');


statement count 1
INSERT INTO docs_wand VALUES (7, 'a fox in a box');


statement count 1
INSERT INTO docs_wand VALUES (8, 'no match here');


statement count 1
INSERT INTO docs_plain VALUES (6, 'fox fox fox');


statement count 1
INSERT INTO docs_plain VALUES (7, 'a fox in a box');


statement count 1
INSERT INTO docs_plain VALUES (8, 'no match here');


statement ok
VACUUM (REFRESH_TABLE) docs_wand;


statement ok
VACUUM (REFRESH_TABLE) docs_plain;


query I
SELECT id FROM docs_wand_idx
WHERE body @@ ts_phrase('fox')
ORDER BY BM25(docs_wand_idx.tableoid) DESC, id
LIMIT 3;
----
id
6
1
2


query I
SELECT id FROM docs_plain_idx
WHERE body @@ ts_phrase('fox')
ORDER BY BM25(docs_plain_idx.tableoid) DESC, id
LIMIT 3;
----
id
6
1
2


# Larger LIMIT spans both segments and forces the heap to fill.

