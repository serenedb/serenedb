hash-threshold 100

# ---------------------------------------------------------------------------
# Coverage for `WITH (optimize_top_k)` on `CREATE INDEX ... USING inverted(...)`.
#
# When set, the catalog InvertedIndex remembers the flag across restart, the
# writer encodes per-block max-impact (WAND) data via a default BM25 scorer,
# and `ORDER BY BM25(...) DESC LIMIT k` queries execute the iterator with
# WandContext{wand_enabled=true} plus running heap-minimum threshold feedback.
# EXPLAIN reflects the option by suffixing the `TopK` row in the
# IRESEARCH_SCAN box with `, optimized` when WAND pruning is engaged.
#
# DuckDB's CREATE INDEX option grammar rejects bare `true`/`false` keywords
# (must be a constant expression). The Postgres-style bare form
# `WITH (optimize_top_k)` evaluates to BOOLEAN(true) and is the canonical way
# to enable. Integer 0/1 and string 'false'/'true' are also accepted because
# the connector casts the value through BOOLEAN.
#
# Uses TERM_EQ predicates: WAND only requires Freq + Norm features which all
# token analyzers expose, and the simple form keeps the EXPLAIN box stable.
# ---------------------------------------------------------------------------

statement ok
CREATE TABLE docs_wand (id INTEGER PRIMARY KEY, body VARCHAR);


statement count 1
INSERT INTO docs_wand VALUES (1, 'fox quick');


statement count 1
INSERT INTO docs_wand VALUES (2, 'fox lazy');


statement count 1
INSERT INTO docs_wand VALUES (3, 'lazy dog');


statement count 1
INSERT INTO docs_wand VALUES (4, 'fox runs fast');


statement count 1
INSERT INTO docs_wand VALUES (5, 'rabbit and a fox');


statement ok
CREATE TEXT SEARCH DICTIONARY en_wand(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true,
    norm = true
);


# Bare-keyword form enables WAND.

statement ok
CREATE INDEX docs_wand_idx ON docs_wand USING inverted(id, body en_wand)
  WITH (optimize_top_k);


statement ok
VACUUM (UPDATE_INDEXES) docs_wand;


# Top-K with WAND on. Tie-break on id for deterministic ordering across
# any FP accumulation differences between the WAND and non-WAND paths.

query I
SELECT id FROM docs_wand_idx
WHERE TERM_EQ(body, 'fox')
ORDER BY BM25(docs_wand_idx.tableoid) DESC, id
LIMIT 3;
----
id
1
2
4


# Same data with a non-WAND index for an equivalence baseline.

statement ok
CREATE TABLE docs_plain (id INTEGER PRIMARY KEY, body VARCHAR);


statement count 1
INSERT INTO docs_plain VALUES (1, 'fox quick');


statement count 1
INSERT INTO docs_plain VALUES (2, 'fox lazy');


statement count 1
INSERT INTO docs_plain VALUES (3, 'lazy dog');


statement count 1
INSERT INTO docs_plain VALUES (4, 'fox runs fast');


statement count 1
INSERT INTO docs_plain VALUES (5, 'rabbit and a fox');


statement ok
CREATE INDEX docs_plain_idx ON docs_plain USING inverted(id, body en_wand);


statement ok
VACUUM (UPDATE_INDEXES) docs_plain;


query I
SELECT id FROM docs_plain_idx
WHERE TERM_EQ(body, 'fox')
ORDER BY BM25(docs_plain_idx.tableoid) DESC, id
LIMIT 3;
----
id
1
2
4


# Larger LIMIT exercises the heap-fill path (BlockSize = 2*k).

query I
SELECT id FROM docs_wand_idx
WHERE TERM_EQ(body, 'fox')
ORDER BY BM25(docs_wand_idx.tableoid) DESC, id
LIMIT 10;
----
id
1
2
4
5


# EXPLAIN: WAND-enabled scan reports `TopK: <k>, optimized`; plain scan
# reports `TopK: <k>` without the suffix. WAND only applies on the top-K
# path so the marker is bundled into the same row instead of a separate one.

query
EXPLAIN SELECT id FROM docs_wand_idx WHERE TERM_EQ(body, 'fox') ORDER BY BM25(docs_wand_idx.tableoid) DESC LIMIT 3;
----
QUERY PLAN
┌───────────────────────────┐
│       IRESEARCH_SCAN      │
│    ────────────────────   │
│      Table: docs_wand     │
│                           │
│       Materializer:       │
│    rocksdb (point Get)    │
│                           │
│          Filter:          │
│AND[Term(body(string)=fox)]│
│                           │
│           Score:          │
│    bm25(k1=1.2, b=0.75)   │
│                           │
│     TopK: 3, optimized    │
│      Projections: id      │
│                           │
│          ~5 rows          │
└───────────────────────────┘


query
EXPLAIN SELECT id FROM docs_plain_idx WHERE TERM_EQ(body, 'fox') ORDER BY BM25(docs_plain_idx.tableoid) DESC LIMIT 3;
----
QUERY PLAN
┌───────────────────────────┐
│       IRESEARCH_SCAN      │
│    ────────────────────   │
│     Table: docs_plain     │
│                           │
│       Materializer:       │
│    rocksdb (point Get)    │
│                           │
│          Filter:          │
│AND[Term(body(string)=fox)]│
│                           │
│           Score:          │
│    bm25(k1=1.2, b=0.75)   │
│                           │
│          TopK: 3          │
│      Projections: id      │
│                           │
│          ~5 rows          │
└───────────────────────────┘


# Omitting the option defaults to false.

statement ok
CREATE TABLE docs_default (id INTEGER PRIMARY KEY, body VARCHAR);


statement count 1
INSERT INTO docs_default VALUES (1, 'fox');


statement count 1
INSERT INTO docs_default VALUES (2, 'fox jumps');


statement ok
CREATE INDEX docs_default_idx ON docs_default USING inverted(id, body en_wand);


statement ok
VACUUM (UPDATE_INDEXES) docs_default;


query I
SELECT id FROM docs_default_idx
WHERE TERM_EQ(body, 'fox')
ORDER BY id;
----
id
1
2


# ---------------------------------------------------------------------------
# Conjunction (AND) and disjunction (OR) filter shapes still produce the
# same top-K results with WAND on as without. The score_top_k pull-up
# happens regardless of the boolean filter shape.
# ---------------------------------------------------------------------------

query I
SELECT id FROM docs_wand_idx
WHERE TERM_EQ(body, 'fox') AND TERM_EQ(body, 'lazy')
ORDER BY BM25(docs_wand_idx.tableoid) DESC, id
LIMIT 3;
----
id
2


query I
SELECT id FROM docs_plain_idx
WHERE TERM_EQ(body, 'fox') AND TERM_EQ(body, 'lazy')
ORDER BY BM25(docs_plain_idx.tableoid) DESC, id
LIMIT 3;
----
id
2


query I
SELECT id FROM docs_wand_idx
WHERE TERM_EQ(body, 'fox') OR TERM_EQ(body, 'lazy')
ORDER BY BM25(docs_wand_idx.tableoid) DESC, id
LIMIT 4;
----
id
2
3
1
4


query I
SELECT id FROM docs_plain_idx
WHERE TERM_EQ(body, 'fox') OR TERM_EQ(body, 'lazy')
ORDER BY BM25(docs_plain_idx.tableoid) DESC, id
LIMIT 4;
----
id
2
3
1
4


# ---------------------------------------------------------------------------
# Multi-segment scenario: a second batch of inserts after VACUUM produces
# an additional segment so the threshold-feedback loop has to carry the
# heap minimum from segment 0 into segment 1 (see SetScoreThreshold round-
# trip in duckdb_search_full_scan.cpp). Top-K results must still match
# the non-WAND baseline over the union of both segments.
# ---------------------------------------------------------------------------

statement count 1
INSERT INTO docs_wand VALUES (6, 'fox fox fox');


statement count 1
INSERT INTO docs_wand VALUES (7, 'a fox in a box');


statement count 1
INSERT INTO docs_wand VALUES (8, 'no match here');


statement count 1
INSERT INTO docs_plain VALUES (6, 'fox fox fox');


statement count 1
INSERT INTO docs_plain VALUES (7, 'a fox in a box');


statement count 1
INSERT INTO docs_plain VALUES (8, 'no match here');


statement ok
VACUUM (UPDATE_INDEXES) docs_wand;


statement ok
VACUUM (UPDATE_INDEXES) docs_plain;


query I
SELECT id FROM docs_wand_idx
WHERE TERM_EQ(body, 'fox')
ORDER BY BM25(docs_wand_idx.tableoid) DESC, id
LIMIT 3;
----
id
6
1
2


query I
SELECT id FROM docs_plain_idx
WHERE TERM_EQ(body, 'fox')
ORDER BY BM25(docs_plain_idx.tableoid) DESC, id
LIMIT 3;
----
id
6
1
2


# Larger LIMIT spans both segments and forces the heap to fill.

query I
SELECT id FROM docs_wand_idx
WHERE TERM_EQ(body, 'fox')
ORDER BY BM25(docs_wand_idx.tableoid) DESC, id
LIMIT 100;
----
id
6
1
2
4
5
7


query I
SELECT id FROM docs_plain_idx
WHERE TERM_EQ(body, 'fox')
ORDER BY BM25(docs_plain_idx.tableoid) DESC, id
LIMIT 100;
----
id
6
1
2
4
5
7


# ---------------------------------------------------------------------------
# EXPLAIN coverage for paths where WAND should NOT engage.
# ---------------------------------------------------------------------------

# 1. No LIMIT -> no score_top_k pull-up -> no `TopK` row at all (whether or
#    not the index has optimize_top_k set). Filtering still happens.

query
EXPLAIN SELECT id, BM25(docs_wand_idx.tableoid) AS s FROM docs_wand_idx WHERE TERM_EQ(body, 'fox') ORDER BY s DESC;
----
QUERY PLAN
┌───────────────────────────┐
│          ORDER_BY         │
│    ────────────────────   │
│  sdb_inverted_index_score │
│            DESC           │
│                           │
│          ~0 rows          │
└─────────────┬─────────────┘
┌─────────────┴─────────────┐
│       IRESEARCH_SCAN      │
│    ────────────────────   │
│      Table: docs_wand     │
│                           │
│       Materializer:       │
│    rocksdb (point Get)    │
│                           │
│          Filter:          │
│AND[Term(body(string)=fox)]│
│                           │
│           Score:          │
│    bm25(k1=1.2, b=0.75)   │
│                           │
│        Projections:       │
│             id            │
│  sdb_inverted_index_score │
│                           │
│          ~8 rows          │
└───────────────────────────┘


# 2. ASC ordering -> TryAttachScoreTopK doesn't fire (it only matches
#    DESC). No `TopK` row, no `optimized` suffix.

query
EXPLAIN SELECT id FROM docs_wand_idx WHERE TERM_EQ(body, 'fox') ORDER BY BM25(docs_wand_idx.tableoid) ASC LIMIT 3;
----
QUERY PLAN
┌───────────────────────────┐
│         PROJECTION        │
│    ────────────────────   │
│             #0            │
│                           │
│           ~1 row          │
└─────────────┬─────────────┘
┌─────────────┴─────────────┐
│           TOP_N           │
│    ────────────────────   │
│           Top: 3          │
│      Order By: #1 ASC     │
│                           │
│           ~1 row          │
└─────────────┬─────────────┘
┌─────────────┴─────────────┐
│       IRESEARCH_SCAN      │
│    ────────────────────   │
│      Table: docs_wand     │
│                           │
│       Materializer:       │
│    rocksdb (point Get)    │
│                           │
│          Filter:          │
│AND[Term(body(string)=fox)]│
│                           │
│           Score:          │
│    bm25(k1=1.2, b=0.75)   │
│                           │
│        Projections:       │
│             id            │
│  sdb_inverted_index_score │
│                           │
│          ~8 rows          │
└───────────────────────────┘


# ---------------------------------------------------------------------------
# Option-value forms accepted by the connector. DuckDB rejects bare
# `true`/`false` so users opt in via the bare keyword, an integer, or a
# string. All four shapes drive the same catalog flag.
# ---------------------------------------------------------------------------

# 3a. Integer 0 -> false (no `, optimized` suffix).

statement ok
CREATE TABLE docs_int_off (id INTEGER PRIMARY KEY, body VARCHAR);


statement count 1
INSERT INTO docs_int_off VALUES (1, 'fox');


statement ok
CREATE INDEX docs_int_off_idx ON docs_int_off
  USING inverted(id, body en_wand)
  WITH (optimize_top_k = 0);


statement ok
VACUUM (UPDATE_INDEXES) docs_int_off;


query I
SELECT id FROM docs_int_off_idx
WHERE TERM_EQ(body, 'fox')
ORDER BY id;
----
id
1


# 3b. Integer 1 -> true (EXPLAIN shows `, optimized`).

statement ok
CREATE TABLE docs_int_on (id INTEGER PRIMARY KEY, body VARCHAR);


statement count 1
INSERT INTO docs_int_on VALUES (1, 'fox');


statement count 1
INSERT INTO docs_int_on VALUES (2, 'fox bar');


statement ok
CREATE INDEX docs_int_on_idx ON docs_int_on
  USING inverted(id, body en_wand)
  WITH (optimize_top_k = 1);


statement ok
VACUUM (UPDATE_INDEXES) docs_int_on;


query
EXPLAIN SELECT id FROM docs_int_on_idx WHERE TERM_EQ(body, 'fox') ORDER BY BM25(docs_int_on_idx.tableoid) DESC LIMIT 2;
----
QUERY PLAN
┌───────────────────────────┐
│       IRESEARCH_SCAN      │
│    ────────────────────   │
│     Table: docs_int_on    │
│                           │
│       Materializer:       │
│    rocksdb (point Get)    │
│                           │
│          Filter:          │
│AND[Term(body(string)=fox)]│
│                           │
│           Score:          │
│    bm25(k1=1.2, b=0.75)   │
│                           │
│     TopK: 2, optimized    │
│      Projections: id      │
│                           │
│          ~2 rows          │
└───────────────────────────┘


