# ---------------------------------------------------------------------------
# Negative case: bare `true` keyword is rejected by DuckDB's CREATE INDEX
# grammar (value must be a constant expression, and the bare boolean
# keyword is not). Documented here so users know to use the bare-key form,
# an integer, or a string literal instead.
# ---------------------------------------------------------------------------

statement error db error: ERROR: Create index option must be a constant value
CREATE INDEX docs_default_bad ON docs_default
  USING inverted(id, body en_wand)
  WITH (optimize_top_k = true);
