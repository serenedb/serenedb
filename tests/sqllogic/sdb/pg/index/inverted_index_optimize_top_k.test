# ---------------------------------------------------------------------------
# Scorer-expression forms. The string is parsed via DuckDB's binder so
# overload resolution / coercion match `ORDER BY <scorer>(...)`. Each scorer
# in the catalog::ScorerOptions variant is exercised here.
# ---------------------------------------------------------------------------

# tfidf with default args.

statement ok
CREATE TABLE docs_tfidf (id INTEGER PRIMARY KEY, body VARCHAR);


statement count 1
INSERT INTO docs_tfidf VALUES (1, 'fox');


statement count 1
INSERT INTO docs_tfidf VALUES (2, 'fox bar');


statement ok
CREATE INDEX docs_tfidf_idx ON docs_tfidf
  USING inverted(id, body en_wand)
  WITH (optimize_top_k = 'tfidf()');


statement ok
VACUUM (REFRESH_TABLE) docs_tfidf;


