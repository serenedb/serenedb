# ---------------------------------------------------------------------------
# Negative cases for `optimize_top_k`.
# ---------------------------------------------------------------------------

# Unknown scorer name.
statement error scorer
CREATE INDEX docs_default_bad_unknown ON docs_default
  USING inverted(id, body en_wand)
  WITH (optimize_top_k = 'mystery_scorer()');


# Out-of-range parameter.
statement error lambda
CREATE INDEX docs_default_bad_lambda ON docs_default
  USING inverted(id, body en_wand)
  WITH (optimize_top_k = 'lm_jm(2.0)');


# Bare identifier (no parentheses) is rejected -- caller must spell out a
# function call.
statement error scorer function call
CREATE INDEX docs_default_bad_bare ON docs_default
  USING inverted(id, body en_wand)
  WITH (optimize_top_k = 'bm25');


# DuckDB's CREATE INDEX grammar still rejects non-constant values like the
# bare `true` keyword.
statement error
CREATE INDEX docs_default_bad_keyword ON docs_default
  USING inverted(id, body en_wand)
  WITH (optimize_top_k = true);
----
db error: ERROR: 'optimize_top_k' expects a scorer function call, got 'true'
HINT: Use e.g. 'tfidf()' or 'bm25(1.2, 0.75)'
