hash-threshold 100

# ---------------------------------------------------------------------------
# Coverage for `WITH (optimize_top_k)` on `CREATE INDEX ... USING inverted(...)`.
#
# When set, the catalog InvertedIndex remembers the flag across restart, the
# writer encodes per-block max-impact (WAND) data via a default BM25 scorer,
# and `ORDER BY BM25(...) DESC LIMIT k` queries execute the iterator with
# WandContext{wand_enabled=true} plus running heap-minimum threshold feedback.
# EXPLAIN reflects the option by suffixing the `TopK` row in the
# IRESEARCH_SCAN box with `, optimized` when WAND pruning is engaged.
#
# `optimize_top_k` is a string-encoded scorer expression, e.g.
# `'bm25(1.2, 0.75)'`, `'tfidf()'`, `'raw_tf()'`. Omitting the option leaves
# WAND off. The catalog stores the parsed `ScorerOptions`; WAND fires only
# when the index's stored scorer matches the ORDER BY scorer.
#
# Single-token `body @@ ts_phrase('x')` collapses to a ByTerm filter, which
# is the simplest WAND-eligible iterator (only needs Freq + Norm features).
# ---------------------------------------------------------------------------

statement ok
CREATE TABLE docs_wand (id INTEGER PRIMARY KEY, body VARCHAR);


statement count 1
INSERT INTO docs_wand VALUES (1, 'fox quick');


statement count 1
INSERT INTO docs_wand VALUES (2, 'fox lazy');


statement count 1
INSERT INTO docs_wand VALUES (3, 'lazy dog');


statement count 1
INSERT INTO docs_wand VALUES (4, 'fox runs fast');


statement count 1
INSERT INTO docs_wand VALUES (5, 'rabbit and a fox');


statement ok
CREATE TEXT SEARCH DICTIONARY en_wand(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true,
    norm = true
);


statement ok
CREATE INDEX docs_wand_idx ON docs_wand USING inverted(id, body en_wand)
  WITH (optimize_top_k = 'bm25(1.2, 0.75)');


statement ok
VACUUM (REFRESH_TABLE) docs_wand;


# Top-K with WAND on. Tie-break on id for deterministic ordering across
# any FP accumulation differences between the WAND and non-WAND paths.

query I
SELECT id FROM docs_wand_idx
WHERE body @@ ts_phrase('fox')
ORDER BY BM25(docs_wand_idx.tableoid) DESC, id
LIMIT 3;
----
id
1
2
4


# Same data with a non-WAND index for an equivalence baseline.

statement ok
CREATE TABLE docs_plain (id INTEGER PRIMARY KEY, body VARCHAR);


statement count 1
INSERT INTO docs_plain VALUES (1, 'fox quick');


statement count 1
INSERT INTO docs_plain VALUES (2, 'fox lazy');


statement count 1
INSERT INTO docs_plain VALUES (3, 'lazy dog');


statement count 1
INSERT INTO docs_plain VALUES (4, 'fox runs fast');


statement count 1
INSERT INTO docs_plain VALUES (5, 'rabbit and a fox');


statement ok
CREATE INDEX docs_plain_idx ON docs_plain USING inverted(id, body en_wand);


statement ok
VACUUM (REFRESH_TABLE) docs_plain;


query I
SELECT id FROM docs_plain_idx
WHERE body @@ ts_phrase('fox')
ORDER BY BM25(docs_plain_idx.tableoid) DESC, id
LIMIT 3;
----
id
1
2
4


# Larger LIMIT exercises the heap-fill path (BlockSize = 2*k).

query I
SELECT id FROM docs_wand_idx
WHERE body @@ ts_phrase('fox')
ORDER BY BM25(docs_wand_idx.tableoid) DESC, id
LIMIT 10;
----
id
1
2
4
5


# --- OFFSET behavior ---
# Single-key ORDER BY + LIMIT + OFFSET: the scan caps at limit + offset
# (combined_limit in row_group_pruner.cpp), so WAND top-K still engages
# and TOP_N above slices the surplus. Multi-key ORDER BY still bails.

# OFFSET 0 matches LIMIT-only behavior.
query I
SELECT id FROM docs_wand_idx
WHERE body @@ ts_phrase('fox')
ORDER BY BM25(docs_wand_idx.tableoid) DESC
LIMIT 3 OFFSET 0;
----
id
1
2
4


# Non-zero OFFSET: scan returns top (limit+offset)=4 rows, TOP_N drops 2.
query I
SELECT id FROM docs_wand_idx
WHERE body @@ ts_phrase('fox')
ORDER BY BM25(docs_wand_idx.tableoid) DESC
LIMIT 2 OFFSET 2;
----
id
4
5


# OFFSET past the result set yields empty output.
query I
SELECT id FROM docs_wand_idx
WHERE body @@ ts_phrase('fox')
ORDER BY BM25(docs_wand_idx.tableoid) DESC
LIMIT 10 OFFSET 100;
----
id


# Plain (non-WAND) index produces the same rows under LIMIT + OFFSET.
query I
SELECT id FROM docs_plain_idx
WHERE body @@ ts_phrase('fox')
ORDER BY BM25(docs_plain_idx.tableoid) DESC
LIMIT 2 OFFSET 2;
----
id
4
5


# EXPLAIN: scan reports `TopK: <limit+offset>, optimized` -- the rewrite
# engages and the scan caps at 4 rows; TOP_N drops the first 1.
query
EXPLAIN SELECT id FROM docs_wand_idx WHERE body @@ ts_phrase('fox') ORDER BY BM25(docs_wand_idx.tableoid) DESC LIMIT 3 OFFSET 1;
----
QUERY PLAN
┌───────────────────────────┐
│           TOP_N           │
│    ────────────────────   │
│           Top: 3          │
│         Offset: 1         │
│     Order By: #1 DESC     │
│                           │
│           ~1 row          │
└─────────────┬─────────────┘
┌─────────────┴─────────────┐
│       IRESEARCH_SCAN      │
│    ────────────────────   │
│    Index: docs_wand_idx   │
│      Lookup: rocksdb      │
│                           │
│          Filter:          │
│ AND[PHRASE[body(string) = │
│    <Term:fox(0, 0); >]]   │
│                           │
│           Score:          │
│    bm25(k1=1.2, b=0.75)   │
│                           │
│     TopK: 4, optimized    │
│                           │
│        Projections:       │
│             id            │
│  sdb_inverted_index_score │
│                           │
│           ~1 row          │
└───────────────────────────┘


# Multi-key ORDER BY + OFFSET: rewrite bails (tied-tiebreak unsafe), no
# `TopK:` line. TOP_N handles both ordering and slicing.
query
EXPLAIN SELECT id FROM docs_wand_idx WHERE body @@ ts_phrase('fox') ORDER BY BM25(docs_wand_idx.tableoid) DESC, id LIMIT 3 OFFSET 1;
----
QUERY PLAN
┌───────────────────────────┐
│           TOP_N           │
│    ────────────────────   │
│           Top: 3          │
│         Offset: 1         │
│                           │
│         Order By:         │
│          #1 DESC          │
│    docs_wand_idx.id ASC   │
│                           │
│           ~1 row          │
└─────────────┬─────────────┘
┌─────────────┴─────────────┐
│       IRESEARCH_SCAN      │
│    ────────────────────   │
│    Index: docs_wand_idx   │
│      Lookup: rocksdb      │
│                           │
│          Filter:          │
│ AND[PHRASE[body(string) = │
│    <Term:fox(0, 0); >]]   │
│                           │
│           Score:          │
│    bm25(k1=1.2, b=0.75)   │
│                           │
│        Projections:       │
│             id            │
│  sdb_inverted_index_score │
│                           │
│           ~1 row          │
└───────────────────────────┘


