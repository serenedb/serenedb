hash-threshold 100

# Repro + coverage for `IS NULL` / `IS NOT NULL` over INCLUDE-only
# columns at every primitive shape: INTEGER, BIGINT, FLOAT, DOUBLE,
# BOOLEAN, VARCHAR, BLOB, DATE, TIMESTAMP. INCLUDE-only columns have no
# inverted-index postings, so the predicate must fall through to a
# residual filter that DuckDB evaluates against the cs-materialised value.

statement ok
CREATE TABLE prim_n (
  pk INTEGER PRIMARY KEY,
  t VARCHAR,
  v_int INTEGER,
  v_big BIGINT,
  v_flt FLOAT,
  v_dbl DOUBLE,
  v_bool BOOLEAN,
  v_str VARCHAR,
  v_blob BLOB,
  v_date DATE,
  v_ts TIMESTAMP
)


statement ok
CREATE TEXT SEARCH DICTIONARY en(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true
)


statement ok
CREATE INDEX prim_n_idx ON prim_n USING inverted(pk, t en)
  INCLUDE (v_int, v_big, v_flt, v_dbl, v_bool, v_str, v_blob, v_date, v_ts)


statement ok
INSERT INTO prim_n VALUES (
  1, 'one',
  10, 1000000000000, 1.5, 2.5,
  TRUE, 'alpha', 'beef'::BLOB,
  DATE '2026-01-02', TIMESTAMP '2026-01-02 03:04:05'
)


# Every INCLUDE column NULL.
statement ok
INSERT INTO prim_n VALUES (
  2, 'two',
  NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL
)


# Some columns NULL, some not.
statement ok
INSERT INTO prim_n VALUES (
  3, 'three',
  30, NULL, 3.5, NULL,
  FALSE, NULL, 'cafe'::BLOB,
  NULL, TIMESTAMP '2026-03-04 05:06:07'
)


statement ok
VACUUM (REFRESH_TABLE) prim_n


# Sanity: the INCLUDE'd columns are served by the cs (i), pk by rocksdb (l).
query
EXPLAIN SELECT pk, v_int, v_big, v_flt, v_dbl, v_bool, v_str, v_blob, v_date, v_ts
FROM prim_n_idx WHERE t @@ ts_phrase('one');
----
