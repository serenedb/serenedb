# Materialised round-trip with explicit NULLs.
query
SELECT pk, v_int, v_big, v_flt, v_dbl, v_bool, v_str, v_blob, v_date, v_ts
FROM prim_n_idx
WHERE t @@ ts_phrase('one') OR t @@ ts_phrase('two') OR t @@ ts_phrase('three')
ORDER BY pk;
----
pk	v_int	v_big	v_flt	v_dbl	v_bool	v_str	v_blob	v_date	v_ts
1	10	1000000000000	1.5	2.5	t	alpha	\\x62656566	2026-01-02	2026-01-02 03:04:05
2	NULL	NULL	NULL	NULL	NULL	NULL	NULL	NULL	NULL
3	30	NULL	3.5	NULL	f	NULL	\\x63616665	NULL	2026-03-04 05:06:07


# IS NULL on every INCLUDE-only primitive type: residual evaluation
# against the cs-materialised value.

query
SELECT pk FROM prim_n_idx
WHERE (t @@ ts_phrase('one') OR t @@ ts_phrase('two') OR t @@ ts_phrase('three'))
  AND v_int IS NULL ORDER BY pk;
----
pk
2


