# IS NOT NULL: returns only the rows where the named column was filled.
query
SELECT pk FROM prim_n_idx
WHERE (t @@ ts_phrase('one') OR t @@ ts_phrase('two') OR t @@ ts_phrase('three'))
  AND v_int IS NOT NULL ORDER BY pk;
----
pk
1
3


query
SELECT pk FROM prim_n_idx
WHERE (t @@ ts_phrase('one') OR t @@ ts_phrase('two') OR t @@ ts_phrase('three'))
  AND v_str IS NOT NULL ORDER BY pk;
