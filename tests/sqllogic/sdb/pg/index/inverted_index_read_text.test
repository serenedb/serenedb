alpha
bravo


# ============================================================================
# Vanished file -- queries that hit only the inverted index keep working;
# queries that project content trigger the lookup TF which opens the file at
# query time and fails when the file is gone.
# ============================================================================

statement ok
COPY (VALUES ('Disappearing payload mentions the unique token gargantuanpixie.'))
TO '${__TEST_DIR__}/rt-vanish.txt' (FORMAT csv, HEADER false);

statement ok
CREATE VIEW v_vanish AS
  SELECT filename AS path, content
  FROM read_text('${__TEST_DIR__}/rt-vanish.txt');

statement ok
CREATE INDEX v_vanish_idx ON v_vanish USING inverted(content read_text_en);

# Sanity: while file holds the indexed term, both no-content and content
# projections work.
query
SELECT count(*) FROM v_vanish_idx WHERE content @@ 'gargantuanpixie';
----
count
1

query
SELECT ts_highlight(content, ts_offsets(content))
FROM v_vanish_idx WHERE content @@ 'gargantuanpixie';
----
ts_highlight
Disappearing payload mentions the unique token <b>gargantuanpixie</b>

# Phase 1 -- overwrite with empty text. File still exists and is valid UTF-8,
# so the lookup TF can still open it (just returns empty content).
# (Direct file deletion via `system rm` doesn't work in docker-compose CI where
# the test runner and serened sit in separate containers; we use server-side
# COPY to mutate the file.)
statement ok
COPY (SELECT '' AS x)
TO '${__TEST_DIR__}/rt-vanish.txt' (FORMAT csv, HEADER false, QUOTE '', ESCAPE '');

# Posting lists are independent of the source: the index still returns 1 row.
query
SELECT count(*) FROM v_vanish_idx WHERE content @@ 'gargantuanpixie';
----
count
1

# A fresh read_text of the now-empty file no longer contains the token.
query
SELECT count(*) FROM read_text('${__TEST_DIR__}/rt-vanish.txt')
WHERE content LIKE '%gargantuanpixie%';
----
count
0

# Phase 2 -- overwrite the same path with parquet bytes so read_text can no
# longer decode it. count(*) via the index still works (no file open); any
# query that projects content forces the lookup TF to read the file and the
# UTF-8 validation step errors.
statement ok
COPY (SELECT 1 AS x) TO '${__TEST_DIR__}/rt-vanish.txt' (FORMAT parquet);

query
SELECT count(*) FROM v_vanish_idx WHERE content @@ 'gargantuanpixie';
----
count
1

statement error read_text: could not read content of file .* as valid UTF-8
SELECT ts_highlight(content, ts_offsets(content))
FROM v_vanish_idx WHERE content @@ 'gargantuanpixie';

statement error read_text: could not read content of file .* as valid UTF-8
SELECT content FROM v_vanish_idx WHERE content @@ 'gargantuanpixie';

# A path that was never written surfaces as zero rows via the bare scan: the
# MultiFileList resolves the literal to an empty set, ALLOW_EMPTY swallows it,
# and no lookup TF ever runs.
query
SELECT count(*) FROM read_text('${__TEST_DIR__}/rt-never_existed.txt');
----
count
0
