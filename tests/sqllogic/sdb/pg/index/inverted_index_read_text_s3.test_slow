control substitution on

# read_text/read_blob against a remote object store. The same DirectFileReader
# machinery used for local paths goes through httpfs when given an s3:// URI;
# this test covers bare scan, glob expansion, the per-file lookup TF (Mode A
# view + inverted index), and the read_blob binary path.

statement ok
CREATE OR REPLACE SECRET read_text_${__DATABASE__} (
  TYPE S3,
  KEY_ID '${MINIO_ACCESS_KEY}',
  SECRET '${MINIO_SECRET_KEY}',
  ENDPOINT '${MINIO_HOST}:${MINIO_PORT}',
  URL_STYLE 'path',
  USE_SSL false,
  SCOPE 's3://${MINIO_BUCKET}/read_text/${__DATABASE__}/'
);

statement ok
SET s3_use_ssl = false;


# Stage three text fixtures directly to S3 via DuckDB's CSV writer. Per-row
# values become per-line bytes (no quoting since the content has no comma /
# quote / newline). Overlapping vocabulary lets BM25 rank meaningfully.
statement ok
COPY (VALUES
  ('# Inverted Index Primer'),
  ('The inverted index is a fundamental structure in information retrieval.'),
  ('It maps each term to a posting list of documents that contain the term.'),
  ('Modern analyzers normalize text and lowercase tokens.'))
TO 's3://${MINIO_BUCKET}/read_text/${__DATABASE__}/alpha.md'
(FORMAT csv, HEADER false);

statement ok
COPY (VALUES
  ('# BM25 Explained'),
  ('BM25 scores documents against a query by combining term frequency.'),
  ('Inverse document frequency and length normalization drive ranking.'),
  ('It is a probabilistic ranking function descended from Robertson work.'))
TO 's3://${MINIO_BUCKET}/read_text/${__DATABASE__}/bravo.md'
(FORMAT csv, HEADER false);

statement ok
COPY (VALUES
  ('Highlighting picks short snippets around matched terms.'),
  ('A common approach is sentence-aware passage extraction.'),
  ('Many systems retokenize the source at query time to produce snippets.'))
TO 's3://${MINIO_BUCKET}/read_text/${__DATABASE__}/charlie.txt'
(FORMAT csv, HEADER false);


statement ok
CREATE TEXT SEARCH DICTIONARY s3_text_en(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'lower',
    stemming = false,
    accent = false,
    frequency = true,
    position = true,
    norm = true,
    offset = true
);


# ============================================================================
# Bare scan against s3://. Single-file form and glob form.
# ============================================================================

query
SELECT count(*) FROM read_text('s3://${MINIO_BUCKET}/read_text/${__DATABASE__}/alpha.md');
----
count
1

query
SELECT count(*) FROM read_text('s3://${MINIO_BUCKET}/read_text/${__DATABASE__}/*');
----
count
3

# A row carries (filename, content, size, last_modified); sizes are non-zero
# and the content survived the round trip.
query
SELECT count(*) FROM read_text('s3://${MINIO_BUCKET}/read_text/${__DATABASE__}/*')
WHERE size > 0 AND length(content) > 0;
----
count
3

# Empty glob is not an error -- httpfs ListFiles returns an empty list.
query
SELECT count(*) FROM read_text('s3://${MINIO_BUCKET}/read_text/${__DATABASE__}/no_such_*');
----
count
0


# ============================================================================
# read_blob over s3:// -- BLOB type, same byte content.
# ============================================================================

query
SELECT count(*) FROM read_blob('s3://${MINIO_BUCKET}/read_text/${__DATABASE__}/*');
----
count
3

query
SELECT DISTINCT typeof(content) AS t FROM read_blob('s3://${MINIO_BUCKET}/read_text/${__DATABASE__}/*');
----
t
BLOB

# read_blob.size equals read_text.size byte-for-byte.
query
SELECT count(*) FROM (
  SELECT t.filename, t.size AS ts, b.size AS bs
  FROM read_text('s3://${MINIO_BUCKET}/read_text/${__DATABASE__}/*') t
  JOIN read_blob('s3://${MINIO_BUCKET}/read_text/${__DATABASE__}/*') b
  USING (filename)
  WHERE ts = bs
) m;
----
count
3


# ============================================================================
# Mode A: view + inverted index against s3:// glob. Exercises the lookup TF
# (MakeTextLookupTableFunction) over httpfs -- each per-file lookup opens the
# remote object and returns the projected columns.
# ============================================================================

statement ok
CREATE VIEW v_s3 AS
  SELECT filename AS path, content
  FROM read_text('s3://${MINIO_BUCKET}/read_text/${__DATABASE__}/*');

statement ok
CREATE INDEX v_s3_idx ON v_s3 USING inverted(content s3_text_en);

# Term match -- count comes from the index alone, no lookup TF involved.
query
SELECT count(*) FROM v_s3_idx WHERE content @@ 'index';
----
count
1

query
SELECT count(*) FROM v_s3_idx WHERE content @@ 'term';
----
count
2

# Projecting the file basename uses filename (a per-file constant from the
# MultiFileList) -- still no content lookup.
query
SELECT regexp_extract(path, '/([a-z]+)[.][a-z]+\$', 1) AS slug
FROM v_s3_idx WHERE content @@ 'ranking' ORDER BY slug;
----
slug
bravo

# BM25 ordering over s3 fixtures.
query
SELECT regexp_extract(path, '/([a-z]+)[.][a-z]+\$', 1) AS slug
FROM v_s3_idx WHERE content @@ ts_phrase('term') OR content @@ ts_phrase('ranking')
ORDER BY BM25(v_s3_idx.tableoid) DESC, slug;
----
slug
bravo
alpha

# ts_highlight forces the lookup TF to open each matching file remotely and
# fetch its content; the snippet should wrap the match.
query
SELECT regexp_extract(path, '/([a-z]+)[.][a-z]+\$', 1) AS slug,
       ts_highlight(content, ts_offsets(content)) AS snippet
FROM v_s3_idx
WHERE content @@ ts_phrase('passage', 'extraction')
ORDER BY slug;
----
slug	snippet
charlie	A common approach is sentence-aware <b>passage extraction</b>


# ============================================================================
# Mode B: materialize the s3 read_text result into a table; content is now a
# real column, no remote lookup at query time.
# ============================================================================

statement ok
CREATE TABLE t_s3 AS
  SELECT filename AS path, content
  FROM read_text('s3://${MINIO_BUCKET}/read_text/${__DATABASE__}/*');

statement ok
CREATE INDEX t_s3_idx ON t_s3 USING inverted(content s3_text_en);

query
SELECT count(*) FROM t_s3;
----
count
3

query
SELECT regexp_extract(path, '/([a-z]+)[.][a-z]+\$', 1) AS slug
FROM t_s3_idx WHERE content @@ 'snippets' ORDER BY slug;
----
slug
charlie


# ============================================================================
# Vanished remote object -- overwrite a fixture with the empty body so its
# content no longer matches the indexed terms, but the original posting lists
# survive in the (already-built) index. Confirms posting-list independence
# from the source object and exercises the remote lookup path for the
# surviving documents.
# ============================================================================

statement ok
COPY (SELECT '' AS x)
TO 's3://${MINIO_BUCKET}/read_text/${__DATABASE__}/bravo.md'
(FORMAT csv, HEADER false, QUOTE '', ESCAPE '');

# Re-scan via read_text directly: still 3 files but bravo's body is now empty
# (so 'ranking' no longer matches when read fresh).
query
SELECT count(*) FROM read_text('s3://${MINIO_BUCKET}/read_text/${__DATABASE__}/*')
WHERE content LIKE '%ranking%';
----
count
0

# The Mode A index still serves the original posting-list snapshot.
query
SELECT count(*) FROM v_s3_idx WHERE content @@ 'ranking';
----
count
1

# A path that never resolved -- httpfs ListFiles is empty, no error.
query
SELECT count(*) FROM read_text('s3://${MINIO_BUCKET}/read_text/${__DATABASE__}/no_such.md');
----
count
0

# But projecting content on a path that doesn't exist surfaces an HTTP 404.
statement error
SELECT content FROM read_text('s3://${MINIO_BUCKET}/no_such_bucket/no_such.md');


# Cleanup. Leaving the bucket populated is fine for the harness (each test run
# uses a fresh container), but we drop the per-test prefix explicitly to keep
# parallel runs idempotent against the same MinIO instance.
statement ok
DROP TABLE t_s3;

statement ok
DROP VIEW v_s3;
