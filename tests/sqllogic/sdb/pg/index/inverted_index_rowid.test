control substitution on

hash-threshold 100

# `rowid` projection on an inverted index over a table without an explicit
# PK. The table's RowID columns advertise the generated_pk virtual column
# (server/connector/duckdb_table_entry.cpp:208), so DuckDB happily binds a
# `SELECT rowid FROM <idx>` query and pushes the virtual id into the scan's
# column_ids. Coverage matters because the scan must produce a unique
# monotonic value per emitted row; a per-chunk reset to 0 silently breaks
# anything that uses rowid for identity, and parallel emitters must observe
# disjoint bases (atomic fetch_add, not load + later add).

statement ok
CREATE TEXT SEARCH DICTIONARY rowid_d (
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'lower',
    stemming = false,
    accent = false,
    frequency = true,
    position = true,
    offset = true
)

statement ok
CREATE TABLE rowid_nopk (body TEXT)

statement ok
CREATE INDEX rowid_nopk_idx ON rowid_nopk USING inverted(body rowid_d)

# Small case: three rows, all match -- exercises a single chunk emission.
statement ok
INSERT INTO rowid_nopk VALUES ('fox news'), ('fox fox'), ('fox cat fox')

statement ok
VACUUM (REFRESH_TABLE) rowid_nopk

query
SELECT rowid FROM rowid_nopk_idx WHERE body @@ ts_phrase('fox') ORDER BY rowid
----
rowid
0
1
2

# Bulk-scan path (no filter / scorer / offsets) drains via
# SearchFullScanBulkLocalState -- different emit site, same rowid contract.
query
SELECT count(*), count(DISTINCT rowid), min(rowid), max(rowid)
FROM rowid_nopk_idx
----
count	count	min	max
3	3	0	2

# Multi-chunk uniqueness: STANDARD_VECTOR_SIZE is 2048 in DuckDB, so 5003
# total rows force at least three chunks and engage parallel scan threads.
# A per-chunk-reset bug would collapse the distinct count or break the
# (min, max) range; a load-then-fetch-add race would surface as duplicates.
statement ok
INSERT INTO rowid_nopk SELECT 'fox big ' || g FROM generate_series(1, 5000) g

statement ok
VACUUM (REFRESH_TABLE) rowid_nopk

query
SELECT count(*), count(DISTINCT rowid), min(rowid), max(rowid)
FROM rowid_nopk_idx
WHERE body @@ ts_phrase('fox')
----
count	count	min	max
5003	5003	0	5002

# Same assertion through the bulk-scan path with the larger row set.
query
SELECT count(*), count(DISTINCT rowid), min(rowid), max(rowid)
FROM rowid_nopk_idx
----
count	count	min	max
5003	5003	0	5002
