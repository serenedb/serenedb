statement ok
CREATE TEXT SEARCH DICTIONARY en(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true,
    norm = true
);


statement ok
CREATE INDEX docs_idx ON docs USING inverted(id, body en);


statement ok
VACUUM (UPDATE_INDEXES) docs;


# BM25 scores are non-negative; verify they are returned and > 0
query
SELECT id, BM25(docs_idx.tableoid) > 0 AS has_score FROM docs_idx WHERE PHRASE(body, 'fox') ORDER BY id;
----
id	has_score
1	t
2	t


# TFIDF scores are also > 0
query
SELECT id, TFIDF(docs_idx.tableoid) > 0 AS has_score FROM docs_idx WHERE PHRASE(body, 'fox') ORDER BY id;
----
id	has_score
1	t
2	t


# BM25 with explicit parameters produces non-zero scores
query
SELECT id, BM25(docs_idx.tableoid, 1.2, 0.75) > 0 AS has_score FROM docs_idx WHERE PHRASE(body, 'fox') ORDER BY id;
----
id	has_score
1	t
2	t


