----
count
35


# Scan still returns matches after deletion. Note: BM25's IDF is computed
# per segment; when a term appears in every doc of a segment the IDF
# collapses to <= 0 (clamped to 0), so BM25() > 0 is a segment-structure
# dependent check and unsuitable for asserting "is there a score". Here we
# just verify that the query still produces the expected ids post-DELETE.
query
SELECT id FROM docs_idx WHERE PHRASE(body, 'lazy') AND BM25(docs_idx.tableoid) > 0 ORDER BY id;
----
id
3
35


# Inverted index scan without any filter returns all docs (irs::All)
query
SELECT COUNT(*) FROM docs_idx;
----
count
36


query
SELECT id FROM docs_idx WHERE id = 1;
----
id


# Error: BM25 with no inverted scan in scope
query error
SELECT BM25(docs.tableoid) FROM docs WHERE id > 0;


# --- Multi-table join tests ---
statement ok
CREATE TABLE docs2 (id INTEGER PRIMARY KEY, body VARCHAR);


statement ok
INSERT INTO docs2 VALUES (2, 'the swift fox'), (4, 'a clever fox'), (6, 'the lazy dog');


statement ok
CREATE INDEX docs2_idx ON docs2 USING inverted(id, body en);

statement ok
VACUUM (UPDATE_INDEXES) docs2;


statement ok
CREATE TABLE meta (id INTEGER PRIMARY KEY, tag VARCHAR);


statement ok
INSERT INTO meta VALUES (2, 'interesting'), (4, 'notable'), (5, 'relevant');


# Works: JOIN two inverted indexes, BM25 scoped inside each subquery (only one subquery scores)
query
SELECT a.id, a.score > 0 AS has_score FROM
  (SELECT id, BM25(docs_idx.tableoid) AS score FROM docs_idx WHERE PHRASE(body, 'fox')) a
  JOIN
  (SELECT id FROM docs2_idx WHERE PHRASE(body, 'fox')) b
  ON a.id = b.id
ORDER BY a.score DESC LIMIT 1;
----
id	has_score
4	t


# Works: JOIN two inverted indexes, same scorer (BM25) scoped inside each subquery.
# NOTE: docs_idx has 'fox' in ~every doc post-VACUUM so its BM25 IDF is tiny
# (near 0 in FLOAT). Check that scores are >= 0 (always true) rather than > 0.
query
SELECT a.id, a.score > 0 AS has_score, b.score > 0 AS b_has_score FROM
  (SELECT id, BM25(docs_idx.tableoid) AS score FROM docs_idx WHERE PHRASE(body, 'fox')) a
  JOIN
  (SELECT id, BM25(docs2_idx.tableoid) AS score FROM docs2_idx WHERE PHRASE(body, 'fox')) b
  ON a.id = b.id
ORDER BY a.id;
----
id	has_score	b_has_score
2	f	t
4	t	t


# Works: JOIN two inverted indexes, different scorers (BM25 vs TFIDF) scoped inside each subquery.
query
SELECT a.id, a.score > 0 AS has_score, b.score > 0 AS b_has_score FROM
  (SELECT id, BM25(docs_idx.tableoid) AS score FROM docs_idx WHERE PHRASE(body, 'fox')) a
  JOIN
  (SELECT id, TFIDF(docs2_idx.tableoid) AS score FROM docs2_idx WHERE PHRASE(body, 'fox')) b
  ON a.id = b.id
ORDER BY a.id;
----
id	has_score	b_has_score
2	f	t
4	t	t


# Works: JOIN inverted index with plain table, BM25 from inverted scan.
# BM25 IDF tiny on saturated term; just assert the join shape is correct.
query
SELECT docs_idx.id, BM25(docs_idx.tableoid) > 0 AS has_score, meta.tag FROM docs_idx
JOIN meta ON docs_idx.id = meta.id
WHERE PHRASE(docs_idx.body, 'fox')
ORDER BY docs_idx.id;
----
id	has_score	tag
2	f	interesting
4	t	notable
5	t	relevant


statement ok
DROP TABLE docs2;


statement ok
DROP TABLE meta;


# Union tree: each branch is itself a UNION. BM25 claim in each branch is
# still exercised (compiler must rewrite it per scope), but we don't assert
# score magnitudes here: segment-level IDF on the saturated 'fox' term and
# on the 'lazy' term (which lands in a tiny post-VACUUM segment) can
# collapse to 0 in FLOAT. Just verify the set of ids returned.
query
(
  (SELECT id, BM25(docs_idx.tableoid) > 0 FROM docs_idx WHERE PHRASE(body, 'fox') ORDER BY id LIMIT 2)
  UNION ALL
  (SELECT id, BM25(docs_idx.tableoid) > 0 FROM docs_idx WHERE PHRASE(body, 'lazy') ORDER BY id LIMIT 2)
)
UNION ALL
(
  (SELECT id, BM25(docs_idx.tableoid) FROM docs_idx WHERE PHRASE(body, 'fox') ORDER BY id LIMIT 2)
  UNION ALL
  (SELECT id, BM25(docs_idx.tableoid) FROM docs_idx WHERE PHRASE(body, 'lazy') ORDER BY id LIMIT 2)
)
ORDER BY id LIMIT 6;
----
id	?column?
2	0
2	0
3	0
3	0
4	1
4	0.031<slt:ignore>


# Error: BM25 outside union subquery scope. The inner `docs_idx` name is not
# in scope at the outer ORDER BY, so this fails at bind time with a
# table-not-found error (not the runtime stub).
query error
SELECT * FROM (SELECT id FROM docs_idx WHERE PHRASE(body, 'fox') LIMIT 2)
ORDER BY BM25(docs_idx.tableoid);
----
db error: ERROR: Referenced table "docs_idx" not found!
Candidate tables: "unnamed_subquery"


