# More than kScoreBlock (32) docs match 'fox'; all should exist in result
query
SELECT COUNT(*) FROM docs_idx WHERE PHRASE(body, 'fox');
----
count
36


# ORDER BY BM25 with >32 results exercises the full-block ScoreBlock path
query
SELECT id, BM25(docs_idx.tableoid) > 0 AS has_score FROM docs_idx WHERE PHRASE(body, 'fox') ORDER BY id LIMIT 3;
----
id	has_score
1	t
2	t
4	t


# BM25 can appear multiple times in the same query (SELECT + ORDER BY)
# Length-normalized BM25: longest docs score lowest (1: 9 tokens, 5: 7 tokens, 4: 4 tokens)
query
SELECT id, BM25(docs_idx.tableoid) > 0 AS has_score FROM docs_idx WHERE PHRASE(body, 'fox') ORDER BY BM25(docs_idx.tableoid) ASC LIMIT 3;
----
id	has_score
1	t
5	t
4	t


# BM25 in SELECT, WHERE, and ORDER BY simultaneously
# With length-normalized BM25, the 2-word "color fox" docs (ids 10-41) tie at the top;
# tie-break by id for deterministic ordering.
query
SELECT id FROM docs_idx WHERE PHRASE(body, 'fox') AND BM25(docs_idx.tableoid) > 0 ORDER BY BM25(docs_idx.tableoid) DESC, id LIMIT 3;
----
id
10
11
12


# BM25 with same explicit params used twice is allowed (idempotent)
query
SELECT id FROM docs_idx WHERE PHRASE(body, 'fox') AND BM25(docs_idx.tableoid, 1.2, 0.75) > 0 ORDER BY BM25(docs_idx.tableoid, 1.2, 0.75) DESC, id LIMIT 3;
----
id
10
11
12


# --- Top-K scorer optimization (ExecuteTopK path) --------------------------
# `ORDER BY BM25(...) DESC LIMIT k` triggers SearchScan.score_top_k so the
# scan precomputes the top-k hits via iresearch's ExecuteTopK instead of
# streaming every matching doc. The result must be identical to the
# non-top-k path.


# Top-K with k=1: single top hit, broken by id for determinism.
query
SELECT id FROM docs_idx WHERE PHRASE(body, 'fox') ORDER BY BM25(docs_idx.tableoid) DESC, id LIMIT 1;
----
id
10


# Top-K with k=5: pulls back first 5 ids from the tied top-score bucket.
query
SELECT id FROM docs_idx WHERE PHRASE(body, 'fox') ORDER BY BM25(docs_idx.tableoid) DESC, id LIMIT 5;
----
id
10
11
12
13
14


# Top-K on a rare term (healthy IDF) -- top hit is the 2-word doc "lazy fox"
# not the 9-token doc id=1.
query
SELECT id FROM docs_idx WHERE PHRASE(body, 'lazy') ORDER BY BM25(docs_idx.tableoid) DESC, id LIMIT 1;
----
id
35


# Top-K on a rare term, k=3: all matching docs returned (only 3 have 'lazy').
query
SELECT id FROM docs_idx WHERE PHRASE(body, 'lazy') ORDER BY BM25(docs_idx.tableoid) DESC, id LIMIT 3;
----
id
35
3
1


# Top-K where k > matching docs: returns all matches without error.
query
SELECT id FROM docs_idx WHERE PHRASE(body, 'lazy') ORDER BY BM25(docs_idx.tableoid) DESC, id LIMIT 100;
----
id
35
3
1


# Top-K with explicit scorer params.
query
SELECT id FROM docs_idx WHERE PHRASE(body, 'fox') ORDER BY BM25(docs_idx.tableoid, 1.2, 0.75) DESC, id LIMIT 3;
----
id
10
11
12


# Top-K with TFIDF scorer (no length norm -- ties on all 3 matching docs).
query
SELECT id FROM docs_idx WHERE PHRASE(body, 'lazy') ORDER BY TFIDF(docs_idx.tableoid) DESC, id LIMIT 2;
----
id
1
3


# Top-K with TFIDF scorer and length normalization enabled: shorter docs
# (id=35 'lazy fox' = 2 tokens) outrank longer ones.
query
SELECT id FROM docs_idx WHERE PHRASE(body, 'lazy') ORDER BY TFIDF(docs_idx.tableoid, true) DESC, id LIMIT 2;
----
id
35
3


# Top-K on a cross-segment term -- LIMIT k fits within a single segment's
# tied top, but the scan must span all segments. k=2 still returns the
# first two 2-word 'fox' docs by id.
query
SELECT id FROM docs_idx WHERE PHRASE(body, 'fox') ORDER BY BM25(docs_idx.tableoid) DESC, id LIMIT 2;
----
id
10
11


# Top-K combined with additional WHERE predicate (PHRASE AND BM25>0); the
# optimizer must still recognise the ORDER BY + LIMIT for the top-K path
# and drop the redundant BM25>0 filter (always true for matching docs).
query
SELECT id FROM docs_idx WHERE PHRASE(body, 'fox') AND BM25(docs_idx.tableoid) > 0 ORDER BY BM25(docs_idx.tableoid) DESC, id LIMIT 3;
----
id
10
11
12


# Top-K with score also projected: both ORDER BY and SELECT reference the
# same scorer (idempotent claim) and the precomputed score must match what
# streaming would produce.
query
SELECT id, BM25(docs_idx.tableoid) AS score FROM docs_idx WHERE PHRASE(body, 'lazy') ORDER BY BM25(docs_idx.tableoid) DESC, id LIMIT 1;
----
id	score
35	2.57<slt:ignore>


# Error: BM25 and BM25 with different params conflict
query error
SELECT id FROM docs_idx WHERE PHRASE(body, 'fox') ORDER BY BM25(docs_idx.tableoid, 1.2, 0.75) DESC, BM25(docs_idx.tableoid, 1.0, 0.5) DESC LIMIT 3;
----
db error: ERROR: Only one scorer function is allowed per inverted index
HINT: Use UNION to combine different score functions for same inverted index


query ok
SELECT id, BM25(docs_idx.tableoid) FROM docs_idx WHERE PHRASE(body, 'fox') AND TFIDF(docs_idx.tableoid) > 0 ORDER BY id LIMIT 3;
----
1	0.019<slt:ignore>
2	0.03<slt:ignore>
4	0.031<slt:ignore>


# UNION ALL: same scorer in each branch — each branch is an independent scoring scope
query
(SELECT id, BM25(docs_idx.tableoid) > 0 AS has_score FROM docs_idx WHERE PHRASE(body, 'fox') ORDER BY id LIMIT 3)
UNION ALL
(SELECT -id, BM25(docs_idx.tableoid) > 0 AS has_score FROM docs_idx WHERE PHRASE(body, 'lazy')  ORDER BY id LIMIT 3)
ORDER BY id;
----
id	has_score
-35 t
-3 t
-1 t
1 t
2 t
4 t


# UNION ALL: different scorer types per branch (BM25 vs TFIDF) — each branch is independent
query
(SELECT id, BM25(docs_idx.tableoid) > 0 AS has_score FROM docs_idx WHERE PHRASE(body, 'fox') LIMIT 2)
UNION ALL
(SELECT -id, TFIDF(docs_idx.tableoid) > 0 AS has_score FROM docs_idx WHERE PHRASE(body, 'lazy') LIMIT 2)
ORDER BY id;
----
id	has_score
-3 t
-1 t
10 t
11 t


# Subquery: BM25 inside subquery, outer references the alias
query
SELECT id, score FROM (
  SELECT id, BM25(docs_idx.tableoid) AS score FROM docs_idx WHERE PHRASE(body, 'fox') ORDER BY BM25(docs_idx.tableoid) DESC, id LIMIT 3
) sub ORDER BY id;
----
id	score
10	0.043<slt:ignore>
11	0.043<slt:ignore>
12	0.043<slt:ignore>


