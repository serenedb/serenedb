# More than kScoreBlock (32) docs match 'fox'; all should exist in result
query
SELECT COUNT(*) FROM docs_idx WHERE body @@ ts_phrase('fox');
----
count
36


# ORDER BY BM25(docs_idx.tableoid) with >32 results exercises the full-block ScoreBlock path
query
SELECT id, BM25(docs_idx.tableoid) > 0 AS has_score FROM docs_idx WHERE body @@ ts_phrase('fox') ORDER BY id LIMIT 3;
----
id	has_score
1	t
2	t
4	t


# BM25(docs_idx.tableoid) can appear multiple times in the same query (SELECT + ORDER BY)
query
SELECT id, BM25(docs_idx.tableoid) > 0 AS has_score FROM docs_idx WHERE body @@ ts_phrase('fox') ORDER BY BM25(docs_idx.tableoid) ASC LIMIT 3;
----
id	has_score
1	t
5	t
4	t


# BM25(docs_idx.tableoid) in SELECT, WHERE, and ORDER BY simultaneously
query
SELECT id FROM docs_idx WHERE body @@ ts_phrase('fox') AND BM25(docs_idx.tableoid) > 0 ORDER BY BM25(docs_idx.tableoid) ASC LIMIT 3;
----
id
1
5
4


# BM25(docs_idx.tableoid) with same explicit params used twice is allowed
query
SELECT id FROM docs_idx WHERE body @@ ts_phrase('fox') AND BM25(docs_idx.tableoid, 1.2, 0.75) > 0 ORDER BY BM25(docs_idx.tableoid, 1.2, 0.75) ASC LIMIT 3;
----
id
1
5
4


# Error: BM25(docs_idx.tableoid) and BM25(docs_idx.tableoid) with different params conflict
query error
SELECT id FROM docs_idx WHERE body @@ ts_phrase('fox') ORDER BY BM25(docs_idx.tableoid, 1.2, 0.75) DESC, BM25(docs_idx.tableoid, 1.0, 0.5) DESC LIMIT 3;
----
db error: ERROR: Only one scorer function is allowed per inverted index
HINT: Use UNION to combine different score functions for the same inverted index


# Error: mixing BM25 and TFIDF scorers in the same index scan is disallowed.
query error
SELECT id, BM25(docs_idx.tableoid) FROM docs_idx WHERE body @@ ts_phrase('fox') AND TFIDF(docs_idx.tableoid) > 0 ORDER BY id LIMIT 3;
----
db error: ERROR: Only one scorer function is allowed per inverted index
HINT: Use UNION to combine different score functions for the same inverted index



# UNION ALL: same scorer in each branch вҖ” each branch is an independent scoring scope
query
(SELECT id, BM25(docs_idx.tableoid) AS score FROM docs_idx WHERE body @@ ts_phrase('fox') ORDER BY id LIMIT 3)
UNION ALL
(SELECT id, BM25(docs_idx.tableoid) AS score FROM docs_idx WHERE body @@ ts_phrase('lazy') ORDER BY id LIMIT 3)
ORDER BY id, score;
----
id	score
1	0.019136623
1	1.1331773
2	0.03676455
3	2.177017
4	0.031871427
35	2.5718682


# UNION ALL: different scorer types per branch (BM25 vs TFIDF) вҖ” each branch is independent
query
(SELECT id, BM25(docs_idx.tableoid) AS score FROM docs_idx WHERE body @@ ts_phrase('fox') ORDER BY id LIMIT 2)
UNION ALL
(SELECT id, TFIDF(docs_idx.tableoid) AS score FROM docs_idx WHERE body @@ ts_phrase('lazy') ORDER BY id LIMIT 2)
ORDER BY id, score;
----
id	score
1	0.019136623
1	2.3513753
2	0.03676455
3	2.3513753


# Subquery: BM25(docs_idx.tableoid) inside subquery, outer references the alias
query
SELECT id, score FROM (
  SELECT id, BM25(docs_idx.tableoid) AS score FROM docs_idx WHERE body @@ ts_phrase('fox') ORDER BY BM25(docs_idx.tableoid) DESC, id LIMIT 3
) sub ORDER BY id;
----
id	score
10	0.043432634
11	0.043432634
12	0.043432634

