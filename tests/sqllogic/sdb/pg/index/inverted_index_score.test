# UNION of two subqueries from same index with outer ORDER BY BM25(docs_idx.tableoid)
query
(SELECT id, BM25(docs_idx.tableoid) > 0 AS has_score FROM docs_idx WHERE body @@ ts_phrase('fox') ORDER BY BM25(docs_idx.tableoid) DESC, id LIMIT 3)
UNION ALL
(SELECT id, BM25(docs_idx.tableoid) > 0 AS has_score FROM docs_idx WHERE body @@ ts_phrase('lazy') ORDER BY BM25(docs_idx.tableoid) DESC, id LIMIT 3)
ORDER BY id;
----
id	has_score
1	t
3	t
10	t
11	t
12	t
35	t


# CTE: BM25(docs_idx.tableoid) computed in CTE, outer query uses the pre-computed alias
query
WITH scored AS (
  SELECT id, BM25(docs_idx.tableoid) AS score FROM docs_idx WHERE body @@ ts_phrase('fox')
)
SELECT id, score > 0 AS has_score FROM scored ORDER BY id LIMIT 3;
----
id	has_score
1	t
2	t
4	t


query
SELECT id, score > 0 AS has_score FROM (
  SELECT id, BM25(docs_idx.tableoid) AS score FROM docs_idx WHERE body @@ ts_phrase('fox')
) sub ORDER BY id LIMIT 3;
----
id	has_score
1	t
2	t
4	t


# BM25(docs_idx.tableoid) in outer query references score column from inner subquery
query error
SELECT id, BM25(docs_idx.tableoid) > 0 AS has_score FROM (
  SELECT id, BM25(docs_idx.tableoid) AS score FROM docs_idx WHERE body @@ ts_phrase('fox')
) sub ORDER BY id LIMIT 3;
----
db error: ERROR: Referenced table "docs_idx" not found!
Candidate tables: "sub"



