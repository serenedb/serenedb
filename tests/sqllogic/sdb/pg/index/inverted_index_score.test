# ============================================================================
# `prefix(col, 'pre')` -- DuckDB's specialised rewrite of `LIKE 'pre%'`
# (when the literal portion has no SQL wildcards). Claimed via
# irs::ByPrefix on keyword-analyzed columns; declined for other
# analyzers (predicate falls back to row-by-row evaluation).
# ============================================================================

statement ok
CREATE TABLE prefix_docs (id INTEGER PRIMARY KEY, sku VARCHAR);


# Default (identity) analyzer on `sku` -- exact-match semantics for
# `=`, `IN`, `LIKE` claimers. No BM25 scoring features so we only
# verify row inclusion for this section; SQL-boost rank semantics
# are covered separately below using the analyzed-body setup.
statement ok
CREATE INDEX prefix_idx ON prefix_docs USING inverted(id, sku);


statement count 1
INSERT INTO prefix_docs VALUES (1, 'alpha-1');


statement count 1
INSERT INTO prefix_docs VALUES (2, 'alpha-2');


statement count 1
INSERT INTO prefix_docs VALUES (3, 'beta-1');


statement count 1
INSERT INTO prefix_docs VALUES (4, 'gamma-1');


statement ok
VACUUM (REFRESH_TABLE) prefix_docs;


# Bare `LIKE 'pre%'` -- DuckDB rewrites to prefix(sku, 'alpha-');
# claimed via ByPrefix.
query
SELECT id FROM prefix_idx WHERE sku LIKE 'alpha-%' ORDER BY id;
----
id
1
2


# Identity-analyzed columns don't carry BM25 scoring features in
# current DDL (no text_dictionary -> StringTokenizer with default
# features), so we verify only inclusion -- claim correctness is
# what matters here. Boost-on-filter correctness is verified
# separately by C++ unit tests (test_Boost_SqlEqualityInOr /
# test_Boost_SqlPrefixInOr) via filter-equality assertions.

# `LIKE 'pre%'` -- DuckDB rewrites to prefix(sku, 'alpha-'); claimed
# via ByPrefix.
query
SELECT id FROM prefix_idx WHERE sku LIKE 'alpha-%' ORDER BY id;
----
id
1
2


# Trailing `_` keeps the `~~` operator (no prefix() rewrite);
# claimed via the LIKE branch as ByWildcard.
query
SELECT id FROM prefix_idx WHERE sku LIKE 'alpha-_' ORDER BY id;
----
id
1
2


# Non-prefix wildcards (`%-1`): claimed via the LIKE branch.
query
SELECT id FROM prefix_idx WHERE sku LIKE '%-1' ORDER BY id;
----
id
1
3
4


# Equality on keyword-analyzed VARCHAR: ByTerm.
query
SELECT id FROM prefix_idx WHERE sku = 'alpha-1' OR sku = 'beta-1' ORDER BY id;
----
id
1
3


# IN on keyword-analyzed VARCHAR: ByTerms.
query
SELECT id FROM prefix_idx
WHERE sku IN ('alpha-1', 'gamma-1', 'beta-1') ORDER BY id;
----
id
1
3
4


statement ok
DROP TABLE prefix_docs;
