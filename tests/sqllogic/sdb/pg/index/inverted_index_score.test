# --- Multi-table join tests ---
statement ok
CREATE TABLE docs2 (id INTEGER PRIMARY KEY, body VARCHAR);


statement ok
INSERT INTO docs2 VALUES (2, 'the swift fox'), (4, 'a clever fox'), (6, 'the lazy dog');


statement ok
CREATE INDEX docs2_idx ON docs2 USING inverted(id, body en);


statement ok
VACUUM (REFRESH_TABLE) docs2;


statement ok
CREATE TABLE meta (id INTEGER PRIMARY KEY, tag VARCHAR);


statement ok
INSERT INTO meta VALUES (2, 'interesting'), (4, 'notable'), (5, 'relevant');


query
SELECT docs_idx.id, BM25(docs_idx.tableoid) FROM docs_idx JOIN docs2_idx ON docs_idx.id = docs2_idx.id
WHERE docs_idx.body @@ ts_phrase('fox') AND docs2_idx.body @@ ts_phrase('fox')
ORDER BY docs_idx.id LIMIT 3;
----
id	bm25
2	0.03676455
4	0.031871427


query
SELECT a.id, a.score > 0 AS has_score FROM
  (SELECT id, BM25(docs_idx.tableoid) AS score FROM docs_idx WHERE body @@ ts_phrase('fox')) a
  JOIN
  (SELECT id FROM docs2_idx WHERE body @@ ts_phrase('fox')) b
  ON a.id = b.id
ORDER BY a.id;
----
id	has_score
2	t
4	t


# Works: JOIN two inverted indexes, same scorer (BM25) scoped inside each subquery
query error
SELECT a.id, a.score > 0 AS has_score, b.score > 0 AS b_has_score FROM
  (SELECT id, BM25(docs_idx.tableoid) AS score FROM docs_idx WHERE body @@ ts_phrase('fox')) a
  JOIN
  (SELECT id, BM25(docs_idx.tableoid) AS score FROM docs2_idx WHERE body @@ ts_phrase('fox')) b
  ON a.id = b.id
ORDER BY a.id;
