# OR filter: match either 'fox' or 'lazy', score comes from the matched docs
query
SELECT id, BM25(docs_idx.tableoid) > 0 AS has_score FROM docs_idx WHERE body @@ ts_phrase('fox') OR body @@ ts_phrase('lazy') ORDER BY id LIMIT 5;
----
id	has_score
1	t
2	t
3	t
4	t
5	t


# AND filter: only docs containing both 'fox' and 'lazy' get scored
query
SELECT id, BM25(docs_idx.tableoid) > 0 AS has_score FROM docs_idx WHERE body @@ ts_phrase('fox') AND body @@ ts_phrase('lazy') ORDER BY id;
----
id	has_score
1	t
35	t


# Subquery: wrap scored result, filter by score threshold
query
SELECT id FROM (SELECT id, BM25(docs_idx.tableoid) AS score FROM docs_idx WHERE body @@ ts_phrase('fox') ORDER BY id) sub WHERE score > 0 ORDER BY id LIMIT 3;
----
id
1
2
4


# COUNT(*) with scoring filter; score > 0 for all matching docs
query
SELECT COUNT(*) FROM docs_idx WHERE body @@ ts_phrase('fox') AND BM25(docs_idx.tableoid) > 0;
----
count
36


# TFIDF with normalize=true produces non-zero scores
query
SELECT id, TFIDF(docs_idx.tableoid, true) > 0 AS has_score FROM docs_idx WHERE body @@ ts_phrase('fox') ORDER BY id LIMIT 3;
----
id	has_score
1	t
2	t
4	t


statement count 1
DELETE FROM docs WHERE id = 1;


statement ok
VACUUM (REFRESH_TABLE) docs;

query
SELECT id FROM docs_idx WHERE body @@ ts_phrase('fox') AND id = 1;
----
id


# Deleted doc does not contribute to count
query
SELECT COUNT(*) FROM docs_idx WHERE body @@ ts_phrase('fox');
----
count
35


# Score ordering still works after deletion
query
SELECT id, BM25(docs_idx.tableoid) > 0 AS has_score FROM docs_idx WHERE body @@ ts_phrase('fox') ORDER BY id LIMIT 3;
----
id	has_score
2	t
4	t
5	t


