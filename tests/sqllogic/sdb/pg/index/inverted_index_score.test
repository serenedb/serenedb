# ============================================================================
# `::boost(K)` on plain SQL conditions outside `@@`. The cast peels the
# WHERE-coercion (BOOSTED_TSQUERY -> BOOLEAN) plus the user-written
# boost cast (BOOLEAN -> BOOSTED_TSQUERY) and applies the factor at
# the leaf-filter level via FilterContext::WithBoost.
# ============================================================================

statement ok
CREATE TABLE sql_boost_docs (id INTEGER PRIMARY KEY, body VARCHAR);


statement ok
CREATE TEXT SEARCH DICTIONARY sql_boost_en(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true,
    norm = true
);


statement ok
CREATE INDEX sql_boost_idx ON sql_boost_docs USING inverted(id, body sql_boost_en);


statement count 1
INSERT INTO sql_boost_docs VALUES (1, 'alpha');


statement count 1
INSERT INTO sql_boost_docs VALUES (2, 'beta');


statement count 1
INSERT INTO sql_boost_docs VALUES (3, 'gamma');


statement ok
VACUUM (REFRESH_TABLE) sql_boost_docs;


# Baseline (no SQL-surface boost): 3-way OR over the body terms; all
# three rows score identically so they sort by id.
query
SELECT id, BM25(sql_boost_idx.tableoid) as d FROM sql_boost_idx
WHERE body @@ 'alpha' OR body @@ 'beta' OR body @@ 'gamma'
ORDER BY d DESC, id;
----
id	d
1	0.9808291
2	0.9808291
3	0.9808291


# End-to-end BM25 ordering via SQL-surface boost wrapping a TSQUERY
# match: `(body @@ 'word')::boost(K)`. The boost peel recurses into
# the @@ expression with WithBoost(K), producing a ByTerm leaf with
# boost K -- which is scored under the analyzed body column. Boost
# on the alpha leg lifts id=1 to the top.
query
SELECT id FROM sql_boost_idx
WHERE (body @@ 'alpha')::boost(1000.0) OR (body @@ 'beta')
ORDER BY BM25(sql_boost_idx.tableoid) DESC, id;
----
id
1
2


# Inverse: boost beta instead -- id=2 ranks first.
query
SELECT id FROM sql_boost_idx
WHERE (body @@ 'alpha') OR (body @@ 'beta')::boost(1000.0)
ORDER BY BM25(sql_boost_idx.tableoid) DESC, id;
----
id
2
1


# Three-way: each leg with its own SQL-surface boost factor; the
# largest factor wins regardless of id order.
query
SELECT id FROM sql_boost_idx
WHERE (body @@ 'alpha')::boost(100.0)
   OR (body @@ 'beta')::boost(1000.0)
   OR (body @@ 'gamma')::boost(10.0)
ORDER BY BM25(sql_boost_idx.tableoid) DESC, id;
----
id
2
1
3


# Boost cast wrapping a compound predicate (AND of @@ + numeric
# equality): the factor applies to the AND group's score
# contribution. id=1 satisfies both conjuncts and gets the boost.
query
SELECT id FROM sql_boost_idx
WHERE (body @@ 'alpha' AND id = 1)::boost(1000.0)
   OR (body @@ 'beta')
ORDER BY BM25(sql_boost_idx.tableoid) DESC, id;
----
id
1
2


# Bind-time error: SQL-surface boost cast on a predicate the inverted
# index can't claim (binary comparison with column refs on both
# sides).
query error ::boost\(K\) used on a predicate the inverted index could not claim
SELECT id FROM sql_boost_idx
WHERE (id > id)::boost(2.0);


