query
SELECT docs_idx.id,
       BM25(docs_idx.tableoid) AS left_score,
       BM25(docs2_idx.tableoid) AS right_score,
       BM25(docs_idx.tableoid) <> BM25(docs2_idx.tableoid) AS differs
FROM docs_idx
JOIN docs2_idx ON docs_idx.id = docs2_idx.id
WHERE docs_idx.body @@ ts_phrase('fox') AND docs2_idx.body @@ ts_phrase('fox')
ORDER BY docs_idx.id;
----
id	left_score	right_score	differs
2	0.03676455	0.47<slt:ignore>	t
4	0.031<slt:ignore>	0.47<slt:ignore>	t


statement ok
DROP TABLE docs2;


statement ok
DROP TABLE meta;


# Union tree: each branch is itself a UNION (((fox UNION lazy) UNION ALL (fox UNION lazy)))
query
(
  (SELECT id, BM25(docs_idx.tableoid) AS score FROM docs_idx WHERE body @@ ts_phrase('fox') ORDER BY id LIMIT 2)
  UNION ALL
  (SELECT id, BM25(docs_idx.tableoid) AS score FROM docs_idx WHERE body @@ ts_phrase('lazy') ORDER BY id LIMIT 2)
)
UNION ALL
(
  (SELECT id, BM25(docs_idx.tableoid) AS score FROM docs_idx WHERE body @@ ts_phrase('fox') ORDER BY id LIMIT 2)
  UNION ALL
  (SELECT id, BM25(docs_idx.tableoid) AS score FROM docs_idx WHERE body @@ ts_phrase('lazy') ORDER BY id LIMIT 2)
)
ORDER BY id LIMIT 6;
----
id	score
2	0.03676455
2	0.03676455
3	2.177017
3	2.177017
4	0.031871427
4	0.031871427


# EXPLAIN for union tree
query
EXPLAIN (
  (SELECT id, BM25(docs_idx.tableoid) AS score FROM docs_idx WHERE body @@ ts_phrase('fox') LIMIT 2)
  UNION ALL
  (SELECT id, BM25(docs_idx.tableoid) AS score FROM docs_idx WHERE body @@ ts_phrase('lazy') LIMIT 2)
)
UNION ALL
(
  (SELECT id, BM25(docs_idx.tableoid) AS score FROM docs_idx WHERE body @@ ts_phrase('fox') LIMIT 2)
  UNION ALL
  (SELECT id, BM25(docs_idx.tableoid) AS score FROM docs_idx WHERE body @@ ts_phrase('lazy') LIMIT 2)
)
ORDER BY id LIMIT 6;
----
