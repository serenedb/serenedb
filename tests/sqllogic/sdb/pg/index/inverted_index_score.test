query error
EXPLAIN
select * from (select * from docs_idx)
order by bm25(tableoid) desc
----
db error: ERROR: Referenced column "tableoid" not found in FROM clause!
Candidate bindings: "body"


query
EXPLAIN (
  (SELECT id, BM25(docs_idx.tableoid) as score FROM docs_idx WHERE body @@ ts_phrase('fox') LIMIT 2)
  UNION ALL
  (SELECT id, BM25(docs_idx.tableoid) as score FROM docs_idx WHERE body @@ ts_phrase('lazy') LIMIT 2)
)
UNION ALL
(
  (SELECT id, BM25(docs_idx.tableoid) as score FROM docs_idx WHERE body @@ ts_phrase('fox') LIMIT 2)
  UNION ALL
  (SELECT id, BM25(docs_idx.tableoid) as score FROM docs_idx WHERE body @@ ts_phrase('lazy') LIMIT 2)
)
ORDER BY score
LIMIT 6;
----
