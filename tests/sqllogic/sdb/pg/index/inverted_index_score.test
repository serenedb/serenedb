# Works: JOIN inverted index with plain table, BM25(docs_idx.tableoid) from inverted scan
query
SELECT docs_idx.id, BM25(docs_idx.tableoid) > 0 AS has_score, meta.tag FROM docs_idx
JOIN meta ON docs_idx.id = meta.id
WHERE docs_idx.body @@ ts_phrase('fox')
ORDER BY docs_idx.id;
----
id	has_score	tag
2	t	interesting
4	t	notable
5	t	relevant


# EXPLAIN for join inverted + plain table with BM25()
query
EXPLAIN SELECT docs_idx.id, BM25(docs_idx.tableoid) > 0 AS has_score, meta.tag FROM docs_idx
JOIN meta ON docs_idx.id = meta.id
WHERE docs_idx.body @@ ts_phrase('fox')
ORDER BY docs_idx.id;
----
