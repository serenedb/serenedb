# EXPLAIN for join two inverted indexes with scorer scoped inside subquery

query
EXPLAIN SELECT a.id, a.score > 0 AS has_score FROM
  (SELECT id, BM25(docs_idx.tableoid) AS score FROM docs_idx WHERE body @@ ts_phrase('fox')) a
  JOIN
  (SELECT id FROM docs2_idx WHERE body @@ ts_phrase('fox')) b
  ON a.id = b.id
ORDER BY a.id;
----
