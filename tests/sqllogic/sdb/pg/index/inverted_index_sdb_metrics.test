control substitution on

statement ok
CREATE TABLE t(r text);

statement ok
CREATE TEXT SEARCH DICTIONARY test_english(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false
);

statement ok
CREATE INDEX index_t ON t USING inverted(r test_english)
WITH (refresh_interval = 0, compaction_interval = 0);

statement ok
INSERT INTO t VALUES ('a'), ('b'), ('c');


query
SELECT metric, value FROM sdb_metrics
WHERE relation_id = (SELECT oid FROM pg_class WHERE relname = 'index_t')
ORDER BY metric;
