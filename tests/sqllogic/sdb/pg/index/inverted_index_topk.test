id


query
SELECT id, BM25(docs_topk_idx.tableoid) > 0 AS has_score FROM docs_topk_idx WHERE PHRASE(body, 'fox') ORDER BY BM25(docs_topk_idx.tableoid) DESC, id LIMIT 3;
