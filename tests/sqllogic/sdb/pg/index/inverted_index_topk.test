# Get expected results from full scan across two segments
query
SELECT id FROM docs_topk_idx WHERE PHRASE(body, 'fox') ORDER BY BM25() DESC, id LIMIT 5;
----
id
10
11
12
13
14


# Same query with topk=5 — should match
statement ok
SET sdb_force_topk = 5;


query
SELECT id FROM docs_topk_idx WHERE PHRASE(body, 'fox') ORDER BY BM25() DESC, id LIMIT 5;
----
id
10
11
12
13
14


# Larger topk across segments
statement ok
SET sdb_force_topk = 20;


query
SELECT COUNT(*) FROM (SELECT id FROM docs_topk_idx WHERE PHRASE(body, 'fox') ORDER BY BM25() DESC) t;
----
count
14


statement ok
SET sdb_force_topk = 0;


# ---- Edge case: no matching docs with topk ----
statement ok
SET sdb_force_topk = 5;


query
SELECT id FROM docs_topk_idx WHERE PHRASE(body, 'nonexistent_term_xyz') ORDER BY BM25() DESC;
----
id


statement ok
SET sdb_force_topk = 0;


# ---- Verify scores are returned correctly with topk ----
statement ok
SET sdb_force_topk = 3;


query
SELECT id, BM25() > 0 AS has_score FROM docs_topk_idx WHERE PHRASE(body, 'fox') ORDER BY BM25() DESC, id LIMIT 3;
----
id	has_score
10	t
11	t
12	t


statement ok
SET sdb_force_topk = 0;


