hash-threshold 100

# A STRUCT INCLUDE column that nests a UNION member. DuckDB's projection
# pushdown extracts the union-typed field (s.u) from the columnstore; union
# member access (union_extract / struct_extract) stays native above the scan,
# so the pushed path stops at the union and never descends into it. This locks
# in that extracting a union-nesting struct through the index returns the right
# values.

statement ok
CREATE TABLE union_struct_inc (
  id INTEGER NOT NULL,
  body TEXT NOT NULL,
  s STRUCT(u UNION(num INTEGER, str VARCHAR), n INTEGER) NOT NULL,
  PRIMARY KEY (id)
);


statement ok
CREATE TEXT SEARCH DICTIONARY union_struct_inc_en(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true
);


statement ok
CREATE INDEX union_struct_inc_idx
  ON union_struct_inc USING inverted(body union_struct_inc_en)
  INCLUDE (s);


statement ok
INSERT INTO union_struct_inc VALUES
  (1, 'alpha cat', {'u': 1::UNION(num INTEGER, str VARCHAR), 'n': 10}),
  (2, 'beta dog', {'u': 'hello'::UNION(num INTEGER, str VARCHAR), 'n': 20}),
  (3, 'gamma cat', {'u': 7::UNION(num INTEGER, str VARCHAR), 'n': 30});


statement ok
VACUUM (REFRESH_TABLE) union_struct_inc;


# Extract the UNION member: whole struct materializes, native s.u is cast to
# VARCHAR for the client.
query
SELECT id, s.u FROM union_struct_inc_idx ORDER BY id;
----
id	u
1	1
2	hello
3	7


# Extract the non-UNION member of the same struct.
query
SELECT id, s.n FROM union_struct_inc_idx ORDER BY id;
----
id	n
1	10
2	20
3	30


# Nested extraction into the union member.
query
SELECT id, union_extract(s.u, 'str') AS s_str FROM union_struct_inc_idx
ORDER BY id;
----
id	s_str
1	NULL
2	hello
3	NULL


# Searchable via the inverted index; the union member still reads back.
query
SELECT id, s.u FROM union_struct_inc_idx WHERE body @@ ts_phrase('cat')
ORDER BY id;
----
id	u
1	1
3	7
