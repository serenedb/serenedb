hash-threshold 100

# End-to-end: INCLUDE'd VARIANT column round-trips through new cs.
# Exercises the iresearch columnstore writer/reader VARIANT path (which
# mirrors the STRUCT path -- VARIANT's physical layout is a STRUCT).
#
# `payload` is declared sdb_indexonly so the column has no main-storage
# data; its bytes flow through the WAL [CP] marker and into the inverted
# index columnstore. The read-side check in duckdb_scan_base permits the
# projection when the scan goes through an inverted-index entry and the
# column has store_values=true.

statement ok
CREATE TABLE variant_inc (
  id INTEGER NOT NULL,
  body TEXT NOT NULL,
  payload VARIANT NOT NULL,
  PRIMARY KEY (id)
) WITH (sdb_indexonly = [payload]);


statement ok
CREATE TEXT SEARCH DICTIONARY variant_inc_en(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true
);


statement ok
CREATE INDEX variant_inc_idx
  ON variant_inc USING inverted(body variant_inc_en) INCLUDE (payload);


statement ok
INSERT INTO variant_inc VALUES
  (1, 'alpha cat', 42::variant),
  (2, 'beta dog', 'hello'::variant),
  (3, 'gamma cat', true::variant),
  (4, 'delta horse', '{"a": 42}'::json::variant);


statement ok
VACUUM (UPDATE_INDEXES) variant_inc;


# Single match: int variant.
query
SELECT id, payload FROM variant_inc_idx WHERE body @@ ts_phrase('alpha')
ORDER BY id;
----
id	payload
1	42


# Two matches: bool and int variants returned through the index cs.
query
SELECT id, payload FROM variant_inc_idx WHERE body @@ ts_phrase('cat')
ORDER BY id;
----
id	payload
1	42
3	true


# JSON-shaped variant round-trips.
query
SELECT id, payload FROM variant_inc_idx WHERE body @@ ts_phrase('delta')
ORDER BY id;
----
id	payload
4	{"a":42}


# Direct projection from the base table is still rejected -- payload has
# no main-storage source.
statement error
SELECT payload FROM variant_inc;
----
db error: ERROR: column "payload" has sdb_indexonly storage and cannot be read directly; it is only accessible through an inverted-index search predicate
