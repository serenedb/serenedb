hash-threshold 100

statement ok
CREATE TABLE variant_inc (
  id INTEGER NOT NULL,
  body TEXT NOT NULL,
  payload VARIANT NOT NULL,
  PRIMARY KEY (id)
);


statement ok
CREATE TEXT SEARCH DICTIONARY variant_inc_en(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true
);


statement ok
CREATE INDEX variant_inc_idx
  ON variant_inc USING inverted(body variant_inc_en) INCLUDE (payload);


statement ok
INSERT INTO variant_inc VALUES
  (1, 'alpha cat', 42::variant),
  (2, 'beta dog', 'hello'::variant),
  (3, 'gamma cat', true::variant),
  (4, 'delta horse', '{"a": 42}'::json::variant);


statement ok
VACUUM (REFRESH_TABLE) variant_inc;


query
SELECT id FROM variant_inc_idx WHERE body @@ ts_phrase('alpha')
ORDER BY id;
----
id
1


query
SELECT id FROM variant_inc_idx WHERE body @@ ts_phrase('cat')
ORDER BY id;
----
id
1
3


query
SELECT id FROM variant_inc_idx WHERE body @@ ts_phrase('delta')
ORDER BY id;
----
id
4


query
SELECT payload FROM variant_inc ORDER BY id;
----
payload
42
"hello"
true
{"a":42}
