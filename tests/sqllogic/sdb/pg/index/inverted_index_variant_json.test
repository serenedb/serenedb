# Indexing a VARIANT-typed indexed expression (a path extraction such as
# `(v['val'])`) -- each row's variant scalar is indexed like a JSON leaf:
# string/number/boolean/null are accepted, object/array are rejected per row.
# Mirrors the JSON-path scenario in inverted_index_json.test. Variant leaves
# are queried by casting at query time (no `->>`/`->` operators on variant).

statement ok
CREATE TEXT SEARCH DICTIONARY verbatim_dict(
    template = 'keyword'
);

statement ok
CREATE TEXT SEARCH DICTIONARY text_dict(
    template = 'text', locale = 'en_US.UTF-8', case = 'none',
    stemming = false, accent = false, frequency = true, position = true);

statement ok
CREATE TABLE logs (id INTEGER PRIMARY KEY, v VARIANT);

# One variant path indexed on the column.
statement ok
CREATE INDEX logs_idx ON logs USING inverted(id, (v['host']) verbatim_dict);

statement ok
INSERT INTO logs VALUES
    (1, '{"host":"server-01"}'::json::variant),
    (2, '{"host":"server-02"}'::json::variant),
    (3, '{"host":"server-03"}'::json::variant),
    (4, '{"host":"server-14"}'::json::variant);

statement ok
VACUUM (REFRESH_TABLE) logs;

# The wildcard 'server-0_' should match ids 1..3 only.
query
SELECT id FROM logs_idx WHERE (v['host'])::text @@ ts_like('server-0_') ORDER BY id;
----
id
1
2
3

# Exact match through the indexed path.
query
SELECT id FROM logs_idx WHERE (v['host'])::text = 'server-02';
----
id
2

# Multiple paths on the same column.
statement ok
CREATE TABLE evts (id INTEGER PRIMARY KEY, v VARIANT);

statement ok
CREATE INDEX evts_idx ON evts USING inverted(
    id,
    (v['host']) verbatim_dict,
    (v['status']) verbatim_dict
);

statement ok
INSERT INTO evts VALUES
    (1, '{"host":"a","status":"ok"}'::json::variant),
    (2, '{"host":"b","status":"error"}'::json::variant),
    (3, '{"host":"a","status":"error"}'::json::variant);

statement ok
VACUUM (REFRESH_TABLE) evts;

query
SELECT id FROM evts_idx WHERE (v['host'])::text @@ ts_like('a') ORDER BY id;
----
id
1
3

query
SELECT id FROM evts_idx WHERE (v['status'])::text @@ ts_like('error') ORDER BY id;
----
id
2
3

# Every primitive leaf kind is accepted; compound leaves are rejected per row.
# A single indexed path can hold different scalar kinds across rows: each is
# routed to its own (string/numeric/bool/null) mangled field.
statement ok
CREATE TABLE prim_types (id INTEGER PRIMARY KEY, v VARIANT);

statement ok
CREATE INDEX prim_types_idx ON prim_types USING inverted(id, (v['val']) verbatim_dict);

statement ok
INSERT INTO prim_types VALUES (1, '{"val":"hello"}'::json::variant);

statement ok
INSERT INTO prim_types VALUES (2, '{"val":42}'::json::variant);

statement ok
INSERT INTO prim_types VALUES (3, '{"val":3.14}'::json::variant);

statement ok
INSERT INTO prim_types VALUES (4, '{"val":true}'::json::variant);

statement ok
INSERT INTO prim_types VALUES (5, '{"val":false}'::json::variant);

# Null leaf -- accepted, indexed under a null-mangled marker.
statement ok
INSERT INTO prim_types VALUES (6, '{"val":null}'::json::variant);

# Missing path -- the extracted variant is SQL-null and indexes under the
# same null marker, so `IS NULL` matches it too.
statement ok
INSERT INTO prim_types VALUES (7, '{"other":"x"}'::json::variant);

# Object leaf -- rejected.
statement error
INSERT INTO prim_types VALUES (8, '{"val":{"x":1}}'::json::variant);
----
db error: ERROR: Variant expression indexed by an inverted index must resolve to a primitive (string/number/boolean/null) scalar; got an object or array


# Array leaf -- rejected.
statement error
INSERT INTO prim_types VALUES (9, '{"val":["a","b"]}'::json::variant);
----
db error: ERROR: Variant expression indexed by an inverted index must resolve to a primitive (string/number/boolean/null) scalar; got an object or array


statement ok
VACUUM (REFRESH_TABLE) prim_types;

# String leaf via ::text.
query
SELECT id FROM prim_types_idx WHERE (v['val'])::text = 'hello';
----
id
1

# Numeric leaf via ::int / range. Cast peeling routes to the numeric field.
query
SELECT id FROM prim_types_idx WHERE (v['val'])::int = 42;
----
id
2

query
SELECT id FROM prim_types_idx WHERE (v['val'])::double > 10 ORDER BY id;
----
id
2

# Boolean leaves.
query
SELECT id FROM prim_types_idx WHERE (v['val'])::bool = true;
----
id
4

query
SELECT id FROM prim_types_idx WHERE (v['val'])::bool = false;
----
id
5

# IS NULL matches the json-null leaf (6) and the missing leaf (7).
query
SELECT id FROM prim_types_idx WHERE (v['val'])::text IS NULL ORDER BY id;
----
id
6
7

# Tokenised (text) dictionary supports phrase queries on a variant path.
statement ok
CREATE TABLE preds (id INTEGER PRIMARY KEY, v VARIANT);

statement ok
CREATE INDEX preds_idx ON preds USING inverted(id, (v['msg']) text_dict);

statement ok
INSERT INTO preds VALUES
    (1, '{"msg":"quick brown fox"}'::json::variant),
    (2, '{"msg":"lazy dog runs"}'::json::variant),
    (3, '{"msg":"the quick fox jumps"}'::json::variant);

statement ok
VACUUM (REFRESH_TABLE) preds;

query
SELECT id FROM preds_idx WHERE (v['msg'])::text @@ ts_phrase('quick fox') ORDER BY id;
----
id
3

# Nested path extraction.
statement ok
CREATE TABLE nested (id INTEGER PRIMARY KEY, v VARIANT);

statement ok
CREATE INDEX nested_idx ON nested USING inverted(id, (v['user']['name']) verbatim_dict);

statement ok
INSERT INTO nested VALUES
    (1, '{"user":{"name":"alice"}}'::json::variant),
    (2, '{"user":{"name":"bob"}}'::json::variant);

statement ok
VACUUM (REFRESH_TABLE) nested;

query
SELECT id FROM nested_idx WHERE (v['user']['name'])::text = 'bob';
----
id
2
