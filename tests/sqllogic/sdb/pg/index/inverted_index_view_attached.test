# Inverted index over views of tables living in a user-ATTACHed duckdb
# database. The PK stored in the index is the duckdb rowid; materialization
# fetches rows from the live catalog entry through the caller's transaction,
# so in-transaction changes to the source are visible immediately. Rows
# deleted in the source after CREATE INDEX materialize as NULLs (same
# contract family as the read_duckdb / parquet / iceberg view indexes:
# the index pins what it indexed).

control substitution on

statement ok
DETACH DATABASE IF EXISTS db172;


statement ok
ATTACH '${__TEST_DIR__}/db172.duckdb' AS db172;


statement ok
CREATE TABLE db172.main.docs(id INTEGER, body TEXT, score INTEGER);


statement ok
INSERT INTO db172.main.docs VALUES
  (1, 'alpha cat runs', 10),
  (2, 'beta dog sleeps', 20),
  (3, 'gamma cat jumps', 30),
  (4, 'delta horse eats', 40);


statement ok
CREATE SCHEMA db172.aux;


statement ok
CREATE TABLE db172.aux.notes(id INTEGER, body TEXT);


statement ok
INSERT INTO db172.aux.notes VALUES
  (100, 'cat note one'),
  (200, 'dog note two');


statement ok
CREATE TEXT SEARCH DICTIONARY view_attached_en(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true
);


statement ok
CREATE VIEW v_att AS
SELECT * FROM db172.main.docs;


# Projection + cast over a non-default schema: covers the name-based column
# mapping and the cast pass of the lookup.
statement ok
CREATE VIEW v_att_notes AS
SELECT id::BIGINT AS id_b, body FROM db172.aux.notes;


query
SELECT count(*) FROM v_att;
----
count
4


statement ok
CREATE INDEX v_att_idx ON v_att USING inverted(body view_attached_en);


statement ok
CREATE INDEX v_att_notes_idx ON v_att_notes USING inverted(body view_attached_en);


query
SELECT id, body, score FROM v_att_idx WHERE body @@ ts_phrase('cat')
ORDER BY id;
----
id	body	score
1	alpha cat runs	10
3	gamma cat jumps	30


query
SELECT id_b, body FROM v_att_notes_idx WHERE body @@ ts_phrase('note')
ORDER BY id_b;
----
id_b	body
100	cat note one
200	dog note two


# Lookups run through the caller's transaction against the live attach: an
# uncommitted DELETE already materializes as NULLs, and ROLLBACK restores
# the row. (Index queries inside an explicit transaction require
# read-your-own-writes to be off.)

statement ok
BEGIN;


statement ok
DELETE FROM db172.main.docs WHERE id = 3;


query
SELECT id, body, score FROM v_att_idx WHERE body @@ ts_phrase('cat')
ORDER BY id NULLS LAST;
----
id	body	score
1	alpha cat runs	10
NULL	NULL	NULL


statement ok
ROLLBACK;



query
SELECT id, body, score FROM v_att_idx WHERE body @@ ts_phrase('cat')
ORDER BY id;
----
id	body	score
1	alpha cat runs	10
3	gamma cat jumps	30


# The index is frozen at CREATE INDEX time: rows inserted into the source
# afterwards exist in the view but produce no postings.
statement ok
INSERT INTO db172.main.docs VALUES (5, 'eta cat hides', 50);


query
SELECT count(*) FROM v_att;
----
count
5


query
SELECT id FROM v_att_idx WHERE body @@ ts_phrase('cat') ORDER BY id;
----
id
1
3


# Committed source deletion after CREATE INDEX: the stale posting
# materializes as NULLs instead of garbage.
statement ok
DELETE FROM db172.main.docs WHERE id = 3;


query
SELECT id, body, score FROM v_att_idx WHERE body @@ ts_phrase('cat')
ORDER BY id NULLS LAST;
----
id	body	score
1	alpha cat runs	10
NULL	NULL	NULL


# DETACH: count-only queries are served by the index alone; materializing
# real columns needs the source and errors until the database is re-attached.
statement ok
DETACH db172;


query
SELECT count(*) FROM v_att_idx WHERE body @@ ts_phrase('cat');
----
count
2


statement error
SELECT id, body, score FROM v_att_idx WHERE body @@ ts_phrase('cat');
----
db error: ERROR: materialising real columns from this view-backed inverted index is not yet supported -- view body must be a simple `SELECT * FROM <reader>(literal_args)` over a recognised fast-path source (read_parquet/csv/json/...)


statement ok
ATTACH '${__TEST_DIR__}/db172.duckdb' AS db172;


query
SELECT id, body, score FROM v_att_idx WHERE body @@ ts_phrase('cat')
ORDER BY id NULLS LAST;
----
id	body	score
1	alpha cat runs	10
NULL	NULL	NULL


statement ok
DROP VIEW v_att CASCADE;


statement ok
DROP VIEW v_att_notes CASCADE;


statement ok
DROP TEXT SEARCH DICTIONARY view_attached_en;


statement ok
DETACH db172;
