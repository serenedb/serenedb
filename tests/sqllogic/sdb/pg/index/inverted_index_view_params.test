hash-threshold 100
control substitution on

# View bodies with non-default reader parameters. The lookup re-bind must
# forward these so the materialize TF reads the file with the same dialect
# / format that CREATE INDEX saw. Detection-only knobs (auto_detect,
# sample_size) are not relevant to the materialize path -- we look up
# concrete columns -- so they are not exercised here.


statement ok
CREATE TEXT SEARCH DICTIONARY view_params_en(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true
);


# ============================================================================
# CSV: delim, quote, escape, header
# ============================================================================

# Semicolon-delimited CSV with header.
statement ok
COPY (SELECT 'a' AS k, 'pudge alpha' AS body
      UNION ALL SELECT 'b', 'manga beta'
      UNION ALL SELECT 'c', 'pudge gamma')
TO '/tmp/${__DATABASE__}_p_csv_delim.csv' (FORMAT CSV, DELIMITER ';', HEADER);

statement ok
CREATE VIEW p_csv_delim_v AS
  SELECT * FROM read_csv('/tmp/${__DATABASE__}_p_csv_delim.csv', delim=';', header=true);

statement ok
CREATE INDEX p_csv_delim_idx ON p_csv_delim_v
  USING inverted(k, body view_params_en);

query
SELECT k, body FROM p_csv_delim_idx ORDER BY k;
----
k	body
a	pudge alpha
b	manga beta
c	pudge gamma

query
SELECT k, body FROM p_csv_delim_idx WHERE body @@ ts_phrase('pudge') ORDER BY k;
----
k	body
a	pudge alpha
c	pudge gamma


# Pipe-delimited CSV without header (column names from auto-detect: column0,
# column1). header=false flows from view body to lookup.
statement ok
COPY (SELECT 1::int4 AS id, 'pudge solo' AS body)
TO '/tmp/${__DATABASE__}_p_csv_nohdr.csv' (FORMAT CSV, DELIMITER '|', HEADER FALSE);

statement ok
CREATE VIEW p_csv_nohdr_v AS
  SELECT * FROM read_csv('/tmp/${__DATABASE__}_p_csv_nohdr.csv', delim='|', header=false);

statement ok
CREATE INDEX p_csv_nohdr_idx ON p_csv_nohdr_v
  USING inverted(column0, column1 view_params_en);

query
SELECT column0, column1 FROM p_csv_nohdr_idx ORDER BY column0;
----
column0	column1
1	pudge solo


# ============================================================================
# JSON: format=array vs nd, records=true|false
# ============================================================================

# JSON array file (entire file is one [...] of records).
statement ok
COPY (SELECT 1::int4 AS id, 'pudge alpha' AS body
      UNION ALL SELECT 2, 'manga beta'
      UNION ALL SELECT 3, 'pudge gamma')
TO '/tmp/${__DATABASE__}_p_json_array.json' (FORMAT JSON, ARRAY);

statement ok
CREATE VIEW p_json_array_v AS
  SELECT * FROM read_json('/tmp/${__DATABASE__}_p_json_array.json', format='array');

statement ok
CREATE INDEX p_json_array_idx ON p_json_array_v
  USING inverted(id, body view_params_en);

query
SELECT id, body FROM p_json_array_idx ORDER BY id;
----
id	body
1	pudge alpha
2	manga beta
3	pudge gamma

query
SELECT id, body FROM p_json_array_idx WHERE body @@ ts_phrase('manga') ORDER BY id;
----
id	body
2	manga beta


# Newline-delimited JSON via the explicit `nd` alias.
statement ok
COPY (SELECT 4::int4 AS id, 'pudge nd alpha' AS body
      UNION ALL SELECT 5, 'pudge nd beta')
TO '/tmp/${__DATABASE__}_p_json_nd.jsonl' (FORMAT JSON);

statement ok
CREATE VIEW p_json_nd_v AS
  SELECT * FROM read_json('/tmp/${__DATABASE__}_p_json_nd.jsonl', format='nd');

statement ok
CREATE INDEX p_json_nd_idx ON p_json_nd_v
  USING inverted(id, body view_params_en);

query
SELECT id, body FROM p_json_nd_idx ORDER BY id;
----
id	body
4	pudge nd alpha
5	pudge nd beta


# ============================================================================
# Parquet: binary_as_string
# ============================================================================

# binary_as_string makes BLOB cells parsed as VARCHAR -- exercises the
# named-param round-trip for parquet.
statement ok
COPY (SELECT 1::int4 AS id, 'pudge bin alpha'::BLOB AS body
      UNION ALL SELECT 2, 'pudge bin beta'::BLOB)
TO '/tmp/${__DATABASE__}_p_pq_bin.parquet' (FORMAT PARQUET);

statement ok
CREATE VIEW p_pq_bin_v AS
  SELECT * FROM read_parquet('/tmp/${__DATABASE__}_p_pq_bin.parquet', binary_as_string=true);

statement ok
CREATE INDEX p_pq_bin_idx ON p_pq_bin_v
  USING inverted(id, body view_params_en);

query
SELECT id, body FROM p_pq_bin_idx ORDER BY id;
----
id	body
1	pudge bin alpha
2	pudge bin beta

query
SELECT id, body FROM p_pq_bin_idx WHERE body @@ ts_phrase('pudge bin') ORDER BY id;
----
id	body
1	pudge bin alpha
2	pudge bin beta


# ============================================================================
# CSV: custom quote char
# ============================================================================

# `#` as quote char + delim `;`. Bodies contain commas and semicolons that
# force quoting on write -- the parser must use `#` as the quote on the
# read side too, otherwise the row splits at every `;` or `,`.
statement ok
COPY (SELECT 1::int4 AS id, 'pudge, alpha; with text' AS body
      UNION ALL SELECT 2, 'manga, beta'
      UNION ALL SELECT 3, 'pudge, gamma'
      ORDER BY id)
TO '/tmp/${__DATABASE__}_p_csv_quote.csv' (FORMAT CSV, HEADER, DELIMITER ';', QUOTE '#');

statement ok
CREATE VIEW p_csv_quote_v AS
  SELECT * FROM read_csv('/tmp/${__DATABASE__}_p_csv_quote.csv',
                          header=true, delim=';', quote='#');

statement ok
CREATE INDEX p_csv_quote_idx ON p_csv_quote_v
  USING inverted(id, body view_params_en);

query
SELECT id, body FROM p_csv_quote_idx ORDER BY id;
----
id	body
1	pudge, alpha; with text
2	manga, beta
3	pudge, gamma

query
SELECT id, body FROM p_csv_quote_idx WHERE body @@ ts_phrase('pudge') ORDER BY id;
----
id	body
1	pudge, alpha; with text
3	pudge, gamma


# ============================================================================
# CSV: nullstr
# ============================================================================

# Two distinct null markers. If nullstr is dropped on the lookup side, the
# materialised body would come back as the literal string "NA" / "NULL"
# instead of NULL.
statement ok
COPY (SELECT 1::int4 AS id, 'pudge null alpha'::VARCHAR AS body
      UNION ALL SELECT 2, NULL
      UNION ALL SELECT 3, 'pudge null gamma')
TO '/tmp/${__DATABASE__}_p_csv_null.csv' (FORMAT CSV, HEADER, NULLSTR 'NA');

statement ok
CREATE VIEW p_csv_null_v AS
  SELECT * FROM read_csv('/tmp/${__DATABASE__}_p_csv_null.csv',
                          header=true, nullstr=['NA', 'NULL']);

statement ok
CREATE INDEX p_csv_null_idx ON p_csv_null_v
  USING inverted(id, body view_params_en);

query
SELECT id, body FROM p_csv_null_idx ORDER BY id;
----
id	body
1	pudge null alpha
2	NULL
3	pudge null gamma


# ============================================================================
# CSV: skip (leading-rows skip), auto-detect post-skip
# ============================================================================

# `skip=2` discards two leading non-data lines before the header. The lookup
# bind must forward `skip` so the byte-offset PKs recorded at index-time
# still point at row starts when the file is re-parsed.
statement ok
COPY (SELECT '# generated' AS line UNION ALL SELECT '# rev=42'
      UNION ALL SELECT 'id,body'
      UNION ALL SELECT '1,pudge skip alpha'
      UNION ALL SELECT '2,manga skip beta'
      UNION ALL SELECT '3,pudge skip gamma')
TO '/tmp/${__DATABASE__}_p_csv_skip.csv' (FORMAT CSV, HEADER FALSE, QUOTE '');

statement ok
CREATE VIEW p_csv_skip_v AS
  SELECT * FROM read_csv('/tmp/${__DATABASE__}_p_csv_skip.csv',
                          skip=2, header=true);

statement ok
CREATE INDEX p_csv_skip_idx ON p_csv_skip_v
  USING inverted(id, body view_params_en);

query
SELECT id, body FROM p_csv_skip_idx ORDER BY id;
----
id	body
1	pudge skip alpha
2	manga skip beta
3	pudge skip gamma


# ============================================================================
# CSV: comment marker
# ============================================================================

# `comment='#'` filters out lines starting with `#` before parsing.
statement ok
COPY (SELECT '# header generated by test' AS line
      UNION ALL SELECT 'id,body'
      UNION ALL SELECT '1,pudge cmt alpha'
      UNION ALL SELECT '# mid-file comment'
      UNION ALL SELECT '2,manga cmt beta'
      UNION ALL SELECT '3,pudge cmt gamma')
TO '/tmp/${__DATABASE__}_p_csv_cmt.csv' (FORMAT CSV, HEADER FALSE, QUOTE '');

statement ok
CREATE VIEW p_csv_cmt_v AS
  SELECT * FROM read_csv('/tmp/${__DATABASE__}_p_csv_cmt.csv',
                          comment='#', header=true);

statement ok
CREATE INDEX p_csv_cmt_idx ON p_csv_cmt_v
  USING inverted(id, body view_params_en);

query
SELECT id, body FROM p_csv_cmt_idx ORDER BY id;
----
id	body
1	pudge cmt alpha
2	manga cmt beta
3	pudge cmt gamma


# ============================================================================
# CSV: gzip compression (auto-detected by extension, also forwarded via param)
# ============================================================================

statement ok
COPY (SELECT 1::int4 AS id, 'pudge gz alpha' AS body
      UNION ALL SELECT 2, 'manga gz beta'
      UNION ALL SELECT 3, 'pudge gz gamma')
TO '/tmp/${__DATABASE__}_p_csv_gz.csv.gz' (FORMAT CSV, HEADER, COMPRESSION gzip);

statement ok
CREATE VIEW p_csv_gz_v AS
  SELECT * FROM read_csv('/tmp/${__DATABASE__}_p_csv_gz.csv.gz',
                          header=true, compression='gzip');

statement ok
CREATE INDEX p_csv_gz_idx ON p_csv_gz_v
  USING inverted(id, body view_params_en);

query
SELECT id, body FROM p_csv_gz_idx ORDER BY id;
----
id	body
1	pudge gz alpha
2	manga gz beta
3	pudge gz gamma


# ============================================================================
# CSV: explicit columns / types
# ============================================================================

# When `columns=` is given, auto-detection is bypassed entirely. The lookup
# bind receives the same dictionary so the produced schema stays identical
# between scan and re-read.
statement ok
COPY (SELECT 1::int4 AS id, 'pudge col alpha' AS body
      UNION ALL SELECT 2, 'manga col beta')
TO '/tmp/${__DATABASE__}_p_csv_cols.csv' (FORMAT CSV, HEADER FALSE);

statement ok
CREATE VIEW p_csv_cols_v AS
  SELECT * FROM read_csv('/tmp/${__DATABASE__}_p_csv_cols.csv',
                          header=false,
                          columns={'id': 'INTEGER', 'body': 'VARCHAR'});

statement ok
CREATE INDEX p_csv_cols_idx ON p_csv_cols_v
  USING inverted(id, body view_params_en);

query
SELECT id, body FROM p_csv_cols_idx ORDER BY id;
----
id	body
1	pudge col alpha
2	manga col beta


# ============================================================================
# JSON: compression -- materialise NOT supported
# ============================================================================

# CREATE INDEX itself is fine: the streaming reader walks the gzipped JSON
# sequentially. SELECT-time materialise calls JSONReader::FetchRow, which
# does a positional read on the file handle, and gzip streams don't support
# positional reads. We surface the standard "fast-path not supported" error
# so the user sees the same message as for any other unsupported view body.
statement ok
COPY (SELECT 1::int4 AS id, 'pudge gz alpha' AS body
      UNION ALL SELECT 2, 'manga gz beta'
      UNION ALL SELECT 3, 'pudge gz gamma')
TO '/tmp/${__DATABASE__}_p_json_gz.jsonl.gz' (FORMAT JSON, COMPRESSION gzip);

statement ok
CREATE VIEW p_json_gz_v AS
  SELECT * FROM read_json('/tmp/${__DATABASE__}_p_json_gz.jsonl.gz',
                           format='nd', compression='gzip');

statement ok
CREATE INDEX p_json_gz_idx ON p_json_gz_v
  USING inverted(id, body view_params_en);

# Bare-scan goes through the inverted index full-scan (no materialise) and
# works.
query
SELECT count(*) FROM p_json_gz_idx;
----
count
3


query error
SELECT id, body FROM p_json_gz_idx ORDER BY id;


# ============================================================================
# JSON: records=true (objects) vs records=false (top-level values)
# ============================================================================

# records=true is the default for object-shaped lines. Pin it explicitly so
# the bind round-trip is exercised; the previous tests rely on default.
statement ok
COPY (SELECT 1::int4 AS id, 'pudge rec alpha' AS body
      UNION ALL SELECT 2, 'manga rec beta')
TO '/tmp/${__DATABASE__}_p_json_rec.jsonl' (FORMAT JSON);

statement ok
CREATE VIEW p_json_rec_v AS
  SELECT * FROM read_json('/tmp/${__DATABASE__}_p_json_rec.jsonl',
                           format='nd', records='true');

statement ok
CREATE INDEX p_json_rec_idx ON p_json_rec_v
  USING inverted(id, body view_params_en);

query
SELECT id, body FROM p_json_rec_idx ORDER BY id;
----
id	body
1	pudge rec alpha
2	manga rec beta


# ============================================================================
# Parquet: file_row_number is implicitly required
# ============================================================================

# Multiple row groups in one file -- the lookup TF must binary-search the
# correct row group via row_group_starts on every PK; this exercises that
# code path with non-default row_group_size.
statement ok
COPY (SELECT i::int4 AS id, ('pudge rg ' || (i % 5)::VARCHAR) AS body
      FROM range(0, 200) t(i))
TO '/tmp/${__DATABASE__}_p_pq_rg.parquet' (FORMAT PARQUET, ROW_GROUP_SIZE 32);

statement ok
CREATE VIEW p_pq_rg_v AS
  SELECT * FROM read_parquet('/tmp/${__DATABASE__}_p_pq_rg.parquet');

statement ok
CREATE INDEX p_pq_rg_idx ON p_pq_rg_v
  USING inverted(id, body view_params_en);

query
SELECT count(*), min(id), max(id) FROM p_pq_rg_idx;
----
count	min	max
200	0	199

# Spot-check phrase across row-group boundaries.
query
SELECT id FROM p_pq_rg_idx WHERE body @@ ts_phrase('pudge rg 3') ORDER BY id LIMIT 5;
----
id
3
8
13
18
23


# ============================================================================
# Unsupported parameters: clear errors
# ============================================================================

# `auto_detect=false` without `columns=` for read_csv -- DuckDB rejects
# this at bind. The view-body bind, the lookup-rebind, and the planner
# should all surface the same readable error.
statement error
CREATE VIEW p_csv_bogus_v AS
  SELECT * FROM read_csv('/tmp/${__DATABASE__}_p_csv_quote.csv',
                          header=true, no_such_param=true);


# Unknown named arg on read_json.
statement error
CREATE VIEW p_json_bogus_v AS
  SELECT * FROM read_json('/tmp/${__DATABASE__}_p_json_rec.jsonl',
                           format='nd', no_such_param=true);


# Unknown named arg on read_parquet.
statement error
CREATE VIEW p_pq_bogus_v AS
  SELECT * FROM read_parquet('/tmp/${__DATABASE__}_p_pq_rg.parquet',
                              no_such_param=true);
