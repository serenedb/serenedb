control substitution on

hash-threshold 100

# View-backed CREATE INDEX: leaf scan should only read what the index uses.
# EXPLAIN exposes the leaf scan's `Projections:` directly, so each case
# asserts both end-to-end correctness AND the narrowed leaf shape.


# Setup: a wide parquet, used by most cases below.

statement count 5
COPY (SELECT 1 AS id, 'pudge goes mid'     AS body, 'alpha' AS unused1, 100 AS unused2, 'X' AS unused3
      UNION ALL SELECT 2, 'anchin reads manga',     'bravo', 200, 'Y'
      UNION ALL SELECT 3, 'pudge plays again',      'charlie', 300, 'Z'
      UNION ALL SELECT 4, 'manga marathon weekend', 'delta', 400, 'W'
      UNION ALL SELECT 5, 'pudge unique phrase',    'echo', 500, 'V')
TO '${__TEST_DIR__}/view_prune.parquet' (FORMAT PARQUET);

statement ok
CREATE TEXT SEARCH DICTIONARY prune_en(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true
);


# Case 1: wide view, narrow index. Pruning drops unused1/unused2/unused3.

statement ok
CREATE VIEW prune_v1 AS SELECT * FROM read_parquet('${__TEST_DIR__}/view_prune.parquet');

query
EXPLAIN CREATE INDEX prune_idx1 ON prune_v1 USING inverted(body prune_en);
----
QUERY PLAN
╭─ Extension ────────────╮
╰────────────┬───────────╯
╭─ Read Parquet ─────────╮
│ Function: READ_PARQUET │
│ Projections: body      │
│ ~5 rows                │
╰────────────────────────╯

statement ok
CREATE INDEX prune_idx1 ON prune_v1 USING inverted(body prune_en);

query
SELECT count(*) FROM prune_idx1 WHERE body @@ ts_phrase('pudge');
----
count
3

query
SELECT count(*) FROM prune_idx1 WHERE body @@ ts_phrase('unique phrase');
----
count
1


# Case 2: index covers every view column. Pruning is a no-op.

statement ok
CREATE VIEW prune_v2 AS SELECT id, body FROM read_parquet('${__TEST_DIR__}/view_prune.parquet');

query
EXPLAIN CREATE INDEX prune_idx2 ON prune_v2 USING inverted(id, body prune_en);
----
QUERY PLAN
╭─ Extension ────────────╮
╰────────────┬───────────╯
╭─ Read Parquet ─────────╮
│ Function: READ_PARQUET │
│ Projections: id, body  │
│ ~5 rows                │
╰────────────────────────╯

statement ok
CREATE INDEX prune_idx2 ON prune_v2 USING inverted(id, body prune_en);

query
SELECT count(*) FROM prune_idx2 WHERE body @@ ts_phrase('pudge');
----
count
3


# Case 3: view projection has a function on the indexed column; only the
# function's input column flows through to the leaf scan.

statement ok
CREATE VIEW prune_v3 AS
  SELECT id, upper(body) AS body
  FROM read_parquet('${__TEST_DIR__}/view_prune.parquet');

query
EXPLAIN CREATE INDEX prune_idx3 ON prune_v3 USING inverted(body prune_en);
----
QUERY PLAN
╭─ Extension ────────────╮
╰────────────┬───────────╯
╭─ Projection ───────────╮
│ Projections: body      │
│ ~5 rows                │
╰────────────┬───────────╯
╭─ Read Parquet ─────────╮
│ Function: READ_PARQUET │
│ Projections: body      │
│ ~5 rows                │
╰────────────────────────╯

statement ok
CREATE INDEX prune_idx3 ON prune_v3 USING inverted(body prune_en);

# Query phrase is uppercase because the view's projection uppercased it.
query
SELECT count(*) FROM prune_idx3 WHERE body @@ ts_phrase('PUDGE');
----
count
3


# Case 4: ORDER BY in view body. The sort key survives pruning even though
# the index only uses `body`.

statement ok
CREATE VIEW prune_v4 AS
  SELECT id, body, unused1, unused2
  FROM read_parquet('${__TEST_DIR__}/view_prune.parquet')
  ORDER BY id;

query
EXPLAIN CREATE INDEX prune_idx4 ON prune_v4 USING inverted(body prune_en);
----
QUERY PLAN
╭─ Extension ───────────────────────╮
╰─────────────────┬─────────────────╯
╭─ Order By ──────┴─────────────────╮
│ Order By: read_parquet.id ASC     │
│ ~5 rows                           │
╰─────────────────┬─────────────────╯
╭─ Projection ────┴─────────────────╮
│ Projections: CAST(#0 AS TINYINT), │
│              #1, #2               │
│ ~5 rows                           │
╰─────────────────┬─────────────────╯
╭─ Read Parquet ──┴─────────────────╮
│ Function: READ_PARQUET            │
│ Projections: id, body             │
│ ~5 rows                           │
╰───────────────────────────────────╯

statement ok
CREATE INDEX prune_idx4 ON prune_v4 USING inverted(body prune_en);

query
SELECT count(*) FROM prune_idx4 WHERE body @@ ts_phrase('pudge');
----
count
3


# Case 5: ORDER BY + LIMIT. The sort key `unused1` isn't in the index but
# must survive the prune; `id` is dropped. The planner expands TopN into
# a HASH_JOIN + TOP_N subtree.

statement ok
CREATE VIEW prune_v5 AS
  SELECT id, body, unused1
  FROM read_parquet('${__TEST_DIR__}/view_prune.parquet')
  ORDER BY unused1
  LIMIT 4;

query
EXPLAIN CREATE INDEX prune_idx5 ON prune_v5 USING inverted(body prune_en);
----
QUERY PLAN
╭─ Extension ────────────────────────╮
╰──────────────────┬─────────────────╯
╭─ Order By ───────┴─────────────────╮
│ Order By: read_parquet.unused1 ASC │
│ ~5 rows                            │
╰──────────────────┬─────────────────╯
╭─ Hash Join ──────┴─────────────────╮
│ Join Type: SEMI                    │
│ Conditions:                        │
│ file_index = file_index,           │
│ file_row_number = file_row_number  │
│ ~5 rows                            │
╰──────────────────┬─────────────────╯
                   ├───────────────────────────────────────╮
╭─ Read Parquet ───┴─────────────────╮  ╭─ Top N ──────────┴─────────────────╮
│ Function: READ_PARQUET             │  │ Top: 4                             │
│ Projections: body, unused1         │  │ Order By: read_parquet.unused1 ASC │
│ ~5 rows                            │  │ ~4 rows                            │
╰────────────────────────────────────╯  ╰──────────────────┬─────────────────╯
                                        ╭─ Projection ─────┴─────────────────╮
                                        │ Projections: unused1, file_index,  │
                                        │              file_row_number       │
                                        │ ~5 rows                            │
                                        ╰──────────────────┬─────────────────╯
                                        ╭─ Read Parquet ───┴─────────────────╮
                                        │ Function: READ_PARQUET             │
                                        │ Projections: unused1               │
                                        │ Filters:                           │
                                        │ optional: Dynamic Filter (unused1) │
                                        │ ~5 rows                            │
                                        ╰────────────────────────────────────╯

statement ok
CREATE INDEX prune_idx5 ON prune_v5 USING inverted(body prune_en);

# LIMIT 4 over unused1-sorted rows excludes row 5 ("pudge unique phrase"),
# leaving rows 1 and 3 as the "pudge" matches.
query
SELECT count(*) FROM prune_idx5 WHERE body @@ ts_phrase('pudge');
----
count
2

query
SELECT count(*) FROM prune_idx5 WHERE body @@ ts_phrase('unique phrase');
----
count
0


# Case 6: single-column inverted index on a view over a base table.
# The view's surrogate PK is the base table's real PK.

statement ok
CREATE TABLE prune_base (
  id INTEGER PRIMARY KEY,
  body TEXT NOT NULL,
  unused1 TEXT NOT NULL,
  unused2 INTEGER NOT NULL
);

statement ok
INSERT INTO prune_base VALUES
  (1, 'pudge goes mid', 'alpha', 100),
  (2, 'anchin reads manga', 'bravo', 200),
  (3, 'pudge plays again', 'charlie', 300);

statement ok
CREATE VIEW prune_v6 AS SELECT * FROM prune_base;

query
EXPLAIN CREATE INDEX prune_idx6 ON prune_v6 USING inverted(body);
----
QUERY PLAN
╭─ Extension ───────────╮
╰───────────┬───────────╯
╭─ Seq Scan ┴───────────╮
│ Table: prune_base     │
│ Type: Sequential Scan │
│ Projections: body     │
│ ~3 rows               │
╰───────────────────────╯

statement ok
CREATE INDEX prune_idx6 ON prune_v6 USING inverted(body);

query
SELECT count(*) FROM prune_v6 WHERE body = 'pudge goes mid';
----
count
1


# Case 7: composite inverted index on view over a base table.

statement ok
CREATE VIEW prune_v7 AS SELECT * FROM prune_base;

# `id` appears twice in projections: once as an index key, once as PK plumbing.
query
EXPLAIN CREATE INDEX prune_idx7 ON prune_v7 USING inverted(id, body);
----
QUERY PLAN
╭─ Extension ───────────╮
╰───────────┬───────────╯
╭─ Seq Scan ┴───────────╮
│ Table: prune_base     │
│ Type: Sequential Scan │
│ Projections: id, body │
│ ~3 rows               │
╰───────────────────────╯

statement ok
CREATE INDEX prune_idx7 ON prune_v7 USING inverted(id, body);

query
SELECT count(*) FROM prune_v7 WHERE id = 3 AND body = 'pudge plays again';
----
count
1


# Case 8: inverted index on a view over read_parquet. The surrogate PK
# (file_row_number) is a virtual column that doesn't surface in Projections.

statement ok
CREATE VIEW prune_v8 AS SELECT * FROM read_parquet('${__TEST_DIR__}/view_prune.parquet');

query
EXPLAIN CREATE INDEX prune_idx8 ON prune_v8 USING inverted(body);
----
QUERY PLAN
╭─ Extension ────────────╮
╰────────────┬───────────╯
╭─ Read Parquet ─────────╮
│ Function: READ_PARQUET │
│ Projections: body      │
│ ~5 rows                │
╰────────────────────────╯

statement ok
CREATE INDEX prune_idx8 ON prune_v8 USING inverted(body);

query
SELECT count(*) FROM prune_v8 WHERE body = 'pudge goes mid';
----
count
1


# Case 9: scalar indexed expression on a view (lower(body)) with INCLUDE
# covering every view column.

statement ok
CREATE VIEW prune_v9 AS
  SELECT * FROM read_parquet('${__TEST_DIR__}/view_prune.parquet');

statement ok
CREATE INDEX prune_idx9 ON prune_v9 USING inverted(
    (lower(body)) prune_en)
INCLUDE (id, body, unused1, unused2, unused3);

query
SELECT count(*) FROM prune_idx9 WHERE lower(body) @@ ts_phrase('pudge');
----
count
3


# Case 10: LIST<VARCHAR> indexed expression on a view
# (regexp_split_to_array(lower(body), '[^a-z0-9]+')) with INCLUDE on every
# view column. Each split token is indexed.

statement ok
CREATE TEXT SEARCH DICTIONARY prune_kw(template = 'keyword');

statement ok
CREATE VIEW prune_v10 AS
  SELECT * FROM read_parquet('${__TEST_DIR__}/view_prune.parquet');

statement ok
CREATE INDEX prune_idx10 ON prune_v10 USING inverted(
    (regexp_split_to_array(lower(body), '[^a-z0-9]+')) prune_kw)
INCLUDE (id, body, unused1, unused2, unused3);

query
SELECT count(*) FROM prune_idx10
WHERE (regexp_split_to_array(lower(body), '[^a-z0-9]+')) @@ ts_like('pudge');
----
count
3


# Case 11: indexed expression on a view with NO INCLUDE clause. `body` is
# referenced only inside the expression -- pruning must keep it alive.

statement ok
CREATE VIEW prune_v11 AS
  SELECT * FROM read_parquet('${__TEST_DIR__}/view_prune.parquet');

statement ok
CREATE INDEX prune_idx11 ON prune_v11 USING inverted(
    (lower(body)) prune_en);

query
SELECT count(*) FROM prune_idx11 WHERE lower(body) @@ ts_phrase('pudge');
----
count
3


# Case 12: view reorders parquet columns so the indexed expression's
# dependent column is NOT at its parquet position.

statement ok
CREATE VIEW prune_v12 AS
  SELECT unused2 AS u2, unused3 AS u3, body AS b, id AS i, unused1 AS u1
  FROM read_parquet('${__TEST_DIR__}/view_prune.parquet');

statement ok
CREATE INDEX prune_idx12 ON prune_v12 USING inverted(
    (lower(b)) prune_en)
INCLUDE (u2, u3, b, i, u1);

query
SELECT count(*) FROM prune_idx12 WHERE lower(b) @@ ts_phrase('pudge');
----
count
3


# Case 13: LIST<VARCHAR> indexed expression on a parquet large enough to
# span multiple chunks (>2048 rows). Each chunk's child Vector must be
# read at its own positions; aliasing across chunks corrupts tokens.

statement count 5000
COPY (SELECT g AS id,
             'word' || (g % 1000) || ' word' || (g % 1000) || ' marker' AS body
      FROM range(0, 5000) AS t(g))
TO '${__TEST_DIR__}/multi_chunk.parquet' (FORMAT PARQUET);

statement ok
CREATE VIEW multi_chunk_v AS
  SELECT id AS Id, body AS Body
  FROM read_parquet('${__TEST_DIR__}/multi_chunk.parquet');

statement ok
CREATE INDEX multi_chunk_idx ON multi_chunk_v USING inverted(
    (regexp_split_to_array(lower(Body), '[^a-z0-9]+')) prune_kw)
INCLUDE (Id, Body);

query
SELECT count(*) FROM multi_chunk_idx
WHERE (regexp_split_to_array(lower(Body), '[^a-z0-9]+')) @@ ts_like('marker');
----
count
5000

query
SELECT count(*) FROM multi_chunk_idx
WHERE (regexp_split_to_array(lower(Body), '[^a-z0-9]+')) @@ ts_like('word0');
----
count
5
