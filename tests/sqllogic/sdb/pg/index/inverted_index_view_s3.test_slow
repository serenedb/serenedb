statement count 3
COPY (SELECT id, who, what FROM company_src WHERE id BETWEEN 4 AND 6)
TO 's3://${MINIO_BUCKET}/${__DATABASE__}_glob_b.csv' (FORMAT csv, HEADER true);

statement count 2
COPY (SELECT id, who, what FROM company_src WHERE id >= 7)
TO 's3://${MINIO_BUCKET}/${__DATABASE__}_glob_c.csv' (FORMAT csv, HEADER true);


statement count 3
COPY (SELECT id,
             CASE WHEN id = 2 THEN NULL ELSE who END AS who,
             what
      FROM company_src WHERE id <= 3)
TO 's3://${MINIO_BUCKET}/${__DATABASE__}_glob_a.jsonl' (FORMAT json);

statement count 3
COPY (SELECT id,
             who,
             CASE WHEN id = 5 THEN NULL ELSE what END AS what
      FROM company_src WHERE id BETWEEN 4 AND 6)
TO 's3://${MINIO_BUCKET}/${__DATABASE__}_glob_b.jsonl' (FORMAT json);

statement count 2
COPY (SELECT id,
             CASE WHEN id = 8 THEN NULL ELSE who END AS who,
             CASE WHEN id = 7 THEN NULL ELSE what END AS what
      FROM company_src WHERE id >= 7)
TO 's3://${MINIO_BUCKET}/${__DATABASE__}_glob_c.jsonl' (FORMAT json);




statement count 8
COPY company_src
