hash-threshold 100

# ---------------------------------------------------------------------------
# WAND top-k combined with a `.col` table filter.
#
# When a top-k scored query (single ORDER BY key) also carries a pushed-down
# INCLUDE-column filter, the scan stays in WAND top-k mode (`Top: k, optimized`)
# and wraps the WAND iterator in a TableFilterDocIterator. The collector then
# drives the WAND iterator through EmitScoredDocs over the filtered survivors:
#   * single Term  -> SingleWandIterator::EmitScoredDocs
#   * ByTerms      -> MaxScoreIterator::EmitScoredDocs (disjunction / WAND)
# Both must self-position from a fresh iterator (no external advance() prime).
# ---------------------------------------------------------------------------

statement ok
CREATE TEXT SEARCH DICTIONARY en_wtf(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true,
    norm = true
);


statement ok
CREATE TABLE wtf (id INTEGER PRIMARY KEY, n INTEGER, body VARCHAR);


# doc length grows with id, so bm25('term') is strictly higher for shorter
# docs; 'rare' (df=2) dominates the disjunction ranking.
statement ok
INSERT INTO wtf VALUES
  (1, 10, 'term'),
  (2, 20, 'term fill'),
  (3, 30, 'term fill fill'),
  (4, 40, 'term fill fill fill rare'),
  (5, 50, 'term fill fill fill fill rare');


statement ok
CREATE INDEX wtf_idx ON wtf USING inverted(body en_wtf) INCLUDE (n)
  WITH (optimize_top_k = 'bm25(1.2, 0.75)');


statement ok
VACUUM (REFRESH_TABLE) wtf;


# --- Case 1: single Term (SingleWandIterator) + `.col` filter + top-k --------

query
EXPLAIN SELECT n FROM wtf_idx WHERE body @@ ts_phrase('term') AND n > 20 ORDER BY BM25(wtf_idx.tableoid) DESC LIMIT 2;
----
QUERY PLAN
╭─ TOP_N ────────────────────────────────╮
│ Top: 2                                 │
│ Order By: #1 DESC                      │
│ ~1 row                                 │
╰────────────────────┬───────────────────╯
╭─ IRESEARCH_SCAN ───┴───────────────────╮
│ Index: wtf_idx                         │
│ Index Filter:                          │
│ ╭─ Term ──────────────╮                │
│ │ Field: body(string) │                │
│ │ Value: term         │                │
│ ╰─────────────────────╯                │
│ Column Filter: n > 20                  │
│ Score: bm25(k1=1.2, b=0.75)            │
│ Top: 2, optimized                      │
│ Projections: n,                        │
│              sdb_inverted_index_score  │
│ ~1 row                                 │
╰────────────────────────────────────────╯


query
SELECT n FROM wtf_idx WHERE body @@ ts_phrase('term') AND n > 20 ORDER BY BM25(wtf_idx.tableoid) DESC LIMIT 2;
----
n
30
40


# --- Case 2: ByTerms disjunction (MaxScoreIterator) + `.col` filter + top-k --

query
EXPLAIN SELECT n FROM wtf_idx WHERE body @@ ts_any(['term', 'rare']) AND n > 20 ORDER BY BM25(wtf_idx.tableoid) DESC LIMIT 2;
----
QUERY PLAN
╭─ TOP_N ────────────────────────────────╮
│ Top: 2                                 │
│ Order By: #1 DESC                      │
│ ~1 row                                 │
╰────────────────────┬───────────────────╯
╭─ IRESEARCH_SCAN ───┴───────────────────╮
│ Index: wtf_idx                         │
│ Index Filter:                          │
│ ╭─ Terms ────────────────╮             │
│ │ Field: body(string)    │             │
│ │ Values: 'rare', 'term' │             │
│ │ Min Match: 1           │             │
│ ╰────────────────────────╯             │
│ Column Filter: n > 20                  │
│ Score: bm25(k1=1.2, b=0.75)            │
│ Top: 2, optimized                      │
│ Projections: n,                        │
│              sdb_inverted_index_score  │
│ ~1 row                                 │
╰────────────────────────────────────────╯


query
SELECT n FROM wtf_idx WHERE body @@ ts_any(['term', 'rare']) AND n > 20 ORDER BY BM25(wtf_idx.tableoid) DESC LIMIT 2;
----
n
40
50


statement ok
DROP TABLE wtf;
