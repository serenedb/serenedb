statement ok
CREATE TABLE test_levenshtein (a INTEGER PRIMARY KEY, b VARCHAR);

statement ok
CREATE TEXT SEARCH DICTIONARY test_english(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'lower',
    stemming = false,
    accent = false
);

statement ok
CREATE INDEX test_levenshtein_idx ON test_levenshtein USING inverted(a, b test_english);

statement ok
INSERT INTO test_levenshtein values (1, 'cat');

statement ok
INSERT INTO test_levenshtein values (2, 'bat');

statement ok
INSERT INTO test_levenshtein values (3, 'car');

statement ok
INSERT INTO test_levenshtein values (4, 'dog');

statement ok
INSERT INTO test_levenshtein values (5, 'cats');

statement ok
INSERT INTO test_levenshtein values (6, 'act');

statement ok
VACUUM (UPDATE_INDEXES) test_levenshtein;

# Exact match (distance 0)
query
SELECT a FROM test_levenshtein_idx WHERE LEVENSHTEIN_MATCH(b, 'cat', 0) ORDER BY a;
----
a
1

# Distance 1: cat, bat (substitution), car (substitution), cats (insertion), act (transposition with default transpositions=true)
query
SELECT a FROM test_levenshtein_idx WHERE LEVENSHTEIN_MATCH(b, 'cat', 1) ORDER BY a;
----
a
1
2
3
5
6

# Distance 1 without transpositions: act is distance 2 (not a single transposition)
query
SELECT a FROM test_levenshtein_idx WHERE LEVENSHTEIN_MATCH(b, 'cat', 1, false) ORDER BY a;
----
a
1
2
3
5

# Distance 2 matches more
query
SELECT a FROM test_levenshtein_idx WHERE LEVENSHTEIN_MATCH(b, 'cat', 2) ORDER BY a;
----
a
1
2
3
5
6

# With maxTerms parameter
query
SELECT a FROM test_levenshtein_idx WHERE LEVENSHTEIN_MATCH(b, 'cat', 1, true, 128) ORDER BY a;
----
a
1
2
3
5
6

# With prefix parameter: search prefix 'ca' + edit distance on remainder
query
SELECT a FROM test_levenshtein_idx WHERE LEVENSHTEIN_MATCH(b, 't', 1, true, 64, 'ca') ORDER BY a;
----
a
1
3
5

# NOT LEVENSHTEIN_MATCH
query
SELECT a FROM test_levenshtein_idx WHERE NOT LEVENSHTEIN_MATCH(b, 'cat', 0) ORDER BY a;
----
a
2
3
4
5
6

# Distance too high (> 4)
statement error
SELECT a FROM test_levenshtein_idx WHERE LEVENSHTEIN_MATCH(b, 'cat', 5);

# Distance too high for transpositions (> 3)
statement error
SELECT a FROM test_levenshtein_idx WHERE LEVENSHTEIN_MATCH(b, 'cat', 4, true);

# Combined with AND
query
SELECT a FROM test_levenshtein_idx WHERE LEVENSHTEIN_MATCH(b, 'cat', 1) AND a < 4 ORDER BY a;
----
a
1
2
3

statement ok
DROP TABLE test_levenshtein;
