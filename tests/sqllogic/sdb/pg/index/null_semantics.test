# ---- Regression: a LazySeek probe that commits an exclusion's include
# iterator must not make the enclosing block-disjunction's window refill
# skip that doc (row 3: kw NULL, num 9 was dropped). Corpus is the fuzz
# seed-12345 distribution; the drop needs this doc layout.
statement ok
CREATE TABLE nsx(id INTEGER PRIMARY KEY, kw VARCHAR, num INTEGER,
                 pad VARCHAR NOT NULL)

statement ok
CREATE INDEX nsx_idx ON nsx USING inverted(id, kw ns_kw, num, pad ns_kw)
    WITH (refresh_interval = 0, compaction_interval = 0)

