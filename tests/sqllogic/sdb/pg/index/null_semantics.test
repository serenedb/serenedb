│ ╰─────────╯      │
│ Projections: id  │
│ ~0 rows          │
╰──────────────────╯


# ---- Degenerate negated match: '' tokenizes to nothing, so `body @@ ''`
# is FALSE on every non-NULL body and UNKNOWN on NULL body (PG: NULL @@ q
# is NULL); its negation returns exactly the non-NULL body rows.
query I
SELECT id FROM ns_idx WHERE NOT (body @@ '') ORDER BY id
----
id
1
3

query
EXPLAIN SELECT id FROM ns_idx WHERE NOT (body @@ '')
----
