hash-threshold 100

# SQL three-valued logic over claimed filters: a NULL row satisfies no
# comparison, and a bare irs::Not runs against ALL live docs and would
# readmit it. The claim loop hoists the rejection to the conjunction level:
# one IS-NOT-NULL guard conjunct per negated column, elided when a positive
# sibling conjunct on the same column already rejects NULL rows; negations
# under a disjunction keep a local null exclusion instead (the guard would
# not be sound there). IS [NOT] NULL claims directly against the null-marker
# term. IS DISTINCT FROM keeps NULL rows by definition. Every index result
# is pinned against the base-table oracle above it. Range comparisons absorb
# negation by operator inversion (postings-only, null-safe by construction).

statement ok
CREATE TEXT SEARCH DICTIONARY ns_kw(template = 'keyword')

statement ok
CREATE TEXT SEARCH DICTIONARY ns_tx(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'lower',
    frequency = true,
    position = true
)

statement ok
CREATE TABLE ns(id INTEGER PRIMARY KEY, scope VARCHAR, body VARCHAR,
                pad VARCHAR NOT NULL)

statement ok
CREATE INDEX ns_idx ON ns USING inverted(scope ns_kw, body ns_tx, pad ns_kw)
    WITH (refresh_interval = 0, compaction_interval = 0)

statement ok
INSERT INTO ns VALUES
  (1, 'a',  'red blue', 'p'),
  (2, NULL, NULL,       'p'),
  (3, 'y',  'red',      'p')

statement ok
VACUUM (REFRESH_TABLE) ns;

query I
SELECT id FROM ns WHERE scope != 'y' ORDER BY id
----
id
1

query I
SELECT id FROM ns_idx WHERE scope != 'y' ORDER BY id
----
id
1

query
EXPLAIN SELECT id FROM ns_idx WHERE scope != 'y'
----
QUERY PLAN
╭─ IRESEARCH_SCAN ─────────────────────────────────╮
│ Index: ns_idx                                    │
│ Lookup: table                                    │
│ Index Filter:                                    │
│ ╭─ Not ────────────────╮                         │
│ ╰───────────┬──────────╯                         │
│             ├────────────────────────╮           │
│ ╭─ Term ────┴──────────╮  ╭─ Term ───┴─────────╮ │
│ │ Field: scope(string) │  │ Field: scope(null) │ │
│ │ Value: y             │  │ Value:             │ │
│ ╰──────────────────────╯  ╰────────────────────╯ │
│ Projections: id                                  │
│ ~1 row                                           │
╰──────────────────────────────────────────────────╯

