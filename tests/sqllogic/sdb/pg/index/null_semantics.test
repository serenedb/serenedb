# ---- NOT IN with a NULL list element is never TRUE: the implicit
# `col != NULL` conjunct is UNKNOWN on every row, so the claim is Empty.
query I
SELECT id FROM ns WHERE scope NOT IN ('y', 'z', NULL) ORDER BY id
----
id

query I
SELECT id FROM ns_idx WHERE scope NOT IN ('y', 'z', NULL) ORDER BY id
