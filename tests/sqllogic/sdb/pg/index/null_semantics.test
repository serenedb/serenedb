# A NOT NULL column has no null-marker to exclude: negations stay plain
# acceptor shapes, and IS [NOT] NULL declines the claim (row filter over the
# scan, correctly empty / all rows).
query I
SELECT id FROM ns_idx WHERE pad IS NULL ORDER BY id
----
id

query I
SELECT id FROM ns_idx WHERE pad IS NOT NULL ORDER BY id
----
id
1
2
