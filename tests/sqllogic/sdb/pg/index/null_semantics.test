# ---- Negated strict disjunction over an indexed EXPRESSION collects the
# expression's own null marker (raw itself is not indexed; lower(raw) is).
statement ok
CREATE TABLE nse(id INTEGER PRIMARY KEY, raw VARCHAR)

statement ok
CREATE INDEX nse_idx ON nse USING inverted(id, (lower(raw)) ns_kw)
    WITH (refresh_interval = 0, compaction_interval = 0)

statement ok
INSERT INTO nse VALUES (1, 'A'), (2, NULL), (3, 'C')

statement ok
VACUUM (REFRESH_TABLE) nse

query I
SELECT id FROM nse WHERE NOT (lower(raw) = 'a' OR lower(raw) = 'b')
ORDER BY id
----
id
3

query I
SELECT id FROM nse_idx WHERE NOT (lower(raw) = 'a' OR lower(raw) = 'b')
ORDER BY id
----
id
3

