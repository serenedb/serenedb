# Extract a context window around the first search hit using byte offsets.
# bo[1] and bo[2] are the 0-based start/end bytes of the first match; SUBSTRING
# is 1-based, so the window start is GREATEST(1, bo[1] + 1 - window) which
# simplifies to GREATEST(1, bo[1] - 3) for window=4.
query
SELECT id, SUBSTRING(body, GREATEST(1, bo[1] - 3), bo[2] - bo[1] + 8) AS context, bo
FROM (
  SELECT id, body, ts_offsets(body, 1) AS bo
  FROM offsets_test_idx
  WHERE body @@ ts_phrase('fox')
) sub
ORDER BY id;
----
id	context	bo
1	ick fox jum	{6,9}
2	fox runs fa	{0,3}
4	fox fox fox	{0,3}


# OFFSETS combined with top-K scoring (ORDER BY BM25 + LIMIT). This path was
# previously rejected by an SDB_ASSERT in the score_top_k branch; it now goes
# through WriteTopkOffsets, which walks the pagination slice in (segment,
# doc) order via WalkSegmentsSorted and writes byte ranges at each row's
# score-rank slot.

# Basic top-K + OFFSETS: ranks docs by BM25 over 'fox' and emits per-doc
# match offsets. Tie-break by id for determinism.
query
SELECT id, ts_offsets(body) AS bo
FROM offsets_test_idx
WHERE body @@ ts_phrase('fox')
ORDER BY BM25(offsets_test_idx.tableoid) DESC, id LIMIT 3;
----
id	bo
4	{0,3,4,7,8,11,12,15,16,19,20,23,24,27,28,31,32,35,36,39,40,43,44,47}
1	{6,9}
2	{0,3}


# Top-K + OFFSETS, has_real=false (no real columns selected -- the output
# is purely virtual: only OFFSETS and ranking). Exercises the WriteTopkOffsets
# path without the Materialize step.
query
SELECT ts_offsets(body) AS bo
FROM offsets_test_idx
WHERE body @@ ts_phrase('fox')
ORDER BY BM25(offsets_test_idx.tableoid) DESC LIMIT 3;
----
bo
{0,3,4,7,8,11,12,15,16,19,20,23,24,27,28,31,32,35,36,39,40,43,44,47}
{6,9}
{0,3}


# Top-K + OFFSETS with LIMIT 1 -- smallest pagination slice.
query
SELECT id, ts_offsets(body) AS bo
FROM offsets_test_idx
WHERE body @@ ts_phrase('fox')
ORDER BY BM25(offsets_test_idx.tableoid) DESC, id LIMIT 1;
----
id	bo
4	{0,3,4,7,8,11,12,15,16,19,20,23,24,27,28,31,32,35,36,39,40,43,44,47}


# Top-K + multi-field OFFSETS. Both title and body have offset-enabled
# dicts; each row gets two ListVector entries.
query
SELECT id, ts_offsets(title) AS t, ts_offsets(body) AS bo
FROM offsets_test_idx
WHERE title @@ ts_phrase('hello') AND body @@ ts_phrase('fox')
ORDER BY BM25(offsets_test_idx.tableoid) DESC, id LIMIT 5;
----
id	t	bo
1	{0,5}	{6,9}
2	{0,5}	{0,3}


# Top-K + OFFSETS with `ts_offsets(col, N)` cap. The N applies per row's
# byte-range list, not to the top-K K.
query
SELECT id, ts_offsets(body, 3) AS bo
FROM offsets_test_idx
WHERE body @@ ts_phrase('fox')
ORDER BY BM25(offsets_test_idx.tableoid) DESC, id LIMIT 3;
----
id	bo
4	{0,3,4,7,8,11}
1	{6,9}
2	{0,3}


# Top-K + OFFSETS over an aggregation -- count(*) of the top-K result set.
# The wrapper subquery materialises the top-K + OFFSETS rows; count counts
# them. Verifies the subquery delivers the right number of rows.
query
SELECT count(*) FROM (
  SELECT ts_offsets(body) FROM offsets_test_idx
  WHERE body @@ ts_phrase('fox')
  ORDER BY BM25(offsets_test_idx.tableoid) DESC LIMIT 2
) sub;
----
count
2


# Top-K + OFFSETS where K exceeds the number of matches. Engine returns all
# matches (no padding/truncation).
query
SELECT id, ts_offsets(body) AS bo
FROM offsets_test_idx
WHERE body @@ ts_phrase('fox')
ORDER BY BM25(offsets_test_idx.tableoid) DESC, id LIMIT 100;
----
id	bo
4	{0,3,4,7,8,11,12,15,16,19,20,23,24,27,28,31,32,35,36,39,40,43,44,47}
1	{6,9}
2	{0,3}


# Top-K + OFFSETS with a BM25-in-expression in SELECT (and bare BM25 in
# ORDER BY). DuckDB inserts an intermediate projection above TopN to
# materialise the ORDER BY value, which used to misalign ts_offsets()'s
# column ref against the GET.
query
SELECT id, ts_offsets(body) AS bo, BM25(offsets_test_idx.tableoid) > 0 AS pos
FROM offsets_test_idx
WHERE body @@ ts_phrase('fox')
ORDER BY BM25(offsets_test_idx.tableoid) DESC, id LIMIT 3;
----
id	bo	pos
4	{0,3,4,7,8,11,12,15,16,19,20,23,24,27,28,31,32,35,36,39,40,43,44,47}	t
1	{6,9}	t
2	{0,3}	t


# Same intermediate-projection shape with BM25 wrapped in a cast.
query
SELECT id, ts_offsets(body) AS bo,
       round(BM25(offsets_test_idx.tableoid)::numeric, 2) AS s
FROM offsets_test_idx
WHERE body @@ ts_phrase('fox')
ORDER BY BM25(offsets_test_idx.tableoid) DESC, id LIMIT 3;
----
id	bo	s
4	{0,3,4,7,8,11,12,15,16,19,20,23,24,27,28,31,32,35,36,39,40,43,44,47}	0.76
1	{6,9}	0.53
2	{0,3}	0.53


# Plan check: secondary ORDER BY (id ASC) keeps the TopN node, producing
# the PROJECTION -> TOP_N -> PROJECTION -> IRESEARCH_SCAN shape. The
# inner projection forwards the offsets virtual column up to the outer.
query
EXPLAIN SELECT id, ts_offsets(body) AS bo,
              BM25(offsets_test_idx.tableoid) > 0 AS pos
FROM offsets_test_idx
WHERE body @@ ts_phrase('fox')
ORDER BY BM25(offsets_test_idx.tableoid) DESC, id LIMIT 3;
----
