statement ok
CREATE TABLE offsets_test (id INTEGER PRIMARY KEY, title VARCHAR, body VARCHAR, wordcount INTEGER);

statement ok
CREATE TEXT SEARCH DICTIONARY offsets_en(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true,
    offset = true
);

statement ok
CREATE INDEX offsets_test_idx ON offsets_test
    USING inverted(title offsets_en, body offsets_en, wordcount);

statement ok
INSERT INTO offsets_test VALUES (1, 'hello world', 'quick fox jumps', 3);

statement ok
INSERT INTO offsets_test VALUES (2, 'hello again', 'fox runs fast', 3);

statement ok
INSERT INTO offsets_test VALUES (3, 'world peace', 'quick cat jumps', 3);

statement ok
INSERT INTO offsets_test VALUES (4, 'good day', 'fox fox fox fox fox fox fox fox fox fox fox fox', 12);

statement ok
VACUUM (UPDATE_INDEXES) offsets_test;

statement ok
CREATE TABLE offsets_test2 (id INTEGER PRIMARY KEY, body VARCHAR);

statement ok
CREATE INDEX offsets_test2_idx ON offsets_test2 USING inverted(id, body offsets_en);

statement ok
INSERT INTO offsets_test2 VALUES (1, 'fox'), (2, 'cat');

statement ok
VACUUM (UPDATE_INDEXES) offsets_test2;

query
SELECT id, OFFSETS(body) AS bo
FROM offsets_test_idx
WHERE PHRASE(body, 'fox')
ORDER BY id;
----
id	bo
1	{6,9}
2	{0,3}
4	{0,3,4,7,8,11,12,15,16,19,20,23,24,27,28,31,32,35,36,39}

query
SELECT id, OFFSETS(offsets_test_idx.body) AS bo
FROM offsets_test_idx
WHERE PHRASE(body, 'fox')
ORDER BY id;
----
id	bo
1	{6,9}
2	{0,3}
4	{0,3,4,7,8,11,12,15,16,19,20,23,24,27,28,31,32,35,36,39}



query
SELECT id, OFFSETS(title) AS to_, OFFSETS(body) AS bo
FROM offsets_test_idx
WHERE PHRASE(title, 'hello') AND PHRASE(body, 'fox')
ORDER BY id;
----
id	to_	bo
1	{0,5}	{6,9}
2	{0,5}	{0,3}


query
SELECT id, OFFSETS(body, 0) AS bo
FROM offsets_test_idx
WHERE TERM_EQ(body, 'fox')
ORDER BY id;
----
id	bo
1	{6,9}
2	{0,3}
4	{0,3,4,7,8,11,12,15,16,19,20,23,24,27,28,31,32,35,36,39,40,43,44,47}


query
SELECT id, OFFSETS(body) AS bo
FROM offsets_test_idx
WHERE TERM_IN(body, 'fox', 'quick')
ORDER BY id;
----
id	bo
1	{0,5,6,9}
2	{0,3}
3	{0,5}
4	{0,3,4,7,8,11,12,15,16,19,20,23,24,27,28,31,32,35,36,39}


query
SELECT id, OFFSETS(body) AS bo
FROM offsets_test_idx
WHERE PHRASE(body, 'fox') AND PHRASE(body, 'quick')
ORDER BY id;
----
id	bo
1	{0,5,6,9}

query
SELECT id, OFFSETS(title) AS to_
FROM offsets_test_idx
WHERE PHRASE(title, 'hello') OR PHRASE(title, 'world')
ORDER BY id;
----
id	to_
1	{0,5,6,11}
2	{0,5}
3	{0,5}

query
