# Plan check: ORDER BY BM25 DESC alone -- top-K pull-up drops the TopN,
# leaving a single PROJECTION above the scan even with BM25-in-expression.
query
EXPLAIN SELECT id, ts_offsets(body) AS bo,
              BM25(offsets_test_idx.tableoid) > 0 AS pos
FROM offsets_test_idx
WHERE body @@ ts_phrase('fox')
ORDER BY BM25(offsets_test_idx.tableoid) DESC LIMIT 3;
