query
SELECT id, array_length(OFFSETS(body, 0), 1) AS num_offsets
FROM offsets_test_idx
WHERE PHRASE(body, 'fox') AND id = 4;
----
id	num_offsets
4	24

query
SELECT id, OFFSETS(body, 2) AS bo
