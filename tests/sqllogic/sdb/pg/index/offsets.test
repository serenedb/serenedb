# Two sub-queries on the same index: first branch requests two offsets columns
# (title + body), second branch requests one (body only). Verifies that each
# DataSource receives only its own filtered and correctly ordered requests.
query
SELECT id, ts_offsets(title) AS title_offs, ts_offsets(body) AS body_offs
FROM offsets_test_idx
WHERE title @@ ts_phrase('hello') AND body @@ ts_phrase('fox')
UNION ALL
SELECT id, NULL::integer[], ts_offsets(body)
FROM offsets_test_idx
WHERE body @@ ts_phrase('quick')
ORDER BY id, title_offs NULLS LAST;
----
id	title_offs	body_offs
1	{0,5}	{6,9}
1	NULL	{0,5}
2	{0,5}	{0,3}
3	NULL	{0,5}


# Same scenario with branches swapped: first branch requests one offsets column
# (body only), second branch requests two (title + body). Verifies correct
# filtering regardless of which branch accumulates requests first.
query
SELECT id, NULL::integer[] AS title_offs, ts_offsets(body) AS body_offs
FROM offsets_test_idx
WHERE body @@ ts_phrase('quick')
UNION ALL
SELECT id, ts_offsets(title), ts_offsets(body)
FROM offsets_test_idx
WHERE title @@ ts_phrase('hello') AND body @@ ts_phrase('fox')
ORDER BY id, title_offs NULLS FIRST;
----
id	title_offs	body_offs
1	NULL	{0,5}
1	{0,5}	{6,9}
2	{0,5}	{0,3}
3	NULL	{0,5}


# Same field in both sub-queries but with different limits. Row id=4 has 12
# fox matches so the limit difference is visible in its output.
query
SELECT id, 2 AS lim, ts_offsets(body, 2) AS body_offs
FROM offsets_test_idx
WHERE body @@ ts_phrase('fox')
UNION ALL
SELECT id, 4, ts_offsets(body, 4)
FROM offsets_test_idx
WHERE body @@ ts_phrase('fox')
ORDER BY id, lim;
----
id	lim	body_offs
1	2	{6,9}
1	4	{6,9}
2	2	{0,3}
2	4	{0,3}
4	2	{0,3,4,7}
4	4	{0,3,4,7,8,11,12,15}


