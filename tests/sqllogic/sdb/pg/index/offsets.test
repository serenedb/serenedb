statement ok
CREATE TABLE offsets_test (id INTEGER PRIMARY KEY, title VARCHAR, body VARCHAR, wordcount INTEGER);

statement ok
CREATE TEXT SEARCH DICTIONARY offsets_en(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true,
    offset = true
);

statement ok
CREATE INDEX offsets_test_idx ON offsets_test
    USING inverted(title offsets_en, body offsets_en, wordcount);

statement ok
INSERT INTO offsets_test VALUES (1, 'hello world', 'quick fox jumps', 3);

statement ok
INSERT INTO offsets_test VALUES (2, 'hello again', 'fox runs fast', 3);

statement ok
INSERT INTO offsets_test VALUES (3, 'world peace', 'quick cat jumps', 3);

statement ok
INSERT INTO offsets_test VALUES (4, 'good day', 'fox fox fox fox fox fox fox fox fox fox fox fox', 12);

statement ok
VACUUM (UPDATE_INDEXES) offsets_test;

statement ok
CREATE TABLE offsets_test2 (id INTEGER PRIMARY KEY, body VARCHAR);

statement ok
CREATE INDEX offsets_test2_idx ON offsets_test2 USING inverted(id, body offsets_en);

statement ok
INSERT INTO offsets_test2 VALUES (1, 'fox'), (2, 'cat');

statement ok
VACUUM (UPDATE_INDEXES) offsets_test2;

query
