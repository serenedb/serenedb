# Opclass name resolution in CREATE INDEX USING inverted.
#
# Built-in opclass names ('hnsw', 'included') are reserved: a text search
# dictionary cannot be created with one of those names, so a bare opclass
# never has to disambiguate between a built-in and a same-named dictionary.
#
# A bare opclass name resolves against the schema's text search dictionaries.
# A built-in opclass must be spelled with the options form 'name (...)'. A
# bare built-in name (no dictionary by that name can exist) surfaces a hint
# pointing at the options form.


# --- Built-in opclass names are reserved for dictionaries ----------------

statement error
CREATE TEXT SEARCH DICTIONARY hnsw(template = 'keyword');
----
db error: ERROR: text search dictionary name "hnsw" is reserved for the built-in 'hnsw' opclass

statement error
CREATE TEXT SEARCH DICTIONARY included(template = 'keyword');
----
db error: ERROR: text search dictionary name "included" is reserved for the built-in 'included' opclass


# --- A bare (non-reserved) dictionary name resolves to the dictionary -----

statement ok
CREATE TEXT SEARCH DICTIONARY verbatim_dict(template = 'keyword');

statement ok
CREATE TABLE dict_col(id INT PRIMARY KEY, s VARCHAR);

statement ok
CREATE INDEX dict_col_idx ON dict_col USING inverted(id, s verbatim_dict);

statement ok
INSERT INTO dict_col VALUES (1, 'foo'), (2, 'bar'), (3, 'foo');

statement ok
VACUUM (REFRESH_TABLE) dict_col;

query
SELECT id FROM dict_col_idx WHERE s = 'foo' ORDER BY id;
----
id
1
3


# Same for an indexed expression.
statement ok
CREATE TABLE dict_expr(id INT PRIMARY KEY, a VARCHAR, b VARCHAR);

statement ok
CREATE INDEX dict_expr_idx ON dict_expr USING inverted(id, (a || b) verbatim_dict);

statement ok
INSERT INTO dict_expr VALUES (1, 'foo', 'bar'), (2, 'baz', 'qux');

statement ok
VACUUM (REFRESH_TABLE) dict_expr;

query
SELECT id FROM dict_expr_idx WHERE a || b = 'foobar';
----
id
1


# --- A bare built-in name has no dictionary -- hint at the options form ---

statement ok
CREATE TABLE hint_col(id INT PRIMARY KEY, s VARCHAR);

statement error
CREATE INDEX hint_hnsw_col_idx ON hint_col USING inverted(id, s hnsw);
----
db error: ERROR: Unknown opclass 'hnsw' on column 's': no text dictionary by that name in schema 'public'
HINT: 'hnsw' is a built-in opclass; use the options form 'hnsw (...)'

statement error
CREATE INDEX hint_inc_col_idx ON hint_col USING inverted(id, s included);
----
db error: ERROR: Unknown opclass 'included' on column 's': no text dictionary by that name in schema 'public'
HINT: 'included' is a built-in opclass; use the options form 'included (...)'

statement ok
CREATE TABLE hint_expr(id INT PRIMARY KEY, a VARCHAR, b VARCHAR);

statement error
CREATE INDEX hint_hnsw_expr_idx ON hint_expr USING inverted(id, (a || b) hnsw);
----
db error: ERROR: Unknown opclass 'hnsw' on column '(a || b)': no text dictionary by that name in schema 'public'
HINT: 'hnsw' is a built-in opclass; use the options form 'hnsw (...)'

statement error
CREATE INDEX hint_inc_expr_idx ON hint_expr USING inverted(id, (a || b) included);
----
db error: ERROR: Unknown opclass 'included' on column '(a || b)': no text dictionary by that name in schema 'public'
HINT: 'included' is a built-in opclass; use the options form 'included (...)'


# --- The options form selects the built-in opclass ------------------------

statement ok
CREATE TABLE parens_hnsw_col(id INT PRIMARY KEY, emb FLOAT[3]);

statement ok
CREATE INDEX parens_hnsw_col_idx ON parens_hnsw_col USING inverted(
    id, emb hnsw(metric = 'l2', m = 8, ef_construction = 16));

statement ok
INSERT INTO parens_hnsw_col VALUES (1, [1, 2, 3]), (2, [10, 10, 10]), (3, [0, 0, 0]);

statement ok
VACUUM (REFRESH_TABLE) parens_hnsw_col;

query
SELECT id FROM parens_hnsw_col_idx ORDER BY emb <-> [1, 2, 3]::FLOAT[3] LIMIT 1;
----
id
1

statement ok
CREATE TABLE parens_inc_col(id INT PRIMARY KEY, s VARCHAR);

statement ok
CREATE INDEX parens_inc_col_idx ON parens_inc_col USING inverted(
    id, s included(compression = 'uncompressed'));

statement ok
INSERT INTO parens_inc_col VALUES (1, 'foo'), (2, 'bar');

statement ok
VACUUM (REFRESH_TABLE) parens_inc_col;

query
SELECT id, s FROM parens_inc_col_idx WHERE id = 1;
----
id	s
1	foo


# Built-in HNSW over an indexed expression.
statement ok
CREATE TABLE parens_hnsw_expr(id INT PRIMARY KEY, x FLOAT, y FLOAT, z FLOAT);

statement ok
CREATE INDEX parens_hnsw_expr_idx ON parens_hnsw_expr USING inverted(
    id, (array_value(x, y, z)) hnsw(metric = 'l2', m = 8, ef_construction = 16));

statement ok
INSERT INTO parens_hnsw_expr VALUES (1, 1, 2, 3), (2, 10, 10, 10);

statement ok
VACUUM (REFRESH_TABLE) parens_hnsw_expr;

query
SELECT id FROM parens_hnsw_expr_idx
ORDER BY array_value(x, y, z) <-> [1, 2, 3]::FLOAT[3] LIMIT 1;
----
id
1


# Built-in 'included' over an indexed expression.
statement ok
CREATE TABLE parens_inc_expr(id INT PRIMARY KEY, a INT, b INT);

statement ok
CREATE INDEX parens_inc_expr_idx ON parens_inc_expr USING inverted(
    id, (a + b) included(compression = 'uncompressed'));

statement ok
INSERT INTO parens_inc_expr VALUES (1, 10, 20), (2, 5, 5);

statement ok
VACUUM (REFRESH_TABLE) parens_inc_expr;

query
SELECT id, a + b AS s FROM parens_inc_expr_idx ORDER BY id;
----
id	s
1	30
2	10


# --- A non-built-in name with the options form is rejected ----------------

statement error
CREATE INDEX bad_parens ON hint_col USING inverted(id, s verbatim_dict(compression = 'zstd'));
----
db error: ERROR: Failed to create index: Unknown built-in opclass 'verbatim_dict' on 's' (known: included, hnsw)


# --- A bare unknown name with no dictionary is rejected -------------------

statement error
CREATE INDEX bad_unknown ON hint_col USING inverted(id, s missing_dict);
----
db error: ERROR: Failed to create index: Unknown opclass 'missing_dict' on column 's': no text dictionary by that name in schema 'public'


# --- ARRAY columns are only indexable as FLOAT[N] with built-in HNSW ------

statement ok
CREATE TABLE arr_int_col(id INT PRIMARY KEY, emb INT[3]);

statement error
CREATE INDEX bad_arr_int_col ON arr_int_col USING inverted(id, emb verbatim_dict);
----
db error: ERROR: Failed to create index: Column 'emb' has unsupported type INTEGER[3]

statement error
CREATE INDEX bad_arr_int_hnsw ON arr_int_col USING inverted(
    id, emb hnsw(metric = 'l2', m = 8, ef_construction = 16));
----
db error: ERROR: Failed to create index: Column 'emb' must be ARRAY(FLOAT, N) to use the 'hnsw' opclass, not INTEGER[3]

statement ok
CREATE TABLE arr_float_col(id INT PRIMARY KEY, emb FLOAT[3]);

statement error
CREATE INDEX bad_arr_float_col ON arr_float_col USING inverted(id, emb verbatim_dict);
----
db error: ERROR: Failed to create index: Column 'emb' has unsupported type FLOAT[3]


# --- An ARRAY-valued expression with a text dict tokenizes per element ----

statement ok
CREATE TABLE arr_expr(id INT PRIMARY KEY, a VARCHAR, b VARCHAR);

statement ok
CREATE INDEX arr_expr_idx ON arr_expr USING inverted(id, (array_value(a, b)) verbatim_dict);

statement ok
INSERT INTO arr_expr VALUES (1, 'foo', 'bar'), (2, 'bar', 'baz');

statement ok
VACUUM (REFRESH_TABLE) arr_expr;

query
SELECT id FROM arr_expr_idx WHERE (array_value(a, b)) @@ ts_like('bar') ORDER BY id;
----
id
1
2
