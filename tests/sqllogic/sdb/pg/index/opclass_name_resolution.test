# Opclass name resolution in CREATE INDEX USING inverted.
#
# A bare opclass name (no parens) on a column or indexed expression is
# resolved against the snapshot's text search dictionaries first. If a
# user-defined dictionary with that name exists, it is used -- even when
# the name collides with a built-in opclass ('ivf', 'included').
#
# With parens, the name must be a built-in opclass; non-built-in names
# with parens error. A bare name that matches a built-in but has no
# user-defined dictionary surfaces a hint about the options form.


# --- dict with a built-in opclass name shadows the built-in --------------

statement ok
CREATE TEXT SEARCH DICTIONARY ivf(template = 'keyword');

statement ok
CREATE TEXT SEARCH DICTIONARY included(template = 'keyword');


# Bare 'ivf' on a column: resolves to the dict, not the built-in IVF.
statement ok
CREATE TABLE shadow_ivf_col(id INT PRIMARY KEY, s VARCHAR);

statement ok
CREATE INDEX shadow_ivf_col_idx ON shadow_ivf_col USING inverted(id, s ivf);

statement ok
INSERT INTO shadow_ivf_col VALUES (1, 'foo'), (2, 'bar'), (3, 'foo');

statement ok
VACUUM (REFRESH_TABLE) shadow_ivf_col;

query
SELECT id FROM shadow_ivf_col_idx WHERE s = 'foo' ORDER BY id;
----
id
1
3


# Bare 'included' on a column: same -- dict wins.
statement ok
CREATE TABLE shadow_inc_col(id INT PRIMARY KEY, s VARCHAR);

statement ok
CREATE INDEX shadow_inc_col_idx ON shadow_inc_col USING inverted(id, s included);

statement ok
INSERT INTO shadow_inc_col VALUES (1, 'foo'), (2, 'bar'), (3, 'foo');

statement ok
VACUUM (REFRESH_TABLE) shadow_inc_col;

query
SELECT id FROM shadow_inc_col_idx WHERE s = 'foo' ORDER BY id;
----
id
1
3


# Bare 'ivf' on an indexed expression: dict wins.
statement ok
CREATE TABLE shadow_ivf_expr(id INT PRIMARY KEY, a VARCHAR, b VARCHAR);

statement ok
CREATE INDEX shadow_ivf_expr_idx ON shadow_ivf_expr USING inverted(
    id, (a || b) ivf);

statement ok
INSERT INTO shadow_ivf_expr VALUES (1, 'foo', 'bar'), (2, 'baz', 'qux');

statement ok
VACUUM (REFRESH_TABLE) shadow_ivf_expr;

query
SELECT id FROM shadow_ivf_expr_idx WHERE a || b = 'foobar';
----
id
1


# Bare 'included' on an indexed expression: dict wins.
statement ok
CREATE TABLE shadow_inc_expr(id INT PRIMARY KEY, a VARCHAR, b VARCHAR);

statement ok
CREATE INDEX shadow_inc_expr_idx ON shadow_inc_expr USING inverted(
    id, (a || b) included);

statement ok
INSERT INTO shadow_inc_expr VALUES (1, 'foo', 'bar'), (2, 'baz', 'qux');

statement ok
VACUUM (REFRESH_TABLE) shadow_inc_expr;

query
SELECT id FROM shadow_inc_expr_idx WHERE a || b = 'foobar';
----
id
1


# --- With parens, the built-in still wins regardless of the dict ---------

# 'ivf (...)' on a vector column: built-in IVF, not the dict named 'ivf'.
statement ok
CREATE TABLE parens_ivf_col(id INT PRIMARY KEY, emb FLOAT[3]);

statement ok
CREATE INDEX parens_ivf_col_idx ON parens_ivf_col USING inverted(
    id, emb ivf(metric = 'l2'));

statement ok
INSERT INTO parens_ivf_col VALUES
    (1, [1, 2, 3]),
    (2, [10, 10, 10]),
    (3, [0, 0, 0]);

statement ok
VACUUM (REFRESH_TABLE) parens_ivf_col;

query
SELECT id FROM parens_ivf_col_idx ORDER BY emb <-> [1, 2, 3]::FLOAT[3] LIMIT 1;
----
id
1


# 'included (...)' on a column: built-in 'included', not the dict named 'included'.
statement ok
CREATE TABLE parens_inc_col(id INT PRIMARY KEY, s VARCHAR);

statement ok
CREATE INDEX parens_inc_col_idx ON parens_inc_col USING inverted(
    id, s included(compression = 'uncompressed'));

statement ok
INSERT INTO parens_inc_col VALUES (1, 'foo'), (2, 'bar');

statement ok
VACUUM (REFRESH_TABLE) parens_inc_col;

query
SELECT id, s FROM parens_inc_col_idx WHERE id = 1;
----
id	s
1	foo


# 'ivf (...)' on an indexed expression: built-in IVF.
statement ok
CREATE TABLE parens_ivf_expr(id INT PRIMARY KEY, x FLOAT, y FLOAT, z FLOAT);

statement ok
CREATE INDEX parens_ivf_expr_idx ON parens_ivf_expr USING inverted(
    id, (array_value(x, y, z)) ivf(metric = 'l2'));

statement ok
INSERT INTO parens_ivf_expr VALUES (1, 1, 2, 3), (2, 10, 10, 10);

statement ok
VACUUM (REFRESH_TABLE) parens_ivf_expr;

query
SELECT id FROM parens_ivf_expr_idx
ORDER BY array_value(x, y, z) <-> [1, 2, 3]::FLOAT[3] LIMIT 1;
----
id
1


# 'included (...)' on an indexed expression: built-in 'included'.
statement ok
CREATE TABLE parens_inc_expr(id INT PRIMARY KEY, a INT, b INT);

statement ok
CREATE INDEX parens_inc_expr_idx ON parens_inc_expr USING inverted(
    id, (a + b) included(compression = 'uncompressed'));

statement ok
INSERT INTO parens_inc_expr VALUES (1, 10, 20), (2, 5, 5);

statement ok
VACUUM (REFRESH_TABLE) parens_inc_expr;

query
SELECT id, a + b AS s FROM parens_inc_expr_idx ORDER BY id;
----
id	s
1	30
2	10


# --- ARRAY: bare 'ivf' resolves to the user text dict, which requires
# VARCHAR/BLOB elements -- it cannot be applied to ARRAY/LIST of numerics.
# Vector search uses the parens form 'ivf(...)' which selects the built-in
# IVF opclass and requires ARRAY(FLOAT, N).

statement ok
CREATE TABLE shadow_ivf_int_arr_col(id INT PRIMARY KEY, emb INT[3]);

statement error
CREATE INDEX shadow_ivf_int_arr_col_idx ON shadow_ivf_int_arr_col USING inverted(
    id, emb ivf);
----
db error: ERROR: Column 'emb' uses a tokenizer; must be VARCHAR, BLOB, or a LIST/ARRAY of VARCHAR/BLOB (got INTEGER[3])


statement ok
CREATE TABLE shadow_ivf_float_arr_col(id INT PRIMARY KEY, emb FLOAT[3]);

statement error
CREATE INDEX shadow_ivf_float_arr_col_idx ON shadow_ivf_float_arr_col USING inverted(
    id, emb ivf);
----
db error: ERROR: Column 'emb' uses a tokenizer; must be VARCHAR, BLOB, or a LIST/ARRAY of VARCHAR/BLOB (got FLOAT[3])


statement ok
CREATE TABLE shadow_ivf_arr_expr(id INT PRIMARY KEY, x FLOAT, y FLOAT, z FLOAT);

statement error
CREATE INDEX shadow_ivf_arr_expr_idx ON shadow_ivf_arr_expr USING inverted(
    id, (array_value(x, y, z)) ivf);
----
db error: ERROR: Column 'array_value(x, y, z)' uses a tokenizer; must be VARCHAR, BLOB, or a LIST/ARRAY of VARCHAR/BLOB (got FLOAT[3])


# The parens form selects the built-in IVF even with the shadowing dict
# in scope -- this is the supported escape hatch. INT[3] still fails at
# validation because IVF requires ARRAY(FLOAT, N).
statement ok
CREATE INDEX good_shadow_ivf_float_arr_col_idx ON shadow_ivf_float_arr_col USING inverted(
    id, emb ivf(metric = 'l2'));

statement error
CREATE INDEX bad_shadow_ivf_int_arr_with_opts_idx ON shadow_ivf_int_arr_col USING inverted(
    id, emb ivf(metric = 'l2'));
----
db error: ERROR: Column 'emb' must be ARRAY(FLOAT, N) to use the 'ivf' opclass, not INTEGER[3]


# --- No dict with a built-in name: bare use surfaces the options hint ----

# Fresh schema with no 'ivf' / 'included' dicts in scope.
statement ok
CREATE SCHEMA hint_only;

statement ok
SET search_path TO hint_only;


# Bare 'ivf' on a column with no dict by that name in this schema -- hint
# error pointing at the options form.
statement ok
CREATE TABLE hint_ivf_col(id INT PRIMARY KEY, s VARCHAR);

statement error
CREATE INDEX hint_ivf_col_idx ON hint_ivf_col USING inverted(id, s ivf);
----
db error: ERROR: Unknown opclass 'ivf' on column 's': no text dictionary by that name in schema 'hint_only'
HINT: 'ivf' is a built-in opclass; use the options form 'ivf (...)'


# Bare 'included' on a column with no dict by that name -- same hint shape.
statement error
CREATE INDEX hint_inc_col_idx ON hint_ivf_col USING inverted(id, s included);
----
db error: ERROR: Unknown opclass 'included' on column 's': no text dictionary by that name in schema 'hint_only'
HINT: 'included' is a built-in opclass; use the options form 'included (...)'


# Bare 'ivf' on an indexed expression with no dict -- same hint.
statement ok
CREATE TABLE hint_ivf_expr(id INT PRIMARY KEY, a VARCHAR, b VARCHAR);

statement error
CREATE INDEX hint_ivf_expr_idx ON hint_ivf_expr USING inverted(
    id, (a || b) ivf);
----
db error: ERROR: Unknown opclass 'ivf' on column '(a || b)': no text dictionary by that name in schema 'hint_only'
HINT: 'ivf' is a built-in opclass; use the options form 'ivf (...)'


# Bare 'included' on an indexed expression with no dict in scope -- same
# hint shape as the column path.
statement ok
CREATE TABLE bare_inc_expr(id INT PRIMARY KEY, a INT, b INT);

statement error
CREATE INDEX bare_inc_expr_idx ON bare_inc_expr USING inverted(
    id, (a + b) included);
----
db error: ERROR: Unknown opclass 'included' on column '(a + b)': no text dictionary by that name in schema 'hint_only'
HINT: 'included' is a built-in opclass; use the options form 'included (...)'


# A non-built-in name with parens is rejected regardless of whether a
# dict exists -- the options form is reserved for built-ins.
statement ok
CREATE TEXT SEARCH DICTIONARY hint_only_dict(template = 'keyword');

statement error
CREATE INDEX hint_parens_dict ON hint_ivf_col USING inverted(
    id, s hint_only_dict (compression = 'zstd'));
----
db error: ERROR: Unknown built-in opclass 'hint_only_dict' on 's' (known: included, ivf)


# A non-built-in name with no dict by that name: bare-name lookup misses,
# resulting in the "Unknown opclass" error.
statement error
CREATE INDEX hint_unknown ON hint_ivf_col USING inverted(id, s missing_dict);
----
db error: ERROR: Unknown opclass 'missing_dict' on column 's': no text dictionary by that name in schema 'hint_only'


statement ok
RESET search_path;
