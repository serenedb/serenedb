# Two different scorers on one index cannot share the single score column.
statement error
SELECT bm25(vedernikoff_alias_idx.tableoid) AS s1, tfidf(vedernikoff_alias_idx.tableoid) AS s2
FROM vedernikoff_alias_idx WHERE abramov @@ ts_phrase('clickclack');
----
db error: ERROR: Only one scorer function is allowed per inverted index
HINT: Use UNION to combine different score functions for the same inverted index


# Same scorer, different parameters -- same restriction.
statement error
SELECT bm25(vedernikoff_alias_idx.tableoid) AS s1, bm25(vedernikoff_alias_idx.tableoid, 1.5, 0.6) AS s2
FROM vedernikoff_alias_idx WHERE abramov @@ ts_phrase('clickclack');
----
db error: ERROR: Only one scorer function is allowed per inverted index
HINT: Use UNION to combine different score functions for the same inverted index


# ---- Same shape for ANN: one vector scorer, one score column, two aliases ----

statement ok
CREATE TABLE deadinside (kostya INT, clickclack FLOAT[3]);


statement ok
CREATE INDEX deadinside_alias_idx ON deadinside USING inverted(kostya, clickclack hnsw (metric = 'l2'));


statement count 4
INSERT INTO deadinside VALUES
  (42,  [100, 0, 0]::FLOAT[3]),
  (322, [50, 50, 50]::FLOAT[3]),
  (666, [50, 25, 50]::FLOAT[3]),
  (993, [50, 50, 100]::FLOAT[3]);


statement ok
VACUUM (REFRESH_TABLE) deadinside;


query
EXPLAIN SELECT kostya, clickclack <-> [0.0, 0.0, 0.0]::FLOAT[3] AS d1, clickclack <-> [0.0, 0.0, 0.0]::FLOAT[3] AS d2 FROM deadinside_alias_idx ORDER BY d1 LIMIT 2;
----
