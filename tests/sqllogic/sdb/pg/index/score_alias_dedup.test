hash-threshold 100

# Aliasing the same score call twice (bm25 ... AS s1, bm25 ... AS s2) must not
# duplicate scorers or score columns: the rewrite keeps one scorer + one
# virtual score column on the scan, and each select-list slot gets its own
# column ref carrying its own alias.
#
# Also pins the scan-order hint column check: ORDER BY a non-score column with
# a scorer in the select list must NOT pull the limit into the scan as a
# score top-k (the scan would return top-k by score and starve the real sort).

statement ok
CREATE TABLE vedernikoff (kostya INTEGER PRIMARY KEY, abramov VARCHAR);


statement count 5
INSERT INTO vedernikoff VALUES
  (42,  'androed clickclack arelav'),
  (322, 'deadinside clickclack'),
  (666, 'ksimironov abramov another'),
  (993, 'clickclack deadinside another'),
  (1337, 'clickclack clickclack ksimironov');


statement ok
CREATE TEXT SEARCH DICTIONARY kostya_dict(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true,
    norm = true
);


statement ok
CREATE INDEX vedernikoff_alias_idx ON vedernikoff USING inverted(kostya, abramov kostya_dict);


statement ok
VACUUM (REFRESH_TABLE) vedernikoff;


# One Score: line, one sdb_inverted_index_score projection -- not two.
query
EXPLAIN SELECT kostya, bm25(vedernikoff_alias_idx.tableoid) AS s1, bm25(vedernikoff_alias_idx.tableoid) AS s2 FROM vedernikoff_alias_idx WHERE abramov @@ ts_phrase('clickclack') ORDER BY s1 DESC LIMIT 3;
----
QUERY PLAN
╭─ TOP_N ────────────────────────────────╮
│ Top: 3                                 │
│ Order By: #1 DESC                      │
│ ~1 row                                 │
╰────────────────────┬───────────────────╯
╭─ PROJECTION ───────┴───────────────────╮
│ Projections: kostya, s1, s2            │
│ ~1 row                                 │
╰────────────────────┬───────────────────╯
╭─ IRESEARCH_SCAN ───┴───────────────────╮
│ Index: vedernikoff_alias_idx           │
│ Lookup: table                          │
│ Filter:                                │
│ ╭─ Term ─────────────────╮             │
│ │ Field: abramov(string) │             │
│ │ Value: clickclack      │             │
│ ╰────────────────────────╯             │
│ Score: bm25(k1=1.2, b=0.75)            │
│ Top: 3                                 │
│ Projections: kostya,                   │
│              sdb_inverted_index_score  │
│ ~1 row                                 │
╰────────────────────────────────────────╯


# Both aliases resolve to the same score values.
query
SELECT count(*) FROM (
  SELECT bm25(vedernikoff_alias_idx.tableoid) AS s1, bm25(vedernikoff_alias_idx.tableoid) AS s2
  FROM vedernikoff_alias_idx WHERE abramov @@ ts_phrase('clickclack')
) WHERE s1 <> s2;
----
count
0


# Header names survive the rewrite.
query
SELECT kostya, bm25(vedernikoff_alias_idx.tableoid) > 0 AS s1, bm25(vedernikoff_alias_idx.tableoid) > 0 AS s2
FROM vedernikoff_alias_idx WHERE abramov @@ ts_phrase('clickclack') ORDER BY kostya LIMIT 2;
----
kostya	s1	s2
42	t	t
322	t	t


# ORDER BY a non-score column: the limit must stay in TOP_N, not become a
# score top-k inside the scan. Matches are 42, 322, 993, 1337 -- the two
# largest kostya values win, not the two best-scored docs.
query
SELECT kostya FROM vedernikoff_alias_idx WHERE abramov @@ ts_phrase('clickclack') ORDER BY kostya DESC LIMIT 2;
----
kostya
1337
993


# No "Top:" line inside the scan box here.
query
EXPLAIN SELECT kostya, bm25(vedernikoff_alias_idx.tableoid) AS s1 FROM vedernikoff_alias_idx WHERE abramov @@ ts_phrase('clickclack') ORDER BY kostya DESC LIMIT 2;
