query
SELECT count(*) FROM (
  SELECT clickclack <-> [0.0, 0.0, 0.0]::FLOAT[3] AS d1, clickclack <-> [0.0, 0.0, 0.0]::FLOAT[3] AS d2
  FROM deadinside_alias_idx
) WHERE d1 <> d2;
----
count
0


# ORDER BY a non-score column with a distance call in the select list: all
# rows must reach TOP_N -- the two smallest kostya values win, not the two
# nearest vectors (which would be 666, 322).
query
SELECT kostya, clickclack <-> [0.0, 0.0, 0.0]::FLOAT[3] > 0 AS d1, clickclack <-> [0.0, 0.0, 0.0]::FLOAT[3] > 0 AS d2
FROM deadinside_alias_idx ORDER BY kostya LIMIT 2;
----
kostya	d1	d2
42	t	t
322	t	t


# Legit score top-k still engages: nearest two by distance.
query
SELECT kostya FROM deadinside_alias_idx ORDER BY clickclack <-> [0.0, 0.0, 0.0]::FLOAT[3] LIMIT 2;
----
kostya
666
322


# ---- Multi-key ORDER BY over score ties: the scan must not truncate ----
# All 8 vectors sit at the same L2 distance; with a secondary sort key the
# limit must stay in TOP_N (an in-scan top-k would keep 2 arbitrary ties).

statement ok
CREATE TABLE arelav (kostya INT, emb FLOAT[3]);


statement ok
CREATE INDEX arelav_idx ON arelav USING inverted(kostya, emb hnsw (metric = 'l2'));


statement count 8
INSERT INTO arelav VALUES
  (8, [100, 0, 0]::FLOAT[3]),
  (7, [0, 100, 0]::FLOAT[3]),
  (6, [0, 0, 100]::FLOAT[3]),
  (5, [-100, 0, 0]::FLOAT[3]),
  (4, [0, -100, 0]::FLOAT[3]),
  (3, [0, 0, -100]::FLOAT[3]),
  (2, [60, 80, 0]::FLOAT[3]),
  (1, [0, 60, 80]::FLOAT[3]);


statement ok
VACUUM (REFRESH_TABLE) arelav;


query
SELECT kostya FROM arelav_idx ORDER BY emb <-> [0.0, 0.0, 0.0]::FLOAT[3], kostya LIMIT 2;
----
kostya
1
2


# ---- Shapes from recovery/inverted_index_wand_faults.test, pinned at plan ----
# level: neither may pull the limit into the scan (no "Top:" in the scan box,
# so no WAND top-k engages).

# Scorer wrapped in arithmetic: a derived expression is not a scan order key.
query
SELECT kostya FROM vedernikoff_alias_idx WHERE abramov @@ ts_phrase('clickclack') ORDER BY 2 * bm25(vedernikoff_alias_idx.tableoid) DESC LIMIT 2;
----
kostya
1337
322


