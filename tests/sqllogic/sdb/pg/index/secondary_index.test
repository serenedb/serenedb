CREATE TABLE stockpiler_stash (pid INTEGER PRIMARY KEY, amount BIGINT, active BOOLEAN);

statement ok
CREATE INDEX stockpiler_stash_amount_idx ON stockpiler_stash USING secondary(amount);

statement ok
CREATE INDEX stockpiler_stash_active_idx ON stockpiler_stash USING secondary(active);

statement ok
INSERT INTO stockpiler_stash VALUES
  (1, 1000000000000, true),
  (2, 2000000000000, false),
  (3, 1000000000000, true),
  (4, 3000000000000, false),
  (5, 1000000000000, false);

query
SELECT pid, amount FROM stockpiler_stash WHERE amount = 1000000000000 ORDER BY pid;
----
pid	amount
1	1000000000000
3	1000000000000
5	1000000000000

query
SELECT pid, active FROM stockpiler_stash WHERE active = true ORDER BY pid;
----
pid	active
1	t
3	t

query
SELECT pid, active FROM stockpiler_stash WHERE active = false ORDER BY pid;
----
pid	active
2	f
4	f
5	f

statement ok
UPDATE stockpiler_stash SET active = false WHERE pid = 1;

query
SELECT pid, active FROM stockpiler_stash WHERE active = true;
----
pid	active
