control substitution on

hash-threshold 100

# Plain (secondary) indexes on views are not supported; views are indexed
# with inverted indexes instead. The inverted index is static: DML on the
# source does not refresh it.


statement ok
CREATE TABLE base_sk (id INTEGER PRIMARY KEY, label TEXT, score INTEGER);

statement ok
INSERT INTO base_sk VALUES
  (1, 'alpha', 30),
  (2, 'beta', 25),
  (3, 'gamma', 30),
  (4, 'delta', 35);

statement ok
CREATE VIEW v_sk_star AS SELECT * FROM base_sk;

statement error
CREATE INDEX v_sk_star_idx ON v_sk_star(score);
----
db error: ERROR: plain indexes on views are not supported; use an inverted index instead


statement error
CREATE UNIQUE INDEX v_sk_star_uniq ON v_sk_star(label);
----
db error: ERROR: plain indexes on views are not supported; use an inverted index instead


# The inverted-index replacement covers the same shape: index a view's
# column, scan the index as a table.

statement ok
CREATE INDEX v_sk_star_inv ON v_sk_star USING inverted(score);

query
SELECT id, label, score FROM v_sk_star_inv ORDER BY score, id;
----
id	label	score
2	beta	25
1	alpha	30
3	gamma	30
4	delta	35

query
SELECT id, label FROM v_sk_star_inv WHERE score = 30 ORDER BY id;
----
id	label
1	alpha
3	gamma


# Static-index membership demo: view body is `... ORDER BY x LIMIT 4` so
# the index captures only the lowest-x 4 rows at CREATE INDEX time. After
# the index is built, mutate the ORDER BY key on a captured row so that
# the live view body would now produce a DIFFERENT set of 4 rows -- but
# the index still reflects the pre-update membership (the unindexed 5th
# row is still absent, and the now-bumped row is still present).
statement ok
CREATE TABLE base_sk_static (id INTEGER PRIMARY KEY, x INTEGER, label TEXT);

statement ok
INSERT INTO base_sk_static VALUES
  (1, 10, 'first'),
  (2, 20, 'second'),
  (3, 30, 'third'),
  (4, 40, 'fourth'),
  (5, 50, 'fifth');

statement ok
CREATE VIEW v_static_after_update AS
  SELECT id, x, label FROM base_sk_static ORDER BY x LIMIT 4;

statement ok
CREATE INDEX v_static_after_update_idx
  ON v_static_after_update USING inverted(label);

query
SELECT id, x, label FROM v_static_after_update_idx ORDER BY id;
----
id	x	label
1	10	first
2	20	second
3	30	third
4	40	fourth

# Bump row 4 above row 5 so live view picks rows 1, 2, 3, 5.
statement ok
UPDATE base_sk_static SET x = 999 WHERE id = 4;

query
SELECT id, x FROM v_static_after_update ORDER BY id;
----
id	x
1	10
2	20
3	30
5	50

# Index still holds rows 1..4 -- row 5 was never indexed, row 4 stays.
query
SELECT id FROM v_static_after_update_idx ORDER BY id;
----
id
1
2
3
4


statement ok
DROP TABLE base_sk CASCADE;

statement ok
DROP TABLE base_sk_static CASCADE;
