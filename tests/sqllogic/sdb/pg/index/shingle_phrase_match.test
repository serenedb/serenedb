db error: ERROR: "minshinglesize" must be between 2 and 16


# Phrase planning relies on unigram terms.
statement error
CREATE TEXT SEARCH DICTIONARY shingle_nouni(
    template = 'shingle',
    outputunigrams = false,
    tokenizer_template = 'delimiter',
    tokenizer_delimiter = ' '
);
----
db error: ERROR: "outputunigrams" = false is not supported for shingle dictionaries
HINT: Phrase planning requires the individual tokens to be indexed alongside the shingles.


# A frequent-words entry must normalize to exactly one base-analyzer token.
statement error
CREATE TEXT SEARCH DICTIONARY shingle_badfreq(
    template = 'shingle',
    frequency = true,
    frequentwords = '"of the"',
    tokenizer_template = 'delimiter',
    tokenizer_delimiter = ' '
);
----
db error: ERROR: "frequentwords" entry "of the" splits into multiple tokens under the base analyzer


# A custom filler token (stands in for base-analyzer-removed positions in
# the stored token stream) is accepted and the dictionary works end-to-end.
statement ok
CREATE TEXT SEARCH DICTIONARY shingle_filler(
    template = 'shingle',
    frequency = true,
    fillertoken = '<gap>',
    tokenizer_template = 'delimiter',
    tokenizer_delimiter = ' '
);

statement ok
CREATE TABLE test_shingle_filler (id INTEGER PRIMARY KEY, body VARCHAR);

statement ok
CREATE INDEX test_shingle_filler_idx ON test_shingle_filler USING inverted(id, body shingle_filler);

statement ok
INSERT INTO test_shingle_filler VALUES (1, 'quick brown fox'), (2, 'brown quick fox');

statement ok
VACUUM (REFRESH_TABLE) test_shingle_filler;

query
SELECT id FROM test_shingle_filler_idx WHERE body @@ ts_phrase('quick brown fox') ORDER BY id;
----
id
1

statement ok
DROP TABLE test_shingle_filler;

statement ok
DROP TEXT SEARCH DICTIONARY shingle_filler;

# The shingle term encoding is only unambiguous for UTF-8 content.
statement ok
CREATE TEXT SEARCH DICTIONARY shingle_varchar_only(
    template = 'shingle',
    frequency = true,
    tokenizer_template = 'delimiter',
    tokenizer_delimiter = ' '
);

statement ok
CREATE TABLE test_shingle_blob (id INTEGER PRIMARY KEY, body BLOB);

statement error
CREATE INDEX test_shingle_blob_idx ON test_shingle_blob USING inverted(id, body shingle_varchar_only);
----
db error: ERROR: Column 'body' uses a shingle analyzer; the column must be VARCHAR


statement ok
DROP TABLE test_shingle_blob;

# --- Terms-only dictionary: storetokens=false drops the verification blob ---
# Every phrase up to maxshinglesize stays an exact single-term lookup; longer
# phrases are rejected with an actionable error.
statement ok
CREATE TEXT SEARCH DICTIONARY shingle_terms_only(
    template = 'shingle',
    minshinglesize = 2,
    maxshinglesize = 3,
    frequency = true,
    storetokens = false,
    tokenizer_template = 'delimiter',
    tokenizer_delimiter = ' '
);

statement ok
CREATE TABLE test_shingle_terms (id INTEGER PRIMARY KEY, body VARCHAR);

statement ok
CREATE INDEX test_shingle_terms_idx ON test_shingle_terms USING inverted(id, body shingle_terms_only);

statement ok
INSERT INTO test_shingle_terms VALUES
  (1, 'the quick brown fox jumps'),
  (2, 'quick brown dog'),
  (3, 'brown fox quick');

statement ok
VACUUM (REFRESH_TABLE) test_shingle_terms;

query
SELECT id FROM test_shingle_terms_idx WHERE body @@ ts_phrase('quick brown fox') ORDER BY id;
----
id
1

query
SELECT id FROM test_shingle_terms_idx WHERE body @@ ts_phrase('quick brown') ORDER BY id;
----
id
1
2

statement error
SELECT id FROM test_shingle_terms_idx WHERE body @@ ts_phrase('quick brown fox jumps') ORDER BY id;
----
db error: ERROR: ts_phrase of 4 words needs verification, which this shingle index cannot provide (no positions and no stored values)
HINT: Raise maxshinglesize to cover the phrase, set storetokens=true, store the column values (list the column again with included() in the index), or add position=true to the dictionary.


statement ok
DROP TABLE test_shingle_terms;

# Listing the column again with included() lands the raw values in the index
# columnstore, and longer phrases verify by re-tokenizing them on the fly.
statement ok
CREATE TABLE test_shingle_raw (id INTEGER PRIMARY KEY, body VARCHAR);

statement ok
CREATE INDEX test_shingle_raw_idx ON test_shingle_raw USING inverted(id, body shingle_terms_only, body included());

statement ok
INSERT INTO test_shingle_raw VALUES
  (1, 'the quick brown fox jumps far'),
  (2, 'quick brown fox elsewhere and brown fox jumps later'),
  (3, 'quick brown dog');

statement ok
VACUUM (REFRESH_TABLE) test_shingle_raw;

# Up to maxshinglesize stays an exact single-term lookup.
query
SELECT id FROM test_shingle_raw_idx WHERE body @@ ts_phrase('quick brown fox') ORDER BY id;
----
id
1
2

# A 4-word phrase verifies against the raw stored value: id 2 holds both
# trigrams but not adjacently and is re-tokenized away.
query
SELECT id FROM test_shingle_raw_idx WHERE body @@ ts_phrase('quick brown fox jumps') ORDER BY id;
----
id
1

statement ok
DROP TABLE test_shingle_raw;

# Mention order does not matter: included() before the dictionary merges into
# the same entry. The stored values also serve covering reads.
statement ok
CREATE TABLE test_shingle_raw2 (id INTEGER PRIMARY KEY, body VARCHAR);

statement ok
CREATE INDEX test_shingle_raw2_idx ON test_shingle_raw2 USING inverted(id, body included(), body shingle_terms_only);

statement ok
INSERT INTO test_shingle_raw2 VALUES
  (1, 'the quick brown fox jumps far'),
  (2, 'quick brown fox elsewhere and brown fox jumps later'),
  (3, 'quick brown dog');

statement ok
VACUUM (REFRESH_TABLE) test_shingle_raw2;

query
SELECT id, body FROM test_shingle_raw2_idx WHERE body @@ ts_phrase('quick brown fox jumps') ORDER BY id;
----
id body
1 the quick brown fox jumps far

statement ok
DROP TABLE test_shingle_raw2;

statement ok
DROP TEXT SEARCH DICTIONARY shingle_terms_only;

# --- Norm: BM25 length normalization. The norm and the stored token stream
# share the index's synthetic column, so a position-free norm dictionary
# requires storetokens = false; longer phrases verify via included() raws.
statement error
CREATE TEXT SEARCH DICTIONARY shingle_norm_bad(
    template = 'shingle',
    frequency = true,
    norm = true,
    tokenizer_template = 'delimiter',
    tokenizer_delimiter = ' '
);
----
db error: ERROR: "norm" = true on a position-free shingle dictionary requires "storetokens" = false
HINT: The norm and the stored token stream share the index's synthetic column. Phrases longer than maxshinglesize can still verify against the raw values (list the column again with included() in the index).


statement ok
CREATE TEXT SEARCH DICTIONARY shingle_norm(
    template = 'shingle',
    minshinglesize = 2,
    maxshinglesize = 3,
    frequency = true,
    norm = true,
    storetokens = false,
    tokenizer_template = 'delimiter',
    tokenizer_delimiter = ' '
);

statement ok
CREATE TABLE test_shingle_norm (id INTEGER PRIMARY KEY, body VARCHAR);

statement ok
CREATE INDEX test_shingle_norm_idx ON test_shingle_norm USING inverted(id, body shingle_norm, body included());

statement ok
INSERT INTO test_shingle_norm VALUES
  (1, 'quick brown fox'),
  (2, 'quick brown fox plus many many extra trailing words here making this document much longer than the first'),
  (3, 'unrelated words entirely');

statement ok
VACUUM (REFRESH_TABLE) test_shingle_norm;

# Same phrase count, shorter document -> higher BM25 (norms discount the
# co-located shingle terms, so the norm is the true token count).
query
SELECT id FROM test_shingle_norm_idx WHERE body @@ ts_phrase('quick brown fox') ORDER BY BM25(test_shingle_norm_idx.tableoid) DESC, id;
----
id
1
2

# The verify path (raw stored values) scores with norms too.
query
SELECT id FROM test_shingle_norm_idx WHERE body @@ ts_phrase('quick brown fox plus') ORDER BY id;
----
id
2

statement ok
DROP TABLE test_shingle_norm;

statement ok
DROP TEXT SEARCH DICTIONARY shingle_norm;

