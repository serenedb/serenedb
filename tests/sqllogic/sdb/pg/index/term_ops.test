statement ok
CREATE TABLE test_term_ops (a INTEGER PRIMARY KEY, b VARCHAR, c VARCHAR);

statement ok
CREATE TEXT SEARCH DICTIONARY test_english(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false
);

statement ok
CREATE INDEX test_term_ops_idx ON test_term_ops USING inverted(a, to_tsvector('test_english', b), to_tsvector('test_english', c));

