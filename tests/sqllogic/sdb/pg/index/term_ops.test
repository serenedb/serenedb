statement ok
CREATE TABLE test_term_ops (a INTEGER PRIMARY KEY, b VARCHAR, c VARCHAR);

statement ok
CREATE TEXT SEARCH DICTIONARY test_english(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'lower',
    stemming = false,
    accent = false
);

statement ok
CREATE INDEX test_term_ops_idx ON test_term_ops USING inverted(a, b test_english, c test_english);

statement ok
INSERT INTO test_term_ops values (1, 'percentAnotAcontain and some other', 'a');

statement ok
INSERT INTO test_term_ops values (2, 'percent_not_contain and some other', 'b');

statement ok
INSERT INTO test_term_ops values (3, 'foo', ' c');

statement ok
INSERT INTO test_term_ops values (4, 'foo', 'D');

statement ok
INSERT INTO test_term_ops values (5, 'foo', 'e');

statement ok
INSERT INTO test_term_ops values (6, 'foo', 'F');

statement ok
VACUUM (UPDATE_INDEXES) test_term_ops;

query
SELECT a FROM test_term_ops_idx WHERE TERM_LIKE(b, 'percent_not_contain') ORDER BY a;
----
a
1
2

query
SELECT a FROM test_term_ops_idx WHERE TERM_LIKE(b, 'percent_not_contain') AND a < 2;
----
a
1

query
SELECT a FROM test_term_ops_idx WHERE TERM_LIKE(b, 'percent\_not\_contain') ORDER BY a;
----
a
2

query
SELECT a FROM test_term_ops_idx WHERE TERM_EQ(c, 'd');
----
a
4


query
SELECT a FROM test_term_ops_idx WHERE c = 'd';
----
a


query
SELECT a FROM test_term_ops_idx WHERE TERM_GT(c, 'd') ORDER BY a DESC;
----
a
6
5

query
SELECT a FROM test_term_ops_idx WHERE TERM_LTE(c, 'd') ORDER BY a DESC;
----
a
4
3
2
1

query
SELECT a FROM test_term_ops_idx WHERE NOT TERM_LT(c, 'd') ORDER BY a DESC;
----
a
6
5
4

query
SELECT a FROM test_term_ops_idx WHERE TERM_IN(c, 'd', 'a') ORDER BY a DESC;
----
a
4
1

