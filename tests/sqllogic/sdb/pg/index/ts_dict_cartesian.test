query
SELECT unnest(ts_dict_agg(body)) AS term, unnest(ts_dict_count(body)) AS docs FROM cart_idx WHERE body IN ('apple','banana','kiwi','date') ORDER BY term, docs
----
term	docs
apple	1666
banana	3334
date	3334
kiwi	3332

# --- len : length(body) = 5
query
EXPLAIN SELECT unnest(ts_dict_agg(body)) AS term, unnest(ts_dict_count(body)) AS docs FROM cart_idx WHERE length(body) = 5 ORDER BY term, docs
----
