hash-threshold 100

# AUTO-GENERATED by gen_cart.py: every WHERE filter over one enumerated
# ts_dict field on a multi-segment ~40k-row dataset. A single supported
# predicate returns terms (with EXPLAIN); a negation or any boolean
# combination is rejected.

statement ok
CREATE TEXT SEARCH DICTIONARY cd(template = 'text', locale = 'en_US.UTF-8',
    case = 'none', stemming = false, accent = false, frequency = true,
    position = true)

statement ok
CREATE TABLE cart(id INTEGER PRIMARY KEY, body VARCHAR)

statement ok
CREATE INDEX cart_idx ON cart USING inverted(body cd)

statement ok
INSERT INTO cart SELECT i, concat_ws(' ', ARRAY['apple','aple','appl','apricot','avocado','banana','berry','blueberry','cherry','citrus','cranberry','date','dragonfruit','elderberry','fig','grape','guava','kiwi','lemon','lime','mango','melon','orange','papaya'][1 + (i % 24)], ARRAY['apple','aple','appl','apricot','avocado','banana','berry','blueberry','cherry','citrus','cranberry','date','dragonfruit','elderberry','fig','grape','guava','kiwi','lemon','lime','mango','melon','orange','papaya'][1 + ((i*7) % 24)]) FROM generate_series(1, 10000) g(i)

statement ok
VACUUM (REFRESH_TABLE) cart;

statement ok
INSERT INTO cart SELECT i, concat_ws(' ', ARRAY['apple','aple','appl','apricot','avocado','banana','berry','blueberry','cherry','citrus','cranberry','date','dragonfruit','elderberry','fig','grape','guava','kiwi','lemon','lime','mango','melon','orange','papaya'][1 + (i % 24)], ARRAY['apple','aple','appl','apricot','avocado','banana','berry','blueberry','cherry','citrus','cranberry','date','dragonfruit','elderberry','fig','grape','guava','kiwi','lemon','lime','mango','melon','orange','papaya'][1 + ((i*7) % 24)]) FROM generate_series(10001, 20000) g(i)

statement ok
VACUUM (REFRESH_TABLE) cart;

