hash-threshold 100

# AUTO-GENERATED by gen_multi.py: two enumerated ts_dict fields (body,title)
# in one scan. With no WHERE each field returns its full dictionary; a WHERE
# over a multi-field ts_dict_agg() is rejected for every per-field combination
# (constrain each field with a single-field subquery instead).

statement ok
CREATE TEXT SEARCH DICTIONARY md(template = 'text', locale = 'en_US.UTF-8',
    case = 'none', stemming = false, accent = false, frequency = true,
    position = true)

statement ok
CREATE TABLE mc(id INTEGER PRIMARY KEY, body VARCHAR, title VARCHAR,
                tag VARCHAR)

statement ok
CREATE INDEX mc_idx ON mc USING inverted(body md, title md, tag md)

statement ok
INSERT INTO mc SELECT i, concat_ws(' ', ARRAY['apple','aple','appl','apricot','avocado','banana','berry','blueberry','cherry','citrus','cranberry','date','dragonfruit','elderberry','fig','grape','guava','kiwi','lemon','lime','mango','melon','orange','papaya'][1 + (i % 24)], ARRAY['apple','aple','appl','apricot','avocado','banana','berry','blueberry','cherry','citrus','cranberry','date','dragonfruit','elderberry','fig','grape','guava','kiwi','lemon','lime','mango','melon','orange','papaya'][1 + ((i*7) % 24)]), concat_ws(' ', ARRAY['red','green','blue','yellow','orange','violet'][1 + (i % 6)], ARRAY['red','green','blue','yellow','orange','violet'][1 + ((i*5) % 6)]), (ARRAY['hot','cold','warm'])[1 + (i % 3)] FROM generate_series(1, 20000) g(i)

statement ok
VACUUM (REFRESH_TABLE) mc;

statement ok
INSERT INTO mc SELECT i, concat_ws(' ', ARRAY['apple','aple','appl','apricot','avocado','banana','berry','blueberry','cherry','citrus','cranberry','date','dragonfruit','elderberry','fig','grape','guava','kiwi','lemon','lime','mango','melon','orange','papaya'][1 + (i % 24)], ARRAY['apple','aple','appl','apricot','avocado','banana','berry','blueberry','cherry','citrus','cranberry','date','dragonfruit','elderberry','fig','grape','guava','kiwi','lemon','lime','mango','melon','orange','papaya'][1 + ((i*7) % 24)]), concat_ws(' ', ARRAY['red','green','blue','yellow','orange','violet'][1 + (i % 6)], ARRAY['red','green','blue','yellow','orange','violet'][1 + ((i*5) % 6)]), (ARRAY['hot','cold','warm'])[1 + (i % 3)] FROM generate_series(20001, 40000) g(i)

statement ok
VACUUM (REFRESH_TABLE) mc;

