hash-threshold 100

# Doc-restricted term enumeration (significant-terms style) is NOT supported:
# it would intersect each term's postings with the matched-document set, which
# defeats the point of reading the term dictionary directly. A WHERE on a
# non-enumerated field (or any boolean combination) is therefore rejected; the
# caller composes such queries with set operations / outer filters instead.

statement ok
CREATE TEXT SEARCH DICTIONARY dr(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true
)


statement ok
CREATE TABLE dr_docs(id INTEGER PRIMARY KEY, body VARCHAR, category VARCHAR)


statement ok
CREATE INDEX dr_idx ON dr_docs USING inverted(body dr, category dr)


statement ok
INSERT INTO dr_docs VALUES
  (1, 'apple banana', 'news'),
  (2, 'apple cherry', 'news'),
  (3, 'apple date',   'blog'),
  (4, 'banana fig',   'news')


statement ok
VACUUM (REFRESH_TABLE) dr_docs;


# A second segment: the global term enumeration still merges counts across
# segments (this is the supported, postings-free behavior).
statement ok
INSERT INTO dr_docs VALUES (5, 'apple apple grape', 'news'), (6, 'kiwi', 'blog')


statement ok
VACUUM (REFRESH_TABLE) dr_docs;


query TI
SELECT unnest(ts_dict_agg(body)) AS term,
       unnest(ts_dict_count(body)) AS docs
FROM dr_idx ORDER BY term
----
term	docs
apple	4
banana	2
cherry	1
date	1
fig	1
grape	1
kiwi	1


# A WHERE on another (non-enumerated) field is rejected -- it would need a
# document set (postings), not the term dictionary.
statement error
SELECT ts_dict_agg(body) FROM dr_idx
WHERE category @@ ts_starts_with('news')
----
db error: ERROR: ts_dict_agg() WHERE accepts a single predicate on the enumerated field (=, IN, LIKE, BETWEEN, length, <>, or @@ ts_*)
HINT: combine conditions with UNION/INTERSECT/EXCEPT over unnest(ts_dict_agg(...)), or filter terms in an outer query


# A term constraint plus a document filter is two conjuncts -> also rejected.
statement error
SELECT ts_dict_agg(body) FROM dr_idx
WHERE body @@ ts_starts_with('a') AND category @@ ts_starts_with('news')
----
db error: ERROR: ts_dict_agg() WHERE accepts a single predicate on the enumerated field (=, IN, LIKE, BETWEEN, length, <>, or @@ ts_*)
HINT: combine conditions with UNION/INTERSECT/EXCEPT over unnest(ts_dict_agg(...)), or filter terms in an outer query


statement ok
DROP TABLE dr_docs


statement ok
DROP TEXT SEARCH DICTIONARY dr
