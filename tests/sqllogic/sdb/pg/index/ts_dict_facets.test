в”Ӯ COALESCE(sdb_inverted_index_term_count$lower(cat), sdb_inverted_index_term_count$brand)  в”Ӯ
в”Ӯ ~4 rows                                                                                  в”Ӯ
в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ
в•ӯв”Җ IRESEARCH_SCAN в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®
в”Ӯ Index: fexs_idx                                                                          в”Ӯ
в”Ӯ TsDict: lower(cat), brand                                                                в”Ӯ
в”Ӯ Projections:                                                                             в”Ӯ
в”Ӯ sdb_inverted_index_term$lower(cat), sdb_inverted_index_term_count$lower(cat),            в”Ӯ
в”Ӯ sdb_inverted_index_term$brand, sdb_inverted_index_term_count$brand                       в”Ӯ
в”Ӯ ~4 rows                                                                                  в”Ӯ
в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ

# Two keys without a NOT NULL proof fall back.
statement ok
CREATE TABLE ftwo(id INTEGER PRIMARY KEY, a VARCHAR, b VARCHAR NOT NULL)

statement ok
CREATE INDEX ftwo_idx ON ftwo USING inverted(a fct_kw, (lower(b)) fct_kw)
    WITH (refresh_interval = 0, compaction_interval = 0)

statement ok
INSERT INTO ftwo VALUES (1, 'x', 'Q'), (2, NULL, 'q')

statement ok
VACUUM (REFRESH_TABLE) ftwo;

query TTI
SELECT a, lower(b) AS lb, count(*) AS n FROM ftwo_idx
GROUP BY GROUPING SETS ((a), (lower(b)))
ORDER BY a NULLS LAST, lb
----
a	lb	n
x	NULL	1
NULL	q	2
NULL	NULL	1

query
EXPLAIN SELECT a, lower(b) AS lb, count(*) AS n FROM ftwo_idx
GROUP BY GROUPING SETS ((a), (lower(b)))
----
QUERY PLAN
в•ӯв”Җ HASH_GROUP_BY в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®
в”Ӯ Groups: #0, #1           в”Ӯ
в”Ӯ Aggregates: count_star() в”Ӯ
в”Ӯ ~1 row                   в”Ӯ
в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ
в•ӯв”Җ PROJECTION в”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®
в”Ӯ Projections: a, lower(b) в”Ӯ
в”Ӯ ~2 rows                  в”Ӯ
в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ
в•ӯв”Җ IRESEARCH_SCAN в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®
в”Ӯ Index: ftwo_idx          в”Ӯ
в”Ӯ Lookup: table            в”Ӯ
в”Ӯ Projections: a, b        в”Ӯ
в”Ӯ ~2 rows                  в”Ӯ
в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ

# The nullable set key's NULL group stays filter-exact under a claimable
# WHERE, and its zero-count groups vanish.
statement ok
CREATE TABLE gsnw(id INTEGER PRIMARY KEY, opt VARCHAR, brand VARCHAR NOT NULL,
                  body VARCHAR NOT NULL)

statement ok
CREATE INDEX gsnw_idx ON gsnw USING inverted(opt fct_kw, brand fct_kw, body fct_body)
    WITH (refresh_interval = 0, compaction_interval = 0)

statement ok
INSERT INTO gsnw VALUES
  (1, 'x',  'acme', 'red apple'),
  (2, NULL, 'acme', 'red pear'),
  (3, 'y',  'bolt', 'green pear'),
  (4, NULL, 'bolt', 'green apple'),
  (5, 'x',  'core', 'red plum')

statement ok
VACUUM (REFRESH_TABLE) gsnw;

query TTI
SELECT opt, brand, count(*) AS n FROM gsnw_idx WHERE body @@ 'red'
GROUP BY GROUPING SETS ((opt), (brand))
ORDER BY opt NULLS LAST, brand NULLS LAST
----
opt	brand	n
x	NULL	2
NULL	acme	2
NULL	core	1
NULL	NULL	1

query
EXPLAIN SELECT opt, brand, count(*) AS n FROM gsnw_idx WHERE body @@ 'red'
GROUP BY GROUPING SETS ((opt), (brand))
----
QUERY PLAN
в•ӯв”Җ PROJECTION в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®
в”Ӯ Projections:                                                                      в”Ӯ
в”Ӯ sdb_inverted_index_term$opt, sdb_inverted_index_term$brand, CAST(#2 AS BIGINT)    в”Ӯ
