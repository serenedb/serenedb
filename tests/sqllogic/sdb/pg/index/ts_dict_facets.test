# Nullable facet column under a cross-field WHERE: the NULL group is counted
# from the null-marker field restricted by the document filter, and groups
# whose filtered count is zero disappear.
statement ok
CREATE TABLE fnw(id INTEGER PRIMARY KEY, opt VARCHAR, body VARCHAR NOT NULL)

statement ok
CREATE INDEX fnw_idx ON fnw USING inverted(opt fct_kw, body fct_body)
    WITH (refresh_interval = 0, compaction_interval = 0)

statement ok
INSERT INTO fnw VALUES
  (1, 'x',  'red apple'),
  (2, NULL, 'red pear'),
  (3, 'y',  'green pear'),
  (4, NULL, 'green apple'),
  (5, 'x',  'red plum')

statement ok
VACUUM (REFRESH_TABLE) fnw;

query TI
SELECT opt, count(*) AS n FROM fnw_idx WHERE body @@ 'red'
GROUP BY opt ORDER BY n DESC, opt
----
opt	n
x	2
NULL	1

query TI
SELECT opt, count(*) AS n FROM fnw_idx WHERE body @@ 'green'
GROUP BY opt ORDER BY n DESC, opt
----
opt	n
y	1
NULL	1

query
EXPLAIN SELECT opt, count(*) AS n FROM fnw_idx WHERE body @@ 'green'
GROUP BY opt 
----
QUERY PLAN
в•ӯв”Җ PROJECTION в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®
в”Ӯ Projections: sdb_inverted_index_term$opt, в”Ӯ
