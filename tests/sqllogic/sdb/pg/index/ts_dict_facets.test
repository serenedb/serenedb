query TTI
SELECT cat, region, count(*) AS n FROM fgs_idx WHERE 1=1
  GROUP BY GROUPING SETS ((cat),(region)) ORDER BY cat NULLS LAST, region NULLS LAST
----
cat	region	n
blue	NULL	1
green	NULL	2
red	NULL	3
NULL	east	1
NULL	north	3
NULL	south	2

query TTI
SELECT cat, region, count(*) AS n FROM fgs_idx WHERE false
  GROUP BY GROUPING SETS ((cat),(region)) ORDER BY cat NULLS LAST, region NULLS LAST
----
cat	region	n
