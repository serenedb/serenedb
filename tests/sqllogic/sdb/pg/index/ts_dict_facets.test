# One nullable key among the sets converts: its genuine NULL group is the
# only all-NULL group key, so it cannot collide with the other sets' padding.
statement ok
CREATE TABLE gsn(id INTEGER PRIMARY KEY, brand VARCHAR NOT NULL, opt VARCHAR)

statement ok
CREATE INDEX gsn_idx ON gsn USING inverted(brand fct_kw, opt fct_kw)
    WITH (refresh_interval = 0, compaction_interval = 0)

statement ok
INSERT INTO gsn VALUES
  (1, 'acme', 'x'),
  (2, 'acme', NULL),
  (3, 'bolt', 'x')

statement ok
VACUUM (REFRESH_TABLE) gsn;

query TTI
SELECT brand, opt, count(*) AS n FROM gsn_idx
GROUP BY GROUPING SETS ((brand), (opt))
ORDER BY brand NULLS LAST, opt NULLS LAST
----
brand	opt	n
acme	NULL	2
bolt	NULL	1
NULL	x	2
NULL	NULL	1

query
EXPLAIN SELECT brand, opt, count(*) AS n FROM gsn_idx
GROUP BY GROUPING SETS ((brand), (opt))
----
