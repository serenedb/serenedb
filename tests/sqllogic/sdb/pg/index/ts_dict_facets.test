в”Ӯ sdb_inverted_index_term$opt, sdb_inverted_index_term_count$opt                    в”Ӯ
в”Ӯ ~3 rows                                                                           в”Ӯ
в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ

# GROUP BY over an indexed keyword expression converts: the group key
# resolves to the expression's own term dictionary and the NULL group rides
# its null-marker field (no NOT NULL proof exists for an expression). An
# indexed-expression WHERE conjunct claims into the document filter. A
# generated STORED column carrying the same expression converts identically.
statement ok
CREATE TABLE fex(id INTEGER PRIMARY KEY, cat VARCHAR NOT NULL, body VARCHAR NOT NULL)

statement ok
CREATE INDEX fex_idx ON fex USING inverted((lower(cat)) fct_kw, (ts_split_by_non_alpha(body, true)) fct_body)
    WITH (refresh_interval = 0, compaction_interval = 0)

statement ok
INSERT INTO fex VALUES
  (1, 'Red',  'alpha beta'),
  (2, 'RED',  'alpha'),
  (3, 'Blue', 'gamma')

statement ok
VACUUM (REFRESH_TABLE) fex;

query TI
SELECT lower(cat) AS lc, count(*) AS n FROM fex_idx
WHERE ts_split_by_non_alpha(body, true) @@ 'alpha'
GROUP BY lower(cat) ORDER BY lc
----
lc	n
red	2

query
EXPLAIN SELECT lower(cat) AS lc, count(*) AS n FROM fex_idx
WHERE ts_split_by_non_alpha(body, true) @@ 'alpha'
GROUP BY lower(cat)
----
