# WHERE on a grouping-set column converts when it compiles to a term
# acceptor: it prunes its own set's enumeration and is re-claimed into the
# document filter so the other sets' counts respect it too.
query TTI
SELECT brand, color, count(*) AS n FROM gsf_idx
WHERE brand != 'acme'
GROUP BY GROUPING SETS ((brand), (color))
ORDER BY brand NULLS LAST, color
----
brand	color	n
bolt	NULL	2
core	NULL	1
NULL	blue	1
NULL	red	2

query TTI
SELECT brand, color, count(*) AS n FROM gsf_idx
WHERE brand != 'acme' AND body @@ ts_regexp('charg.*')
GROUP BY GROUPING SETS ((brand), (color))
ORDER BY brand NULLS LAST, color
----
brand	color	n
bolt	NULL	1
core	NULL	1
NULL	blue	1
NULL	red	1

query
EXPLAIN SELECT brand, color, count(*) AS n FROM gsf_idx
WHERE brand != 'acme' AND body @@ ts_regexp('charg.*')
GROUP BY GROUPING SETS ((brand), (color))
----
