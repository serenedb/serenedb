hash-threshold 100

statement ok
SET compaction_interval = 0

statement ok
SET refresh_interval = 0

# `SELECT col, count(*) FROM idx GROUP BY col` over a keyword NOT NULL column
# is a facet served from the term dictionary: the groups are exactly the
# field's live terms and each group's size is the term's live document count.
# The user's own GROUP BY merges the per-segment term rows (summing counts), so
# results stay exact under deletion masks. A nullable column converts too, with
# the NULL group synthesized from the null-marker field (restricted by the
# claimed document filter under WHERE). Cross-field and tsquery WHERE clauses
# convert when every conjunct is index-claimable: they compile into the scan's
# document filter and terms are counted against the matched doc set.
# Group keys are indexed keyword columns or indexed keyword expressions (the
# latter have no NOT NULL proof, so their NULL group always rides the
# null-marker field). GROUPING SETS over distinct singleton keyword keys
# convert to a multi-field term scan regrouped as GROUP BY (terms...) +
# sum(coalesce) when at most ONE key is nullable (a second nullable key's
# genuine NULL group would collide with the first one's all-NULL group key);
# a WHERE conjunct on one NOT NULL set column prunes its own set's
# enumeration and is re-claimed into the document filter so the other sets
# respect it. count(col) over a nullable column, extra aggregates,
# non-claimable WHERE conjuncts, same-field WHERE on a nullable column,
# multiple plain group keys, GROUPING() markers and non-singleton or empty
# sets fall back to the document scan.
# Background maintenance is disabled; visibility is driven by
# VACUUM (REFRESH_TABLE).

statement ok
CREATE TEXT SEARCH DICTIONARY fct_kw(template = 'keyword')

statement ok
CREATE TABLE ft(id INTEGER PRIMARY KEY, cat VARCHAR NOT NULL, opt VARCHAR)

statement ok
CREATE INDEX ft_idx ON ft USING inverted(cat fct_kw, opt fct_kw)
    WITH (refresh_interval = 0, compaction_interval = 0)

statement ok
INSERT INTO ft VALUES
  (1, 'red',   'x'),
  (2, 'green', NULL),
  (3, 'red',   'y'),
  (4, 'blue',  'x'),
  (5, 'red',   'x'),
  (6, 'green', 'z')

statement ok
VACUUM (REFRESH_TABLE) ft;

query TI
SELECT cat, count(*) AS n FROM ft_idx GROUP BY cat ORDER BY cat
----
cat	n
blue	1
green	2
red	3

query TI
SELECT cat, count(*) AS n FROM ft GROUP BY cat ORDER BY cat
----
cat	n
blue	1
green	2
red	3

query TI
SELECT cat, count(cat) AS n FROM ft_idx GROUP BY cat ORDER BY cat
----
cat	n
blue	1
green	2
red	3

query
EXPLAIN SELECT cat, count(cat) AS n FROM ft_idx GROUP BY cat 
----
