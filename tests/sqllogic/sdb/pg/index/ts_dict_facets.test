cat	n

# --- A constant-false predicate declines the pushdown and stays restrictive:
# it is a real conjunct (not folded away), so the scan runs and eliminates
# every row.
query
EXPLAIN SELECT cat, count(*) AS n FROM fconst_idx WHERE false GROUP BY cat
