# The same folding applies on the GROUPING SETS path (multiple singleton
# keyword keys): a constant-true WHERE is transparent and the multi-field term
# scan is preserved; a constant-false WHERE still empties the result.

statement ok
CREATE TABLE fgs(id INTEGER PRIMARY KEY, cat VARCHAR NOT NULL, region VARCHAR NOT NULL)

statement ok
CREATE INDEX fgs_idx ON fgs USING inverted(cat fct_kw, region fct_kw)
    WITH (refresh_interval = 0, compaction_interval = 0)

statement ok
INSERT INTO fgs VALUES
  (1,'red','north'),(2,'green','south'),(3,'red','north'),
  (4,'blue','east'),(5,'red','south'),(6,'green','north')

statement ok
VACUUM (REFRESH_TABLE) fgs;

query TTI
SELECT cat, region, count(*) AS n FROM fgs_idx WHERE true
  GROUP BY GROUPING SETS ((cat),(region)) ORDER BY cat NULLS LAST, region NULLS LAST
----
cat	region	n
blue	NULL	1
green	NULL	2
red	NULL	3
NULL	east	1
NULL	north	3
NULL	south	2

query
EXPLAIN SELECT cat, region, count(*) AS n FROM fgs_idx WHERE true
  GROUP BY GROUPING SETS ((cat),(region))
----
QUERY PLAN
в•ӯв”Җ PROJECTION в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®
