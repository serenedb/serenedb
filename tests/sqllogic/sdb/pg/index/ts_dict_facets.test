# Expression keys join grouping sets as the single nullable key.
statement ok
CREATE TABLE fexs(id INTEGER PRIMARY KEY, cat VARCHAR NOT NULL, brand VARCHAR NOT NULL)

statement ok
CREATE INDEX fexs_idx ON fexs USING inverted((lower(cat)) fct_kw, brand fct_kw)
    WITH (refresh_interval = 0, compaction_interval = 0)

statement ok
INSERT INTO fexs VALUES
  (1, 'Red',  'acme'),
  (2, 'RED',  'bolt'),
  (3, 'Blue', 'acme')

statement ok
VACUUM (REFRESH_TABLE) fexs;

query TTI
SELECT lower(cat) AS lc, brand, count(*) AS n FROM fexs_idx
GROUP BY GROUPING SETS ((lower(cat)), (brand))
ORDER BY lc NULLS LAST, brand
----
lc	brand	n
blue	NULL	1
red	NULL	2
NULL	acme	2
NULL	bolt	1

query
EXPLAIN SELECT lower(cat) AS lc, brand, count(*) AS n FROM fexs_idx
GROUP BY GROUPING SETS ((lower(cat)), (brand))
----
