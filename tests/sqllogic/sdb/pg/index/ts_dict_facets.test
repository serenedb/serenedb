# Deletions: 'blue' dies with row 4 and 'red' loses row 5; facet counts are
# live-exact on the still-dirty segment.
statement ok
DELETE FROM ft WHERE id IN (4, 5)

statement ok
VACUUM (REFRESH_TABLE) ft;

query TI
SELECT cat, count(*) AS n FROM ft_idx GROUP BY cat ORDER BY cat
----
cat	n
green	2
red	2

# A fresh clean segment sums with the dirty one per term.
statement ok
INSERT INTO ft VALUES (7, 'red', 'x'), (8, 'amber', NULL)

statement ok
VACUUM (REFRESH_TABLE) ft;

query TI
SELECT cat, count(*) AS n FROM ft_idx GROUP BY cat ORDER BY cat
----
cat	n
amber	1
green	2
red	3

query TI
SELECT cat, count(*) AS n FROM ft_idx GROUP BY cat
ORDER BY n DESC, cat LIMIT 2
----
cat	n
red	3
green	2

query TI
SELECT cat, count(*) AS n FROM ft GROUP BY cat ORDER BY cat
----
cat	n
amber	1
green	2
red	3

# The NULL group stays exact through deletion masks and across segments: the
# deletions masked two x rows in the now-dirty first segment while row 8
# added a NULL in the clean second one.
query TI
SELECT opt, count(*) AS n FROM ft_idx GROUP BY opt ORDER BY opt NULLS FIRST
----
opt	n
NULL	2
x	2
y	1
z	1

query TI
SELECT opt, count(*) AS n FROM ft GROUP BY opt ORDER BY opt NULLS FIRST
----
opt	n
NULL	2
x	2
y	1
z	1

# Deleting a NULL row must shrink the NULL group before compaction: the
# null-marker postings are masked exactly like term postings.
statement ok
DELETE FROM ft WHERE id = 2

statement ok
VACUUM (REFRESH_TABLE) ft;

query TI
SELECT opt, count(*) AS n FROM ft_idx GROUP BY opt ORDER BY opt NULLS FIRST
----
opt	n
NULL	1
x	2
y	1
z	1

query TI
SELECT opt, count(*) AS n FROM ft GROUP BY opt ORDER BY opt NULLS FIRST
----
opt	n
NULL	1
x	2
y	1
z	1

# Masking the last NULL row of a segment drops its synthesized row entirely;
# with no NULL rows left anywhere the group vanishes.
statement ok
DELETE FROM ft WHERE id = 8

statement ok
VACUUM (REFRESH_TABLE) ft;

query TI
SELECT opt, count(*) AS n FROM ft_idx GROUP BY opt ORDER BY opt NULLS FIRST
----
opt	n
x	2
y	1
z	1

query TI
SELECT opt, count(*) AS n FROM ft GROUP BY opt ORDER BY opt NULLS FIRST
----
opt	n
x	2
y	1
z	1

# A text-tokenized column must NOT convert: its terms are word tokens, so a
# term-dictionary facet would return token counts instead of row counts. The
# IsKeywordField gate forces the document-scan fallback; groups are whole
# column values with row-exact counts.
statement ok
CREATE TEXT SEARCH DICTIONARY fct_tx(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'lower',
    frequency = true,
    position = true
)

statement ok
CREATE TABLE ftx(id INTEGER PRIMARY KEY, descr VARCHAR NOT NULL)

statement ok
CREATE INDEX ftx_idx ON ftx USING inverted(descr fct_tx)
    WITH (refresh_interval = 0, compaction_interval = 0)

statement ok
INSERT INTO ftx VALUES
  (1, 'quick brown fox'),
  (2, 'quick red fox'),
  (3, 'lazy dog')

statement ok
VACUUM (REFRESH_TABLE) ftx;

query TI
SELECT descr, count(*) AS n FROM ftx_idx GROUP BY descr ORDER BY descr
----
descr	n
lazy dog	1
quick brown fox	1
quick red fox	1

query TI
SELECT descr, count(*) AS n FROM ftx GROUP BY descr ORDER BY descr
----
descr	n
lazy dog	1
quick brown fox	1
quick red fox	1

query
EXPLAIN SELECT descr, count(*) AS n FROM ftx_idx GROUP BY descr
----
QUERY PLAN
в•ӯв”Җ HASH_GROUP_BY в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®
в”Ӯ Groups: #0               в”Ӯ
в”Ӯ Aggregates: count_star() в”Ӯ
в”Ӯ ~1 row                   в”Ӯ
в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ
в•ӯв”Җ IRESEARCH_SCAN в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®
в”Ӯ Index: ftx_idx           в”Ӯ
в”Ӯ Lookup: table            в”Ӯ
в”Ӯ Projections: descr       в”Ӯ
в”Ӯ ~3 rows                  в”Ӯ
в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ

# A fully index-claimable WHERE converts even when it is a tsquery on another
# field: the conjuncts compile into the scan's document filter and each term
# is counted against the matched doc set, so the facet stays filter-exact
# without materializing rows.
statement ok
CREATE TEXT SEARCH DICTIONARY fct_body(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'lower',
    frequency = true,
    position = true
)

statement ok
CREATE TABLE ffw(id INTEGER PRIMARY KEY, scope VARCHAR NOT NULL, body VARCHAR NOT NULL)

statement ok
CREATE INDEX ffw_idx ON ffw USING inverted(scope fct_kw, body fct_body)
    WITH (refresh_interval = 0, compaction_interval = 0)

statement ok
INSERT INTO ffw VALUES
  (1, 'auth',    'charging session started'),
  (2, 'auth',    'idle'),
  (3, 'billing', 'charge failed'),
  (4, 'billing', 'charging done'),
  (5, 'net',     'packet drop')

statement ok
VACUUM (REFRESH_TABLE) ffw;

query TI
SELECT scope, count(*) AS n FROM ffw_idx
WHERE body @@ ts_regexp('charg.*') GROUP BY scope ORDER BY n DESC, scope
----
scope	n
billing	2
auth	1

query
EXPLAIN SELECT scope, count(*) AS n FROM ffw_idx
WHERE body @@ ts_regexp('charg.*') GROUP BY scope
----
QUERY PLAN
в•ӯв”Җ PROJECTION в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®
