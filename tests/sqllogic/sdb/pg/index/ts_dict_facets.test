# Filtered grouping sets: the claimed document filter restricts every set.
query TTI
SELECT brand, color, count(*) AS n FROM gsf_idx
WHERE body @@ ts_regexp('charg.*')
GROUP BY GROUPING SETS ((brand), (color))
ORDER BY brand NULLS LAST, color
----
brand	color	n
acme	NULL	2
bolt	NULL	1
core	NULL	1
NULL	blue	2
NULL	red	2

query
EXPLAIN SELECT brand, color, count(*) AS n FROM gsf_idx
WHERE body @@ ts_regexp('charg.*')
GROUP BY GROUPING SETS ((brand), (color))
----
