# GROUPING SETS over singleton NOT NULL keyword columns convert to one
# multi-field term scan: each set's terms come from its own dictionary and the
# padded NULLs of the other set columns regroup exactly as the sets demand.
statement ok
CREATE TABLE gsf(id INTEGER PRIMARY KEY, brand VARCHAR NOT NULL,
                 color VARCHAR NOT NULL, body VARCHAR NOT NULL)

statement ok
CREATE INDEX gsf_idx ON gsf USING inverted(brand fct_kw, color fct_kw, body fct_body)
    WITH (refresh_interval = 0, compaction_interval = 0)

statement ok
INSERT INTO gsf VALUES
  (1, 'acme', 'red',  'fast charging dock'),
  (2, 'acme', 'blue', 'slow charger'),
  (3, 'bolt', 'red',  'charging cable'),
  (4, 'bolt', 'red',  'usb hub'),
  (5, 'core', 'blue', 'wall charger')

statement ok
VACUUM (REFRESH_TABLE) gsf;

query TTI
SELECT brand, color, count(*) AS n FROM gsf_idx
GROUP BY GROUPING SETS ((brand), (color))
ORDER BY brand NULLS LAST, color
----
brand	color	n
acme	NULL	2
bolt	NULL	2
core	NULL	1
NULL	blue	2
NULL	red	3

query
EXPLAIN SELECT brand, color, count(*) AS n FROM gsf_idx
GROUP BY GROUPING SETS ((brand), (color))
----
