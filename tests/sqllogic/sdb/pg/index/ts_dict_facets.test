# A conjunct the index cannot claim keeps falling back with sets too.
query TTI
SELECT brand, color, count(*) AS n FROM gsf_idx
WHERE id < 3
GROUP BY GROUPING SETS ((brand), (color))
ORDER BY brand NULLS LAST, color
----
brand	color	n
acme	NULL	2
NULL	blue	1
NULL	red	1

query
EXPLAIN SELECT brand, color, count(*) AS n FROM gsf_idx
WHERE id < 3
GROUP BY GROUPING SETS ((brand), (color))
----
QUERY PLAN
в•ӯв”Җ HASH_GROUP_BY в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®
в”Ӯ Groups: #0, #1           в”Ӯ
в”Ӯ Aggregates: count_star() в”Ӯ
в”Ӯ ~0 rows                  в”Ӯ
в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ
