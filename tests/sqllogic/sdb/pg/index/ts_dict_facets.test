# A view-backed inverted index (over read_parquet, another view, ...) has no
# catalog table, so its keys carry no NOT NULL proof -- every key rides its
# null-marker field for the synthesized NULL group. The GROUP BY facet still
# converts to a term-dictionary scan, and an indexed-expression WHERE claims
# into the document filter exactly as for a table-backed index.
statement ok
CREATE TEXT SEARCH DICTIONARY fvw_kw(template = 'keyword')

statement ok
CREATE TABLE fvw_base(id INTEGER PRIMARY KEY, sev VARCHAR, body VARCHAR NOT NULL)

statement ok
INSERT INTO fvw_base VALUES
  (1, 'ERROR', 'disk error'),
  (2, 'INFO',  'all ok'),
  (3, NULL,    'net failed'),
  (4, 'INFO',  'error retry')

statement ok
CREATE VIEW fvw AS SELECT id, sev AS SeverityText, body AS Body FROM fvw_base

statement ok
CREATE INDEX fvw_idx ON fvw USING inverted((ts_split_by_non_alpha(Body, true)) fvw_kw, SeverityText fvw_kw)
    WITH (refresh_interval = 0, compaction_interval = 0)

statement ok
VACUUM (REFRESH_TABLE) fvw_base;

query TI
SELECT SeverityText AS sev, count(*) AS n FROM fvw_idx
WHERE ts_split_by_non_alpha(Body, true) @@ ts_any(['error', 'failed'])
GROUP BY SeverityText ORDER BY n DESC, sev
----
sev	n
ERROR	1
INFO	1
NULL	1

query
EXPLAIN SELECT SeverityText AS sev, count(*) AS n FROM fvw_idx
WHERE ts_split_by_non_alpha(Body, true) @@ ts_any(['error', 'failed'])
GROUP BY SeverityText
----
QUERY PLAN
в•ӯв”Җ PROJECTION в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®
в”Ӯ Projections:                                 в”Ӯ
в”Ӯ sdb_inverted_index_term$severitytext,        в”Ӯ
в”Ӯ CAST(#1 AS BIGINT)                           в”Ӯ
в”Ӯ ~1 row                                       в”Ӯ
в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ
в•ӯв”Җ HASH_GROUP_BY в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®
в”Ӯ Groups: #0                                   в”Ӯ
в”Ӯ Aggregates: sum(#1)                          в”Ӯ
в”Ӯ ~1 row                                       в”Ӯ
в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ
в•ӯв”Җ IRESEARCH_SCAN в”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®
в”Ӯ Index: fvw_idx                               в”Ӯ
в”Ӯ Index Filter:                                в”Ӯ
в”Ӯ в•ӯв”Җ Terms в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•® в”Ӯ
в”Ӯ в”Ӯ Field: ts_split_by_non_alpha(body, true) в”Ӯ в”Ӯ
в”Ӯ в”Ӯ Values: 'error', 'failed'                в”Ӯ в”Ӯ
в”Ӯ в”Ӯ Min Match: 1                             в”Ӯ в”Ӯ
в”Ӯ в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ в”Ӯ
в”Ӯ TsDict: severitytext                         в”Ӯ
в”Ӯ Projections:                                 в”Ӯ
в”Ӯ sdb_inverted_index_term$severitytext,        в”Ӯ
в”Ӯ sdb_inverted_index_term_count$severitytext   в”Ӯ
в”Ӯ ~2 rows                                      в”Ӯ
в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ

query TI
SELECT SeverityText AS sev, count(*) AS n FROM fvw_idx
GROUP BY SeverityText ORDER BY n DESC, sev
----
sev	n
INFO	2
ERROR	1
NULL	1

# count(DISTINCT), min and max over the same view-backed index push down
# (NULL-safe -- no null-marker needed).
query I
SELECT count(DISTINCT SeverityText) AS n FROM fvw_idx
----
n
2

query
EXPLAIN SELECT count(DISTINCT SeverityText) FROM fvw_idx
