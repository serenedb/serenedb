statement ok
CREATE TABLE fes(id INTEGER PRIMARY KEY, cat VARCHAR NOT NULL,
                 lc VARCHAR GENERATED ALWAYS AS (lower(cat)) STORED NOT NULL,
                 body VARCHAR NOT NULL)

statement ok
CREATE INDEX fes_idx ON fes USING inverted(lc fct_kw, (ts_split_by_non_alpha(body, true)) fct_body)
    WITH (refresh_interval = 0, compaction_interval = 0)

statement ok
INSERT INTO fes(id, cat, body) VALUES
  (1, 'Red',  'alpha beta'),
  (2, 'RED',  'alpha'),
  (3, 'Blue', 'gamma')

statement ok
VACUUM (REFRESH_TABLE) fes;

query TI
SELECT lc, count(*) AS n FROM fes_idx
WHERE ts_split_by_non_alpha(body, true) @@ 'alpha'
GROUP BY lc ORDER BY lc
----
lc	n
red	2

query
EXPLAIN SELECT lc, count(*) AS n FROM fes_idx
WHERE ts_split_by_non_alpha(body, true) @@ 'alpha'
GROUP BY lc
