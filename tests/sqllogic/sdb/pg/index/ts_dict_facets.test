# Same-field WHERE on a nullable column keeps falling back: SQL drops the
# NULL rows while the term routes would still synthesize the NULL group.
query TI
SELECT opt, count(*) AS n FROM fnw_idx WHERE opt = 'x' GROUP BY opt
----
opt	n
x	2

query
EXPLAIN SELECT opt, count(*) AS n FROM fnw_idx WHERE opt = 'x' GROUP BY opt
----
