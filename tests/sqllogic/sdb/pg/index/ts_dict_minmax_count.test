hash-threshold 100

# count(DISTINCT col), min(col) and max(col) over a keyword-analyzed
# inverted-index column reduce exactly the field's distinct terms, so the
# optimizer serves them from the term dictionary like array_agg(DISTINCT).
# Unlike array_agg they skip NULLs, so no NOT NULL constraint is required.
# min-only requests stop after the first live term per segment; max-only
# requests seek straight to the segment's greatest term when it has no
# deletions. Background maintenance is disabled so deletion masks persist.

statement ok
CREATE TEXT SEARCH DICTIONARY mmc_kw(template = 'keyword')

statement ok
CREATE TABLE mc(id INTEGER PRIMARY KEY, cat VARCHAR NOT NULL, opt VARCHAR)

statement ok
CREATE INDEX mc_idx ON mc USING inverted(cat mmc_kw, opt mmc_kw)
    WITH (refresh_interval = 0, compaction_interval = 0)

statement ok
INSERT INTO mc VALUES
  (1, 'red',   'x'),
  (2, 'green', NULL),
  (3, 'red',   'y'),
  (4, 'blue',  'x'),
  (5, 'amber', NULL)

statement ok
VACUUM (REFRESH_TABLE) mc;

query ITT
SELECT count(DISTINCT cat) AS cnt, min(cat) AS mn, max(cat) AS mx FROM mc_idx
----
cnt	mn	mx
4	amber	red

# Nullable column: count/min/max skip NULLs, matching the dictionary exactly.
query ITT
SELECT count(DISTINCT opt) AS cnt, min(opt) AS mn, max(opt) AS mx FROM mc_idx
----
cnt	mn	mx
2	x	y

# Base-table equivalents.
query ITT
SELECT count(DISTINCT cat) AS cnt, min(cat) AS mn, max(cat) AS mx FROM mc
----
cnt	mn	mx
4	amber	red

query ITT
SELECT count(DISTINCT opt) AS cnt, min(opt) AS mn, max(opt) AS mx FROM mc
----
cnt	mn	mx
2	x	y

# All four convertible aggregates convert together off one term enumeration.
query ITTT
SELECT count(DISTINCT cat) AS cnt, min(cat) AS mn, max(cat) AS mx,
       list_sort(array_agg(DISTINCT cat)) AS lst
FROM mc_idx
----
cnt	mn	mx	lst
4	amber	red	{amber,blue,green,red}

query
