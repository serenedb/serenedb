query
EXPLAIN SELECT count(DISTINCT cat) AS cnt, min(cat) AS mn, max(cat) AS mx,
               list_sort(array_agg(DISTINCT cat)) AS lst
FROM mc_idx
----
QUERY PLAN
╭─ PROJECTION ─────────────────────────────╮
│ Projections: cnt, mn, mx, lst            │
│ ~1 row                                   │
╰─────────────────────┬────────────────────╯
╭─ UNGROUPED_AGGREGATE ────────────────────╮
│ Aggregates:                              │
│ count(#0), min(#0), max(#0),             │
│ list(#0) FILTER (WHERE #1) Filter: #1    │
│ ~1 row                                   │
╰─────────────────────┬────────────────────╯
╭─ PROJECTION ────────┴────────────────────╮
│ Projections:                             │
│ sdb_inverted_index_term$cat,             │
│ sdb_inverted_index_term$cat IS NOT NULL  │
│ ~2 rows                                  │
╰─────────────────────┬────────────────────╯
╭─ HASH_GROUP_BY ─────┴────────────────────╮
│ Groups: #0                               │
│ ~2 rows                                  │
╰─────────────────────┬────────────────────╯
╭─ IRESEARCH_SCAN ────┴────────────────────╮
│ Index: mc_idx                            │
│ TsDict: cat                              │
│ Projections: sdb_inverted_index_term$cat │
│ ~5 rows                                  │
╰──────────────────────────────────────────╯

# count(*) needs document rows: the node is not converted and both aggregates
# stay correct on the regular scan.
query II
SELECT count(DISTINCT cat) AS c1, count(*) AS c2 FROM mc_idx
----
c1	c2
4	5

# A WHERE clause referencing any other column disables implicit conversion and
# the aggregates fall back to the regular scan.
query IT
SELECT count(DISTINCT cat) AS cnt, min(cat) AS mn FROM mc_idx WHERE id > 2
----
cnt	mn
3	amber

# A WHERE clause on the enumerated column itself stays convertible: the
# ts_dict claim absorbs it as a term acceptor or post-filter.
query TI
SELECT min(cat) AS mn, count(DISTINCT cat) AS cnt FROM mc_idx
WHERE cat LIKE 'r%'
----
mn	cnt
red	1

query
EXPLAIN SELECT min(cat) AS mn, count(DISTINCT cat) AS cnt FROM mc_idx
WHERE cat LIKE 'r%'
----
QUERY PLAN
╭─ UNGROUPED_AGGREGATE ────────────────────╮
│ Aggregates: min(#0), count(#0)           │
│ ~1 row                                   │
╰─────────────────────┬────────────────────╯
╭─ HASH_GROUP_BY ─────┴────────────────────╮
│ Groups: #0                               │
│ ~0 rows                                  │
╰─────────────────────┬────────────────────╯
╭─ IRESEARCH_SCAN ────┴────────────────────╮
│ Index: mc_idx                            │
│ Filter:                                  │
│ ╭─ Starts With ──────╮                   │
│ │ Field: cat(string) │                   │
│ │ Prefix: r          │                   │
│ │ Limit: 1024        │                   │
│ ╰────────────────────╯                   │
│ TsDict: cat                              │
│ Projections: sdb_inverted_index_term$cat │
│ ~1 row                                   │
╰──────────────────────────────────────────╯

query T
SELECT list_sort(array_agg(DISTINCT cat)) AS lst FROM mc_idx WHERE id > 2
----
lst
{amber,blue,red}

query
EXPLAIN SELECT min(cat) FROM mc_idx WHERE id > 2
----
QUERY PLAN
╭─ UNGROUPED_AGGREGATE ─╮
│ Aggregates: min(#0)   │
│ ~1 row                │
╰───────────┬───────────╯
╭─ IRESEARCH_SCAN ──────╮
│ Index: mc_idx         │
│ Lookup: table         │
│ Projections: cat      │
│ Column Filter: id > 2 │
│ ~1 row                │
╰───────────────────────╯

# Explicit ts_dict_* aggregates split away from sibling document-row
# aggregates: the dict side enumerates terms, the document side scans rows.
query TI
SELECT list_sort(ts_dict_agg(cat)) AS a, count(*) AS c FROM mc_idx
----
a	c
{amber,blue,green,red}	5
