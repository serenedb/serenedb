# Three segments (clean / dirty / clean): the global min 'bb' lives in the
# dirty middle segment behind its dead 'aa', the global max 'zz' in a clean
# segment served by the max-only seek.
statement ok
CREATE TABLE mmx3(id INTEGER PRIMARY KEY, cat VARCHAR NOT NULL)

statement ok
CREATE INDEX mmx3_idx ON mmx3 USING inverted(cat mmx_kw)
    WITH (refresh_interval = 0, compaction_interval = 0)

statement ok
INSERT INTO mmx3 VALUES (1, 'mm'), (2, 'pp')

statement ok
VACUUM (REFRESH_TABLE) mmx3;

query II
