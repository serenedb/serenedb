       (SELECT count(DISTINCT cat) FROM mmx3) AS tbl_cnt
----
idx_cnt	tbl_cnt
2	2

statement ok
INSERT INTO mmx3 VALUES (3, 'aa'), (4, 'bb'), (5, 'rr')

statement ok
VACUUM (REFRESH_TABLE) mmx3;

