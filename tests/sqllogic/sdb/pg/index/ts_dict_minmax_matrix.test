# Dead 'aa' passes the length filter but has no live docs; live 'a' fails the
# filter: the dictionary min must skip both. Symmetric for dead 'zz' and live
# 'z' at max. The implicit forms fall back to the document scan and must agree.
statement ok
DELETE FROM mmx2 WHERE id IN (5, 6)

statement ok
VACUUM (REFRESH_TABLE) mmx2;

