hash-threshold 100

# min/max/count(DISTINCT) over keyword inverted-index columns crossed with
# WHERE acceptors, deletion masks and NULLs. min-only requests stop after the
# first live term per segment and max-only requests seek to the greatest term
# of a clean segment, so the cases below place dead terms at the byte-smallest
# and byte-greatest positions and combine min/max with consumers that force
# full enumeration. Background maintenance is disabled; visibility is driven
# by VACUUM (REFRESH_TABLE) only, so deletion masks persist.

statement ok
CREATE TEXT SEARCH DICTIONARY mmx_kw(template = 'keyword')

statement ok
CREATE TABLE mmx1(id INTEGER PRIMARY KEY, cat VARCHAR NOT NULL, nul VARCHAR)

statement ok
CREATE INDEX mmx1_idx ON mmx1 USING inverted(cat mmx_kw, nul mmx_kw)
    WITH (refresh_interval = 0, compaction_interval = 0)

statement ok
INSERT INTO mmx1 VALUES
  (1, 'aa', NULL), (2, 'ab', NULL), (3, 'ac', NULL), (4, 'ba', NULL),
  (5, 'bd', NULL), (6, 'bm', NULL), (7, 'bt', NULL), (8, 'bz', NULL),
  (9, 'cc', NULL), (10, 'cc', NULL), (11, 'yy', NULL), (12, 'zx', NULL),
  (13, 'zz', NULL)

statement ok
VACUUM (REFRESH_TABLE) mmx1;

# Clean segment: min-only stop and max-only seek shortcuts.
query T
SELECT min(cat) AS mn FROM mmx1_idx
----
mn
aa

query T
SELECT max(cat) AS mx FROM mmx1_idx
----
mx
zz

# min + max in one query forces full enumeration.
query TT
SELECT min(cat) AS mn, max(cat) AS mx FROM mmx1_idx
----
mn	mx
aa	zz

query II
SELECT (SELECT count(DISTINCT cat) FROM mmx1_idx) AS idx_cnt,
       (SELECT count(DISTINCT cat) FROM mmx1) AS tbl_cnt
----
idx_cnt	tbl_cnt
12	12

# A column that is NULL for every row exposes no terms: count 0, min/max NULL.
query ITT
SELECT count(DISTINCT nul) AS cnt, min(nul) AS mn, max(nul) AS mx FROM mmx1_idx
----
cnt	mn	mx
0	NULL	NULL

query ITT
SELECT count(DISTINCT nul) AS cnt, min(nul) AS mn, max(nul) AS mx FROM mmx1
----
cnt	mn	mx
0	NULL	NULL

# WHERE acceptors narrow the enumerated range for explicit ts_dict_min/max.
query TT
SELECT ts_dict_min(cat) AS lo, ts_dict_max(cat) AS hi
FROM mmx1_idx WHERE cat LIKE 'b%'
----
lo	hi
ba	bz

query
EXPLAIN SELECT ts_dict_min(cat) AS lo, ts_dict_max(cat) AS hi
FROM mmx1_idx WHERE cat LIKE 'b%'
----
QUERY PLAN
┌───────────────────────────┐
│    UNGROUPED_AGGREGATE    │
│    ────────────────────   │
│        Aggregates:        │
│          min(#0)          │
│          max(#1)          │
│                           │
│           ~1 row          │
└─────────────┬─────────────┘
┌─────────────┴─────────────┐
│         PROJECTION        │
│    ────────────────────   │
│  sdb_inverted_index_term$ │
│  sdb_inverted_index_term$ │
│                           │
│           ~1 row          │
└─────────────┬─────────────┘
┌─────────────┴─────────────┐
│       HASH_GROUP_BY       │
│    ────────────────────   │
│         Groups: #0        │
│                           │
│           ~1 row          │
└─────────────┬─────────────┘
┌─────────────┴─────────────┐
│         PROJECTION        │
│    ────────────────────   │
│             #0            │
│                           │
│          ~2 rows          │
└─────────────┬─────────────┘
┌─────────────┴─────────────┐
│       IRESEARCH_SCAN      │
│    ────────────────────   │
│      Index: mmx1_idx      │
│                           │
│          Filter:          │
│  ┌─────────────────────┐  │
│  │┌───────────────────┐│  │
│  ││    STARTS_WITH    ││  │
│  ││    ────────────   ││  │
│  ││  cat(string) 'b'  ││  │
│  ││     limit=1024    ││  │
│  │└───────────────────┘│  │
│  └─────────────────────┘  │
│                           │
│        TsDict: cat        │
│                           │
│        Projections:       │
│  sdb_inverted_index_term$ │
│                           │
│          ~2 rows          │
└───────────────────────────┘

query TT
SELECT ts_dict_min(cat) AS lo, ts_dict_max(cat) AS hi
FROM mmx1_idx WHERE cat = 'bm'
----
lo	hi
bm	bm

query TT
SELECT ts_dict_min(cat) AS lo, ts_dict_max(cat) AS hi
FROM mmx1_idx WHERE cat BETWEEN 'ac' AND 'bt'
----
lo	hi
ac	bt

query TT
SELECT min(cat) AS lo, max(cat) AS hi FROM mmx1 WHERE cat LIKE 'b%'
----
lo	hi
ba	bz

# min combined with ts_dict_count: the min-only stop must not apply, so the
# count list stays complete (12 terms covering all 13 live documents).
query TII
SELECT min(cat) AS mn, len(ts_dict_count(cat)) AS n_terms,
       list_sum(ts_dict_count(cat)) AS docs
FROM mmx1_idx
----
mn	n_terms	docs
aa	12	13

query TT
SELECT max(cat) AS mx, list_sort(ts_dict_agg(cat)) AS terms FROM mmx1_idx
----
mx	terms
zz	{aa,ab,ac,ba,bd,bm,bt,bz,cc,yy,zx,zz}

# Kill the four byte-smallest terms, the three byte-greatest terms and both
# boundary terms of the b-range. The segment stays dirty (masks only).
statement ok
DELETE FROM mmx1 WHERE cat IN ('aa', 'ab', 'ac', 'ba', 'bz', 'yy', 'zx', 'zz')

statement ok
VACUUM (REFRESH_TABLE) mmx1;

# min probes across the four consecutive dead prefix terms to the first live
# one; dirty max enumerates fully past the dead tail to the last live term.
query T
SELECT min(cat) AS mn FROM mmx1_idx
----
mn
bd

query T
SELECT max(cat) AS mx FROM mmx1_idx
----
mx
cc

query TT
SELECT min(cat) AS mn, max(cat) AS mx FROM mmx1_idx
----
mn	mx
bd	cc

query II
SELECT (SELECT count(DISTINCT cat) FROM mmx1_idx) AS idx_cnt,
       (SELECT count(DISTINCT cat) FROM mmx1) AS tbl_cnt
----
idx_cnt	tbl_cnt
4	4

# Dead terms sit exactly at the min and max positions of the accepted range.
query TT
SELECT ts_dict_min(cat) AS lo, ts_dict_max(cat) AS hi
FROM mmx1_idx WHERE cat LIKE 'b%'
----
lo	hi
bd	bt

query TT
SELECT ts_dict_min(cat) AS lo, ts_dict_max(cat) AS hi
FROM mmx1_idx WHERE cat BETWEEN 'ba' AND 'zz'
----
lo	hi
bd	cc

query TT
SELECT ts_dict_min(cat) AS lo, ts_dict_max(cat) AS hi
FROM mmx1_idx WHERE cat = 'bm'
----
lo	hi
bm	bm

# Equality on a dead term: the dictionary still stores it, the liveness probe
# drops it. Equality on a term that never existed behaves the same.
query TT
SELECT ts_dict_min(cat) AS lo, ts_dict_max(cat) AS hi
FROM mmx1_idx WHERE cat = 'ba'
----
lo	hi
NULL	NULL

query TT
SELECT ts_dict_min(cat) AS lo, ts_dict_max(cat) AS hi
FROM mmx1_idx WHERE cat = 'bq'
----
lo	hi
NULL	NULL

query TT
SELECT min(cat) AS lo, max(cat) AS hi FROM mmx1 WHERE cat LIKE 'b%'
----
lo	hi
bd	bt

# Consumer combination on the dirty segment: min stays correct and the count
# list is complete (4 terms, 5 live documents -- 'cc' counts two).
query TII
SELECT min(cat) AS mn, len(ts_dict_count(cat)) AS n_terms,
       list_sum(ts_dict_count(cat)) AS docs
FROM mmx1_idx
----
mn	n_terms	docs
bd	4	5

query TT
SELECT max(cat) AS mx, list_sort(ts_dict_agg(cat)) AS terms FROM mmx1_idx
----
mx	terms
cc	{bd,bm,bt,cc}

# Implicit min/max with a WHERE clause fall back to the regular document scan
# (conversion requires a bare aggregate-over-scan shape); explicit
# ts_dict_min/ts_dict_max keep the dictionary and apply the same-field
# post-filter over emitted terms, forcing full enumeration so min/max see the
# filtered set: 'a' and 'z' sit at the shortcut positions but fail the filter.
statement ok
CREATE TABLE mmx2(id INTEGER PRIMARY KEY, cat VARCHAR NOT NULL)

statement ok
CREATE INDEX mmx2_idx ON mmx2 USING inverted(cat mmx_kw)
    WITH (refresh_interval = 0, compaction_interval = 0)

statement ok
INSERT INTO mmx2 VALUES (1, 'a'), (2, 'bb'), (3, 'cc'), (4, 'z')

statement ok
VACUUM (REFRESH_TABLE) mmx2;

query T
SELECT min(cat) AS mn FROM mmx2_idx WHERE length(cat) = 2
----
mn
bb

query T
SELECT max(cat) AS mx FROM mmx2_idx WHERE length(cat) = 2
----
mx
cc

query TT
SELECT ts_dict_min(cat) AS mn, ts_dict_max(cat) AS mx FROM mmx2_idx
WHERE length(cat) = 2
----
mn	mx
bb	cc

query
EXPLAIN SELECT ts_dict_min(cat) AS mn, ts_dict_max(cat) AS mx FROM mmx2_idx
WHERE length(cat) = 2
----
QUERY PLAN
┌───────────────────────────┐
