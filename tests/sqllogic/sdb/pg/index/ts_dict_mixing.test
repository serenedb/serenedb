hash-threshold 100

statement ok
SET compaction_interval = 0

statement ok
SET refresh_interval = 0

statement ok
CREATE TEXT SEARCH DICTIONARY mix_kw(template = 'keyword')

statement ok
CREATE TABLE mixt(id INTEGER PRIMARY KEY, cat VARCHAR NOT NULL, opt VARCHAR,
                  num INTEGER)

statement ok
CREATE INDEX mixt_idx ON mixt USING inverted(cat mix_kw, opt mix_kw)
    WITH (refresh_interval = 0, compaction_interval = 0)

statement ok
INSERT INTO mixt VALUES
  (1, 'red',   'x',  10),
  (2, 'green', NULL, 20),
  (3, 'red',   'y',  30),
  (4, 'blue',  'x',  40),
  (5, 'amber', NULL, 50)

statement ok
VACUUM (REFRESH_TABLE) mixt;

query ITTT
SELECT count(DISTINCT cat) AS cnt, min(cat) AS mn, max(cat) AS mx,
       list_sort(array_agg(DISTINCT cat)) AS lst
FROM mixt_idx
----
cnt	mn	mx	lst
4	amber	red	{amber,blue,green,red}

query
EXPLAIN SELECT count(DISTINCT cat) AS cnt, min(cat) AS mn, max(cat) AS mx,
       list_sort(array_agg(DISTINCT cat)) AS lst
FROM mixt_idx
----
QUERY PLAN
╭─ PROJECTION ─────────────────────────────╮
│ Projections: cnt, mn, mx, lst            │
│ ~1 row                                   │
╰─────────────────────┬────────────────────╯
╭─ UNGROUPED_AGGREGATE ────────────────────╮
│ Aggregates:                              │
│ count(#0), min(#0), max(#0),             │
│ list(#0) FILTER (WHERE #1) Filter: #1    │
│ ~1 row                                   │
╰─────────────────────┬────────────────────╯
╭─ PROJECTION ────────┴────────────────────╮
│ Projections:                             │
│ sdb_inverted_index_term$cat,             │
│ sdb_inverted_index_term$cat IS NOT NULL  │
│ ~2 rows                                  │
╰─────────────────────┬────────────────────╯
╭─ HASH_GROUP_BY ─────┴────────────────────╮
│ Groups: #0                               │
│ ~2 rows                                  │
╰─────────────────────┬────────────────────╯
╭─ IRESEARCH_SCAN ────┴────────────────────╮
│ Index: mixt_idx                          │
│ TsDict: cat                              │
│ Projections: sdb_inverted_index_term$cat │
│ ~4 rows                                  │
╰──────────────────────────────────────────╯

