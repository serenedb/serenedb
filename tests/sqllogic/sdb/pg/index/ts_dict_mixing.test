       min(cat) AS mn
FROM mixt_idx
----
terms	cnt	mn
{amber,blue,green,red}	4	amber

query TT
SELECT ts_dict_min(cat) AS dmn, min(cat) AS mn FROM mixt_idx
----
dmn	mn
amber	amber

query TT
SELECT list_sort(ts_dict_count(cat)) AS counts, max(cat) AS mx FROM mixt_idx
----
counts	mx
{1,1,1,2}	red

query TIT
SELECT unnest(ts_dict_agg(cat)) AS term, unnest(ts_dict_count(cat)) AS docs,
       max(cat) AS mx
FROM mixt_idx ORDER BY term
----
term	docs	mx
amber	1	red
blue	1	red
green	1	red
red	2	red

# Ungrouped mixed aggregates split into a term-dict scan and a document scan
# cross-joined; each side computes its own aggregates.
query TI
SELECT list_sort(ts_dict_agg(cat)) AS a, count(*) AS c FROM mixt_idx
----
a	c
{amber,blue,green,red}	5

query TI
SELECT ts_dict_min(cat) AS mn, sum(id) AS s FROM mixt_idx
----
mn	s
amber	15

# The WHERE applies to both sides: term filter on the dict scan, document
# filter on the count.
query TI
SELECT list_sort(ts_dict_agg(cat)) AS a, count(*) AS c FROM mixt_idx
WHERE cat @@ ts_starts_with('r')
----
a	c
{red}	2

# Grouped mixed aggregates stay rejected.
statement error
SELECT ts_dict_agg(cat), count(*) FROM mixt_idx GROUP BY opt
----
db error: ERROR: ts_dict_* aggregates cannot be combined with other aggregates over the same scan
HINT: compute the other aggregates in a separate subquery


# Window usage is rejected: a per-row window frame has no dictionary scan to
# claim, so the stub must not survive to execution.
statement error
SELECT ts_dict_agg(cat) OVER () FROM mixt_idx
----
db error: ERROR: ts_dict_agg() cannot be used as a window function
HINT: use it as a plain aggregate over an inverted index scan


statement error
SELECT ts_dict_min(cat) OVER (PARTITION BY opt) FROM mixt_idx
----
db error: ERROR: ts_dict_min() cannot be used as a window function
HINT: use it as a plain aggregate over an inverted index scan



