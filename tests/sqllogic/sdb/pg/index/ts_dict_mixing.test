hash-threshold 100

statement ok
CREATE TEXT SEARCH DICTIONARY mix_kw(template = 'keyword')

statement ok
CREATE TABLE mixt(id INTEGER PRIMARY KEY, cat VARCHAR NOT NULL, opt VARCHAR,
                  num INTEGER)

statement ok
CREATE INDEX mixt_idx ON mixt USING inverted(cat mix_kw, opt mix_kw)
    WITH (refresh_interval = 0, compaction_interval = 0)

statement ok
INSERT INTO mixt VALUES
  (1, 'red',   'x',  10),
  (2, 'green', NULL, 20),
  (3, 'red',   'y',  30),
  (4, 'blue',  'x',  40),
  (5, 'amber', NULL, 50)

statement ok
VACUUM (REFRESH_TABLE) mixt;

query ITTT
SELECT count(DISTINCT cat) AS cnt, min(cat) AS mn, max(cat) AS mx,
       list_sort(array_agg(DISTINCT cat)) AS lst
FROM mixt_idx
----
cnt	mn	mx	lst
4	amber	red	{amber,blue,green,red}

query
EXPLAIN SELECT count(DISTINCT cat) AS cnt, min(cat) AS mn, max(cat) AS mx,
       list_sort(array_agg(DISTINCT cat)) AS lst
FROM mixt_idx
----
QUERY PLAN
в•ӯв”Җ PROJECTION в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®
в”Ӯ Projections: cnt, mn, mx, lst            в”Ӯ
в”Ӯ ~1 row                                   в”Ӯ
в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ
в•ӯв”Җ UNGROUPED_AGGREGATE в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®
в”Ӯ Aggregates:                              в”Ӯ
в”Ӯ count(#0), min(#0), max(#0),             в”Ӯ
в”Ӯ list(#0) FILTER (WHERE #1) Filter: #1    в”Ӯ
в”Ӯ ~1 row                                   в”Ӯ
в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ
