query I
SELECT count(DISTINCT cat) AS c FROM mixt_idx HAVING c > 1
----
c
4

query I
SELECT count(*) AS n
FROM (SELECT count(DISTINCT cat) AS c FROM mixt_idx HAVING c > 10) x
----
n
0

query I
SELECT count(DISTINCT cat) AS c FROM mixt_idx ORDER BY min(cat)
----
c
4


# A pure ts_dict aggregate under GROUP BY has no sibling aggregate to trip
# the mixed guard; it must still reject cleanly (the conversion would leave
# the group key referencing a document column the term scan never exposes).
statement error
SELECT ts_dict_agg(cat) FROM mixt_idx GROUP BY opt
----
db error: ERROR: ts_dict_* aggregates cannot be combined with GROUP BY
HINT: compute the ts_dict_* aggregate in a separate subquery


statement ok
DROP TABLE mixt

statement ok
DROP TEXT SEARCH DICTIONARY mix_kw
