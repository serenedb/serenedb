hash-threshold 100

# Several term acceptors on the enumerated field compose: the most selective
# claimable acceptor drives the enumeration (ByTerm > ByTerms > ByPrefix /
# ByRange > automatons) and every other claimable acceptor becomes a term
# predicate checked per emitted term inside the scan, so @@ ts_* matchers can
# be combined. Scalar shapes keep post-filtering above the scan. The score
# column reflects the DRIVING acceptor only. Background maintenance disabled;
# visibility driven by VACUUM (REFRESH_TABLE).

statement ok
CREATE TEXT SEARCH DICTIONARY tp_kw(template = 'keyword')

statement ok
CREATE TEXT SEARCH DICTIONARY tp_tx(template = 'text', locale = 'en_US.UTF-8',
    case = 'lower', stemming = false, accent = false, frequency = true,
    position = true)

statement ok
CREATE TABLE tp(id INTEGER PRIMARY KEY, cat VARCHAR NOT NULL, body VARCHAR)

statement ok
CREATE INDEX tp_idx ON tp USING inverted(cat tp_kw, body tp_tx)
    WITH (refresh_interval = 0, compaction_interval = 0)

statement ok
INSERT INTO tp VALUES
  (1, 'apple',   'aple axle apple'),
  (2, 'apricot', 'apex date'),
  (3, 'banana',  'banana'),
  (4, 'avocado', 'amaze arise')

statement ok
VACUUM (REFRESH_TABLE) tp;

# Two @@ matchers: the prefix drives, the regexp filters terms in the scan.
query T
SELECT unnest(ts_dict_agg(body)) AS term
FROM tp_idx WHERE body @@ ts_starts_with('a') AND body @@ ts_regexp('a.*e')
ORDER BY term
----
term
amaze
aple
apple
arise
axle

query
EXPLAIN SELECT unnest(ts_dict_agg(body)) AS term
FROM tp_idx WHERE body @@ ts_starts_with('a') AND body @@ ts_regexp('a.*e')
----
