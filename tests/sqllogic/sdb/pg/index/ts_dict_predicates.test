# The prefix outranks the levenshtein matcher, so it drives and the score
# column stays at the driver's constant 1 (not the fuzzy similarity).
query TR
SELECT unnest(ts_dict_agg(body)) AS term, unnest(ts_dict_score(body)) AS score
FROM tp_idx
WHERE body @@ ts_starts_with('ap') AND body @@ ts_levenshtein('aple', 1)
ORDER BY term
----
term	score
aple	1
apple	1
axle	1

# Two automaton-ranked matchers: the first conjunct drives, so the fuzzy
# similarity IS the score and the regexp filters.
query TR
SELECT unnest(ts_dict_agg(body)) AS term, unnest(ts_dict_score(body)) AS score
FROM tp_idx
WHERE body @@ ts_levenshtein('aple', 1) AND body @@ ts_regexp('a.*e')
ORDER BY term
----
term	score
aple	1
apple	1
axle	1

# The min-only stop composes with predicates: first live term passing them.
query T
SELECT ts_dict_min(cat) AS mn
FROM tp_idx WHERE cat LIKE 'a%' AND cat > 'apple'
----
mn
apricot

# Disjoint acceptors fuse into an automaton that accepts nothing: the scan
# enumerates no terms and the result is empty, not an error.
query T
SELECT unnest(ts_dict_agg(body)) AS term
FROM tp_idx WHERE body @@ ts_starts_with('b') AND body @@ ts_regexp('a.*')
ORDER BY term
----
term

# Boolean combinations of acceptors on the enumerated field compile into a
# single term predicate: the tree is checked per term inside the scan. With a
# claimable AND-sibling that sibling drives; a pure disjunction enumerates the
# full dictionary under the predicate.
query T
SELECT unnest(ts_dict_agg(body)) AS term
FROM tp_idx
WHERE body @@ ts_starts_with('a')
  AND (body @@ ts_regexp('.*x.*') OR body @@ ts_levenshtein('aple', 1))
ORDER BY term
----
term
apex
aple
apple
axle
date

query T
SELECT unnest(ts_dict_agg(body)) AS term
FROM tp_idx
WHERE body @@ ts_starts_with('ax') OR body @@ ts_starts_with('ban')
ORDER BY term
----
term
aple
apple
axle
banana

query
EXPLAIN SELECT unnest(ts_dict_agg(body)) AS term
FROM tp_idx
WHERE body @@ ts_starts_with('ax') OR body @@ ts_starts_with('ban')
----
