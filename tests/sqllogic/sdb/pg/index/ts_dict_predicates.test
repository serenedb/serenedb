query T
SELECT unnest(ts_dict_agg(cat)) AS term
FROM tp_idx
WHERE cat IN ('apple', 'banana') OR cat = 'avocado'
ORDER BY term
----
term
apple
avocado
banana

# The clean-segment max seek must not fire under predicates: the dictionary
# max 'banana' is rejected and the greatest ACCEPTED term wins.
query T
SELECT ts_dict_max(cat) AS mx
FROM tp_idx WHERE cat LIKE 'ap%' OR cat = 'apple'
----
mx
apricot

query T
SELECT ts_dict_min(cat) AS mn
FROM tp_idx WHERE cat LIKE 'av%' OR cat = 'banana'
----
mn
avocado

query T
SELECT unnest(ts_dict_agg(cat)) AS term
FROM tp_idx WHERE cat = 'apple' OR body @@ ts_starts_with('a')
ORDER BY term
----
term
apple
apricot
avocado

# Term-level filtering pushes down from the outer/HAVING position: the
# filter over the emitted terms claims into the dictionary enumeration.
query T
SELECT t AS term FROM (SELECT unnest(ts_dict_agg(body)) AS t FROM tp_idx) sub
WHERE t LIKE 'ap%' ORDER BY t
----
term
apex
aple
apple

query T
SELECT t AS term
FROM (SELECT unnest(ts_dict_agg(body)) AS t FROM tp_idx) sub
GROUP BY t HAVING t LIKE 'ap%' ORDER BY t
----
term
apex
aple
apple

# The pushed term filter claims into the enumeration: the scan carries the
# prefix acceptor, no FILTER node remains above.
query T
EXPLAIN SELECT t AS term
FROM (SELECT unnest(ts_dict_agg(body)) AS t FROM tp_idx) sub
WHERE t LIKE 'ap%'
----
