query TI
SELECT unnest(ts_dict_agg(cat)) AS term, unnest(ts_dict_count(cat)) AS docs
FROM tp_idx WHERE cat LIKE 'a%' AND cat IN ('apple', 'banana', 'avocado')
ORDER BY term
----
term	docs
apple	1
avocado	1

# Driver + term predicate + scalar post-filter in one WHERE.
query T
SELECT unnest(ts_dict_agg(cat)) AS term
FROM tp_idx
WHERE cat LIKE 'a%' AND cat BETWEEN 'ap' AND 'az' AND length(cat) = 7
ORDER BY term
----
term
apricot
avocado

query
EXPLAIN SELECT unnest(ts_dict_agg(cat)) AS term
FROM tp_idx
WHERE cat LIKE 'a%' AND cat BETWEEN 'ap' AND 'az' AND length(cat) = 7
----
