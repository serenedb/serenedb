# Term condition + document WHERE: the term filter drives the enumeration,
# counts come from the doc-restricted set (docs with a d-token).
query T
SELECT t AS term
FROM (SELECT unnest(ts_dict_agg(body)) AS t FROM tp_idx
      WHERE body @@ ts_starts_with('d')) sub
WHERE t LIKE 'ap%' ORDER BY t
----
term
apex

# Same-field OR of mixed acceptor shapes fuses into ONE automaton driver
# (wildcard forces scattered acceptance; term and prefix ride along).
query T
SELECT unnest(ts_dict_agg(cat)) AS term FROM tp_idx
WHERE cat LIKE 'ap%' OR cat = 'banana' OR cat LIKE '%cado'
ORDER BY term
----
term
apple
apricot
avocado
banana

query
EXPLAIN SELECT unnest(ts_dict_agg(cat)) AS term FROM tp_idx
WHERE cat LIKE 'ap%' OR cat = 'banana' OR cat LIKE '%cado'
----
