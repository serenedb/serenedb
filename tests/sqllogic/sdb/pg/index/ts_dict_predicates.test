# Negation claims into the tree: SQL NOT and the TSQUERY !! prefix both
# lower to an exclusion checked per term.
query T
SELECT unnest(ts_dict_agg(body)) AS term
FROM tp_idx
WHERE body @@ ts_starts_with('a') AND NOT (body @@ ts_regexp('.*e'))
ORDER BY term
----
term

query T
SELECT unnest(ts_dict_agg(body)) AS term
FROM tp_idx
WHERE body @@ ts_starts_with('a') AND body @@ (!! ts_regexp('.*e'))
ORDER BY term
----
term

query T
SELECT unnest(ts_dict_agg(body)) AS term
FROM tp_idx
WHERE NOT (body @@ ts_starts_with('a'))
ORDER BY term
----
term
banana

query
EXPLAIN SELECT unnest(ts_dict_agg(body)) AS term
FROM tp_idx
WHERE body @@ ts_starts_with('a') AND NOT (body @@ ts_regexp('.*e'))
----
