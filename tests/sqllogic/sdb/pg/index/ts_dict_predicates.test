# Nested OR parenthesization converges to the same fused automaton.
query T
SELECT unnest(ts_dict_agg(cat)) AS term FROM tp_idx
WHERE (cat LIKE 'ap%' OR cat = 'banana') OR cat LIKE '%cado'
ORDER BY term
----
term
apple
apricot
avocado
banana

# A range disjunct is not regex-renderable: the OR stays a disjunction and
# still enumerates correctly.
query T
SELECT unnest(ts_dict_agg(cat)) AS term FROM tp_idx
WHERE cat BETWEEN 'apple' AND 'az' OR cat = 'kiwi'
ORDER BY term
----
term
apple
apricot
avocado

query
EXPLAIN SELECT unnest(ts_dict_agg(cat)) AS term FROM tp_idx
WHERE cat BETWEEN 'apple' AND 'az' OR cat = 'kiwi'
