│ ~0 rows                                   │
╰─────────────────────┬─────────────────────╯
╭─ IRESEARCH_SCAN ────┴─────────────────────╮
│ Index: rtab_idx                           │
│ Index Filter:                             │
│ ╭─ Term ──────────────╮                   │
│ │ Field: body(string) │                   │
│ │ Value: failed       │                   │
│ ╰─────────────────────╯                   │
│ Column Filter: svc = 'frontend'           │
│ TsDict: sev                               │
│ Projections:                              │
│ sdb_inverted_index_term$sev,              │
│ sdb_inverted_index_term_count$sev         │
│ ~1 row                                    │
╰───────────────────────────────────────────╯

query TI
SELECT sev, count(*) AS n FROM rbase
WHERE svc = 'frontend' AND body LIKE '%failed%' GROUP BY sev ORDER BY n DESC, sev
----
sev	n
ERROR	3
WARN	1

