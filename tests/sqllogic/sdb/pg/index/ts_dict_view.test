# --- array_agg keeps a NULL element the term dictionary has none for, and the
# --- view cannot prove NOT NULL, so it stays a document scan (result correct).
query T
SELECT array_agg(DISTINCT Brand ORDER BY Brand) AS lst FROM vlog_idx
----
lst
{CLAAS,FENDT,NULL}

query
EXPLAIN SELECT array_agg(DISTINCT Brand) FROM vlog_idx
----
QUERY PLAN
╭─ UNGROUPED_AGGREGATE ──────────────╮
│ Aggregates: array_agg(DISTINCT #0) │
│ ~1 row                             │
╰──────────────────┬─────────────────╯
╭─ IRESEARCH_SCAN ─┴─────────────────╮
│ Index: vlog_idx                    │
│ Projections: brand                 │
│ ~5 rows                            │
╰────────────────────────────────────╯

query T
SELECT array_agg(DISTINCT brand ORDER BY brand) AS lst FROM vbase
----
lst
{CLAAS,FENDT,NULL}

# --- array_agg over the NOT-NULL-in-base column: no null rows, so no NULL
# --- element -- still a document scan on the view.
query T
SELECT array_agg(DISTINCT Status ORDER BY Status) AS lst FROM vlog_idx
----
lst
{done,open}

# --- Explicit ts_dict_* over the view: aggregate the dictionary directly (no
# --- NULL element -- these read terms, not documents).
query T
SELECT list_sort(ts_dict_agg(Brand)) AS terms FROM vlog_idx
----
terms
{CLAAS,FENDT}

query
EXPLAIN SELECT ts_dict_agg(Brand) FROM vlog_idx
----
QUERY PLAN
╭─ UNGROUPED_AGGREGATE ──────────────────────╮
│ Aggregates:                                │
│ list(#0) FILTER (WHERE #1) Filter: #1      │
│ ~1 row                                     │
╰──────────────────────┬─────────────────────╯
╭─ PROJECTION ─────────┴─────────────────────╮
│ Projections:                               │
│ sdb_inverted_index_term$brand,             │
│ sdb_inverted_index_term$brand IS NOT NULL  │
│ ~1 row                                     │
╰──────────────────────┬─────────────────────╯
╭─ HASH_GROUP_BY ──────┴─────────────────────╮
│ Groups: #0                                 │
│ ~1 row                                     │
╰──────────────────────┬─────────────────────╯
╭─ IRESEARCH_SCAN ─────┴─────────────────────╮
│ Index: vlog_idx                            │
│ TsDict: brand                              │
│ Projections:                               │
│ sdb_inverted_index_term$brand              │
│ ~2 rows                                    │
╰────────────────────────────────────────────╯

query TI
SELECT t AS term, c AS docs
FROM (SELECT unnest(ts_dict_agg(Brand)) AS t, unnest(ts_dict_count(Brand)) AS c
      FROM vlog_idx) s ORDER BY t
----
term	docs
CLAAS	1
FENDT	3

query TI
SELECT t AS term, f AS freq
FROM (SELECT unnest(ts_dict_agg(Brand)) AS t, unnest(ts_dict_freq(Brand)) AS f
      FROM vlog_idx) s ORDER BY t
----
term	freq
CLAAS	1
FENDT	3

query TT
SELECT ts_dict_min(Status) AS lo, ts_dict_max(Status) AS hi FROM vlog_idx
----
lo	hi
done	open

# --- ts_dict_* over a VARCHAR[] keyword column on the view: array elements are
# --- the field's terms; per-term doc counts dedup within a row.
query TI
SELECT t AS term, c AS docs
FROM (SELECT unnest(ts_dict_agg(Tags)) AS t, unnest(ts_dict_count(Tags)) AS c
      FROM vlog_idx) s ORDER BY t
----
term	docs
blue	1
fast	2
green	1
red	2

query
EXPLAIN SELECT unnest(ts_dict_agg(Tags)), unnest(ts_dict_count(Tags))
FROM vlog_idx
