statement ok
CREATE TABLE wdt(id INTEGER PRIMARY KEY, body VARCHAR)

statement ok
CREATE INDEX wdt_idx ON wdt USING inverted(body wd_tx)
    WITH (refresh_interval = 0, compaction_interval = 0)

statement ok
INSERT INTO wdt VALUES
  (1, 'apple banana'),
  (2, 'Aple cherry'),
  (3, 'appl banana'),
  (4, 'axle date')

statement ok
VACUUM (REFRESH_TABLE) wdt;

statement ok
DELETE FROM wdt WHERE id IN (3, 4)

statement ok
VACUUM (REFRESH_TABLE) wdt;

query TII
SELECT unnest(ts_dict_agg(body)) AS term,
       unnest(ts_dict_count(body)) AS docs,
       unnest(ts_dict_freq(body)) AS freq
FROM wdt_idx ORDER BY term
----
term	docs	freq
aple	1	1
apple	1	1
banana	1	2
cherry	1	1

query TIR
SELECT unnest(ts_dict_agg(body)) AS term,
       unnest(ts_dict_count(body)) AS docs,
       unnest(ts_dict_score(body)) AS score
FROM wdt_idx WHERE body @@ ts_levenshtein('apple', 1) ORDER BY term
----
term	docs	score
aple	1	0.75
apple	1	1

