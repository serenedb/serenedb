# Cross-field WHERE = doc restriction; deletes stay masked out of the bitset.
query T
SELECT list_sort(ts_dict_agg(cat)) FROM wdk_idx WHERE tag = 'x'
----
list_sort
{apple,lime,pear,pine}


# Multi-field WHERE routes the LIKE to cat; tag enumerates fully. Dead p*
# terms (peach, plum) stay masked out.
query TT
SELECT list_sort(ts_dict_agg(cat)) AS c, list_sort(ts_dict_agg(tag)) AS t FROM wdk_idx WHERE cat LIKE 'p%'
----
c	t
{pear,pine}	{x}


statement ok
CREATE TABLE wdt(id INTEGER PRIMARY KEY, body VARCHAR)

statement ok
CREATE INDEX wdt_idx ON wdt USING inverted(body wd_tx)
    WITH (refresh_interval = 0, compaction_interval = 0)

statement ok
INSERT INTO wdt VALUES
  (1, 'apple banana'),
  (2, 'Aple cherry'),
  (3, 'appl banana'),
  (4, 'axle date')

statement ok
VACUUM (REFRESH_TABLE) wdt;

statement ok
DELETE FROM wdt WHERE id IN (3, 4)

statement ok
VACUUM (REFRESH_TABLE) wdt;

query TII
SELECT unnest(ts_dict_agg(body)) AS term,
       unnest(ts_dict_count(body)) AS docs,
       unnest(ts_dict_freq(body)) AS freq
FROM wdt_idx ORDER BY term
----
term	docs	freq
aple	1	1
apple	1	1
banana	1	2
cherry	1	1

query TIR
SELECT unnest(ts_dict_agg(body)) AS term,
       unnest(ts_dict_count(body)) AS docs,
       unnest(ts_dict_score(body)) AS score
FROM wdt_idx WHERE body @@ ts_levenshtein('apple', 1) ORDER BY term
----
term	docs	score
aple	1	1
apple	1	1
banana	1	1
cherry	1	1

query
EXPLAIN SELECT unnest(ts_dict_agg(body)) AS term
FROM wdt_idx WHERE body @@ ts_levenshtein('apple', 1)
----
QUERY PLAN
╭─ HASH_GROUP_BY ────────────────╮
│ Groups: #0                     │
│ ~0 rows                        │
╰────────────────┬───────────────╯
╭─ IRESEARCH_SCAN ───────────────╮
│ Index: wdt_idx                 │
│ Index Filter:                  │
│ ╭─ Levenshtein ───────╮        │
│ │ Field: body(string) │        │
│ │ Target: apple       │        │
│ │ Max Terms: 1024     │        │
│ ╰─────────────────────╯        │
│ TsDict: body                   │
│ Projections:                   │
│ sdb_inverted_index_term$body   │
│ ~1 row                         │
╰────────────────────────────────╯

query T
SELECT unnest(ts_dict_agg(body)) AS term
FROM wdt_idx WHERE body @@ ts_starts_with('ap') ORDER BY term
----
term
aple
apple
banana
cherry

query T
SELECT unnest(ts_dict_agg(body)) AS term
FROM wdt_idx WHERE body @@ ts_regexp('a[a-z]*e') ORDER BY term
----
term
aple
apple
banana
cherry

query I
SELECT count(*) AS n FROM wdt_idx WHERE body @@ ts_starts_with('ap')
----
n
2

query T
SELECT unnest(ts_dict_agg(body)) AS term
FROM wdt_idx WHERE length(body) = 4 ORDER BY term
----
term
aple

query T
SELECT unnest(ts_dict_agg(body)) AS term
FROM wdt_idx WHERE body <> 'apple' ORDER BY term
----
term
aple
banana
cherry

