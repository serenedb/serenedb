query T
SELECT unnest(ts_dict_agg(body)) AS term
FROM wdt_idx WHERE body @@ ts_starts_with('ap') ORDER BY term
----
term
aple
apple

query T
SELECT unnest(ts_dict_agg(body)) AS term
FROM wdt_idx WHERE body @@ ts_regexp('a[a-z]*e') ORDER BY term
----
term
aple
apple

query I
SELECT count(*) AS n FROM wdt_idx WHERE body @@ ts_starts_with('ap')
----
n
2

query T
SELECT unnest(ts_dict_agg(body)) AS term
FROM wdt_idx WHERE length(body) = 4 ORDER BY term
----
