hash-threshold 100

statement ok
CREATE TEXT SEARCH DICTIONARY wd_kw(template = 'keyword')

statement ok
CREATE TEXT SEARCH DICTIONARY wd_tx(template = 'text', locale = 'en_US.UTF-8',
    case = 'lower', stemming = false, accent = false, frequency = true,
    position = true)

statement ok
CREATE TABLE wdk(id INTEGER PRIMARY KEY, cat VARCHAR NOT NULL, tag VARCHAR)

statement ok
CREATE INDEX wdk_idx ON wdk USING inverted(cat wd_kw, tag wd_kw)
    WITH (refresh_interval = 0, compaction_interval = 0)

statement ok
INSERT INTO wdk VALUES
  (1, 'apple', 'x'),
  (2, 'fig', 'x'),
  (3, 'grape', 'x'),
  (4, 'grape', 'x'),
  (5, 'grape', 'x'),
  (6, 'kiwi', 'x'),
  (7, 'lime', 'x'),
  (8, 'peach', 'x'),
  (9, 'pear', 'x'),
  (10, 'pine', 'x'),
  (11, 'plum', 'x'),
  (12, 'quail', 'x'),
  (13, 'quince', 'x')

statement ok
VACUUM (REFRESH_TABLE) wdk;

statement ok
DELETE FROM wdk WHERE id IN (2, 5, 6, 8, 11, 12, 13)

statement ok
VACUUM (REFRESH_TABLE) wdk;

query TI
SELECT unnest(ts_dict_agg(cat)) AS term, unnest(ts_dict_count(cat)) AS docs
FROM wdk_idx ORDER BY term
----
term	docs
apple	1
grape	2
lime	1
pear	1
pine	1

