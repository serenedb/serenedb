INSERT INTO t_l1 VALUES (1, [100, 0, 0]::FLOAT[3]), (2, [50, 50, 50]::FLOAT[3]), (3, [50, 25, 50]::FLOAT[3]), (4, [50, 50, 100]::FLOAT[3]);

statement ok
VACUUM (UPDATE_INDEXES) t_l1;

query
SELECT id FROM l1_index ORDER BY l1_distance(emb, [0, 0, 0]::FLOAT[3]) LIMIT 2;
----
id
1
3


statement ok
CREATE TABLE t_err (id INT, emb FLOAT[3]);

statement error
CREATE INDEX bad_opt ON t_err USING inverted(emb hnsw (ef_search = 50));

statement error
CREATE INDEX bad_metric ON t_err USING inverted(emb hnsw (metric = 'manhattan'));

statement error
CREATE INDEX bad_m_low ON t_err USING inverted(emb hnsw (m = 1));

statement error
CREATE INDEX bad_m_high ON t_err USING inverted(emb hnsw (m = 200));

statement error
CREATE INDEX bad_ef ON t_err USING inverted(emb hnsw (m = 32, ef_construction = 8));

statement error
CREATE INDEX bad_m_type ON t_err USING inverted(emb hnsw (m = 'sixteen'));


query
