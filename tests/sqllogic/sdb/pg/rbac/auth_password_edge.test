# Password edge cases, serenedb-only (pg_authid.rolpassword is superuser-only
# and its verifier bytes aren't oracle-comparable):
#  * PASSWORD '' clears the password (stores no verifier) rather than storing a
#    verifier for the empty string.
#  * A real password stores a verifier; pg_authid.rolpassword is visible to the
#    superuser (pg_dumpall relies on this) and NULL for a passwordless role.
#
# Fixture prefix: ape_ (auth_password_edge).

statement ok
DROP ROLE IF EXISTS ape_empty;

statement ok
DROP ROLE IF EXISTS ape_pw;

statement ok
DROP ROLE IF EXISTS ape_none;


# PASSWORD '' is not a valid password -> cleared (rolpassword NULL).
statement ok
CREATE ROLE ape_empty LOGIN PASSWORD '';

query
SELECT rolpassword IS NULL FROM pg_authid WHERE rolname = 'ape_empty';
----
?column?
t


# A real password stores a SCRAM verifier, visible to the superuser.
statement ok
CREATE ROLE ape_pw LOGIN PASSWORD 'hunter2';

query
SELECT rolpassword IS NOT NULL AND rolpassword LIKE 'SCRAM-SHA-256$%'
FROM pg_authid WHERE rolname = 'ape_pw';
----
?column?
t


# A passwordless role has NULL rolpassword.
statement ok
CREATE ROLE ape_none;

query
SELECT rolpassword IS NULL FROM pg_authid WHERE rolname = 'ape_none';
----
?column?
t


# ---- cleanup ----
statement ok
DROP ROLE ape_empty;

statement ok
DROP ROLE ape_pw;

statement ok
DROP ROLE ape_none;
