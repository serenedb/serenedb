# SereneDB applies CREATE ROLE and GRANT immediately and does NOT roll them
# back; PostgreSQL is fully transactional for role DDL and GRANT, so a ROLLBACK
# undoes them (verified on PG19: after BEGIN/CREATE ROLE/ROLLBACK the role is
# gone, and after BEGIN/GRANT/ROLLBACK has_table_privilege is false).
#
# This pins SDB's non-transactional behavior: the role and the grant SURVIVE a
# ROLLBACK. (The runner drives BEGIN/CREATE/ROLLBACK as separate statements on
# one connection, which is enough to observe the divergence.)
#
# Lore: vedernikoff the role, the clickclack table. Self-cleaning.

statement ok
DROP TABLE IF EXISTS divcat_tx_clickclack;


statement ok
DROP ROLE IF EXISTS divcat_tx_vedernikoff;


# ---- BEGIN; CREATE ROLE; ROLLBACK -- the role persists on SDB ----

statement ok
BEGIN;


statement ok
CREATE ROLE divcat_tx_vedernikoff;


statement ok
ROLLBACK;


# Divergence: PG would report 0 here (the CREATE ROLE was rolled back); SDB
# kept the role.
query
SELECT count(*) AS n FROM pg_roles WHERE rolname = 'divcat_tx_vedernikoff';
----
n
1


# ---- BEGIN; GRANT; ROLLBACK -- the grant persists on SDB ----

statement ok
CREATE TABLE divcat_tx_clickclack (id int);


statement ok
BEGIN;


statement ok
GRANT SELECT ON divcat_tx_clickclack TO divcat_tx_vedernikoff;


statement ok
ROLLBACK;


# Divergence: PG would report f here (the GRANT was rolled back); SDB kept the
# privilege.
query
SELECT has_table_privilege('divcat_tx_vedernikoff', 'divcat_tx_clickclack', 'SELECT') AS sel;
----
sel
t


# ---- REVOKE inside a rolled-back txn also sticks (the inverse) ----

statement ok
BEGIN;


statement ok
REVOKE SELECT ON divcat_tx_clickclack FROM divcat_tx_vedernikoff;


statement ok
ROLLBACK;


# Divergence: PG would still show t (REVOKE rolled back); SDB applied the
# REVOKE and never restored it.
query
SELECT has_table_privilege('divcat_tx_vedernikoff', 'divcat_tx_clickclack', 'SELECT') AS sel;
----
sel
f


# Cleanup.
statement ok
DROP TABLE divcat_tx_clickclack;


statement ok
DROP ROLE divcat_tx_vedernikoff;
