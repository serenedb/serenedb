# serenedb-only DIVERGENCE: zero-referenced-column reads.
#
# SELECT enforcement is anchored on the binder's per-column read hook (the PG
# markVarForSelectPriv analogue). A relation that contributes NO referenced
# column to the query therefore escapes the check, so serenedb ALLOWS reads
# that PostgreSQL DENIES:
#   - SELECT count(*) FROM t            (no column referenced)
#   - SELECT 1 FROM t                   (no column referenced)
#   - SELECT a.x FROM a, t              (t cross-joined but never read)
#   - ... WHERE EXISTS (SELECT 1 FROM t)(t in subquery, no column read)
# PostgreSQL charges table-level SELECT on EVERY relation in the range table
# regardless of column references, so it denies all of the above.
#
# This test LOCKS DOWN CURRENT serenedb behavior (the reads succeed). It is a
# known, accepted divergence; if the bind-time enforcement is later extended to
# a per-relation (whole-table) check, the `statement ok` blocks below become
# `statement error` and this file moves/merges into any/pg/rbac.
#
# Cannot run on PostgreSQL (it would deny) and relies on serenedb's Trust-stub
# `connection ... user=` auth.
#
# Lore: clickclack is the accessible table; mop is the one vedernikoff was never
# granted.

statement ok
DROP TABLE IF EXISTS zcr_clickclack;


statement ok
DROP TABLE IF EXISTS zcr_mop;


statement ok
DROP ROLE IF EXISTS zcr_vedernikoff;


statement ok
CREATE ROLE zcr_vedernikoff LOGIN PASSWORD 'pw';


statement ok
CREATE TABLE zcr_clickclack (id int, payload text);


statement ok
CREATE TABLE zcr_mop (id int, label text);


statement ok
INSERT INTO zcr_clickclack VALUES (1, 'p1'), (2, 'p2');


statement ok
INSERT INTO zcr_mop VALUES (1, 'm1'), (2, 'm2');


# vedernikoff gets SELECT on clickclack only; NOTHING on mop.
statement ok
GRANT SELECT ON zcr_clickclack TO zcr_vedernikoff;


# Oracle: vedernikoff genuinely holds no privilege on mop.
query
SELECT has_table_privilege('zcr_vedernikoff','zcr_mop','SELECT') AS mop_select;
----
mop_select
f


# ---- As zcr_vedernikoff: each of these references NO column of mop ----
# PostgreSQL would raise "permission denied for table zcr_mop"; serenedb allows.

# count(*) over the un-granted table: allowed (divergence).
connection c_zcr user=zcr_vedernikoff
query
SELECT count(*) AS n FROM zcr_mop;
----
n
2


# SELECT constant from the un-granted table, no column referenced anywhere:
# allowed (divergence). (Adding a WHERE that touches a column would reference it
# and flip this to denied -- that boundary is exercised at the end.)
connection c_zcr user=zcr_vedernikoff
query
SELECT 1 AS one FROM zcr_mop;
----
one
1
1


# Cross join where mop is present but never read: allowed (divergence).
connection c_zcr user=zcr_vedernikoff
query
SELECT a.payload FROM zcr_clickclack a, zcr_mop b ORDER BY a.payload;
----
payload
p1
p1
p2
p2


# EXISTS subquery over the un-granted table (no column read): allowed
# (divergence).
connection c_zcr user=zcr_vedernikoff
query
SELECT a.payload FROM zcr_clickclack a WHERE EXISTS (SELECT 1 FROM zcr_mop) ORDER BY a.payload;
----
payload
p1
p2


# CONTRAST -- the moment a column of mop IS referenced, the per-column hook
# fires and serenedb denies it (byte-identical to PG). This is the boundary of
# the divergence.
connection c_zcr user=zcr_vedernikoff
statement error
SELECT b.label FROM zcr_clickclack a, zcr_mop b;
----
db error: ERROR: permission denied for table zcr_mop<slt:ignore>


connection c_zcr user=zcr_vedernikoff
statement error
SELECT a.payload FROM zcr_clickclack a JOIN zcr_mop b ON a.id = b.id;
----
db error: ERROR: permission denied for table zcr_mop<slt:ignore>


statement ok
DROP TABLE zcr_clickclack;


statement ok
DROP TABLE zcr_mop;


statement ok
DROP ROLE zcr_vedernikoff;
