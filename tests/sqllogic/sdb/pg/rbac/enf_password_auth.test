# serenedb-only: end-to-end per-role password authentication. CREATE ROLE ...
# PASSWORD stores a SCRAM-SHA-256 verifier on the role; the catalog-backed
# credential provider authenticates each connection against it. Cannot run on
# PostgreSQL: the shared PG test container runs HBA `trust`, so it never
# enforces (or rejects) a password, while serenedb enforces per-role passwords
# out of the box.
#
# Exercised: correct login, wrong password rejected, missing password rejected,
# one role's password does not work for another, ALTER ROLE changes/clears it,
# a role with no password logs in under trust, and an unknown role is refused
# (no silent superuser fallback).
#
# Lore: vedernikoff guards the MOP; clickclack tends the iceberg.

statement ok
DROP ROLE IF EXISTS pwa_vedernikoff;


statement ok
DROP ROLE IF EXISTS pwa_clickclack;


statement ok
DROP ROLE IF EXISTS pwa_trusty;


# Two login roles, each with its own password, plus one passwordless role.
statement ok
CREATE ROLE pwa_vedernikoff LOGIN PASSWORD 'mop_secret';


statement ok
CREATE ROLE pwa_clickclack LOGIN PASSWORD 'iceberg_secret';


statement ok
CREATE ROLE pwa_trusty LOGIN;


# --- correct password connects, with the role's own identity ---
connection c_ved user=pwa_vedernikoff password=mop_secret
query
SELECT current_user, current_setting('is_superuser') AS is_superuser;
----
current_user	is_superuser
pwa_vedernikoff	off


# --- a second role logs in with its own password ---
connection c_click user=pwa_clickclack password=iceberg_secret
query
SELECT current_user;
----
current_user
pwa_clickclack


# --- wrong password is rejected ---
connection c_ved_bad user=pwa_vedernikoff password=wrong_secret
statement error
SELECT 1;
----
db error: FATAL: password authentication failed for user "pwa_vedernikoff"<slt:ignore>


# --- empty password is rejected (the role has one set) ---
connection c_ved_empty user=pwa_vedernikoff password=
statement error
SELECT 1;
----
db error: FATAL: password authentication failed for user "pwa_vedernikoff"<slt:ignore>


# --- one role's password does not authenticate another role ---
connection c_cross user=pwa_clickclack password=mop_secret
statement error
SELECT 1;
----
db error: FATAL: password authentication failed for user "pwa_clickclack"<slt:ignore>


# --- a role with no stored password logs in under trust ---
connection c_trusty user=pwa_trusty password=anything_goes
query
SELECT current_user;
----
current_user
pwa_trusty


# --- an unknown role is refused, not silently downgraded to superuser ---
connection c_ghost user=pwa_phantom password=whatever
statement error
SELECT 1;
----
db error: FATAL: role "pwa_phantom" does not exist<slt:ignore>


# --- ALTER ROLE rotates the password: the old one stops working, new one works ---
connection default
statement ok
ALTER ROLE pwa_vedernikoff PASSWORD 'new_mop_secret';


connection c_ved_old user=pwa_vedernikoff password=mop_secret
statement error
SELECT 1;
----
db error: FATAL: password authentication failed for user "pwa_vedernikoff"<slt:ignore>


connection c_ved_new user=pwa_vedernikoff password=new_mop_secret
query
SELECT current_user;
----
current_user
pwa_vedernikoff


# --- ALTER ROLE ... PASSWORD NULL clears the password: trust login again ---
connection default
statement ok
ALTER ROLE pwa_vedernikoff PASSWORD NULL;


connection c_ved_cleared user=pwa_vedernikoff password=irrelevant
query
SELECT current_user;
----
current_user
pwa_vedernikoff


# Cleanup.
connection default
statement ok
DROP ROLE pwa_vedernikoff;


statement ok
DROP ROLE pwa_clickclack;


statement ok
DROP ROLE pwa_trusty;
