# serenedb-only: a pre-hashed SCRAM-SHA-256 verifier presented as the PASSWORD
# literal (from pg_dumpall / psql \password / migrations) is stored verbatim, not
# re-hashed -- so the ORIGINAL password still authenticates. An md5 hash literal
# is rejected (serened verifies only SCRAM; double-hashing it would silently lock
# the account out). Cannot run on the shared trust PG container (per-role
# password sessions).
#
# The verifier below is a real SCRAM-SHA-256 verifier for the password
# 'graftedpw' (iterations=4096, deterministic salt), byte-formatted exactly as
# serened's ScramVerifierToString / ParseScramVerifier expect.
#
# Lore: vedernikoff's credentials are restored from a dump of the old ledger.

statement ok
DROP ROLE IF EXISTS eph_vedernikoff;


statement ok
DROP ROLE IF EXISTS eph_plain;


statement ok
DROP ROLE IF EXISTS eph_altered;


statement ok
DROP ROLE IF EXISTS eph_md5;


# --- an md5 verifier literal is accepted and stored verbatim (like SCRAM) ---
# md5<hex> = "md5" + md5(password + username); this one is for user eph_md5,
# password 'md5pw'. Stored as-is, not re-hashed.
statement ok
CREATE ROLE eph_md5 LOGIN PASSWORD 'md5d8e52850c67d91f23e0f978386689553';


# Under the default (scram) ruleset a loopback connection is routed to
# scram-sha-256, which cannot verify an md5-stored secret, so the md5 role's
# login is refused (PG-identical: a scram line cannot authenticate md5 storage).
# Its md5 verifier is exercised end-to-end by the network mask test / gtests,
# which can drive the md5 method from a non-loopback source.
connection c_md5 user=eph_md5 password=md5pw
statement error
SELECT 1;
----
db error: FATAL:<slt:ignore>


# --- a plaintext password is still hashed and works (regression) ---
statement ok
CREATE ROLE eph_plain LOGIN PASSWORD 'plain_pw';


connection c_plain user=eph_plain password=plain_pw
query
SELECT current_user;
----
current_user
eph_plain


# --- a pre-hashed SCRAM verifier is stored verbatim: 'graftedpw' authenticates ---
statement ok
CREATE ROLE eph_vedernikoff LOGIN PASSWORD 'SCRAM-SHA-256$4096:AAECAwQFBgcICQoLDA0ODw==$n/3jpqEWdr/HAMvLy7q2/jozU3VKxgOqKKTsGlBQrf4=:UzTV0NO8SS/ZDjfZDoJ7ujblgR6eb/Tfo9TMOjPB5rA=';


# The original password behind the verifier logs in. (If the verifier string had
# been re-hashed, 'graftedpw' would NOT authenticate.)
connection c_ved user=eph_vedernikoff password=graftedpw
query
SELECT current_user;
----
current_user
eph_vedernikoff


# --- ALTER ROLE ... PASSWORD <verifier> is verbatim too ---
statement ok
CREATE ROLE eph_altered LOGIN PASSWORD 'placeholder_pw';


connection default
statement ok
ALTER ROLE eph_altered PASSWORD 'SCRAM-SHA-256$4096:AAECAwQFBgcICQoLDA0ODw==$n/3jpqEWdr/HAMvLy7q2/jozU3VKxgOqKKTsGlBQrf4=:UzTV0NO8SS/ZDjfZDoJ7ujblgR6eb/Tfo9TMOjPB5rA=';


connection c_alt user=eph_altered password=graftedpw
query
SELECT current_user;
----
current_user
eph_altered


# cleanup
connection default
statement ok
DROP ROLE eph_vedernikoff;


statement ok
DROP ROLE eph_plain;


statement ok
DROP ROLE eph_altered;


statement ok
DROP ROLE eph_md5;
