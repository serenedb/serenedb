arrow_large_buffer_size	off	Whether Arrow buffers for strings, blobs, uuids and bits should be exported using large buffers
arrow_lossless_conversion	off	Whenever a DuckDB type does not have a clear native or canonical extension match in Arrow, export the types with a duckdb.type_name extension name.
arrow_output_list_view	off	Whether export to Arrow format should use ListView as the physical layout for LIST columns
arrow_output_version	1.0	Whether strings should be produced by DuckDB in Utf8View format instead of Utf8
asof_loop_join_threshold	64	The maximum number of rows we need on the left side of an ASOF join to use a nested loop join
auto_checkpoint_skip_wal_threshold	100000	The estimated WAL write size at which point we will skip writing to the WAL and only checkpoint. Skipping writing to the WAL means concurrent commits are blocked while the checkpoint is happening.
auto_fallback_to_full_download	on	Allows automatically falling back to full file downloads when possible.
autoinstall_extension_repository	(empty)	Overrides the custom endpoint for extension installation on autoloading
autoinstall_known_extensions	off	Whether known extensions are allowed to be automatically installed when a query depends on them
autoload_known_extensions	off	Whether known extensions are allowed to be automatically loaded when a query depends on them
binary_as_string	off	In Parquet files, interpret binary data as a string.
block_allocator_memory	0 bytes	Physical memory that the block allocator is allowed to use (this memory is never freed and cannot be reduced).
bytea_output	hex	Sets the output format for bytea.
ca_cert_file	(empty)	Path to a custom certificate file for self-signed certificates.
catalog_error_max_schemas	100	The maximum number of schemas the system will scan for "did you mean..." style errors in the catalog
checkpoint_on_detach	DEFAULT	Override checkpoint behavior when detaching a database. ENABLED always checkpoints, DISABLED never checkpoints, DEFAULT defers to the global checkpoint_on_shutdown setting.
checkpoint_threshold	16.0 MiB	The WAL size threshold at which to automatically trigger a checkpoint (e.g. 1GB)
cleanup_interval_step	1	Number of commit ticks between background unreferenced-file cleanup passes for newly created inverted indexes. Per-index WITH (cleanup_interval_step = ...) overrides. 0 disables cleanup. Default: 1.
client_encoding	UTF8	Sets the client's character set encoding.
client_min_messages	notice	Sets the message levels that are sent to the client.
compaction_interval	1000	Background compaction interval (ms) for newly created inverted indexes. Per-index WITH (compaction_interval = ...) overrides. 0 disables the compaction task. Default: 1000.
configure_metrics	[*]	Accepts a JSON enabling custom metrics
configure_profiling	[*]	Accepts a JSON enabling custom metrics
current_transaction_invalidation_policy	STANDARD_POLICY	Which types of exceptions invalidate the database for the current transaction
custom_extension_repository	(empty)	Overrides the custom endpoint for remote extension installation
custom_profiling_settings	[*]	Accepts a JSON enabling custom metrics
custom_user_agent	(empty)	Metadata from DuckDB callers
debug_asof_iejoin	off	DEBUG SETTING: force use of IEJoin to implement AsOf joins
debug_checkpoint_abort	NONE	DEBUG SETTING: trigger an abort while checkpointing for testing purposes
debug_checkpoint_sleep_ms	0	DEBUG SETTING: time to sleep before a checkpoint
debug_disable_optimizer	off	DEBUG SETTING: disable optimizer for most queries
debug_eviction_queue_sleep_micro_seconds	0	DEBUG SETTING: time for the eviction queue to sleep before acquiring shared ownership of block memory
debug_force_external	off	DEBUG SETTING: force out-of-core computation for operators that support it, used for testing
debug_force_fetch_row	off	DEBUG SETTING: force per-row fetching during scans, used for testing
debug_force_no_cross_product	off	DEBUG SETTING: Force disable cross product generation when hyper graph isn't connected, used for testing
debug_physical_table_scan_execution_strategy	DEFAULT	DEBUG SETTING: force use of given strategy for executing physical table scans
debug_skip_checkpoint_on_commit	off	DEBUG SETTING: skip checkpointing on commit
