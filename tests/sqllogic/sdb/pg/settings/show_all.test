duckdb_api	cpp	DuckDB API surface
dynamic_or_filter_threshold	50	The maximum amount of OR filters we generate dynamically from a hash join
enable_caching_operators	on	Enables caching operators that cache intermediate results
enable_curl_server_cert_verification	on	Enable server side certificate verification for CURL backend.
enable_external_access	on	Allow the database to access external state (through e.g. loading/installing modules, COPY TO/FROM, CSV readers, pandas replacement scans, etc)
