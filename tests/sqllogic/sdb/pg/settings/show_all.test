external_file_cache_local_block_size	16384	Block size in bytes for the external file cache when reading local (non-remote) files.
external_file_cache_remote_block_size	2097152	Block size in bytes for the external file cache when reading remote files (e.g. HTTP/S3).
external_threads	1	The number of external threads that work on DuckDB tasks.
extra_float_digits	1	Sets the number of digits displayed for floating-point values.
file_search_path	(empty)	A comma separated list of directories to search for input files
force_bitpacking_mode	AUTO	DEBUG SETTING: forces a specific bitpacking mode
force_column_metadata_reuse	off	Force re-use of row group metadata on a column-level when checkpointing on older storage versions 6 and 7. This breaks storage backward-compatibility with older DuckDB versions.
force_compression	auto	DEBUG SETTING: forces a specific compression method to be used
force_download	off	Forces upfront download of file
force_download_threshold	0	Forces upfront download of files smaller than the given size in bytes
force_mbedtls_unsafe	off	Enable mbedtls for encryption (WARNING: unsafe to use)
force_variant_shredding	INVALID	Forces the VARIANT shredding that happens at checkpoint to use the provided schema for the shredding.
geometry_minimum_shredding_size	30000	Minimum size of a rowgroup to enable GEOMETRY shredding, or set to -1 to disable entirely. Defaults to 1/4th of a rowgroup
hf_max_per_page	0	Debug option to limit number of items returned in list requests
home_directory	(empty)	Sets the home directory used by the system
http_keep_alive	on	Keep alive connections. Setting this to false can help when running into connection failures
http_logging_output	(empty)	(deprecated) The file to which HTTP logging output should be saved, or empty to print to the terminal
http_proxy	(empty)	HTTP proxy host (defaults to the HTTP_PROXY environment variable when unset)
http_proxy_password	(empty)	Password for HTTP proxy
http_proxy_username	(empty)	Username for HTTP proxy
http_retries	3	HTTP retries on I/O error
http_retry_backoff	4	Backoff factor for exponentially increasing retry wait time
http_retry_wait_ms	100	Time between retries
http_timeout	30	HTTP timeout read/write/connection/retry (in seconds)
httpfs_client_implementation	default	Select which is the HTTPUtil implementation to be used
httpfs_connection_caching	off	Enable connection caching for HTTP requests
iceberg_test_force_token_expiry	off	DEBUG SETTING: force OAuth2 token expiry for testing automatic refresh
iceberg_use_metadata_log	on	Whether or not to make use of the (optional) 'metadata-log' of a table to ensure atomicity guarantees hold, at the cost of making another GET for json metadata in rare circumstances
iceberg_via_aws_sdk_for_catalog_interactions	off	Use legacy code to interact with AWS-based catalogs, via AWS's SDK
ieee_floating_point_ops	on	Use IEEE 754 behavior for supported floating point operations, returning NAN/INF instead of errors/NULL.
ignore_row_group_size_for_partitioned_tables	off	Ignore unsupported write.parquet.row-group-size-bytes table property for partitioned tables
ignore_target_file_size_for_partitioned_tables	off	Ignore unsupported write.target-file-size-bytes table property for partitioned tables
ignore_unknown_crs	off	Ignore unknown Coordinate Reference Systems (CRS) when creating geometry types or importing geospatial data.
immediate_transaction_mode	off	Whether transactions should be started lazily when needed, or immediately when BEGIN TRANSACTION is called
in_hot_standby	off	Shows whether hot standby is currently active.
index_scan_max_count	2048	The maximum index scan count sets a threshold for index scans. If fewer than MAX(index_scan_max_count, index_scan_percentage * total_row_count) rows match, we perform an index scan instead of a table scan.
index_scan_percentage	0.001	The index scan percentage sets a threshold for index scans. If fewer than MAX(index_scan_max_count, index_scan_percentage * total_row_count) rows match, we perform an index scan instead of a table scan.
initial_column_segment_size	2048	The initial memory (in bytes) reserved for the first transient column segment. Must be a power of two. Internally, we subtract the block header size (typically 8 bytes) for segments with or exceeding 1024 bytes. Subsequent segments double in size until reaching the block size.
integer_datetimes	on	Shows whether datetimes are integer based.
integer_division	off	Whether or not the / operator defaults to integer division, or to floating point division
is_superuser	on	Shows whether the current session's user is a superuser.
lambda_syntax	ENABLE_SINGLE_ARROW	Configures the use of the deprecated single arrow operator (->) for lambda functions.
late_materialization_max_rows	50	The maximum amount of rows in the LIMIT/SAMPLE for which we trigger late materialization
legacy_metrics_format	off	When enabled, profiling output uses the legacy flat format instead of the current grouped format
lock_configuration	off	Whether or not configurations can be altered
log_query_path	(empty)	Specifies the path to which queries should be logged (default: NULL, queries are not logged)
logging_level	<slt:ignore>	The log level which will be recorded in the log
logging_mode	<slt:ignore>	Determines which types of log messages are logged
logging_storage	<slt:ignore>	Set the logging storage (memory/stdout/file/<custom>)
max_execution_time	0	The maximum execution time per query in milliseconds (0 = no limit)
max_expression_depth	1000	The maximum expression depth limit in the parser. WARNING: increasing this setting and using very deep expressions might lead to stack overflow errors.
max_memory	<slt:ignore>	The maximum memory of the system (e.g. 1GB)
max_temp_directory_size	90% of available disk space	The maximum amount of data stored inside the 'temp_directory' (when set) (e.g. 1GB)
max_vacuum_tasks	100	The maximum vacuum tasks to schedule during a checkpoint.
memory_limit	<slt:ignore>	The maximum memory of the system (e.g. 1GB)
merge_http_secret_into_s3_request	on	Merges http secret params into S3 requests
merge_join_threshold	1000	The maximum number of rows on either table to choose a merge join
nested_loop_join_threshold	5	The maximum number of rows on either table to choose a nested loop join
norm_row_group_size	122880	Default column row-group size for norm columns of text-indexed fields (Norm feature) in newly created inverted indexes. Per-column (row_group_size = ...) and per-index WITH (row_group_size = ...) override. Reads from existing indexes are unaffected. Default: 122'880.
null_order	NULLS_LAST	NULL ordering used when none is specified (NULLS_FIRST or NULLS_LAST)
old_implicit_casting	off	Allow implicit casting to/from VARCHAR
operator_memory_limit	NULL	The maximum memory for query intermediates (sorts, hash tables) per connection (e.g. 256MB)
order_by_non_integer_literal	off	Allow ordering by non-integer literals - ordering by such literals has no effect.
ordered_aggregate_threshold	262144	The number of rows to accumulate before sorting, used for tuning
parallelize_sequential_sources	on	Whether to automatically parallelize sequential sources
parquet_metadata_cache	off	Cache Parquet metadata - useful when reading the same files multiple times
partitioned_write_flush_threshold	524288	The threshold in number of rows after which we flush a thread state when writing using PARTITION_BY
partitioned_write_max_open_files	100	The maximum amount of files the system can keep open before flushing to disk when writing using PARTITION_BY
password	(empty)	The password to use. Ignored for legacy compatibility.
perfect_ht_threshold	12	Threshold in bytes for when to use a perfect hash table
pg_array_as_varchar	off	Read Postgres arrays as varchar - enables reading mixed dimensional arrays
pg_connection_cache	on	Whether or not to use the connection pooling. This option is deprecated, instead to disable the connection pooling use "SET pg_pool_max_connections=0" for newly attached Postgres databases and "FROM postgres_configure_pool(catalog_name='my_attached_postgres_db', max_connections=0)" for already attached Postgres databases.
pg_connection_limit	32	The maximum amount of concurrent Postgres connections. This option is deprecated, instead use "SET pg_pool_max_connections = 42" for newly attached Postgres databases and "FROM postgres_configure_pool(catalog_name='my_attached_postgres_db', max_connections=42)" for already attached Postgres databases.
pg_debug_show_queries	off	DEBUG SETTING: print all queries sent to Postgres to stdout
pg_experimental_filter_pushdown	on	Whether or not to use filter pushdown
pg_idle_in_transaction_timeout_millis	NULL	Postgres idle in transaction timeout in milliseconds to set on scan connections
pg_null_byte_replacement	NULL	When writing NULL bytes to Postgres, replace them with the given character
pg_oauth_token	NULL	OAuth bearer token for PostgreSQL OAUTHBEARER authentication. Takes priority over the PGOAUTHTOKEN environment variable
pg_pages_per_task	1000	The amount of pages per task
pg_pool_acquire_mode	force	How to acquire connections from the pool: 'force' (always connect, ignore pool limit), 'wait' (block until available), 'try' (fail immediately if unavailable) (default: force)
pg_pool_enable_reaper_thread	on	Whether to enable the connection pool reaper thread, that periodically scans the pool to check the 'max_lifetime_millis' and 'idle_timeout_millis' and closes the connection which exceed the specified values. Either 'max_lifetime_millis' or 'idle_timeout_millis' must be set to a non-zero value for this option to be effective. This option only applies to newly attached Postgres databases, to configure a database that is already attached use "FROM postgres_configure_pool(catalog_name='my_attached_postgres_db', enable_reaper_thread=TRUE)"
pg_pool_enable_thread_local_cache	off	Whether to enable the connection caching in thread-local cache. Such connections are getting pinned to the threads and are not made available to other threads, while still taking the place in the pool. This option only applies to newly attached Postgres databases, to configure a database that is already attached use "FROM postgres_configure_pool(catalog_name='my_attached_postgres_db', enable_thread_local_cache=FALSE)"
pg_pool_health_check_query	SELECT 1	The query that is used to check that the connection is healthy. Setting this option to an empty string disables the health check. This option only applies to newly attached Postgres databases, to configure a database that is already attached use "FROM postgres_configure_pool(catalog_name='my_attached_postgres_db', health_check_query=SELECT 42)"
pg_pool_idle_timeout_millis	60000	Maximum number of milliseconds the connection can be kept idle in the pool. This number is checked when the connection is taken from the pool. When the connection pool reaper thread is enabled ('pg_pool_enable_reaper_thread' option), then this number is checked in background periodically. This option only applies to newly attached Postgres databases, to configure a database that is already attached use "FROM postgres_configure_pool(catalog_name='my_attached_postgres_db', idle_timeout_millis=300000)"
pg_pool_max_connections	32	Maximum number of connections that are allowed to be cached in a connection pool for each attached Postgres database. This number can be temporary exceeded when parallel scans are used. This option only applies to newly attached Postgres databases, to configure a database that is already attached use "FROM postgres_configure_pool(catalog_name='my_attached_postgres_db', max_connections=42)"
pg_pool_max_lifetime_millis	0	Maximum number of milliseconds the connection can be kept open. This number is checked when the connection is taken from the pool and returned to the pool. When the connection pool reaper thread is enabled ('pg_pool_enable_reaper_thread' option), then this number is checked in background periodically. This option only applies to newly attached Postgres databases, to configure a database that is already attached use "FROM postgres_configure_pool(catalog_name='my_attached_postgres_db', max_lifetime_millis=600000)"
pg_pool_wait_timeout_millis	30000	Maximum number of milliseconds to wait when acquiring a connection from a pool where all available connections are already taken. This option only applies to newly attached Postgres databases, to configure a database that is already attached use "FROM postgres_configure_pool(catalog_name='my_attached_postgres_db', wait_timeout_millis=60000)"
pg_statement_timeout_millis	NULL	Postgres statement timeout in milliseconds to set on scan connections
pg_use_binary_copy	on	Whether or not to use BINARY copy to read data
pg_use_ctid_scan	on	Whether or not to parallelize scanning using table ctids
pg_use_text_protocol	off	Whether or not to use TEXT protocol to read data. This is slower, but provides better compatibility with non-Postgres systems
pin_threads	auto	Whether to pin threads to cores (Linux only, default AUTO: on when there are more than 64 cores)
pivot_filter_threshold	20	The threshold to switch from using filtered aggregates to LIST with a dedicated pivot operator
pivot_limit	100000	The maximum number of pivot columns in a pivot statement
prefer_range_joins	off	Force use of range joins with mixed predicates
prefetch_all_parquet_files	off	Use the prefetching mechanism for all types of parquet files
preserve_identifier_case	off	Whether or not to preserve the identifier case, instead of always lowercasing all non-quoted identifiers
preserve_insertion_order	on	Whether or not to preserve insertion order. If set to false the system is allowed to re-order any results that do not contain ORDER BY clauses.
produce_arrow_string_view	off	Whether Arrow strings should be produced by DuckDB in Utf8View format instead of Utf8
profile_output	(empty)	The file to which profile output should be saved, or empty to print to the terminal
profiling_coverage	SELECT	The profiling coverage (SELECT or ALL)
profiling_mode	NULL	The profiling mode (STANDARD or DETAILED)
profiling_output	(empty)	The file to which profile output should be saved, or empty to print to the terminal
progress_bar_time	2000	Sets the time (in milliseconds) how long a query needs to take before we start printing a progress bar
refresh_interval	1000	Background refresh interval (ms) for newly created inverted indexes. Per-index WITH (refresh_interval = ...) overrides. 0 disables the refresh task. Default: 1000.
role	postgres	Sets the current role.
row_group_size	122880	Default column row-group size for INCLUDEd in newly created inverted indexes. Per-column (row_group_size = ...) and per-index WITH (row_group_size = ...) override. Reads from existing indexes are unaffected. Default: 122'880.
s3_access_key_id	NULL	S3 Access Key ID
s3_allow_recursive_globbing	on	Whether globs on S3-like storage are optimized with recursive strategy (alterative is listing)
s3_endpoint	NULL	S3 Endpoint
s3_kms_key_id	NULL	S3 KMS Key ID
s3_region	NULL	S3 Region
s3_requester_pays	off	S3 use requester pays mode
s3_secret_access_key	NULL	S3 Access Key
s3_session_token	NULL	S3 Session Token
s3_uploader_max_filesize	800GB	S3 Uploader max filesize (between 50GB and 5TB)
s3_uploader_max_parts_per_file	10000	S3 Uploader max parts per file (between 1 and 10000)
s3_uploader_thread_limit	50	S3 Uploader global thread limit
s3_url_compatibility_mode	off	Disable Globs and Query Parameters on S3 URLs
s3_url_style	vhost	S3 URL style
s3_use_ssl	on	S3 use SSL
s3_version_id_pinning	off	Pin S3 reads to a specific object version for consistency
scalar_subquery_error_on_multiple_rows	on	When a scalar subquery returns multiple rows - return a random row instead of returning an error.
scheduler_process_partial	off	Partially process tasks before rescheduling - allows for more scheduler fairness between separate queries
schema	public	Sets the default search schema. Equivalent to setting search_path to a single value.
scram_iterations	4096	Sets the iteration count for SCRAM secret generation.
sdb_disable_top_k_optimization	off	When true, the optimizer skips pulling `ORDER BY <scorer>(...) DESC LIMIT k` into the inverted-index scan, so WAND (Block-Max top-K) pruning never engages. Default: false (optimization on).
sdb_ef_search	0	Per-session override for the HNSW search-time neighbourhood size (efSearch). 0 (default) uses Top-K value instead.
sdb_read_your_own_writes	on	Controls whether queries can see uncommitted writes from the current transaction.
sdb_scored_terms_limit	1024	The maximum number of terms to consider for scoring in multi-term filters. Higher values give more accurate IDF-style scoring at the cost of memory and per-query work. 0 disables scored-term collection entirely.
sdb_write_conflict_policy	emit_error	Sets the write conflict policy. Valid values are 'emit_error' (the default), 'do_nothing' (skip conflicted rows) and 'replace'.
search_path	<slt:ignore>	Sets <slt:ignore>
secret_directory	<slt:ignore>	Set the directory to which persistent secrets are stored
server_encoding	UTF8	Shows the server (database) character set encoding.
server_version	18.3	Shows the server version.
server_version_num	180003	Shows the server version as an integer.
session_authorization	postgres	Sets the current session's user name.
standard_conforming_strings	on	Causes '...' strings to treat backslashes literally.
statement_timeout	0	Aborts any statement that takes more than the specified number of milliseconds. Accepted for compatibility but not currently enforced.
storage_block_prefetch	REMOTE_ONLY	In which scenarios to use storage block prefetching
storage_compatibility_version	latest	Serialize on checkpoint with compatibility for a given duckdb version
streaming_buffer_size	976.5 KiB	The maximum memory to buffer between fetching from a streaming result (e.g. 1GB)
temp_directory	.tmp	Set the directory to which to write temp files
temp_file_encryption	off	Encrypt all temporary files if database is encrypted
threads	<slt:ignore>	The number of total threads used by the system.
tracked_metrics	[*]	A list of metric glob patterns to enable for collection (e.g. ['query.*', 'optimizer.*'])
transaction_isolation	repeatable read	Sets the current transaction's isolation level.
unsafe_disable_etag_checks	off	Disable checks on ETag consistency
unsafe_enable_version_guessing	off	Enable globbing the filesystem (if possible) to find the latest version metadata. This could result in reading an uncommitted version.
unsafe_iceberg_ignore_sort_order	off	Allow INSERT/UPDATE on iceberg tables that declare a sort order, without applying that sort order to the written data. The Iceberg spec permits this (writers are not required to honour a declared sort order, and readers do not assume files are sorted), but skipping the sort may reduce later file-pruning effectiveness and compression.
user	<slt:ignore>	The username to use. Ignored for legacy compatibility.
username	<slt:ignore>	The username to use. Ignored for legacy compatibility.
vacuum_rebuild_indexes	0	(Experimental) Allow vacuum to compact row groups on tables with bound ART indexes, rebuilding the indexes afterward. Tables with a row count exceeding this threshold are skipped. 0 = disabled.
validate_external_file_cache	VALIDATE_ALL	Cache validation mode: VALIDATE_ALL (default, validate all cache entries), VALIDATE_REMOTE (validate only remote cache entries), or NO_VALIDATION (disable cache validation).
variant_minimum_shredding_size	30000	Minimum size of a rowgroup to enable VARIANT shredding, or set to -1 to disable entirely. Defaults to 1/4th of a rowgroup
wal_autocheckpoint	16.0 MiB	The WAL size threshold at which to automatically trigger a checkpoint (e.g. 1GB)
wal_autocheckpoint_entries	0	Trigger automatic checkpoint when WAL entry count reaches or exceeds N (0 = disabled)
warnings_as_errors	off	Escalate all warnings to errors.
worker_threads	<slt:ignore>	The number of total threads used by the system.
write_buffer_row_group_count	5	The amount of row groups to buffer in bulk ingestion prior to flushing them together. Reducing this setting can reduce memory consumption.
write_buffer_row_group_memory_limit	<slt:ignore>	The maximum data to buffer in row groups (in bytes) to buffer prior to flushing them together. When either this limit is reached, or write_buffer_row_group_count is reached, we flush the data to disk. Defaults to 20% of memory limit divided by thread count.
zstd_min_string_length	4096	The (average) length at which to enable ZSTD compression, defaults to 4096


# Check that SHOW ALL see updated settings

statement ok
set default_transaction_isolation = 'read committed';


query
SHOW ALL;
----
name	setting	description
