# A facade database holds no row data itself (it lives in the hidden store
# database), so pragma_database_size used to report 0 for it. GetDatabaseSize now
# delegates to the store, so the facade database reports a real (non-zero) size.

statement ok
CREATE TABLE dbsize_t (a INT, b INT);


statement ok
INSERT INTO dbsize_t SELECT i, i FROM generate_series(1, 1000) t(i);


statement ok
CHECKPOINT;


query
SELECT block_size > 0 AS has_size FROM pragma_database_size() WHERE database_name = 'postgres';
