connection ssl-tls sslmode=prefer
skipif postgres-extended
query
select 1234567890123456::numeric;
----
numeric
1234567890123456.0000000000000000000


connection ssl-tls2 sslmode=prefer port=ssl
skipif postgres-extended
query
select 1234567890123456::numeric;
----
numeric
1234567890123456.0000000000000000000


connection ssl-tls3 sslmode=require port=ssl
skipif postgres-extended
query error error performing TLS handshake: server does not support TLS
select 1234567890123456::numeric;


connection ssl-tls4 sslmode=require
skipif postgres-extended
query error
select 1234567890123456::numeric;
----
error performing TLS handshake: server does not support TLS


connection ssl-tls5 port=ssl
skipif postgres-extended
query ?
select 1234567890123456::numeric;
----
numeric
1234567890123456.0000000000000000000
