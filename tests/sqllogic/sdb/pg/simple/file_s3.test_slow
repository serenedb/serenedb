control substitution on

# Requires MinIO running

statement ok
CREATE TABLE clickclack
(
  id INTEGER PRIMARY KEY,
  name TEXT
);


statement count 5
INSERT INTO clickclack VALUES (1, 'vedernikoff'), (2, 'pavelvi'), (3, 'babsky'), (4, 'pudge'), (5, 'mom');


statement count 5
COPY clickclack TO 's3://${MINIO_BUCKET}/${__DATABASE__}_s3_clickclack.csv'
WITH (
  FORMAT csv,
  HEADER true,
  S3_ACCESS_KEY '${MINIO_ACCESS_KEY}',
  S3_SECRET_KEY '${MINIO_SECRET_KEY}',
  S3_ENDPOINT 'localhost:${MINIO_PORT}'
);


statement ok
CREATE TABLE s3_csv_vedernikoff
(
  id INTEGER PRIMARY KEY,
  name TEXT
);


statement count 5
COPY s3_csv_vedernikoff FROM 's3://${MINIO_BUCKET}/${__DATABASE__}_s3_clickclack.csv'
WITH (
  FORMAT csv,
  HEADER true,
  S3_ACCESS_KEY '${MINIO_ACCESS_KEY}',
  S3_SECRET_KEY '${MINIO_SECRET_KEY}',
  S3_ENDPOINT 'localhost:${MINIO_PORT}'
);


query
SELECT *
FROM s3_csv_vedernikoff
ORDER BY 1;
----
id	name
1	vedernikoff
2	pavelvi
3	babsky
4	pudge
5	mom


