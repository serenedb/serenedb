query
SELECT '192.168.0.1/24'::INET AS a;
----
a
192.168.0.1/24


query
SELECT host('192.168.0.1/24'::INET) AS host;
----
host
192.168.0.1


query
SELECT family('1.2.3.4'::INET) AS fam;
----
fam
4


query
SELECT family('::1'::INET) AS fam;
----
fam
6


query
SELECT network('192.168.1.5/24'::INET) AS net;
----
net
192.168.1.0/24


query
SELECT broadcast('192.168.1.5/24'::INET) AS bcast;
----
bcast
192.168.1.255/24


query
SELECT netmask('192.168.1.5/24'::INET) AS mask;
----
mask
255.255.255.0/24


query
SELECT '192.168.1.5'::INET <<= '192.168.1.0/24'::INET AS contained;
----
contained
t


query
SELECT '192.168.1.0/24'::INET >>= '192.168.1.5'::INET AS contains;
----
contains
t


query
SELECT '10.0.0.1'::INET + 5 AS plus5;
----
plus5
10.0.0.6


query
SELECT '10.0.0.10'::INET - 5 AS minus5;
----
minus5
10.0.0.5


query
SELECT html_escape('<a href="x">') AS esc;
----
esc
&lt;a href=&quot;x&quot;&gt;


query
SELECT html_unescape('&lt;a&gt;') AS unesc;
----
unesc
<a>


statement ok
CREATE TABLE inet_values(id INTEGER, ip INET);


statement ok
INSERT INTO inet_values VALUES
  (1, '10.0.0.1'::INET),
  (2, '2001:db8::1/64'::INET),
  (3, '192.168.1.0/24'::INET);


query
SELECT id, ip FROM inet_values ORDER BY id;
----
id	ip
1	10.0.0.1
2	2001:db8::1/64
3	192.168.1.0/24


query
SELECT [ '1.2.3.4'::INET, '5.6.7.8/30'::INET ] AS arr;
----
arr
{1.2.3.4,5.6.7.8/30}


# INET is serialized natively as PG `inet` (OID 869), not wrapped to text, so it
# reports as the inet type over the wire. The extended-protocol client renders
# regtype as a raw OID (no OID->name map), so these checks run on simple only.
skipif pg-wire-extended
query
SELECT pg_typeof('1.2.3.4'::INET) AS typ;
----
typ
inet


skipif pg-wire-extended
query
SELECT 'inet'::regtype AS rt;
----
rt
inet
