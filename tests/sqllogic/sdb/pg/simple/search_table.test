## storage WITH-option for CREATE TABLE: selects the table's physical backend.
## PR 2.2 scope: lifecycle only -- CREATE / DROP must work; DML on a kSearch
## table is gated to a later milestone and isn't exercised here.

# Default (no WITH clause) is the rocksdb row store.
statement ok
CREATE TABLE storage_default (a INTEGER PRIMARY KEY, b TEXT);

statement ok
DROP TABLE storage_default;


# Explicit rocksdb -- equivalent to default.
statement ok
CREATE TABLE storage_rocks (a INTEGER PRIMARY KEY, b TEXT)
  WITH (storage = 'rocksdb');

statement ok
DROP TABLE storage_rocks;


# Headline smoke: kSearch shard creates iresearch directory + empty writer,
# dtor closes cleanly, drop wipes the directory.
statement ok
CREATE TABLE storage_search (a INTEGER PRIMARY KEY, b TEXT)
  WITH (storage = 'search');

statement ok
DROP TABLE storage_search;


# Value is case-insensitive (the parser lowercases before matching).
statement ok
CREATE TABLE storage_search_upper (a INTEGER PRIMARY KEY, b TEXT)
  WITH (storage = 'SEARCH');

statement ok
DROP TABLE storage_search_upper;


# Two search tables coexist in the same schema (independent directories).
statement ok
CREATE TABLE storage_search_a (a INTEGER PRIMARY KEY, b TEXT)
  WITH (storage = 'search');

statement ok
CREATE TABLE storage_search_b (a INTEGER PRIMARY KEY, b TEXT)
  WITH (storage = 'search');

statement ok
DROP TABLE storage_search_a;

statement ok
DROP TABLE storage_search_b;


# Error: unknown storage kind.
statement error
CREATE TABLE storage_err1 (a INTEGER PRIMARY KEY)
  WITH (storage = 'invalid_storage_type');
----
db error: ERROR: WITH option "storage" must be 'rocksdb' or 'search', got "invalid_storage_type"


# Error: non-constant expression -- a list literal trips ExtractString's
# expression-type check (it's a FunctionExpression(list_value), not a
# VALUE_CONSTANT). Scalar numeric/boolean values cast cleanly to VARCHAR
# and reach the "rocksdb|search" check above instead.
statement error
CREATE TABLE storage_err2 (a INTEGER PRIMARY KEY)
  WITH (storage = ['search']);
----
db error: ERROR: WITH option "storage" expects a string literal


## DML reachability matrix. M3 lifted INSERT (PR 3.4); M4 lifts SELECT
## (PR 4.1, committed-reads only -- R-y-o-w overlay deferred). UPDATE /
## DELETE / TRUNCATE land in M6. CREATE INDEX has no scheduled milestone.

statement ok
CREATE TABLE search_dml (a INTEGER PRIMARY KEY, b TEXT)
  WITH (storage = 'search');

statement ok
INSERT INTO search_dml VALUES (1, 'x'), (2, 'y'), (3, 'z');

# SearchTableShard has no background commit thread yet (parity with
# InvertedIndexShard's TasksSettings is deferred), so VACUUM forces the
# iresearch writer to flush pending trxs into a segment that a fresh
# DirectoryReader can see. Without it, the SELECT below would snapshot
# the writer's pre-INSERT state. Plain `VACUUM t` routes through
# DuckDB's PhysicalVacuum (rejects non-DuckDB tables) -- the
# (UPDATE_INDEXES) option is what serenedb's pragma hook listens for.
statement ok
VACUUM (UPDATE_INDEXES) search_dml;

# SELECT round-trips via the search scan: iresearch DirectoryReader pinned
# in the txn, ColumnstoreMaterializer materialises each segment's slice.
query
SELECT * FROM search_dml ORDER BY a;
----
a	b
1	x
2	y
3	z


# UPDATE / DELETE / TRUNCATE / CREATE INDEX have their own operator-side
# guards re-added now that the SCAN guard no longer catches them. The
# user sees the operation-specific message (not "SELECT") at the
# operator-construction site.
statement error
UPDATE search_dml SET b = 'y' WHERE a = 1;
----
db error: ERROR: UPDATE on a search-backed table is not yet supported (M3-M6)


statement error
DELETE FROM search_dml WHERE a = 1;
----
db error: ERROR: DELETE on a search-backed table is not yet supported (M3-M6)


statement error
TRUNCATE search_dml;
----
db error: ERROR: TRUNCATE on a search-backed table is not yet supported (M3-M6)


# All access methods rejected (including USING inverted -- iresearch on
# top of iresearch makes no sense).
statement error
CREATE INDEX search_dml_idx ON search_dml (b);
----
db error: ERROR: CREATE INDEX on a search-backed table is not yet supported (M3-M6)


statement error
CREATE INDEX search_dml_inv_idx ON search_dml USING inverted (b);
----
db error: ERROR: CREATE INDEX on a search-backed table is not yet supported (M3-M6)


statement ok
DROP TABLE search_dml;


## Generated-PK search table -- INSERT path reserves the sequence range
## at Sink time and recovers per-row PKs via a cursor walk at Finalize
## (LocalTableChangesEntry::reserved_pk_ranges). Memory: O(num_sink_calls),
## not O(num_rows). The user-visible row identity comes from the row
## contents -- we just observe that INSERT round-trips through the search
## scan.
statement ok
CREATE TABLE search_genpk (a INTEGER, b TEXT) WITH (storage = 'search');

statement ok
INSERT INTO search_genpk VALUES (10, 'p'), (20, 'q'), (30, 'r');

statement ok
VACUUM (UPDATE_INDEXES) search_genpk;

query
SELECT * FROM search_genpk ORDER BY a;
----
a	b
10	p
20	q
30	r

statement ok
DROP TABLE search_genpk;


# CREATE TABLE AS SELECT into a search-backed table: rejected before the
# new table is materialised (parsed-options check, no catalog mutation).
statement error
CREATE TABLE search_ctas WITH (storage = 'search') AS SELECT 1 AS a;
----
db error: ERROR: CREATE TABLE ... AS SELECT into a search-backed table is not yet supported (M3-M6)
