control substitution on

statement ok
SET TIME ZONE 'UTC';


statement ok
CREATE TABLE tbnd_src
(
  id    INTEGER PRIMARY KEY,
  ts    TIMESTAMP,
  tz    TIMESTAMPTZ,
  ts_s  TIMESTAMP_S,
  ts_ms TIMESTAMP_MS,
  ts_ns TIMESTAMP_NS,
  tz_ns TIMESTAMPTZ_NS,
  d     DATE,
  t     TIME,
  t_tz  TIMETZ,
  t_ns  TIME_NS
);


statement ok
CREATE TABLE tbnd_dst
(
  id    INTEGER PRIMARY KEY,
  ts    TIMESTAMP,
  tz    TIMESTAMPTZ,
  ts_s  TIMESTAMP_S,
  ts_ms TIMESTAMP_MS,
  ts_ns TIMESTAMP_NS,
  tz_ns TIMESTAMPTZ_NS,
  d     DATE,
  t     TIME,
  t_tz  TIMETZ,
  t_ns  TIME_NS
);


statement count 3
INSERT INTO tbnd_src VALUES
    (1, '0001-01-01 00:00:00', '0001-01-01 00:00:00+00',
