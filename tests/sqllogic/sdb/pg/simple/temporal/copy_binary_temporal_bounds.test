query
SELECT hour(t) AS h_t, hour(t_ns) AS h_tns,
       extract(hour FROM t_tz) AS h_ttz, extract(timezone FROM t_tz) AS off
FROM tbnd_dst WHERE id = 1;
----
h_t	h_tns	h_ttz	off
0	0	0	19800


query
SELECT hour(t) AS h_t, hour(t_ns) AS h_tns,
       extract(hour FROM t_tz) AS h_ttz, extract(timezone FROM t_tz) AS off
FROM tbnd_dst WHERE id = 2;
