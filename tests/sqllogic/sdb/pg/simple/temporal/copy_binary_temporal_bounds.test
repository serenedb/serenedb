query
SELECT count(*) AS us_micros FROM tbnd_dst
WHERE id = 2
  AND ts = '9999-12-31 23:59:59.999999'::TIMESTAMP
  AND ts_ns = '2262-04-11 23:47:16.854775'::TIMESTAMP_NS
  AND t_ns = '23:59:59.999999'::TIME_NS;
----
us_micros
1
