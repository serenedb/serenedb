        NULL, NULL,
        NULL, NULL,
        '4713-01-01 (BC)', NULL, NULL, NULL);


statement count 3
COPY tbnd_src TO '${__TEST_DIR__}/copy_binary_tbnd.bin' (FORMAT binary);


statement count 3
COPY tbnd_dst FROM '${__TEST_DIR__}/copy_binary_tbnd.bin' (FORMAT binary);


query
SELECT
  (SELECT count(*) FROM (SELECT * FROM tbnd_src EXCEPT SELECT * FROM tbnd_dst) a)
  + (SELECT count(*) FROM (SELECT * FROM tbnd_dst EXCEPT SELECT * FROM tbnd_src) b)
  AS diff;
----
diff
0


query
SELECT year(ts) AS y_ts, year(tz) AS y_tz, year(ts_s) AS y_s, year(ts_ms) AS y_ms,
       year(ts_ns) AS y_ns, year(tz_ns::TIMESTAMP_NS) AS y_tzns, year(d) AS y_d
FROM tbnd_dst WHERE id = 1;
----
y_ts	y_tz	y_s	y_ms	y_ns	y_tzns	y_d
1	1	1	1	1677	1677	1


query
SELECT year(ts) AS y_ts, year(tz) AS y_tz, year(ts_s) AS y_s, year(ts_ms) AS y_ms,
       year(ts_ns) AS y_ns, year(tz_ns::TIMESTAMP_NS) AS y_tzns, year(d) AS y_d
FROM tbnd_dst WHERE id = 2;
