statement count 4
COPY s_time TO '${__TEST_DIR__}/time.txt' (FORMAT text);

statement ok
CREATE TABLE d_time (id INTEGER, v TIME);

statement count 4
COPY d_time FROM '${__TEST_DIR__}/time.txt' (FORMAT text);

query
SELECT (SELECT count(*) FROM (SELECT * FROM s_time EXCEPT SELECT * FROM d_time) a)
     + (SELECT count(*) FROM (SELECT * FROM d_time EXCEPT SELECT * FROM s_time) b) AS diff;
----
diff
0


