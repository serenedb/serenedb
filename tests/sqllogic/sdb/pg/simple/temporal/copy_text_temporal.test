# ---- TIMESTAMP_NS (representable-range edges, epoch +/-1ns, full ns, infinity) ----
# Rows 2/3 are the representable extremes: the earliest renderable day and the
# largest finite value. INT64_MAX ns is the infinity sentinel, so the max finite
# value is one ns below it (...806); the exact ...807 and the 1677-09-21 minimum
# day are unreachable (int64 overflow in the ns<->components conversion).
statement ok
CREATE TABLE s_tsns (id INTEGER, v TIMESTAMP_NS);

statement count 8
INSERT INTO s_tsns VALUES
 (1,'2024-02-29 12:34:56.789012345'),(2,'1677-09-22 00:00:00'),(3,'2262-04-11 23:47:16.854775806'),
 (4,'1970-01-01 00:00:00.000000001'),(5,'1969-12-31 23:59:59.999999999'),
 (6,'infinity'),(7,'-infinity'),(8,NULL);

statement count 8
COPY s_tsns TO '${__TEST_DIR__}/tsns.txt' (FORMAT text);

statement ok
CREATE TABLE d_tsns (id INTEGER, v TIMESTAMP_NS);

statement count 8
COPY d_tsns FROM '${__TEST_DIR__}/tsns.txt' (FORMAT text);

query
SELECT (SELECT count(*) FROM (SELECT * FROM s_tsns EXCEPT SELECT * FROM d_tsns) a)
     + (SELECT count(*) FROM (SELECT * FROM d_tsns EXCEPT SELECT * FROM s_tsns) b) AS diff;
----
diff
0


# ---- TIMESTAMPTZ (infinity, pre-1970, year 1) ----
statement ok
CREATE TABLE s_tstz (id INTEGER, v TIMESTAMPTZ);

statement count 6
INSERT INTO s_tstz VALUES
 (1,'2024-02-29 12:34:56.789012+00'),(2,'infinity'),(3,'-infinity'),
 (4,'1969-07-20 20:17:40+00'),(5,'0001-01-01 00:00:00+00'),(6,NULL);

statement count 6
COPY s_tstz TO '${__TEST_DIR__}/tstz.txt' (FORMAT text);

statement ok
CREATE TABLE d_tstz (id INTEGER, v TIMESTAMPTZ);

statement count 6
COPY d_tstz FROM '${__TEST_DIR__}/tstz.txt' (FORMAT text);

query
SELECT (SELECT count(*) FROM (SELECT * FROM s_tstz EXCEPT SELECT * FROM d_tstz) a)
     + (SELECT count(*) FROM (SELECT * FROM d_tstz EXCEPT SELECT * FROM s_tstz) b) AS diff;
----
diff
0


# ---- TIMESTAMPTZ_NS (full ns, late year, pre-1970 incl. sub-us, infinity) ----
# Row 4 is a pre-epoch value with a full-nanosecond fraction: the ns->us split in
# the ICU render used truncating division, which gave a negative sub-us remainder
# (rendered as garbage) for negative instants.
statement ok
CREATE TABLE s_tstzns (id INTEGER, v TIMESTAMPTZ_NS);

statement count 7
INSERT INTO s_tstzns VALUES
 (1,'2024-02-29 12:34:56.789012345+00'),(2,'2262-04-11 23:47:16.854775806+00'),
 (3,'1969-06-01 12:00:00.123456789+00'),(4,'1969-12-31 23:59:59.999999999+00'),
 (5,'infinity'),(6,'-infinity'),(7,NULL);

statement count 7
COPY s_tstzns TO '${__TEST_DIR__}/tstzns.txt' (FORMAT text);

statement ok
CREATE TABLE d_tstzns (id INTEGER, v TIMESTAMPTZ_NS);

statement count 7
COPY d_tstzns FROM '${__TEST_DIR__}/tstzns.txt' (FORMAT text);

query
SELECT (SELECT count(*) FROM (SELECT * FROM s_tstzns EXCEPT SELECT * FROM d_tstzns) a)
     + (SELECT count(*) FROM (SELECT * FROM d_tstzns EXCEPT SELECT * FROM s_tstzns) b) AS diff;
----
diff
0


# ---- INTERVAL (mixed, negative, large) ----
statement ok
CREATE TABLE s_iv (id INTEGER, v INTERVAL);

statement count 7
INSERT INTO s_iv VALUES
 (1,'1 year 2 months 3 days 04:05:06.789'),(2,'-1 year -2 months'),(3,'90 days'),
 (4,'04:05:06.123456'),(5,'-04:05:06.123456'),(6,'1000 years'),(7,NULL);

statement count 7
COPY s_iv TO '${__TEST_DIR__}/iv.txt' (FORMAT text);

statement ok
CREATE TABLE d_iv (id INTEGER, v INTERVAL);

statement count 7
COPY d_iv FROM '${__TEST_DIR__}/iv.txt' (FORMAT text);

query
SELECT (SELECT count(*) FROM (SELECT * FROM s_iv EXCEPT SELECT * FROM d_iv) a)
     + (SELECT count(*) FROM (SELECT * FROM d_iv EXCEPT SELECT * FROM s_iv) b) AS diff;
----
diff
0


# ---- Session-zone decode: a zone-less value is read in the session TimeZone ----
# COPY always writes an explicit offset, so the source is a naive type whose text
# has no offset. TIMESTAMPTZ / TIMESTAMPTZ_NS localize to New York; TIMETZ has no
# date to localize against and stays UTC (+00).
statement ok
SET TIME ZONE 'America/New_York';

statement ok
CREATE TABLE naive_src (id INTEGER, ts TIMESTAMP, tsn TIMESTAMP_NS, tt TIME);

statement count 1
INSERT INTO naive_src VALUES
 (1, TIMESTAMP '2024-01-02 12:00:00', TIMESTAMP_NS '2024-01-02 12:00:00.123456789', TIME '12:00:00');

statement count 1
COPY naive_src TO '${__TEST_DIR__}/naive.txt' (FORMAT text);

statement ok
CREATE TABLE zoneless_dst (id INTEGER, ts TIMESTAMPTZ, tsn TIMESTAMPTZ_NS, tt TIMETZ);

statement count 1
COPY zoneless_dst FROM '${__TEST_DIR__}/naive.txt' (FORMAT text);

query
SELECT id, ts::VARCHAR AS ts, tsn::VARCHAR AS tsn, tt::VARCHAR AS tt
FROM zoneless_dst
ORDER BY id;
----
id	ts	tsn	tt
1	2024-01-02 12:00:00-05	2024-01-02 12:00:00.123456789-05	12:00:00+00
