# ---- TIMESTAMP (infinity, era + year bounds, leap day) ----
statement ok
CREATE TABLE s_ts (id INTEGER, v TIMESTAMP);

statement count 7
INSERT INTO s_ts VALUES
 (1,'2024-02-29 12:34:56.789012'),(2,'0001-01-01 00:00:00'),(3,'infinity'),(4,'-infinity'),
 (5,'1970-01-01 00:00:00'),(6,'9999-12-31 23:59:59.999999'),(7,NULL);

statement count 7
COPY s_ts TO '${__TEST_DIR__}/ts.txt' (FORMAT text);

statement ok
CREATE TABLE d_ts (id INTEGER, v TIMESTAMP);

statement count 7
COPY d_ts FROM '${__TEST_DIR__}/ts.txt' (FORMAT text);

query
SELECT (SELECT count(*) FROM (SELECT * FROM s_ts EXCEPT SELECT * FROM d_ts) a)
     + (SELECT count(*) FROM (SELECT * FROM d_ts EXCEPT SELECT * FROM s_ts) b) AS diff;
----
diff
0


