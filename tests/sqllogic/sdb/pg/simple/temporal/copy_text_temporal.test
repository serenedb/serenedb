control substitution on

# Text COPY round-trip (write to a file, read it back through the VarFormat::Text
# serializers + deserializers) for every temporal type, with corner cases:
# infinity, epoch, leap day, min/max years, max fractional precision, extreme UTC
# offsets, and NULL. `diff = 0` asserts encode and decode agree exactly. The
# final section covers the session-zone decode of zone-less input.

statement ok
SET TIME ZONE 'UTC';


# ---- DATE ----
statement ok
CREATE TABLE s_date (id INTEGER, v DATE);

statement count 6
INSERT INTO s_date VALUES
 (1,'2024-02-29'),(2,'0001-01-01'),(3,'infinity'),(4,'-infinity'),(5,'1970-01-01'),(6,NULL);

statement count 6
COPY s_date TO '${__TEST_DIR__}/date.txt' (FORMAT text);

statement ok
CREATE TABLE d_date (id INTEGER, v DATE);

statement count 6
COPY d_date FROM '${__TEST_DIR__}/date.txt' (FORMAT text);

query
SELECT (SELECT count(*) FROM (SELECT * FROM s_date EXCEPT SELECT * FROM d_date) a)
     + (SELECT count(*) FROM (SELECT * FROM d_date EXCEPT SELECT * FROM s_date) b) AS diff;
----
diff
0


# ---- TIME ----
statement ok
CREATE TABLE s_time (id INTEGER, v TIME);

statement count 4
INSERT INTO s_time VALUES
