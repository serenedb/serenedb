    template = 'ngram',
    mingram = 2,
    maxgram = 3,
    preserveoriginal = '1'
)


# --- Invalid integer value ---

statement error db error: ERROR: invalid input syntax for type integer: "abc"
CREATE TEXT SEARCH DICTIONARY t_err14(
    template = 'ngram',
    mingram = 'abc',
    maxgram = 3
)


statement error db error: ERROR: invalid input syntax for type integer: "three"
