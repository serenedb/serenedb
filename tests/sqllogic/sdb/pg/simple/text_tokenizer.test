control substitution on


# ===========================================================================
# ERROR CASES
# ===========================================================================

# --- Missing required parameter: template ---

statement error required parameter "template" was not found
CREATE TEXT SEARCH DICTIONARY t_err1(
    locale = 'en_US.UTF-8'
)


# --- Invalid template value ---

statement error
CREATE TEXT SEARCH DICTIONARY t_err2(
    template = 'whaaat',
    locale = 'en_US.UTF-8'
)
----
db error: ERROR: Invalid type of text search dictionary



# --- Duplicate option ---

statement error conflicting or redundant options
CREATE TEXT SEARCH DICTIONARY t_err3(
    template = 'text',
    locale = 'en_US.UTF-8',
    locale = 'fr_FR.UTF-8'
)


# --- Invalid case value ---

statement error
CREATE TEXT SEARCH DICTIONARY t_err4(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'invalid'
)
----
db error: ERROR: invalid value in "case" parameter
HINT: Text case conversion: none, lower, upper



# --- Option not supported by tokenizer ---

statement error
CREATE TEXT SEARCH DICTIONARY t_err5(
    template = 'ngram',
    locale = 'en_US.UTF-8'
)
----
db error: ERROR: option "locale" is not applicable in this context
HINT: Use WITH (HELP) to see available options



statement error
CREATE TEXT SEARCH DICTIONARY t_err6(
    template = 'stem',
    stopwords = 'a,the'
)
----
db error: ERROR: option "stopwords" is not applicable in this context
HINT: Use WITH (HELP) to see available options



statement error
CREATE TEXT SEARCH DICTIONARY t_err7(
    template = 'segmentation',
    accent = true
)
----
db error: ERROR: option "accent" is not applicable in this context
HINT: Use WITH (HELP) to see available options



statement error
CREATE TEXT SEARCH DICTIONARY t_err8(
    template = 'text',
    locale = 'en_US.UTF-8',
    numhashes = 5
)
----
db error: ERROR: option "numhashes" is not applicable in this context
HINT: Use WITH (HELP) to see available options



statement error
CREATE TEXT SEARCH DICTIONARY t_err9(
    template = 'norm',
    locale = 'en_US.UTF-8',
    delimiter = ','
)
----
db error: ERROR: option "delimiter" is not applicable in this context
HINT: Use WITH (HELP) to see available options



statement error
CREATE TEXT SEARCH DICTIONARY t_err10(
    template = 'collation',
    locale = 'en_US.UTF-8',
    mingram = 2
)
----
db error: ERROR: option "mingram" is not applicable in this context
HINT: Use WITH (HELP) to see available options



# --- Invalid boolean value ---

statement error db error: ERROR: invalid value for CREATE TEXT SEARCH DICTIONARY parameter "accent": "maybe"
CREATE TEXT SEARCH DICTIONARY t_err11(
    template = 'text',
    locale = 'en_US.UTF-8',
    accent = 'maybe'
)


statement error db error: ERROR: invalid value for CREATE TEXT SEARCH DICTIONARY parameter "stemming": "yes"
CREATE TEXT SEARCH DICTIONARY t_err12(
    template = 'text',
    locale = 'en_US.UTF-8',
    stemming = 'yes'
)


statement error db error: ERROR: invalid value for CREATE TEXT SEARCH DICTIONARY parameter "preserveoriginal": "1"
