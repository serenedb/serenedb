    template = 'text',
    locale = 'en_US.UTF-8',
    norm = true
)
----
db error: ERROR: missing feature 'frequency' required when 'norm' feature is specified


statement ok
CREATE TEXT SEARCH DICTIONARY text_frequency_feature(
    template = 'text',
    locale = 'en_US.UTF-8',
    norm = true,
    frequency = true
)


statement ok
CREATE TEXT SEARCH DICTIONARY text_all_features(
    template = 'text',
    locale = 'en_US.UTF-8',
    norm = true,
    frequency = true,
    position = true,
    offset = true
)


statement ok
CREATE TEXT SEARCH DICTIONARY ngram_with_features(
    template = 'ngram',
    mingram = 2,
    maxgram = 3,
    norm = true,
    frequency = true
)


