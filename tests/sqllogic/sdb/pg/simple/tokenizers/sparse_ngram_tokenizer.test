control substitution on


# ERROR CASES

# --- maxngramlength below minimum ---

statement error
CREATE TEXT SEARCH DICTIONARY sng_err1(
    template = 'sparse_ngram',
    maxngramlength = 2
)
----
db error: ERROR: "maxngramlength" must be at least 3
HINT: Maximum emitted n-gram length (minimum 3)


# --- covering option not applicable to other tokenizers ---

statement error
CREATE TEXT SEARCH DICTIONARY sng_err2(
    template = 'text',
    locale = 'en_US.UTF-8',
    covering = true
)
----
db error: ERROR: option "covering" is not applicable in this context
HINT: Use WITH (HELP) to see available options


# --- offset feature is not supported ---

statement error
CREATE TEXT SEARCH DICTIONARY sng_err3(
    template = 'sparse_ngram',
    frequency = true,
    position = true,
    offset = true
)
----
db error: ERROR: Unsupported index features are specified: 7


# --- position feature is not supported (grams have no meaningful positions) ---

statement error
CREATE TEXT SEARCH DICTIONARY sng_err4(
    template = 'sparse_ngram',
    frequency = true,
    position = true
)
----
db error: ERROR: Unsupported index features are specified: 3


# SPARSE NGRAM TOKENIZER

# --- Index side: all sparse ngrams ---

statement ok
CREATE TEXT SEARCH DICTIONARY code_grams(
    template = 'sparse_ngram'
)


query
SELECT ts_lexize('code_grams', 'hello world');
----
ts_lexize
{hel,ell,llo,"lo ","o w","lo w"," wo","lo wo",wor,orl,worl,rld}


query
SELECT ts_lexize('code_grams', 'for(int i=42');
----
ts_lexize
{for,or(,for(,r(i,for(i,(in,int,(int,"nt ","t i"," i=","t i=",i=4,"t i=4","nt i=4","(int i=4",=42}


# --- Inputs shorter than 3 bytes produce no tokens ---

query
SELECT ts_lexize('code_grams', 'he');
----
ts_lexize
{}


query
SELECT ts_lexize('code_grams', 'hel');
----
ts_lexize
{hel}


# --- Query side: minimal covering chain ---

statement ok
CREATE TEXT SEARCH DICTIONARY code_grams_covering(
    template = 'sparse_ngram',
    covering = true
)


query
SELECT ts_lexize('code_grams_covering', 'hello world');
----
ts_lexize
{hel,ell,llo,rld,worl,"lo wo"}


query
SELECT ts_lexize('code_grams_covering', 'for(int i=42');
----
ts_lexize
{for(i,"(int i=4",=42}


# --- copy_from inherits and overrides ---

statement ok
CREATE TEXT SEARCH DICTIONARY code_grams_copy(
    template = 'copy_from',
    from = 'code_grams',
    covering = true
)


query
SELECT ts_lexize('code_grams_copy', 'for(int i=42');
----
ts_lexize
{for(i,"(int i=4",=42}


# INVERTED INDEX + SUBSTRING SEARCH

statement ok
CREATE TABLE snippets(id INT, code TEXT);


statement ok
INSERT INTO snippets VALUES
    (1, 'for(int i=42; i<n; ++i) total += data[i];'),
    (2, 'for(int j=0; j<n; ++j) total -= data[j];'),
    (3, 'while(n--) { sum += *ptr++; }'),
    (4, 'hello world');


statement ok
CREATE INDEX snippets_idx ON snippets USING inverted(id, code code_grams);


# All covering grams of the query must match: substring search.

query
SELECT id FROM snippets_idx WHERE code @@ ts_all(ts_tokenize(ARRAY['for(int i=42'], 'code_grams_covering')) ORDER BY id;
----
id
1


query
SELECT id FROM snippets_idx WHERE code @@ ts_all(ts_tokenize(ARRAY['total'], 'code_grams_covering')) ORDER BY id;
----
id
1
2


query
SELECT id FROM snippets_idx WHERE code @@ ts_all(ts_tokenize(ARRAY['hello world'], 'code_grams_covering')) ORDER BY id;
----
id
4


query
SELECT id FROM snippets_idx WHERE code @@ ts_all(ts_tokenize(ARRAY['nonexistent substring'], 'code_grams_covering')) ORDER BY id;
----
id


# BM25 RANKING OVER GRAMS
# frequency/norm on the index dictionary make bm25() rank by gram overlap:
# similarity to the query decreases monotonically down the expected output.
# Documents are arranged so the matched gram sets are nested (1 > 2 > 3) and
# each weaker match is also longer, so term frequency and length norms agree
# on the order; the unrelated document must not match at all.

statement ok
CREATE TEXT SEARCH DICTIONARY code_grams_ranked(
    template = 'sparse_ngram',
    frequency = true,
    norm = true
)


statement ok
CREATE TABLE ranked(id INT, code TEXT);


statement ok
INSERT INTO ranked VALUES
    (1, 'while l < r: m = (l + r) // 2'),
    (2, 'some noise prefix; m = (l + r) // 2'),
    (3, 'much longer noise that matches nothing at all; r) // 2'),
    (4, 'completely unrelated text');


statement ok
CREATE INDEX ranked_idx ON ranked USING inverted(id, code code_grams_ranked);


query
SELECT id FROM ranked_idx
WHERE code @@ ts_any(ts_tokenize(ARRAY['while l < r: m = (l + r) // 2'], 'code_grams_covering'), 1)
ORDER BY bm25(ranked_idx.tableoid) DESC;
----
id
1
2
3


# TS_HIGHLIGHT / TS_OFFSETS OVER SPARSE NGRAM
# Regression: the tokenizer emits grams out of start-offset order, so the
# offsets/highlight path re-derives them by sorting the grams in an in-memory
# index. Before the sorting adapter this segfaulted (positions written, offsets
# not). The matched substring region must come back wrapped, and ts_offsets
# must return pairs sorted ascending by start.

query
SELECT ts_highlight(code) FROM snippets_idx
WHERE code @@ ts_all(ts_lexize('code_grams_covering', 'for(int i=42'))
ORDER BY id;
----
ts_highlight
<b>for(int i=42</b>; i<n; ++i) total += data[i


query
SELECT ts_offsets(code) FROM snippets_idx
WHERE code @@ ts_all(ts_lexize('code_grams_covering', 'for(int i=42'))
ORDER BY id;
----
ts_offsets
{0,3,0,4,0,5,1,4,2,5,3,6,3,7,3,11,4,7,5,8,5,11,6,9,6,10,6,11,7,10,8,11,9,12}


# Guard: union interleaves independent sub-tokenizers and cannot produce
# offsets at all, so highlight must raise a clean error instead of crashing.

statement ok
CREATE TEXT SEARCH DICTIONARY union_dict(
    template = 'union',
    tokenizer1_template = 'text',
    tokenizer1_locale = 'en_US.UTF-8',
    tokenizer1_case = 'lower',
    tokenizer1_stemming = false,
    tokenizer2_template = 'ngram',
    tokenizer2_mingram = 3,
    tokenizer2_maxgram = 3,
    frequency = true,
    position = true
)


statement ok
CREATE TABLE union_tbl(id INT, body TEXT)


statement ok
INSERT INTO union_tbl VALUES (1, 'hello world')


statement ok
CREATE INDEX union_idx ON union_tbl USING inverted(id, body union_dict)


statement error
SELECT ts_highlight(body) FROM union_idx WHERE body @@ ts_tokenize('hello')
----
db error: ERROR: ts_offsets()/ts_highlight() is not supported for this dictionary: its tokenizer does not produce text offsets


statement ok
DROP TABLE union_tbl


statement ok
DROP TEXT SEARCH DICTIONARY union_dict


statement ok
DROP TABLE snippets;


statement ok
DROP TEXT SEARCH DICTIONARY code_grams_copy;


statement ok
DROP TEXT SEARCH DICTIONARY code_grams_covering;


statement ok
DROP TEXT SEARCH DICTIONARY code_grams;

statement ok
DROP TABLE ranked;

statement ok
DROP TEXT SEARCH DICTIONARY code_grams_ranked;
