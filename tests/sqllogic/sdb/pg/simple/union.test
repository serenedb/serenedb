statement ok
CREATE TABLE union_values(id INTEGER, u UNION(num INTEGER, str VARCHAR));


statement count 4
INSERT INTO union_values VALUES
  (1, union_value(num := 1)),
  (2, 'two'),
  (3, union_value(str := 'three')),
  (4, 4);


# The union renders to the client as the active member's text value: the
# WrapUnsupportedTypes optimizer casts UNION -> VARCHAR, mirroring how VARIANT
# is cast to JSON.
query
EXPLAIN SELECT u FROM union_values;
----
QUERY PLAN
╭─ PROJECTION ─────────────────────╮
│ Projections: CAST(#0 AS VARCHAR) │
│ ~4 rows                          │
╰─────────────────┬────────────────╯
╭─ SEQ_SCAN ──────┴────────────────╮
│ Table: union_values              │
│ Type: Sequential Scan            │
│ Projections: u                   │
│ ~4 rows                          │
╰──────────────────────────────────╯


query
EXPLAIN SELECT id, u FROM union_values;
----
QUERY PLAN
╭─ PROJECTION ──────────────────────╮
│ Projections: #0,                  │
│              CAST(#1 AS VARCHAR)  │
│ ~4 rows                           │
╰─────────────────┬─────────────────╯
╭─ SEQ_SCAN ──────┴─────────────────╮
│ Table: union_values               │
│ Type: Sequential Scan             │
│ Projections: id, u                │
│ ~4 rows                           │
╰───────────────────────────────────╯


query
SELECT id, u FROM union_values ORDER BY id;
----
id	u
1	1
2	two
3	three
4	4


# The regtype text formatter on the server returns "union", but the
# extended-protocol client (sqllogictest-rs) has a hardcoded OID->name map of
# well-known PG OIDs and falls back to printing the raw OID for the custom
# UNION OID, so the pg_typeof / regtype assertions only run on simple protocol.
skipif pg-wire-extended
query
SELECT pg_typeof(u) FROM union_values WHERE id = 1;
----
pg_typeof
union


skipif pg-wire-extended
query
SELECT 'union'::regtype;
----
regtype
union


statement ok
CREATE TABLE ctas_union AS SELECT union_value(num := 7) AS u;


skipif pg-wire-extended
query
SELECT pg_typeof(u) FROM ctas_union;
----
pg_typeof
union


query
SELECT u FROM ctas_union;
----
u
7


statement ok
CREATE TABLE union_pk(id INTEGER PRIMARY KEY, u UNION(num INTEGER, str VARCHAR));


statement count 4
INSERT INTO union_pk VALUES
  (1, union_value(num := 1)),
  (2, 'two'),
  (3, union_value(str := 'three')),
  (4, 4);


query
SELECT u FROM union_pk WHERE id = 2;
----
u
two


query
SELECT id, u FROM union_pk ORDER BY id;
----
id	u
1	1
2	two
3	three
4	4


# A search table stores every column in the iresearch columnstore, so a UNION
# column round-trips through the struct-backed column reader/writer.
statement ok
CREATE TABLE union_search(id INTEGER PRIMARY KEY, u UNION(num INTEGER, str VARCHAR))
  WITH (storage = 'search');


statement count 4
INSERT INTO union_search VALUES
  (1, union_value(num := 1)),
  (2, 'two'),
  (3, union_value(str := 'three')),
  (4, 4);


statement ok
VACUUM (REFRESH_TABLE) union_search;


query
SELECT id, u FROM union_search ORDER BY id;
----
id	u
1	1
2	two
3	three
4	4


# union_extract / union_tag / dot-access keep working on stored unions.
query
SELECT id, union_extract(u, 'str') AS s, union_tag(u) AS t FROM union_search ORDER BY id;
----
id	s	t
1	NULL	num
2	two	str
3	three	str
4	NULL	num
