query
SELECT '{"a": 42}'::json::variant;
----
variant
{"a":42}


# The regtype text formatter on the server returns "variant", but the
# extended-protocol client (sqllogictest-rs) has a hardcoded OID->name map
# of well-known PG OIDs and falls back to printing the raw OID for VARIANT,
# so the assertions below only run on the simple protocol.
skipif pg-wire-extended
query
SELECT pg_typeof('{"a": 42}'::json::variant);
----
pg_typeof
variant


skipif pg-wire-extended
query
SELECT 'variant'::regtype;
----
regtype
variant


statement ok
CREATE TABLE variant_values(id INTEGER, x VARIANT);


statement ok
INSERT INTO variant_values VALUES
  (1, 42::variant),
  (2, 'hello'::variant),
  (3, true::variant),
  (4, '{"a": 42}'::json::variant);


skipif pg-wire-extended
query
SELECT pg_typeof(x) FROM variant_values WHERE id = 1;
----
pg_typeof
variant


statement ok
CREATE TABLE ctas_variant AS SELECT '{"a": 42}'::json::variant AS v;


skipif pg-wire-extended
query
SELECT pg_typeof(v) FROM ctas_variant;
----
pg_typeof
variant


query
EXPLAIN SELECT x FROM variant_values;
----
QUERY PLAN
╭─ PROJECTION ──────────────────╮
│ Projections: CAST(#0 AS JSON) │
│ ~4 rows                       │
╰───────────────┬───────────────╯
╭─ SEQ_SCAN ────┴───────────────╮
│ Table: variant_values         │
│ Type: Sequential Scan         │
│ Projections: x                │
│ ~4 rows                       │
╰───────────────────────────────╯


query
SELECT x FROM variant_values ORDER BY id;
----
x
42
"hello"
true
{"a":42}


