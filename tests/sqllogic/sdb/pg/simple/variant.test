statement ok
CREATE TABLE variant_pk(id INTEGER PRIMARY KEY, x VARIANT);


statement ok
INSERT INTO variant_pk VALUES
  (1, 42::variant),
  (2, 'hello'::variant),
  (3, true::variant),
  (4, '{"a": 42}'::json::variant);


query
EXPLAIN SELECT x FROM variant_pk WHERE id = 2;
----
QUERY PLAN
╭─ PROJECTION ──────────────────╮
│ Projections: CAST(#0 AS JSON) │
│ ~1 row                        │
╰───────────────┬───────────────╯
╭─ SEQ_SCAN ────┴───────────────╮
│ Table: variant_pk             │
│ Type: Sequential Scan         │
│ Projections: x                │
│ Filters: id = 2               │
│ ~1 row                        │
╰───────────────────────────────╯


query
SELECT x FROM variant_pk WHERE id = 2;
----
x
"hello"


