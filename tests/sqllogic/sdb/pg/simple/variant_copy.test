hash-threshold 100

control substitution on

statement ok
CREATE TABLE variant_src(id INTEGER, x VARIANT);


statement count 4
INSERT INTO variant_src VALUES
  (1, 42::variant),
  (2, 'hello'::variant),
  (3, true::variant),
  (4, '{"a": 42}'::json::variant);


statement count 4
COPY variant_src TO '${__TEST_DIR__}/variant.parquet' (FORMAT PARQUET);


statement ok
CREATE TABLE variant_pq(id INTEGER, x VARIANT);


statement count 4
COPY variant_pq FROM '${__TEST_DIR__}/variant.parquet' (FORMAT PARQUET);


query
SELECT id, x FROM variant_pq ORDER BY id;
----
id	x
1	42
2	"hello"
3	true
4	{"a":42}


statement count 4
COPY variant_src TO '${__TEST_DIR__}/variant.csv' (FORMAT CSV, HEADER TRUE);


# Read the CSV back into a TEXT column to verify the on-disk content.
# COPY TO CSV uses VARIANT's native text encoding (NOT the JSON cast that
# regular SELECT statements get from the WrapUnsupportedTypes optimizer),
# so the format is e.g. `{'a': 42}` rather than `{"a":42}`.
statement ok
CREATE TABLE variant_csv_text(id INTEGER, x TEXT);


statement count 4
COPY variant_csv_text FROM '${__TEST_DIR__}/variant.csv'
  (FORMAT CSV, HEADER TRUE);


query
SELECT id, x FROM variant_csv_text ORDER BY id;
----
id	x
1	42
2	hello
3	true
4	{'a': 42}


statement count 4
COPY (SELECT * FROM variant_src ORDER BY id) TO '${__TEST_DIR__}/variant_subq.parquet' (FORMAT PARQUET);


statement ok
CREATE TABLE variant_pq2(id INTEGER, x VARIANT);


statement count 4
COPY variant_pq2 FROM '${__TEST_DIR__}/variant_subq.parquet' (FORMAT PARQUET);


query
SELECT id, x FROM variant_pq2 ORDER BY id;
----
id	x
1	42
2	"hello"
3	true
4	{"a":42}
