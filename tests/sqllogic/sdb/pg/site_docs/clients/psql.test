# DOCS_TEST: example_002

statement ok
DROP TABLE IF EXISTS movies;

statement ok
CREATE TABLE movies(id INTEGER, title VARCHAR, genre VARCHAR, year INTEGER, rating DOUBLE);

statement ok
COPY (SELECT * FROM (VALUES
    (5, 'New Frontier', 'action', 2023, 8.8),
    (6, 'Quiet Place', 'horror', 2018, 7.5)
) AS t(id, title, genre, year, rating)) TO '${__TEST_DIR__}/clients_psql_example_002_movies_csv.csv' (FORMAT CSV, HEADER TRUE);

