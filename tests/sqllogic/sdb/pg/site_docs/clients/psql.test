statement ok
CREATE TABLE movies(id INTEGER, title VARCHAR, genre VARCHAR, year INTEGER, rating DOUBLE);

statement ok
INSERT INTO movies VALUES
    (1, 'Intro to Search', 'sci-fi', 2024, 9.5),
    (2, 'Scaling Analytics', 'drama', 2025, 8.1),
    (3, 'The Last Index', 'sci-fi', 2016, 7.7),
    (4, 'Old Classic', 'drama', 2009, 8.9);

# DOCS_TEST_BODY

query
SELECT title, rating FROM movies WHERE year > 2015 ORDER BY rating DESC LIMIT 5;
