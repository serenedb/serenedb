control substitution on

# Doc examples for the "Behavioral Differences from PostgreSQL" section of the
# compatibility/core-sql-compatibility page. The `_pgscan` suffix tells
# tests/sqllogic/run.sh to bring up a real postgres backend at ${PGHOST}:${PGPORT}.
# Each expression is checked on BOTH engines in one result set: the PostgreSQL
# column runs it on the attached postgres via postgres_query(); the SereneDB
# column evaluates it locally. COALESCE(TRY(...), 'error') turns a local
# evaluation error into the literal 'error'. The three casts that PostgreSQL
# itself rejects are written as a literal 'error' (postgres_query would abort the
# whole statement, and TRY cannot wrap a scalar subquery).

# DOCS_TEST: example_001

statement ok
DETACH IF EXISTS pg_${__DATABASE__};

statement ok
ATTACH 'host=${PGHOST} port=${PGPORT} dbname=postgres user=${PGUSER}' AS pg_${__DATABASE__} (TYPE postgres);

# DOCS_TEST_RAW
#| ATTACH 'host=localhost port=5432 dbname=mydb user=postgres' AS pg (TYPE postgres);
#|
#| SELECT '''1.1'' = 1'     AS "Expression", 'error'                                                              AS "PostgreSQL", COALESCE(TRY(('1.1' = 1)::text),     'error') AS "SereneDB"
#| UNION ALL SELECT '''1.1'' = 1.1',  (SELECT r FROM postgres_query('pg', 'SELECT (''1.1'' = 1.1)::text r')),  COALESCE(TRY(('1.1' = 1.1)::text),  'error')
#| UNION ALL SELECT '1 = 1.1',        (SELECT r FROM postgres_query('pg', 'SELECT (1 = 1.1)::text r')),         COALESCE(TRY((1 = 1.1)::text),      'error')
#| UNION ALL SELECT 'true = ''true''',(SELECT r FROM postgres_query('pg', 'SELECT (true = ''true'')::text r')), COALESCE(TRY((true = 'true')::text),'error')
#| UNION ALL SELECT 'true = 1',       'error',                                                                  COALESCE(TRY((true = 1)::text),     'error')
#| UNION ALL SELECT '''true'' = 1',   'error',                                                                  COALESCE(TRY(('true' = 1)::text),   'error');

# DOCS_TEST_BODY

query
SELECT '''1.1'' = 1' AS "Expression", 'error' AS "PostgreSQL", COALESCE(TRY(('1.1' = 1)::text), 'error') AS "SereneDB"
UNION ALL SELECT '''1.1'' = 1.1', (SELECT r FROM postgres_query('pg_${__DATABASE__}', 'SELECT (''1.1'' = 1.1)::text AS r')), COALESCE(TRY(('1.1' = 1.1)::text), 'error')
UNION ALL SELECT '1 = 1.1', (SELECT r FROM postgres_query('pg_${__DATABASE__}', 'SELECT (1 = 1.1)::text AS r')), COALESCE(TRY((1 = 1.1)::text), 'error')
UNION ALL SELECT 'true = ''true''', (SELECT r FROM postgres_query('pg_${__DATABASE__}', 'SELECT (true = ''true'')::text AS r')), COALESCE(TRY((true = 'true')::text), 'error')
UNION ALL SELECT 'true = 1', 'error', COALESCE(TRY((true = 1)::text), 'error')
UNION ALL SELECT '''true'' = 1', 'error', COALESCE(TRY(('true' = 1)::text), 'error');
----
Expression	PostgreSQL	SereneDB
'1.1' = 1	error	true
'1.1' = 1.1	true	true
1 = 1.1	false	false
true = 'true'	true	true
true = 1	error	true
'true' = 1	error	error

statement ok
DETACH pg_${__DATABASE__};
