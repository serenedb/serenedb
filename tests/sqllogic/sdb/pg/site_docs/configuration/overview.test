# DOCS_TEST: example_001

# DOCS_TEST_BODY

query
SELECT current_setting('memory_limit') AS memlimit;
----
memlimit
<slt:ignore>

# DOCS_TEST: example_002

# DOCS_TEST_BODY

statement ok
SELECT setting AS memlimit
FROM pg_settings
WHERE name = 'memory_limit';

# DOCS_TEST: example_003

# DOCS_TEST_BODY

statement ok
SET memory_limit = '10GB';

# DOCS_TEST: example_004

