# DOCS_TEST: example_001

query
SELECT current_setting('memory_limit') AS memlimit;
----
memlimit
<slt:ignore>

# DOCS_TEST: example_002

statement ok
SELECT value AS memlimit
FROM duckdb_settings()
WHERE name = 'memory_limit';

# DOCS_TEST: example_003

statement ok
SET memory_limit = '10GB';

# DOCS_TEST: example_004

statement ok
SET threads TO 1;

# DOCS_TEST: example_005

statement ok
SET enable_logging = true;

statement ok
SET logging_level = 'debug';

# DOCS_TEST: example_006

query
SELECT write_log('A new client has connected.', level := 'debug', scope := 'connection');
