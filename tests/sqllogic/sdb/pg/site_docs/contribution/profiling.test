query
CALL enable_profiling(
    format := 'json',
    save_location := '/tmp/${__DATABASE__}_contribution_profiling_example_002_output.json',
    coverage := 'select',
    mode := 'standard',
    metrics := ['QUERY_NAME', 'LATENCY', 'OPERATOR_TIMING']
);
