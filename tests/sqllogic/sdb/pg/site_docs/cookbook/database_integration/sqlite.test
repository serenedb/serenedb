# DOCS_TEST: example_004

# DOCS_TEST_BODY

statement error
-- Attach the SQLite file "test.db"
ATTACH 'test.db' AS test (TYPE sqlite);
----
db error: ERROR: Extension "/var/lib/serenedb/.duckdb/extensions/v0.0.1/linux_arm64/sqlite_scanner.duckdb_extension" not found.
Extension "sqlite" is an existing extension.

Install it first using "INSTALL sqlite".


query error
-- The table "tbl_name" can now be queried as if it is a regular table
SELECT * FROM test.tbl_name;
----
db error: ERROR: Table with name "test\.tbl_name" does not exist because schema "test" does not exist\.


statement ok
-- Switch the active database to "test"
USE test;

query
-- List all tables in the file
SHOW TABLES;
