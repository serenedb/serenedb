# DOCS_TEST: example_003

statement ok
USE $__DATABASE__;

statement ok
CREATE TABLE tbl (
    id INTEGER,
    name VARCHAR,
    col1 DOUBLE,
    col2 DOUBLE,
    "Some Column Name" VARCHAR,
    i INTEGER,
    a INTEGER,
    b INTEGER,
    c INTEGER,
    number INTEGER,
    number1 INTEGER,
    number2 INTEGER
);

statement ok
INSERT INTO tbl VALUES
    (1, 'mark', 1, 2, 'alpha', 1, 10, 20, 30, 10, 100, 1000),
    (3, 'bookmark', 4, 5, 'beta', 2, 11, 21, 31, 20, 200, 2000),
    (7, 'other', 9, 16, 'gamma', 3, 12, 22, 32, NULL, 300, 3000);

statement ok
COPY (SELECT * FROM (VALUES
    (8, 'fixture', 1.5, 2.5, 'delta', 4, 13, 23, 33, 30, 400, 4000),
    (9, 'sample', 3.5, 4.5, 'epsilon', 5, 14, 24, 34, 40, 500, 5000)
) AS t("id", "name", "col1", "col2", "Some Column Name", "i", "a", "b", "c", "number", "number1", "number2")) TO '/tmp/${__DATABASE__}_cookbook_file_formats_json_import_example_003_1_input_json.json' (FORMAT json);

