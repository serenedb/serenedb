    (1, 'alpha', 10),
    (2, 'beta', 20)
) AS t("id", "name", "value")) TO '/tmp/${__DATABASE__}_cookbook_file_formats_parquet_import_example_001_1_input_parquet.parquet' (FORMAT parquet);

