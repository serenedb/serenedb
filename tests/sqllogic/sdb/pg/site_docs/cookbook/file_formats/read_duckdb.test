control substitution on

# DOCS_TEST: example_001

statement ok
DETACH IF EXISTS db1;

statement ok
ATTACH '${__TEST_DIR__}/db1.duckdb' AS db1;

statement ok
DROP TABLE IF EXISTS db1.region;

statement ok
CREATE TABLE db1.region AS SELECT * FROM (VALUES
    (0, 'AFRICA'),
    (1, 'AMERICA'),
    (2, 'ASIA'),
    (3, 'EUROPE'),
    (4, 'MIDDLE EAST')
) AS t(r_regionkey, r_name);

statement ok
DETACH db1;

# DOCS_TEST_RAW
#| FROM read_duckdb('path_to_database', table_name = 'table_to_read');

# DOCS_TEST_BODY

query
FROM read_duckdb('${__TEST_DIR__}/db1.duckdb', table_name = 'region');
----
r_regionkey	r_name
0	AFRICA
1	AMERICA
2	ASIA
3	EUROPE
4	MIDDLE EAST


