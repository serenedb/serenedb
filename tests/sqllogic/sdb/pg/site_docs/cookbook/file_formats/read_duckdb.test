# DOCS_TEST: example_002

# DOCS_TEST_RAW
#| SELECT r_regionkey, r_name
#| FROM read_duckdb('https://blobs.duckdb.org/data/tpch-sf10.db', table_name = 'region');

# DOCS_TEST_BODY

statement ok
DETACH IF EXISTS read_duckdb_region;

statement ok
ATTACH '/tmp/${__DATABASE__}_cookbook_file_formats_read_duckdb_example_002_tpch_sf10.duckdb' AS read_duckdb_region;

statement ok
DROP TABLE IF EXISTS read_duckdb_region.region;

statement ok
CREATE TABLE read_duckdb_region.region AS SELECT * FROM (VALUES
    (0, 'AFRICA'),
    (1, 'AMERICA'),
    (2, 'ASIA'),
    (3, 'EUROPE'),
    (4, 'MIDDLE EAST')
) AS t(r_regionkey, r_name);

statement ok
DETACH read_duckdb_region;

query
SELECT r_regionkey, r_name
FROM read_duckdb('/tmp/${__DATABASE__}_cookbook_file_formats_read_duckdb_example_002_tpch_sf10.duckdb', table_name = 'region');
----
r_regionkey	r_name
0	AFRICA
1	AMERICA
2	ASIA
3	EUROPE
4	MIDDLE EAST

