# DOCS_TEST: example_003

statement ok
DETACH IF EXISTS read_duckdb_numbers_1_${__RUN_ID__};

statement ok
DETACH IF EXISTS read_duckdb_numbers_2_${__RUN_ID__};

statement ok
ATTACH '${__TEST_DIR__}/${__RUN_ID__}_cookbook_file_formats_read_duckdb_example_003_my_1.duckdb' AS read_duckdb_numbers_1_${__RUN_ID__};

statement ok
DROP TABLE IF EXISTS read_duckdb_numbers_1_${__RUN_ID__}.numbers;

statement ok
CREATE TABLE read_duckdb_numbers_1_${__RUN_ID__}.numbers AS SELECT 42 AS x;

statement ok
DROP TABLE IF EXISTS read_duckdb_numbers_1_${__RUN_ID__}.letters;

statement ok
CREATE TABLE read_duckdb_numbers_1_${__RUN_ID__}.letters AS SELECT 'm' AS a;

statement ok
DETACH read_duckdb_numbers_1_${__RUN_ID__};

statement ok
ATTACH '${__TEST_DIR__}/${__RUN_ID__}_cookbook_file_formats_read_duckdb_example_003_my_2.duckdb' AS read_duckdb_numbers_2_${__RUN_ID__};

statement ok
