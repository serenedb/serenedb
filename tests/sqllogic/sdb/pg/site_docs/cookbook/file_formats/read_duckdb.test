control substitution on

# DOCS_TEST: example_001

statement ok
DETACH IF EXISTS read_duckdb_intro_${__RUN_ID__};

statement ok
ATTACH '${__TEST_DIR__}/${__RUN_ID__}_cookbook_file_formats_read_duckdb_example_001_database.duckdb' AS read_duckdb_intro_${__RUN_ID__};

statement ok
DROP TABLE IF EXISTS read_duckdb_intro_${__RUN_ID__}.region;

statement ok
CREATE TABLE read_duckdb_intro_${__RUN_ID__}.region AS SELECT * FROM (VALUES
    (0, 'AFRICA'),
    (1, 'AMERICA'),
    (2, 'ASIA'),
    (3, 'EUROPE'),
    (4, 'MIDDLE EAST')
) AS t(r_regionkey, r_name);

statement ok
DETACH read_duckdb_intro_${__RUN_ID__};

# DOCS_TEST_RAW
#| FROM read_duckdb('path_to_database', table_name = 'table_to_read');

# DOCS_TEST_BODY

query
FROM read_duckdb('${__TEST_DIR__}/${__RUN_ID__}_cookbook_file_formats_read_duckdb_example_001_database.duckdb', table_name = 'region');
----
r_regionkey	r_name
0	AFRICA
1	AMERICA
2	ASIA
3	EUROPE
4	MIDDLE EAST


