statement ok
DESCRIBE FROM read_text('README.md');

# DOCS_TEST: example_004

statement ok
COPY (
    SELECT * FROM (VALUES
        (1, 'a', DATE '2012-01-01'),
        (2, 'b', DATE '2013-01-01'),
        (3, 'c', DATE '2014-01-01')
    ) AS t(value, part, date)
) TO '/tmp/${__DATABASE__}_cookbook_file_formats_read_file_example_004_hive'
(FORMAT parquet, PARTITION_BY (part, date), OVERWRITE_OR_IGNORE);

# DOCS_TEST_RAW
#| SELECT *
#| FROM read_blob('data/parquet-testing/hive-partitioning/simple/**/*.parquet')
#| WHERE part IN ('a', 'b') AND date >= '2012-01-01';

# DOCS_TEST_BODY

query
WITH files AS MATERIALIZED (
    SELECT *
    FROM read_blob('/tmp/${__DATABASE__}_cookbook_file_formats_read_file_example_004_hive/**/*.parquet')
)
SELECT *
FROM (
    SELECT
        regexp_replace(filename, '^.*/(part=.*)', 'data/parquet-testing/hive-partitioning/simple/\\1') AS filename,
        content,
        size,
        TIMESTAMP '2024-11-12 02:23:20' AS last_modified,
        date,
        part
    FROM files
) normalized
WHERE part IN ('a', 'b') AND date >= '2012-01-01'
ORDER BY part, date;
----
filename	content	size	last_modified	date	part
data/parquet-testing/hive-partitioning/simple/part=a/date=2012-01-01/data_0.parquet	\\	198	2024-11-12 02:23:20	2012-01-01	a
data/parquet-testing/hive-partitioning/simple/part=b/date=2013-01-01/data_0.parquet	\\	198	2024-11-12 02:23:20	2013-01-01	b
