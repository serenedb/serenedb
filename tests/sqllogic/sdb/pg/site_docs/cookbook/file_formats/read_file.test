control substitution on

# DOCS_TEST: example_001

statement ok
COPY (SELECT 'Hello World!' AS content) TO '/tmp/${__DATABASE__}_cookbook_file_formats_read_file_example_001_one.txt' (FORMAT csv, HEADER false, DELIMITER '|', QUOTE '');

statement ok
COPY (SELECT '42' AS content) TO '/tmp/${__DATABASE__}_cookbook_file_formats_read_file_example_001_three.txt' (FORMAT csv, HEADER false, DELIMITER '|', QUOTE '');

statement ok
COPY (SELECT 'Föö Bär' AS content) TO '/tmp/${__DATABASE__}_cookbook_file_formats_read_file_example_001_two.txt' (FORMAT csv, HEADER false, DELIMITER '|', QUOTE '');

# DOCS_TEST_RAW
#| SELECT size, parse_path(filename), content
#| FROM read_text('test/sql/table_function/files/*.txt');

# DOCS_TEST_BODY

query
SELECT
    size - 1 AS size,
    parse_path('test/sql/table_function/files/' || regexp_replace(filename, '^.*_example_001_', '')) AS "parse_path(filename)",
    left(content, length(content) - 1) AS content
FROM read_text('/tmp/${__DATABASE__}_cookbook_file_formats_read_file_example_001_*.txt')
ORDER BY regexp_replace(filename, '^.*_example_001_', '');
----
size	parse_path(filename)	content
12	{test,sql,table_function,files,one.txt}	Hello World!
2	{test,sql,table_function,files,three.txt}	42
10	{test,sql,table_function,files,two.txt}	Föö Bär

