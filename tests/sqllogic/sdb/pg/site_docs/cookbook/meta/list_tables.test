# DOCS_TEST: example_003

statement ok
DETACH IF EXISTS db_listtables;

statement ok
ATTACH ':memory:' AS db_listtables;

statement ok
CREATE TABLE db_listtables.main.main_tbl (u VARCHAR);

statement ok
CREATE SCHEMA db_listtables.s1;

statement ok
CREATE TABLE db_listtables.s1.schema_tbl (v VARCHAR);

