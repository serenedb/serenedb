# DOCS_TEST: example_002

statement ok
COPY (SELECT * FROM (VALUES
    (1, 'alpha', 10),
    (2, 'beta', 20)
) AS t("id", "name", "value")) TO '/tmp/${__DATABASE__}_cookbook_network_cloud_storage_cloudflare_r2_import_example_002_1_file.parquet' (FORMAT parquet);

