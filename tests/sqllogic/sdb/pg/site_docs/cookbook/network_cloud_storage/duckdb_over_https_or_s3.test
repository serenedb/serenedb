# DOCS_SETUP: local_stations_db_example_001

statement ok
DETACH IF EXISTS stations_fixture;

statement ok
ATTACH '/tmp/${__DATABASE__}_cookbook_network_cloud_storage_duckdb_over_https_or_s3_example_001_stations.duckdb' AS stations_fixture;

statement ok
DROP TABLE IF EXISTS stations_fixture.stations;

statement ok
CREATE TABLE stations_fixture.stations AS SELECT * FROM (VALUES
    (1, 'Amsterdam Centraal'),
    (2, 'Rotterdam Centraal')
) AS t(station_id, station_name);

statement ok
DETACH stations_fixture;

