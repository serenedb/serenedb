# DOCS_TEST: example_001

statement ok
DETACH IF EXISTS db111;

statement ok
ATTACH '${__TEST_DIR__}/db111.duckdb' AS db111;

statement ok
DROP TABLE IF EXISTS db111.stations;

statement ok
CREATE TABLE db111.stations AS SELECT * FROM (VALUES
    (1, 'Amsterdam Centraal'),
    (2, 'Rotterdam Centraal')
) AS t(station_id, station_name);

statement ok
DETACH db111;

