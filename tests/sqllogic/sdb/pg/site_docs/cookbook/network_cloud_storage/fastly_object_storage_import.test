# DOCS_TEST: example_002

statement ok
COPY (SELECT * FROM (VALUES
    (1, 'alpha', 10),
    (2, 'beta', 20)
) AS t("id", "name", "value")) TO '${__TEST_DIR__}/cookbook_network_cloud_storage_fastly_object_storage_import_example_002_1_file_csv.csv' (FORMAT CSV, HEADER true, DELIMITER ',');

statement ok
