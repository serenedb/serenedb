    (1, '[2,3]', 4.5),
    (2, '[5,8]', 9.5)
) AS t("duck", "goose", "swan")) TO '/tmp/${__DATABASE__}_cookbook_network_cloud_storage_http_import_example_004_1_prices_parquet.parquet' (FORMAT parquet);

