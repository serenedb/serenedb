control substitution on

# DOCS_TEST: example_003

statement ok
COPY (SELECT * FROM (VALUES
    (1, 'alpha', 10),
    (2, 'beta', 20)
) AS t("id", "name", "value")) TO '/tmp/${__DATABASE__}_cookbook_network_cloud_storage_http_import_example_003_1_file_parquet.parquet' (FORMAT parquet);

# DOCS_TEST_RAW
#| SELECT * FROM read_parquet('https://⟨domain⟩/path/to/file.parquet');

# DOCS_TEST_BODY

query
SELECT * FROM read_parquet('/tmp/${__DATABASE__}_cookbook_network_cloud_storage_http_import_example_003_1_file_parquet.parquet');
----
id	name	value
1	alpha	10
2	beta	20

# DOCS_TEST: example_004

statement ok
COPY (SELECT * FROM (VALUES
    (1, '[2,3]', 4.5),
    (2, '[5,8]', 9.5)
) AS t("a", "b", "c")) TO '/tmp/${__DATABASE__}_cookbook_network_cloud_storage_http_import_example_004_1_prices_parquet.parquet' (FORMAT parquet);

