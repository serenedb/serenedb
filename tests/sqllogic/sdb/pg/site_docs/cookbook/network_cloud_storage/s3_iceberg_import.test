    (1, 'alpha', 10),
    (2, 'beta', 20)
) AS t("id", "name", "value")) TO '${__TEST_DIR__}/cookbook_network_cloud_storage_s3_iceberg_import_example_005_1_iceberg_table_file.parquet' (FORMAT parquet);

