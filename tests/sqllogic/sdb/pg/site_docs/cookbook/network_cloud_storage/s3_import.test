# DOCS_TEST: example_005

statement ok
COPY (SELECT * FROM (VALUES
    (1, 'alpha', 10),
    (2, 'beta', 20)
) AS t("id", "name", "value")) TO '/tmp/${__DATABASE__}_cookbook_network_cloud_storage_s3_import_example_005_1_file.parquet' (FORMAT parquet);

# DOCS_TEST_RAW
#| SELECT * FROM read_parquet('s3://⟨bucket⟩/⟨file⟩');

