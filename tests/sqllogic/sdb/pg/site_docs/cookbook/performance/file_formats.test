# DOCS_TEST: example_001

statement ok
COPY (SELECT * FROM (VALUES
    (1, 'alpha'),
    (2, 'beta')
) AS t("hello", "world")) TO '/tmp/${__DATABASE__}_cookbook_performance_file_formats_example_001_part_0001.csv' (FORMAT CSV, HEADER true, DELIMITER ',');

