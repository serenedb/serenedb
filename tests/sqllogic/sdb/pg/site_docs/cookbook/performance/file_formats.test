# DOCS_TEST_BODY

query
SELECT replace(
    Prompt,
    '/tmp/${__DATABASE__}_cookbook_performance_file_formats_example_001_part_0001.csv',
    'file_path.csv'
) AS Prompt
FROM sniff_csv('/tmp/${__DATABASE__}_cookbook_performance_file_formats_example_001_part_0001.csv');
