# DOCS_TEST_BODY

statement ok
SET disabled_optimizers = '';

# DOCS_TEST: example_004

# DOCS_TEST_BODY

statement ok
CREATE OR REPLACE TEMPORARY TABLE t1 AS
    SELECT
        r.region_id,
        r.region_name,
        c.customer_id,
        c.name
    FROM regions AS r
    JOIN customers AS c ON c.region_id = r.region_id;

statement ok
CREATE OR REPLACE TEMPORARY TABLE t2 AS
    SELECT
        t1.region_name,
        t1.name,
        o.amount
    FROM t1
    JOIN orders AS o ON o.customer_id = t1.customer_id;

query
SELECT *
FROM t2
ORDER BY amount;
----
region_name	name	amount
South	Bob	30
North	Alice	50
North	Alice	75

