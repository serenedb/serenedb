# DOCS_TEST: example_009

statement error db error: ERROR: required parameter "template" was not found
CREATE TEXT SEARCH DICTIONARY search_friendly (
    TEMPLATE = 'text',
    LOCALE = 'en_US.UTF-8',
    CASE = 'lower',
    STEMMING = true,
    ACCENT = false,
    FREQUENCY = true,
    POSITION = true
);

