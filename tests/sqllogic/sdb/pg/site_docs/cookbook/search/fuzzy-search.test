# DOCS_TEST: example_001

statement error db error: ERROR: required parameter "template" was not found
CREATE TEXT SEARCH DICTIONARY fuzzy_dict (
    TEMPLATE = 'text',
    LOCALE = 'en_US.UTF-8',
    CASE = 'lower',
    STEMMING = false,
    ACCENT = false
);

statement ok
CREATE TABLE products (
    id INTEGER PRIMARY KEY,
    name TEXT
);

statement error db error: ERROR: Failed to create index: Unknown opclass 'fuzzy_dict' on column 'name': not a built\-in type \(known: included, hnsw\) and no text dictionary by that name in schema 'public'
CREATE INDEX idx_products ON products
    USING inverted (id, name fuzzy_dict);

statement ok
INSERT INTO products VALUES
    (1, 'cat'), (2, 'bat'), (3, 'car'),
    (4, 'dog'), (5, 'cats'), (6, 'act');

statement ok
VACUUM (UPDATE_INDEXES) products;

# DOCS_TEST: example_002

query error
