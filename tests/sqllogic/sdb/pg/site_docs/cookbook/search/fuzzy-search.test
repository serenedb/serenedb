# DOCS_TEST: example_001

statement ok
CREATE TEXT SEARCH DICTIONARY fuzzy_dict (
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'lower',
    stemming = false,
    accent = false
);

statement ok
CREATE TABLE products (
    id INTEGER PRIMARY KEY,
    name TEXT
);

statement ok
CREATE INDEX idx_products ON products
    USING inverted (id, name fuzzy_dict);

statement ok
INSERT INTO products VALUES
    (1, 'cat'), (2, 'bat'), (3, 'car'),
    (4, 'dog'), (5, 'cats'), (6, 'act');

statement ok
VACUUM (UPDATE_INDEXES) products;

# DOCS_TEST: example_002

query error
-- Exact match only (distance 0)
SELECT id, name FROM idx_products
WHERE LEVENSHTEIN_MATCH(name, 'cat', 0)
ORDER BY id;
----
db error: ERROR: Scalar Function with name levenshtein_match does not exist!
Did you mean "<slt:ignore>"?


query error
-- Distance 1: one edit away
SELECT id, name FROM idx_products
WHERE LEVENSHTEIN_MATCH(name, 'cat', 1)
ORDER BY id;
----
db error: ERROR: Scalar Function with name levenshtein_match does not exist!
Did you mean "<slt:ignore>"?


query error
-- Distance 2: two edits away
SELECT id, name FROM idx_products
WHERE LEVENSHTEIN_MATCH(name, 'cat', 2)
ORDER BY id;
----
db error: ERROR: Scalar Function with name levenshtein_match does not exist!
Did you mean "<slt:ignore>"?


