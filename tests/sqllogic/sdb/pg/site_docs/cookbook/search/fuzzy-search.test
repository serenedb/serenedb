# DOCS_TEST: example_005

statement error db error: ERROR: required parameter "template" was not found
CREATE TEXT SEARCH DICTIONARY bigram_dict (
    TEMPLATE = 'ngram',
    MINGRAM = 2,
    MAXGRAM = 2,
    FREQUENCY = true,
    POSITION = true
);

statement ok
CREATE TABLE articles (
    id INTEGER PRIMARY KEY,
    title TEXT
);

statement error db error: ERROR: Failed to create index: Unknown opclass 'bigram_dict' on column 'title': not a built\-in type \(known: included, hnsw\) and no text dictionary by that name in schema 'public'
CREATE INDEX idx_articles_ngram ON articles
    USING inverted (id, title bigram_dict);

statement ok
INSERT INTO articles VALUES
    (1, 'hello'), (2, 'help'), (3, 'world'),
    (4, 'held'), (5, 'hero');

statement ok
VACUUM (UPDATE_INDEXES) articles;

# DOCS_TEST: example_006

query error
-- Default threshold (0.7) — strict matching
SELECT id, title FROM idx_articles_ngram
WHERE NGRAM_MATCH(title, 'hello')
ORDER BY id;
----
db error: ERROR: Table with name idx_articles_ngram does not exist!
Did you mean "<slt:ignore>"?


query error
-- Lower threshold (0.3) — matches more loosely
SELECT id, title FROM idx_articles_ngram
WHERE NGRAM_MATCH(title, 'hello', 0.3)
ORDER BY id;
----
db error: ERROR: Table with name idx_articles_ngram does not exist!
Did you mean "<slt:ignore>"?


query error
-- Threshold 0.0 — matches anything with at least one shared n-gram
SELECT id, title FROM idx_articles_ngram
WHERE NGRAM_MATCH(title, 'hello', 0.0)
ORDER BY id;
----
db error: ERROR: Table with name idx_articles_ngram does not exist!
Did you mean "<slt:ignore>"?


# DOCS_TEST: example_007

query error
-- Fuzzy match + exact filter
SELECT id, name FROM idx_products
WHERE LEVENSHTEIN_MATCH(name, 'cat', 1) AND id < 4
ORDER BY id;
----
db error: ERROR: Table with name idx_products does not exist!
Did you mean "<slt:ignore>"?


query error
-- Fuzzy match + phrase search
SELECT id, title FROM idx_articles_ngram
WHERE NGRAM_MATCH(title, 'hello', 0.3) AND PHRASE(title, 'world')
ORDER BY id;
----
db error: ERROR: Table with name idx_articles_ngram does not exist!
Did you mean "<slt:ignore>"?
