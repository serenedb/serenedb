CREATE TABLE logs (
    id INTEGER,
    timestamp TIMESTAMP,
    level TEXT,
    service TEXT,
    message TEXT
) USING EXTERNAL WITH (
    PATH = 's3://my-bucket/logs/2025/*.parquet',
    FORMAT = 'Parquet',
    S3_ACCESS_KEY = 'your-access-key',
    S3_SECRET_KEY = 'your-secret-key',
    S3_REGION = 'us-east-1'
);
