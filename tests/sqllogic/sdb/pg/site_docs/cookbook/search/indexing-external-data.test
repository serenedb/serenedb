# DOCS_TEST: example_005

query error
-- Full-text search
SELECT id, timestamp, message
FROM logs_search
WHERE PHRASE(message, 'connection timeout')
ORDER BY BM25() DESC
LIMIT 20;
----
db error: ERROR: Scalar Function with name phrase does not exist!
Did you mean "<slt:ignore>"?


query error
-- Combine search with exact filters
SELECT id, timestamp, level, message
FROM logs_search
WHERE PHRASE(message, 'out of memory') AND level = 'ERROR'
ORDER BY timestamp DESC;
----
db error: ERROR: Scalar Function with name phrase does not exist!
Did you mean "<slt:ignore>"?


query error
-- Fuzzy matching for typo tolerance
SELECT id, service, message
FROM logs_search
WHERE LEVENSHTEIN_MATCH(service, 'postgre', 1)
ORDER BY id;
