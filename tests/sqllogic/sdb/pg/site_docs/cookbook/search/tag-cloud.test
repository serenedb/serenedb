# DOCS_TEST: setup

# DOCS_TEST_BODY

statement ok
CREATE TEXT SEARCH DICTIONARY tx (
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'lower',
    stemming = false,
    accent = false,
    frequency = true,
    position = true,
    stopwords = '"the","a","an","and","at","to","of","in","for","more","than"'
);

statement ok
CREATE TABLE posts (id INTEGER PRIMARY KEY, body VARCHAR);

statement ok
INSERT INTO posts VALUES
(1, 'Espresso starts at the grind. Grind finer to slow the shot, grind coarser to speed the shot.'),
(2, 'Dial the grind, pull the shot, read the crema. A tight grind pulls a rich shot.'),
(3, 'Fresh beans need a fresh grind. Grind the beans and pull a clean shot.'),
(4, 'The grinder matters more than the machine. Dose, grind, tamp, pull: the grind rules the shot.');

statement ok
CREATE INDEX posts_idx ON posts USING inverted (id, body tx);

statement ok
VACUUM (REFRESH_TABLE) posts;

# DOCS_TEST: example_001

# DOCS_TEST_BODY

query
SELECT unnest(ts_dict_agg(body))  AS term,
       unnest(ts_dict_freq(body)) AS mentions
FROM posts_idx
ORDER BY mentions DESC, term;
----
term	mentions
grind	9
shot	6
pull	3
beans	2
fresh	2
clean	1
coarser	1
crema	1
dial	1
dose	1
espresso	1
finer	1
grinder	1
machine	1
matters	1
need	1
pulls	1
read	1
rich	1
rules	1
slow	1
speed	1
starts	1
tamp	1
tight	1

# DOCS_TEST: example_002

# DOCS_TEST_BODY

query
SELECT unnest(ts_dict_agg(body))   AS term,
       unnest(ts_dict_count(body))  AS docs,
       unnest(ts_dict_freq(body))   AS mentions
FROM posts_idx
ORDER BY mentions DESC, term;
----
term	docs	mentions
grind	4	9
shot	4	6
pull	3	3
beans	1	2
fresh	1	2
clean	1	1
coarser	1	1
crema	1	1
dial	1	1
dose	1	1
espresso	1	1
finer	1	1
grinder	1	1
machine	1	1
matters	1	1
need	1	1
pulls	1	1
read	1	1
rich	1	1
rules	1	1
slow	1	1
speed	1	1
starts	1	1
tamp	1	1
tight	1	1

# DOCS_TEST: example_003

# DOCS_TEST_BODY

query
SELECT unnest(ts_dict_agg(body))  AS term,
       unnest(ts_dict_freq(body)) AS mentions
FROM posts_idx
ORDER BY mentions DESC, term
LIMIT 2;
----
term	mentions
grind	9
shot	6
