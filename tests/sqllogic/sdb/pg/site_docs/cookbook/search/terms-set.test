# DOCS_TEST: example_003

# DOCS_TEST_BODY

query
SELECT id, name, skills
FROM candidates_idx
WHERE has_any_tokens(skills, ['java', 'sql', 'rust'], 2)
ORDER BY id;
----
id	name	skills
1	Alice	{java,sql,rust}
2	Bob	{java,sql,python}
3	Carol	{java,rust,go}
5	Erin	{java,sql,rust,go}
