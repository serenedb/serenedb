# DOCS_TEST: example_003

# DOCS_TEST_BODY

control substitution off

query ?? rowsort
SELECT
    message.lower().regexp_extract('\b(ci|cli|python)\b') AS topic,
    count(*) AS num_commits
FROM commits
WHERE topic <> ''
GROUP BY ALL
ORDER BY num_commits DESC;
----
topic	num_commits
ci	3
cli	1
python	1

control substitution on


# DOCS_TEST: example_004

# DOCS_TEST_BODY

control substitution off

statement ok
CREATE TABLE words AS
    SELECT unnest(
        message
            .lower()
            .regexp_replace('\W', ' ')
            .trim(' ')
            .string_split_regex('\W')
        ) AS word
FROM commits;

control substitution on


