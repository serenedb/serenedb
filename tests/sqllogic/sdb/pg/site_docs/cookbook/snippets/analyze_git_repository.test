# DOCS_TEST_BODY

statement ok
CREATE TABLE commits AS
    FROM read_csv(
            '/tmp/${__DATABASE__}_cookbook_snippets_analyze_git_repository_example_001_1_git_log_csv.csv',
            delim = '🍥',
            header = false,
            column_names = ['timestamp', 'hash', 'author', 'message']
        );


