# DOCS_TEST: example_003

query error substitution failed: Invalid escape sequence: \\b
SELECT
    message.lower().regexp_extract('\b(ci|cli|python)\b') AS topic,
    count(*) AS num_commits
FROM commits
WHERE topic <> ''
GROUP BY ALL
ORDER BY num_commits DESC;

# DOCS_TEST: example_004

statement error substitution failed: Invalid escape sequence: \\W
CREATE TABLE words AS
    SELECT unnest(
        message
            .lower()
            .regexp_replace('\W', ' ')
            .trim(' ')
            .string_split_regex('\W')
        ) AS word
FROM commits;

