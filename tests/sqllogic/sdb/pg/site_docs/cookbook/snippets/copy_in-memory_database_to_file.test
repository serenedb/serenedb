statement ok
ATTACH '/tmp/${__DATABASE__}_cookbook_snippets_copy_in_memory_database_to_file_example_001_my_database.db' AS my_database;

statement ok
COPY FROM DATABASE memory TO my_database;

statement ok
DETACH my_database;
