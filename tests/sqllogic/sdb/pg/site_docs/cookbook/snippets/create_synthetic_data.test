# DOCS_TEST_BODY

query
SELECT
    hash(i * 10 + j)                                          AS id,
    DATE '2000-01-01' + (hash(i * 10 + j) % 9000)::INTEGER    AS creation_date,
    left(md5((i * 10 + j)::VARCHAR), 12)                      AS short_text,
    md5((i * 10 + j)::VARCHAR) || md5((j * 100 + i)::VARCHAR)  AS long_text,
    (j % 2 = 1)                                               AS flag
FROM generate_series(1, 5) AS s(i)
CROSS JOIN generate_series(1, 2) AS t(j)
ORDER BY i, j;
