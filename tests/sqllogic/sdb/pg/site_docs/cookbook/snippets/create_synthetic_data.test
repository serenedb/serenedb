# DOCS_TEST: example_002

# DOCS_TEST_BODY

statement ok
CREATE TABLE synthetic_users AS
SELECT
    i                                              AS id,
    'user_' || i                                   AS username,
    DATE '2024-01-01' + (hash(i) % 365)::INTEGER   AS signed_up,
    (hash(i * 31) % 1000) / 10.0                   AS balance
FROM generate_series(1, 1000) AS s(i);

query
SELECT COUNT(*) AS rows, MIN(id) AS min_id, MAX(id) AS max_id
FROM synthetic_users;
----
rows	min_id	max_id
1000	1	1000
