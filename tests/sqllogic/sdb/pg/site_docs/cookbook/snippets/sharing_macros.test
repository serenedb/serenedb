# DOCS_TEST: example_004

# DOCS_TEST_BODY

statement ok
CREATE MACRO checksum(table_name) AS TABLE
    SELECT bit_xor(md5_number(COLUMNS(*)::VARCHAR))
    FROM query_table(table_name);

# DOCS_TEST: example_006

statement ok
COPY (SELECT * FROM (VALUES
    (1, '[2,3]', 4.5::DOUBLE),
    (2, '[5,8]', 9.5::DOUBLE)
) AS t("duck", "goose", "swan")) TO '/tmp/${__DATABASE__}_cookbook_snippets_sharing_macros_example_006_1_stations_parquet.parquet' (FORMAT parquet);

