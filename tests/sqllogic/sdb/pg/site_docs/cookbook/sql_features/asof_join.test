# DOCS_TEST_BODY

statement ok
CREATE TABLE prices AS FROM '/tmp/${__DATABASE__}_cookbook_sql_features_asof_join_example_001_prices.csv';

statement ok
CREATE TABLE holdings AS FROM '/tmp/${__DATABASE__}_cookbook_sql_features_asof_join_example_001_holdings.csv';

# DOCS_TEST: example_002

statement ok
DROP TABLE IF EXISTS prices;

statement ok
DROP TABLE IF EXISTS holdings;

statement ok
CREATE TABLE prices (
    ticker VARCHAR,
    "when" TIMESTAMP,
    price DOUBLE
);

statement ok
INSERT INTO prices VALUES
    ('APPL', TIMESTAMP '2001-01-01 00:00:00', 1.0),
    ('APPL', TIMESTAMP '2001-01-01 00:01:00', 2.0),
    ('APPL', TIMESTAMP '2001-01-01 00:02:00', 3.0),
    ('MSFT', TIMESTAMP '2001-01-01 00:00:00', 1.0),
    ('MSFT', TIMESTAMP '2001-01-01 00:01:00', 2.0),
    ('MSFT', TIMESTAMP '2001-01-01 00:02:00', 3.0),
    ('GOOG', TIMESTAMP '2001-01-01 00:00:00', 1.0),
    ('GOOG', TIMESTAMP '2001-01-01 00:01:00', 2.0),
    ('GOOG', TIMESTAMP '2001-01-01 00:02:00', 3.0);

statement ok
CREATE TABLE holdings (
    ticker VARCHAR,
    "when" TIMESTAMP,
    shares DOUBLE
);

statement ok
INSERT INTO holdings VALUES
    ('APPL', TIMESTAMP '2000-12-31 23:59:30', 5.16),
    ('APPL', TIMESTAMP '2001-01-01 00:00:30', 2.94),
    ('APPL', TIMESTAMP '2001-01-01 00:01:30', 24.13),
    ('GOOG', TIMESTAMP '2000-12-31 23:59:30', 9.33),
    ('GOOG', TIMESTAMP '2001-01-01 00:00:30', 23.45),
    ('GOOG', TIMESTAMP '2001-01-01 00:01:30', 10.58),
    ('DATA', TIMESTAMP '2000-12-31 23:59:30', 6.65),
    ('DATA', TIMESTAMP '2001-01-01 00:00:30', 17.95),
    ('DATA', TIMESTAMP '2001-01-01 00:01:30', 18.37);

# DOCS_TEST_BODY

query ??? rowsort
SELECT h.ticker, h.when, price * shares AS value
FROM holdings h
ASOF JOIN prices p
       ON h.ticker = p.ticker
      AND h.when >= p.when;
----
ticker	when	value
APPL	2001-01-01 00:00:30	2.94
APPL	2001-01-01 00:01:30	48.26
GOOG	2001-01-01 00:00:30	23.45
GOOG	2001-01-01 00:01:30	21.16

# DOCS_TEST: example_003

# DOCS_TEST_RAW
#| SELECT h.ticker, h.when, price * shares AS value
#| FROM holdings h
#| ASOF LEFT JOIN prices p
#|             ON h.ticker = p.ticker
#|            AND h.when >= p.when;

# DOCS_TEST_BODY

query ???
SELECT h.ticker, h.when, price * shares AS value
FROM holdings h
ASOF LEFT JOIN prices p
            ON h.ticker = p.ticker
           AND h.when >= p.when
ORDER BY
    CASE h.ticker WHEN 'APPL' THEN 1 WHEN 'GOOG' THEN 2 WHEN 'DATA' THEN 3 ELSE 4 END,
    h.when;
----
ticker	when	value
APPL	2000-12-31 23:59:30	NULL
APPL	2001-01-01 00:00:30	2.94
APPL	2001-01-01 00:01:30	48.26
GOOG	2000-12-31 23:59:30	NULL
GOOG	2001-01-01 00:00:30	23.45
GOOG	2001-01-01 00:01:30	21.16
DATA	2000-12-31 23:59:30	NULL
DATA	2001-01-01 00:00:30	NULL
DATA	2001-01-01 00:01:30	NULL

# DOCS_TEST: example_004

# DOCS_TEST_BODY

query ??? rowsort
SELECT ticker, h.when, price * shares AS value
FROM holdings h
ASOF JOIN prices p USING (ticker, "when");
----
ticker	when	value
APPL	2001-01-01 00:00:30	2.94
APPL	2001-01-01 00:01:30	48.26
GOOG	2001-01-01 00:00:30	23.45
GOOG	2001-01-01 00:01:30	21.16

