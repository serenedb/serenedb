# DOCS_TEST: example_001

statement ok
COPY (SELECT * FROM (VALUES
    ('APPL', TIMESTAMP '2001-01-01 00:00:00', 1.0),
    ('APPL', TIMESTAMP '2001-01-01 00:01:00', 2.0),
    ('APPL', TIMESTAMP '2001-01-01 00:02:00', 3.0),
    ('MSFT', TIMESTAMP '2001-01-01 00:00:00', 1.0),
    ('MSFT', TIMESTAMP '2001-01-01 00:01:00', 2.0),
    ('MSFT', TIMESTAMP '2001-01-01 00:02:00', 3.0),
    ('GOOG', TIMESTAMP '2001-01-01 00:00:00', 1.0),
    ('GOOG', TIMESTAMP '2001-01-01 00:01:00', 2.0),
    ('GOOG', TIMESTAMP '2001-01-01 00:02:00', 3.0)
) AS t("ticker", "when", "price")) TO '/tmp/${__DATABASE__}_cookbook_sql_features_asof_join_example_001_prices.csv' (FORMAT CSV, HEADER true, DELIMITER ',');

statement ok
COPY (SELECT * FROM (VALUES
    ('APPL', TIMESTAMP '2000-12-31 23:59:30', 5.16),
    ('APPL', TIMESTAMP '2001-01-01 00:00:30', 2.94),
    ('APPL', TIMESTAMP '2001-01-01 00:01:30', 24.13),
    ('GOOG', TIMESTAMP '2000-12-31 23:59:30', 9.33),
    ('GOOG', TIMESTAMP '2001-01-01 00:00:30', 23.45),
    ('GOOG', TIMESTAMP '2001-01-01 00:01:30', 10.58),
    ('DATA', TIMESTAMP '2000-12-31 23:59:30', 6.65),
    ('DATA', TIMESTAMP '2001-01-01 00:00:30', 17.95),
    ('DATA', TIMESTAMP '2001-01-01 00:01:30', 18.37)
) AS t("ticker", "when", "shares")) TO '/tmp/${__DATABASE__}_cookbook_sql_features_asof_join_example_001_holdings.csv' (FORMAT CSV, HEADER true, DELIMITER ',');

