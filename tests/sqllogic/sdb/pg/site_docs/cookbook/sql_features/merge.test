3	103	Feathers	Rouen	Pond B	2025-11-24	2025-11-24	false
9	104	Splash	Muscovy	Pond C	2025-11-25	NULL	true
11	105	Puddles	Indian Runner	Relocated	2025-11-25	NULL	true
4	105	Puddles	Indian Runner	Pond A	2025-11-24	2025-11-24	false

query
