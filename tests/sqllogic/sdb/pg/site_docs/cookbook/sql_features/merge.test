CREATE TABLE IF NOT EXISTS incoming_employees (
    employee_id     INTEGER,
    employee_name   VARCHAR,
    department       VARCHAR,
    office    VARCHAR,
    begin_date  DATE,
    end_date    DATE,
    is_current  BOOLEAN
);

statement ok
