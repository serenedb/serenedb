# DOCS_TEST: example_001

# DOCS_TEST_BODY

statement ok
SET timezone = 'America/Los_Angeles';

statement ok
CREATE OR REPLACE TABLE times AS
    FROM range('2025-08-30'::TIMESTAMPTZ, '2025-08-31'::TIMESTAMPTZ, INTERVAL 1 HOUR) tbl(t);

query
SELECT count(*) AS matching_rows
FROM times
WHERE t <= '2025-08-30';
----
matching_rows
1

