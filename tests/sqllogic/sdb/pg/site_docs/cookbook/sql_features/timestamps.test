# DOCS_TEST: example_001

statement ok
SET timezone = 'America/Los_Angeles';

statement error
CREATE TABLE times AS
    FROM range('2025-08-30'::TIMESTAMPTZ, '2025-08-31'::TIMESTAMPTZ, INTERVAL 1 HOUR) tbl(t);
----
db error: ERROR: No function matches the given name and argument types 'range(TIMESTAMP WITH TIME ZONE, TIMESTAMP WITH TIME ZONE, INTERVAL)'. You might need to add explicit type casts.
	Candidate functions:
	range(BIGINT)
	range(BIGINT, BIGINT)
	range(BIGINT, BIGINT, BIGINT)
	range(TIMESTAMP, TIMESTAMP, INTERVAL)


query error
FROM times WHERE t <= '2025-08-30';
----
db error: ERROR: Table with name times does not exist!
Did you mean "<slt:ignore>"?


