# DOCS_TEST: example_004

statement ok
SET timezone = 'Europe/Amsterdam';

statement error
CREATE OR REPLACE TABLE hourly AS
    SELECT
        ts,
        year::SMALLINT AS year,
        month::TINYINT AS month,
        day::TINYINT AS day,
        hour::TINYINT AS hour,
    FROM (
        SELECT ts, unnest(date_part(['year', 'month', 'day', 'hour',], ts))
        FROM generate_series(
            '2020-01-01'::DATE::TIMESTAMPTZ,
            '2100-01-01'::DATE::TIMESTAMPTZ,
            INTERVAL 1 HOUR) tbl(ts)
    ) parts;
----
db error: ERROR: No function matches the given name and argument types 'generate_series(TIMESTAMP WITH TIME ZONE, TIMESTAMP WITH TIME ZONE, INTERVAL)'. You might need to add explicit type casts.
	Candidate functions:
	generate_series(BIGINT)
	generate_series(BIGINT, BIGINT)
	generate_series(BIGINT, BIGINT, BIGINT)
	generate_series(TIMESTAMP, TIMESTAMP, INTERVAL)


