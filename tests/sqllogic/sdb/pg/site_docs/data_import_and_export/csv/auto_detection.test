# DOCS_TEST: example_001

statement ok
COPY (SELECT * FROM (VALUES
    (1, 'alpha', 10),
    (2, 'beta', 20)
) AS t("id", "name", "value")) TO '/tmp/${__DATABASE__}_data_import_and_export_csv_auto_detection_example_001_my_csv_file.csv' (FORMAT CSV, HEADER true, DELIMITER ',');

