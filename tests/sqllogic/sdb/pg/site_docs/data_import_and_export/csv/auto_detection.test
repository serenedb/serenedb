# DOCS_TEST: example_002

statement ok
COPY (SELECT * FROM (VALUES
    (1, 'alpha', 10),
    (2, 'beta', 20)
) AS t("id", "name", "value")) TO '/tmp/${__DATABASE__}_data_import_and_export_csv_auto_detection_example_002_1_my_file_csv.csv' (FORMAT CSV, HEADER true, DELIMITER ',');

# DOCS_TEST_RAW
#| FROM sniff_csv('my_file.csv');
#|
#| FROM sniff_csv('my_file.csv', sample_size = 1000);

# DOCS_TEST_BODY

query
SELECT
    Delimiter,
    Quote,
    Escape,
    NewLineDelimiter,
    Comment,
    SkipRows,
    HasHeader,
    Columns,
    DateFormat,
    TimestampFormat,
    UserArguments,
    regexp_replace(Prompt, '''/tmp/[^'']*''', '''my_file.csv''') AS Prompt
FROM sniff_csv('/tmp/${__DATABASE__}_data_import_and_export_csv_auto_detection_example_002_1_my_file_csv.csv');
----
Delimiter	Quote	Escape	NewLineDelimiter	Comment	SkipRows	HasHeader	Columns	DateFormat	TimestampFormat	UserArguments	prompt
,	(empty)	(empty)	\\n	(empty)	0	t	{"(id,BIGINT)","(name,VARCHAR)","(value,BIGINT)"}	NULL	NULL	NULL	FROM read_csv('my_file.csv', auto_detect=false, delim=',', quote='', escape='', new_line='\\n', skip=0, comment='', header=true, columns={'id': 'BIGINT', 'name': 'VARCHAR', 'value': 'BIGINT'});


query
SELECT
    Delimiter,
    Quote,
    Escape,
    NewLineDelimiter,
    Comment,
    SkipRows,
    HasHeader,
    Columns,
    DateFormat,
    TimestampFormat,
    UserArguments,
    regexp_replace(Prompt, '''/tmp/[^'']*''', '''my_file.csv''') AS Prompt
FROM sniff_csv('/tmp/${__DATABASE__}_data_import_and_export_csv_auto_detection_example_002_1_my_file_csv.csv', sample_size = 1000);
----
Delimiter	Quote	Escape	NewLineDelimiter	Comment	SkipRows	HasHeader	Columns	DateFormat	TimestampFormat	UserArguments	prompt
,	(empty)	(empty)	\\n	(empty)	0	t	{"(id,BIGINT)","(name,VARCHAR)","(value,BIGINT)"}	NULL	NULL	sample_size=1000	FROM read_csv('my_file.csv', auto_detect=false, delim=',', quote='', escape='', new_line='\\n', skip=0, comment='', header=true, columns={'id': 'BIGINT', 'name': 'VARCHAR', 'value': 'BIGINT'}, sample_size=1000);

# DOCS_TEST: example_003

statement ok
COPY (SELECT * FROM (VALUES
    (1, 'alpha', 10),
    (2, 'beta', 20)
) AS t("id", "name", "value")) TO '/tmp/${__DATABASE__}_data_import_and_export_csv_auto_detection_example_003_my_file_csv.csv' (FORMAT CSV, HEADER true, DELIMITER ',');

# DOCS_TEST_RAW
#| SELECT Prompt FROM sniff_csv('my_file.csv');

# DOCS_TEST_BODY

query
SELECT regexp_replace(Prompt, '''/tmp/[^'']*''', '''my_file.csv''') AS Prompt
FROM sniff_csv('/tmp/${__DATABASE__}_data_import_and_export_csv_auto_detection_example_003_my_file_csv.csv');
----
prompt
FROM read_csv('my_file.csv', auto_detect=false, delim=',', quote='', escape='', new_line='\\n', skip=0, comment='', header=true, columns={'id': 'BIGINT', 'name': 'VARCHAR', 'value': 'BIGINT'});
