control substitution on

# DOCS_TEST: example_001

statement ok
COPY (SELECT * FROM (VALUES
    (DATE '2024-01-01', 'AA', 'New York, NY', 'Los Angeles, CA'),
    (DATE '2024-01-02', 'UA', 'San Francisco, CA', 'Seattle, WA')
) AS t("FlightDate", "UniqueCarrier", "OriginCityName", "DestCityName")) TO '${__TEST_DIR__}/data_import_and_export_csv_overview_example_001_1_flights_csv.csv' (FORMAT CSV, HEADER true, DELIMITER ',');

# DOCS_TEST_RAW
#| SELECT * FROM 'flights.csv';

# DOCS_TEST_BODY

query
SELECT * FROM '${__TEST_DIR__}/data_import_and_export_csv_overview_example_001_1_flights_csv.csv';
----
flightdate	uniquecarrier	origincityname	destcityname
2024-01-01	AA	New York, NY	Los Angeles, CA
2024-01-02	UA	San Francisco, CA	Seattle, WA

