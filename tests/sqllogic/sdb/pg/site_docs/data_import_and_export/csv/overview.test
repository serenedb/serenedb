# DOCS_TEST: example_006

statement ok
COPY (SELECT * FROM (VALUES
    (1, 'alpha', 10),
    (2, 'beta', 20)
) AS t("id", "name", "value")) TO '${__TEST_DIR__}/data_import_and_export_csv_overview_example_006_1_csv_file_csv.csv' (FORMAT CSV, HEADER true, DELIMITER ',');

