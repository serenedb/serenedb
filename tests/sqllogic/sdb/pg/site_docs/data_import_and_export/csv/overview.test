) AS t("FlightDate", "UniqueCarrier", "OriginCityName", "DestCityName")) TO '${__TEST_DIR__}/data_import_and_export_csv_overview_example_002_1_flights_csv.csv' (FORMAT CSV, HEADER true, DELIMITER '|');

# DOCS_TEST_RAW
