control substitution on

# DOCS_SETUP: file_fixtures_example_001

statement ok
COPY (SELECT * FROM (VALUES
    (DATE '2024-01-01', 'AA', 'New York, NY', 'Los Angeles, CA'),
    (DATE '2024-01-02', 'UA', 'San Francisco, CA', 'Seattle, WA')
) AS t("FlightDate", "UniqueCarrier", "OriginCityName", "DestCityName")) TO '/tmp/${__DATABASE__}_data_import_and_export_csv_tips_example_001_1_flights_csv.csv' (FORMAT CSV, HEADER true, DELIMITER ',');

# DOCS_TEST: example_001
# DOCS_RAW_BEGIN
#| SELECT * FROM read_csv('flights.csv', header = true);
# DOCS_RAW_END

query
SELECT * FROM read_csv('/tmp/${__DATABASE__}_data_import_and_export_csv_tips_example_001_1_flights_csv.csv', header = true);
----
flightdate	uniquecarrier	origincityname	destcityname
2024-01-01	AA	New York, NY	Los Angeles, CA
2024-01-02	UA	San Francisco, CA	Seattle, WA


