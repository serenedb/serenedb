# DOCS_TEST: example_001

query
SELECT to_json('duck');
----
to_json
"duck"

# DOCS_TEST: example_002

query
SELECT to_json([1, 2, 3]);
----
to_json
[1,2,3]

# DOCS_TEST: example_003

query
SELECT to_json({duck : 42});
----
to_json
{"duck":42}

# DOCS_TEST: example_004

query
SELECT to_json(MAP(['duck'], [42]));
----
to_json
{"duck":42}

# DOCS_TEST: example_005

query
SELECT json_array('duck', 42, 'goose', 123);
----
json_array
["duck",42,"goose",123]

# DOCS_TEST: example_006

query
SELECT json_object('duck', 42, 'goose', 123);
----
json_object
{"duck":42,"goose":123}

# DOCS_TEST: example_007

query
SELECT json_merge_patch('{"duck": 42}', '{"goose": 123}');
----
json_merge_patch
{"duck":42,"goose":123}
