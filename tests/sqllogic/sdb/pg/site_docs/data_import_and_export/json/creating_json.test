# DOCS_TEST: example_001

# DOCS_TEST_BODY

query
SELECT to_json('mercury');
----
to_json
"mercury"

# DOCS_TEST: example_002

# DOCS_TEST_BODY

query
SELECT to_json([1, 2, 3]);
----
to_json
[1,2,3]

# DOCS_TEST: example_003

# DOCS_TEST_BODY

query
SELECT to_json({mercury : 42});
----
to_json
{"mercury":42}

# DOCS_TEST: example_004

# DOCS_TEST_BODY

query
SELECT to_json(MAP(['mercury'], [42]));
----
to_json
{"mercury":42}

# DOCS_TEST: example_005

# DOCS_TEST_BODY

query
SELECT json_array('mercury', 42, 'venus', 123);
----
json_array
["mercury",42,"venus",123]

# DOCS_TEST: example_006

# DOCS_TEST_BODY

query
SELECT json_object('mercury', 42, 'venus', 123);
----
json_object
{"mercury":42,"venus":123}

# DOCS_TEST: example_007

# DOCS_TEST_BODY

query
SELECT json_merge_patch('{"mercury": 42}', '{"venus": 123}');
----
json_merge_patch
{"mercury":42,"venus":123}
