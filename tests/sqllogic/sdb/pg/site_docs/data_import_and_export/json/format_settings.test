# DOCS_SETUP: file_fixtures_example_001

statement ok
COPY (SELECT * FROM (VALUES
    ('{"key1":"value1", "key2": "value1"}'),
    ('{"key1":"value2", "key2": "value2"}'),
    ('{"key1":"value3", "key2": "value3"}')
) AS t(line)) TO '/tmp/${__DATABASE__}_data_import_and_export_json_format_settings_example_001_filename.json' (FORMAT csv, HEADER false, DELIMITER '|', QUOTE '');

# DOCS_TEST: example_001
# DOCS_RAW_BEGIN
#| SELECT *
#| FROM filename.json;
# DOCS_RAW_END

query
SELECT *
FROM '/tmp/${__DATABASE__}_data_import_and_export_json_format_settings_example_001_filename.json';
----
key1	key2
value1	value1
value2	value2
value3	value3


