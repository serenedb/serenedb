control substitution on

# DOCS_TEST: example_001

statement ok
COPY (SELECT * FROM (VALUES
    (1, 1, 'write docs fixtures', false),
    (1, 2, 'run sqllogictest', true)
) AS t("userId", "id", "title", "completed")) TO '${__TEST_DIR__}/data_import_and_export_json_loading_json_example_001_1_todos_json.json' (FORMAT json);

# DOCS_TEST_RAW
#| SELECT *
#| FROM read_json('todos.json')
#| LIMIT 5;

# DOCS_TEST_BODY

query
SELECT *
FROM read_json('${__TEST_DIR__}/data_import_and_export_json_loading_json_example_001_1_todos_json.json')
LIMIT 5;
----
userId	id	title	completed
1	1	write docs fixtures	f
1	2	run sqllogictest	t

# DOCS_TEST: example_002

statement ok
COPY (SELECT * FROM (VALUES
    (1, 1, 'write docs fixtures', false),
    (1, 2, 'run sqllogictest', true)
) AS t("userId", "id", "title", "completed")) TO '${__TEST_DIR__}/data_import_and_export_json_loading_json_example_002_1_todos_json.json' (FORMAT json);

# DOCS_TEST_RAW
#| CREATE TABLE todos AS
#|     SELECT *
#|     FROM read_json('todos.json');
#|
#| DESCRIBE todos;

# DOCS_TEST_BODY

statement ok
CREATE TABLE todos AS
    SELECT *
    FROM read_json('${__TEST_DIR__}/data_import_and_export_json_loading_json_example_002_1_todos_json.json');

query
DESCRIBE TABLE todos;
----
column_name	column_type	null	key	default	extra
userId	BIGINT	YES	NULL	NULL	NULL
id	BIGINT	YES	NULL	NULL	NULL
title	VARCHAR	YES	NULL	NULL	NULL
completed	BOOLEAN	YES	NULL	NULL	NULL

# DOCS_TEST: example_003

statement ok
COPY (SELECT * FROM (VALUES
    (1, 1, 'write docs fixtures', false),
    (1, 2, 'run sqllogictest', true)
) AS t("userId", "id", "title", "completed")) TO '${__TEST_DIR__}/data_import_and_export_json_loading_json_example_003_1_todos_json.json' (FORMAT json);

# DOCS_TEST_RAW
#| SELECT *
#| FROM read_json(
#|         'todos.json',
#|         columns = {userId: 'UBIGINT', completed: 'BOOLEAN'}
#|     )
#| LIMIT 5;

# DOCS_TEST_BODY

query
SELECT *
FROM read_json(
        '${__TEST_DIR__}/data_import_and_export_json_loading_json_example_003_1_todos_json.json',
        columns = {userId: 'UBIGINT', completed: 'BOOLEAN'}
    )
LIMIT 5;
----
userid	completed
1	f
1	t

# DOCS_TEST: example_004

statement ok
COPY (
    SELECT '{"a":42}' AS line
    UNION ALL
    SELECT '{"b":[1,2,3]}' AS line
) TO '${__TEST_DIR__}/data_import_and_export_json_loading_json_example_004_1_birds_json.json' (FORMAT csv, HEADER false, DELIMITER '|', QUOTE '');

# DOCS_TEST_RAW
#| FROM read_json_objects('data.json', format = 'unstructured');

# DOCS_TEST_BODY

query
FROM read_json_objects('${__TEST_DIR__}/data_import_and_export_json_loading_json_example_004_1_birds_json.json', format = 'unstructured');
----
json
{"a":42}
{"b":[1,2,3]}

