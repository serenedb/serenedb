    SELECT '{"a":43,"b":[4,5,6],"c":3.3}' AS line
) TO '${__TEST_DIR__}/data_import_and_export_json_loading_json_example_007_2_birds2_json.json' (FORMAT csv, HEADER false, DELIMITER '|', QUOTE '');

# DOCS_TEST_RAW
