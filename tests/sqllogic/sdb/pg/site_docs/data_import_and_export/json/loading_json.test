#| FROM read_json(
#|     ['data1.json', 'data2.json'],
#|     columns = {a: 'INTEGER', b: 'INTEGER[]', c: 'DOUBLE'}
#| );

# DOCS_TEST_BODY

query
SELECT *
FROM read_json(
    ['${__TEST_DIR__}/data_import_and_export_json_loading_json_example_007_1_birds1_json.json', '${__TEST_DIR__}/data_import_and_export_json_loading_json_example_007_2_birds2_json.json'],
    columns = {a: 'INTEGER', b: 'INTEGER[]', c: 'DOUBLE'}
);
----
a	b	c
42	{1,2,3}	NULL
43	{4,5,6}	3.3

