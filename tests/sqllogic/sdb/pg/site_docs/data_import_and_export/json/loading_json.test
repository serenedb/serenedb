control substitution on

# DOCS_SETUP: file_fixtures_example_001

statement ok
COPY (SELECT * FROM (VALUES
    (1, 1, 'write docs fixtures', false),
    (1, 2, 'run sqllogictest', true)
) AS t("userId", "id", "title", "completed")) TO '/tmp/${__DATABASE__}_data_import_and_export_json_loading_json_example_001_1_todos_json.json' (FORMAT json);

# DOCS_TEST: example_001
# DOCS_RAW_BEGIN
#| SELECT *
#| FROM read_json('todos.json')
#| LIMIT 5;
# DOCS_RAW_END

query
SELECT *
FROM read_json('/tmp/${__DATABASE__}_data_import_and_export_json_loading_json_example_001_1_todos_json.json')
LIMIT 5;
----
userid	id	title	completed
1	1	write docs fixtures	f
1	2	run sqllogictest	t


