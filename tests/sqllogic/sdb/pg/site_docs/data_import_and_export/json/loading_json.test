# DOCS_TEST: example_007

statement ok
COPY (
    SELECT '{"a":42,"b":[1,2,3]}' AS line
) TO '${__TEST_DIR__}/data_import_and_export_json_loading_json_example_007_1_birds1_json.json' (FORMAT csv, HEADER false, DELIMITER '|', QUOTE '');

statement ok
