# DOCS_TEST: example_001

statement ok
COPY (SELECT * FROM (VALUES
    (1, 1, 'write docs fixtures', false),
    (1, 2, 'run sqllogictest', true)
) AS t("userId", "id", "title", "completed")) TO '${__TEST_DIR__}/data_import_and_export_json_overview_example_001_1_todos_json.json' (FORMAT json);

# DOCS_TEST_RAW
#| SELECT * FROM 'todos.json';

# DOCS_TEST_BODY

query
SELECT * FROM '${__TEST_DIR__}/data_import_and_export_json_overview_example_001_1_todos_json.json';
----
userId	id	title	completed
1	1	write docs fixtures	f
1	2	run sqllogictest	t

# DOCS_TEST: example_002

statement ok
COPY (SELECT * FROM (VALUES
    (1, 1, 'write docs fixtures', false),
    (1, 2, 'run sqllogictest', true)
) AS t("userId", "id", "title", "completed")) TO '${__TEST_DIR__}/data_import_and_export_json_overview_example_002_1_todos_json.json' (FORMAT json, ARRAY true);

# DOCS_TEST_RAW
#| SELECT *
#| FROM read_json('todos.json',
#|                format = 'array',
#|                columns = {userId: 'UBIGINT',
#|                           id: 'UBIGINT',
#|                           title: 'VARCHAR',
#|                           completed: 'BOOLEAN'});

# DOCS_TEST_BODY

query
SELECT *
FROM read_json('${__TEST_DIR__}/data_import_and_export_json_overview_example_002_1_todos_json.json',
               format = 'array',
               columns = {userId: 'UBIGINT',
                          id: 'UBIGINT',
                          title: 'VARCHAR',
                          completed: 'BOOLEAN'});
----
userid	id	title	completed
1	1	write docs fixtures	f
1	2	run sqllogictest	t

