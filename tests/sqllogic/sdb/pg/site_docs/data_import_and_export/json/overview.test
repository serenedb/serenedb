    (1, 2, 'run sqllogictest', true)
) AS t("userId", "id", "title", "completed")) TO '${__TEST_DIR__}/data_import_and_export_json_overview_example_003_1_todos_json.json' (FORMAT json);

# DOCS_TEST_RAW
