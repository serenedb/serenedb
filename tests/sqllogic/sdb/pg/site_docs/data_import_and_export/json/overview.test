# DOCS_TEST: example_004

statement ok
USE $__DATABASE__;

statement ok
DROP TABLE IF EXISTS todos;

statement ok
COPY (SELECT * FROM (VALUES
    (1, 1, 'write docs fixtures', false),
    (1, 2, 'run sqllogictest', true)
) AS t("userId", "id", "title", "completed")) TO '${__TEST_DIR__}/data_import_and_export_json_overview_example_004_1_todos_json.json' (FORMAT json);

# DOCS_TEST_RAW
#| CREATE TABLE todos AS
#|     SELECT * FROM 'todos.json';

# DOCS_TEST_BODY

statement ok
CREATE TABLE todos AS
    SELECT * FROM '${__TEST_DIR__}/data_import_and_export_json_overview_example_004_1_todos_json.json';

# DOCS_TEST: example_006

statement ok
DROP TABLE IF EXISTS todos;

statement ok
CREATE TABLE todos (userId BIGINT, id BIGINT, title VARCHAR, completed BOOLEAN);

statement ok
INSERT INTO todos VALUES
    (1, 1, 'first todo', FALSE),
    (1, 2, 'second todo', TRUE);

# DOCS_TEST_RAW
#| COPY (SELECT * FROM todos) TO 'todos.json';

# DOCS_TEST_BODY

statement ok
COPY (SELECT * FROM todos) TO '${__TEST_DIR__}/data_import_and_export_json_overview_example_006_1_todos_json.json';

# DOCS_TEST: example_007

# DOCS_TEST_BODY

statement ok
CREATE TABLE example (j JSON);

statement ok
INSERT INTO example VALUES
    ('{ "family": "anatidae", "species": [ "duck", "goose", "swan", null ] }');

# DOCS_TEST: example_008

# DOCS_TEST_BODY

query
SELECT j['family'] FROM example;
----
j
"anatidae"

# DOCS_TEST: example_009

# DOCS_TEST_BODY

query
SELECT j->'family' FROM example;
----
?column?
"anatidae"

# DOCS_TEST: example_010

