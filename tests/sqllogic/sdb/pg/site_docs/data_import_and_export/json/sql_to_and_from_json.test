# DOCS_TEST: example_004

# The error JSON serializes its keys in a non-deterministic order, so the
# runnable body ignores the value and the displayed sample comes from RAW.

# DOCS_TEST_RAW
#| SELECT json_serialize_sql('TOTALLY NOT VALID SQL');
#| ----
#| json_serialize_sql
#| {"error":true,"error_type":"parser","error_message":"syntax error at or near \"VALID\"","error_subtype":"SYNTAX_ERROR","position":"12"}

# DOCS_TEST_BODY

query
SELECT json_serialize_sql('TOTALLY NOT VALID SQL');
----
json_serialize_sql
<slt:ignore>

# DOCS_TEST: example_005

# DOCS_TEST_BODY

query
SELECT json_deserialize_sql(json_serialize_sql('SELECT 1 + 2'));
----
json_deserialize_sql
SELECT (1 + 2)

# DOCS_TEST: example_006

# DOCS_TEST_BODY

query
SELECT json_deserialize_sql(json_serialize_sql('FROM x SELECT 1 + 2'));
----
json_deserialize_sql
SELECT (1 + 2) FROM x

# DOCS_TEST: example_007

# DOCS_TEST_BODY

query
SELECT * FROM json_execute_serialized_sql(json_serialize_sql('SELECT 1 + 2'));
----
?column?
3

# DOCS_TEST: example_008

# DOCS_TEST_BODY

query error
SELECT * FROM json_execute_serialized_sql(json_serialize_sql('TOTALLY NOT VALID SQL'));
----
db error: ERROR: Error parsing json: parser: syntax error at or near "VALID"
