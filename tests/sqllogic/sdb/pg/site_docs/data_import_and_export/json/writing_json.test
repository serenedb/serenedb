control substitution on

# DOCS_TEST: example_001

# DOCS_TEST_RAW
#| CREATE TABLE cities AS
#|     FROM (VALUES ('Amsterdam', 1), ('London', 2)) cities(name, id);
#|
#| COPY cities TO 'cities.json';

# DOCS_TEST_BODY

statement ok
CREATE TABLE cities AS
    FROM (VALUES ('Amsterdam', 1), ('London', 2)) cities(name, id);

statement ok
COPY cities TO '${__TEST_DIR__}/data_import_and_export_json_writing_json_example_001_cities.json';

# DOCS_TEST: example_002

# DOCS_TEST_RAW
#| SELECT unnest(string_split(rtrim(content, chr(10)), chr(10))) AS line
#| FROM read_text('cities.json');
#| ----
#| line
#| {"name":"Amsterdam","id":1}
#| {"name":"London","id":2}

# DOCS_TEST_BODY

query
SELECT unnest(string_split(rtrim(content, chr(10)), chr(10))) AS line
FROM read_text('${__TEST_DIR__}/data_import_and_export_json_writing_json_example_001_cities.json');
----
line
{"name":"Amsterdam","id":1}
{"name":"London","id":2}
