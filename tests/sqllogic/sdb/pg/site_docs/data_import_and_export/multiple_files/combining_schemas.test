control substitution on

# DOCS_TEST: example_001

statement ok
COPY (SELECT * FROM (VALUES
    (DATE '2024-01-01', 'AA', 'New York, NY', 'Los Angeles, CA'),
    (DATE '2024-01-02', 'UA', 'San Francisco, CA', 'Seattle, WA')
) AS t("FlightDate", "UniqueCarrier", "OriginCityName", "DestCityName")) TO '${__TEST_DIR__}/data_import_and_export_multiple_files_combining_schemas_example_001_flights_1.csv' (FORMAT CSV, HEADER true, DELIMITER ',');

statement ok
COPY (SELECT * FROM (VALUES
    (DATE '2024-02-01', 'DL', 'Boston, MA', 'Chicago, IL', 867)
) AS t("FlightDate", "UniqueCarrier", "OriginCityName", "DestCityName", "Distance")) TO '${__TEST_DIR__}/data_import_and_export_multiple_files_combining_schemas_example_001_flights_2.csv' (FORMAT CSV, HEADER true, DELIMITER ',');

# DOCS_TEST_RAW
#| SELECT * FROM read_csv('flights*.csv');

# DOCS_TEST_BODY

query
SELECT * FROM read_csv('${__TEST_DIR__}/data_import_and_export_multiple_files_combining_schemas_example_001_flights_*.csv');
----
flightdate	uniquecarrier	origincityname	destcityname
2024-01-01	AA	New York, NY	Los Angeles, CA
2024-01-02	UA	San Francisco, CA	Seattle, WA
2024-02-01	DL	Boston, MA	Chicago, IL

