# DOCS_TEST: example_001

statement ok
COPY (SELECT * FROM (VALUES
    (1, 'alpha', 10),
    (2, 'beta', 20)
) AS t("id", "name", "value")) TO '${__TEST_DIR__}/data_import_and_export_multiple_files_overview_example_001_dir_csv_1.csv' (FORMAT CSV, HEADER true, DELIMITER ',');

