# DOCS_TEST_RAW
#| SELECT *
#| FROM read_csv(['flights1.csv', 'flights2.csv'], union_by_name = true, filename = true);

# DOCS_TEST_BODY

query
SELECT
    flightdate,
    uniquecarrier,
    origincityname,
    destcityname,
    distance,
    replace(
        replace(
            filename,
            '${__TEST_DIR__}/data_import_and_export_multiple_files_overview_example_005_1_flights1_csv.csv',
            'flights1.csv'
        ),
        '${__TEST_DIR__}/data_import_and_export_multiple_files_overview_example_005_2_flights2_csv.csv',
        'flights2.csv'
    ) AS filename
FROM read_csv(['${__TEST_DIR__}/data_import_and_export_multiple_files_overview_example_005_1_flights1_csv.csv', '${__TEST_DIR__}/data_import_and_export_multiple_files_overview_example_005_2_flights2_csv.csv'], union_by_name = true, filename = true);
----
flightdate	uniquecarrier	origincityname	destcityname	distance	filename
2024-02-01	DL	Boston, MA	Chicago, IL	867	flights1.csv
2024-02-01	DL	Boston, MA	Chicago, IL	867	flights2.csv

