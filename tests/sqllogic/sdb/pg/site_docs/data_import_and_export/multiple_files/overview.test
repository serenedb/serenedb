# DOCS_TEST_RAW
#| SELECT *
#| FROM glob('*');

# DOCS_TEST_BODY

query
SELECT replace(
    file,
    '${__TEST_DIR__}/data_import_and_export_multiple_files_overview_example_014_',
    ''
) AS file
FROM glob('${__TEST_DIR__}/data_import_and_export_multiple_files_overview_example_014_*')
ORDER BY file;
