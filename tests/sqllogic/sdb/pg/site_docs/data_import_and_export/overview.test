# DOCS_TEST: example_001

statement ok
CREATE TABLE people (id INTEGER, name VARCHAR);

control substitution on

# DOCS_TEST_BODY

statement ok
INSERT INTO people VALUES (1, 'Mark');

# DOCS_TEST: example_002

statement ok
COPY (SELECT * FROM (VALUES
    (1, 'alpha', 10),
    (2, 'beta', 20)
) AS t("id", "name", "value")) TO '${__TEST_DIR__}/data_import_and_export_overview_example_002_1_test_csv.csv' (FORMAT CSV, HEADER true, DELIMITER ',');

# DOCS_TEST_RAW
#| SELECT * FROM 'test.csv';

# DOCS_TEST_BODY

query
SELECT * FROM '${__TEST_DIR__}/data_import_and_export_overview_example_002_1_test_csv.csv';
----
id	name	value
1	alpha	10
2	beta	20

