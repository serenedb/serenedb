# DOCS_TEST_RAW
#| COPY (FROM (VALUES (42), (43)) t(x)) TO 'test.parquet';
#|
#| SELECT *, filename FROM 'test.parquet';

# DOCS_TEST_BODY

statement ok
COPY (FROM (VALUES (42), (43)) t(x)) TO '${__TEST_DIR__}/data_import_and_export_overview_example_013_1_test_parquet.parquet';

query
SELECT x, 'test.parquet' AS filename
FROM (
    SELECT *, filename
    FROM '${__TEST_DIR__}/data_import_and_export_overview_example_013_1_test_parquet.parquet'
) AS t(x, source_filename);
----
x	filename
42	test.parquet
43	test.parquet
