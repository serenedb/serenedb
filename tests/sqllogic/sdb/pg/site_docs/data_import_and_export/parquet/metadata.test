# DOCS_TEST_RAW
#| SELECT
#|     len(parquet_metadata)    AS column_chunks,
#|     len(parquet_schema)      AS schema_elements,
#|     len(parquet_kv_metadata) AS kv_pairs
#| FROM parquet_full_metadata('test.parquet');

# DOCS_TEST_BODY

query
SELECT
    len(parquet_metadata)    AS column_chunks,
    len(parquet_schema)      AS schema_elements,
    len(parquet_kv_metadata) AS kv_pairs
FROM parquet_full_metadata('/tmp/${__DATABASE__}_data_import_and_export_parquet_metadata_example_007_1_test_parquet.parquet');
----
column_chunks	schema_elements	kv_pairs
3	4	0

# DOCS_TEST: example_008

statement ok
COPY (SELECT * FROM (VALUES
    (1, 'alpha', 10),
    (2, 'beta', 20)
) AS t("id", "name", "value")) TO '/tmp/${__DATABASE__}_data_import_and_export_parquet_metadata_example_008_1_my_file_parquet.parquet' (FORMAT parquet);

# DOCS_TEST_RAW
#| FROM parquet_bloom_probe('my_file.parquet', 'name', 'gamma');

# DOCS_TEST_BODY

query
SELECT
    replace(
        file_name,
        '/tmp/${__DATABASE__}_data_import_and_export_parquet_metadata_example_008_1_my_file_parquet.parquet',
        'my_file.parquet'
    ) AS file_name,
    row_group_id,
    bloom_filter_excludes
FROM parquet_bloom_probe('/tmp/${__DATABASE__}_data_import_and_export_parquet_metadata_example_008_1_my_file_parquet.parquet', 'name', 'gamma')
ORDER BY row_group_id;
----
file_name	row_group_id	bloom_filter_excludes
my_file.parquet	0	f

