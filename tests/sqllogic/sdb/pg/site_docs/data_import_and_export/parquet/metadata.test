statement ok
COPY (SELECT * FROM (VALUES
    (1, 'alpha', 10),
    (2, 'beta', 20)
) AS t("id", "name", "value")) TO '/tmp/${__DATABASE__}_data_import_and_export_parquet_metadata_example_002_1_parquet_1.parquet' (FORMAT parquet);

statement ok
COPY (SELECT * FROM (VALUES
    (1, 'alpha', 10),
    (2, 'beta', 20)
) AS t("id", "name", "value")) TO '/tmp/${__DATABASE__}_data_import_and_export_parquet_metadata_example_002_1_parquet_2.parquet' (FORMAT parquet);

# DOCS_TEST_RAW
#| SELECT *
#| FROM parquet_metadata('data/*.parquet');

# DOCS_TEST_BODY

query
SELECT * REPLACE (
    replace(
        file_name,
        '/tmp/${__DATABASE__}_data_import_and_export_parquet_metadata_example_002_1_parquet_',
        'data/file_'
    ) AS file_name
)
FROM parquet_metadata('/tmp/${__DATABASE__}_data_import_and_export_parquet_metadata_example_002_1_parquet_*.parquet')
ORDER BY file_name, column_id;
