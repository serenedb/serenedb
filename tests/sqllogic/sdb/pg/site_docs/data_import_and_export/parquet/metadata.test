# DOCS_TEST: example_006

statement ok
COPY (
    SELECT
        42 AS number,
        true AS is_even
) TO '/tmp/${__DATABASE__}_data_import_and_export_parquet_metadata_example_006_1_test_parquet.parquet' (
    FORMAT parquet,
    KV_METADATA {
        number: 'Answer to life, universe, and everything',
        is_even: 'not ''odd'''
    }
);

