# DOCS_TEST: example_006

statement ok
COPY (
    SELECT
        42 AS number,
        true AS is_even
) TO '/tmp/${__DATABASE__}_data_import_and_export_parquet_metadata_example_006_1_test_parquet.parquet' (
    FORMAT parquet,
    KV_METADATA {
        number: 'Answer to life, universe, and everything',
        is_even: 'not ''odd'''
    }
);

# DOCS_TEST_RAW
#| SELECT *
#| FROM parquet_kv_metadata('test.parquet');

# DOCS_TEST_BODY

query
SELECT
    replace(
        file_name,
        '/tmp/${__DATABASE__}_data_import_and_export_parquet_metadata_example_006_1_test_parquet.parquet',
        'test.parquet'
    ) AS file_name,
    key,
    value
FROM parquet_kv_metadata('/tmp/${__DATABASE__}_data_import_and_export_parquet_metadata_example_006_1_test_parquet.parquet')
ORDER BY key;
----
file_name	key	value
test.parquet	\\x69735f6576656e	\\x6e6f7420276f646427
test.parquet	\\x6e756d626572	\\x416e7377657220746f206c6966652c20756e6976657273652c20616e642065766572797468696e67

