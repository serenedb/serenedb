control substitution on

# DOCS_TEST: example_001

statement ok
COPY (SELECT * FROM (VALUES
    (DATE '2024-01-01', 'AA', 'New York, NY', 'Los Angeles, CA', 2475),
    (DATE '2024-01-02', 'UA', 'San Francisco, CA', 'Seattle, WA', 679)
) AS t("FlightDate", "UniqueCarrier", "OriginCityName", "DestCityName", "Distance")) TO '/tmp/${__DATABASE__}_data_import_and_export_parquet_tips_example_001_flights_1.parquet' (FORMAT parquet);

statement ok
COPY (SELECT * FROM (VALUES
    (DATE '2024-01-03', 'DL', 'Boston, MA', 'Chicago, IL', 867)
) AS t("FlightDate", "UniqueCarrier", "OriginCityName", "DestCityName", "Distance")) TO '/tmp/${__DATABASE__}_data_import_and_export_parquet_tips_example_001_flights_2.parquet' (FORMAT parquet);

# DOCS_TEST_RAW
#| SELECT *
#| FROM read_parquet('flights*.parquet', union_by_name = true);

# DOCS_TEST_BODY

query
SELECT *
FROM read_parquet('/tmp/${__DATABASE__}_data_import_and_export_parquet_tips_example_001_flights_*.parquet', union_by_name = true);
----
flightdate	uniquecarrier	origincityname	destcityname	distance
2024-01-01	AA	New York, NY	Los Angeles, CA	2475
2024-01-02	UA	San Francisco, CA	Seattle, WA	679
2024-01-03	DL	Boston, MA	Chicago, IL	867

# DOCS_TEST: example_002

# DOCS_TEST_RAW
#| COPY
#|     (FROM generate_series(10_000_000))
#|     TO 'test.parquet'
#|     (FORMAT parquet, PER_THREAD_OUTPUT);

# DOCS_TEST_BODY

statement ok
COPY
    (FROM generate_series(10_000_000))
    TO '/tmp/${__DATABASE__}_data_import_and_export_parquet_tips_example_002_1_test_parquet.parquet'
    (FORMAT parquet, PER_THREAD_OUTPUT, OVERWRITE);

# DOCS_TEST: example_003

# DOCS_TEST_RAW
#| COPY
#|     (FROM generate_series(100_000))
#|     TO 'row-groups.parquet'
#|     (FORMAT parquet, ROW_GROUP_SIZE 100_000);

# DOCS_TEST_BODY

statement ok
COPY
    (FROM generate_series(100_000))
    TO '/tmp/${__DATABASE__}_data_import_and_export_parquet_tips_example_003_1_row_groups_parquet.parquet'
    (FORMAT parquet, ROW_GROUP_SIZE 100_000);

# DOCS_TEST: example_004

# DOCS_TEST_BODY

statement ok
COPY
    (FROM generate_series(100_000))
    TO '/tmp/${__DATABASE__}_data_import_and_export_parquet_tips_example_004_output_directory'
    (FORMAT parquet, ROW_GROUP_SIZE 20_000, ROW_GROUPS_PER_FILE 2, OVERWRITE);
