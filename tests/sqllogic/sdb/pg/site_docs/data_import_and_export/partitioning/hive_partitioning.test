# DOCS_TEST: example_006

statement ok
COPY (SELECT * FROM (VALUES
    (1, 'november order', 110, 2022, 11),
    (2, 'december order', 120, 2022, 12),
    (3, 'older order', 90, 2021, 11)
) AS t("id", "name", "value", "year", "month"))
TO '${__TEST_DIR__}/data_import_and_export_partitioning_hive_partitioning_example_006_orders'
(FORMAT parquet, PARTITION_BY (year, month), OVERWRITE_OR_IGNORE);

# DOCS_TEST_RAW
#| SELECT *
#| FROM read_parquet('orders/*/*/*.parquet', hive_partitioning = true)
#| WHERE year = 2022
#|   AND month = 11;

# DOCS_TEST_BODY

query
SELECT *
FROM read_parquet('${__TEST_DIR__}/data_import_and_export_partitioning_hive_partitioning_example_006_orders/*/*/*.parquet', hive_partitioning = true)
WHERE year = 2022
  AND month = 11;
----
id	name	value	month	year
1	november order	110	11	2022

# DOCS_TEST: example_008

statement ok
COPY (SELECT * FROM (VALUES
    (1, 'alpha', 10, DATE '2024-01-01', 5),
    (2, 'beta', 20, DATE '2024-02-01', 6)
) AS t("id", "name", "value", "release", "orders"))
TO '${__TEST_DIR__}/data_import_and_export_partitioning_hive_partitioning_example_008_dir'
(FORMAT parquet, PARTITION_BY (release, orders), OVERWRITE_OR_IGNORE);

# DOCS_TEST_RAW
#| SELECT *
#| FROM read_parquet(
#|     'dir/**/*.parquet',
#|     hive_partitioning = true,
#|     hive_types = {'release': DATE, 'orders': BIGINT}
#| );

# DOCS_TEST_BODY

query
SELECT *
FROM read_parquet(
    '${__TEST_DIR__}/data_import_and_export_partitioning_hive_partitioning_example_008_dir/**/*.parquet',
    hive_partitioning = true,
    hive_types = {'release': DATE, 'orders': BIGINT}
)
ORDER BY id;
----
id	name	value	orders	release
1	alpha	10	5	2024-01-01
2	beta	20	6	2024-02-01
