# DOCS_TEST: example_002

statement ok
DROP TABLE IF EXISTS orders;

statement ok
CREATE TABLE orders (
    order_id INTEGER,
    customer VARCHAR,
    amount INTEGER,
    year INTEGER,
    month INTEGER
);

statement ok
INSERT INTO orders VALUES
    (1, 'Ada', 100, 2024, 1),
    (2, 'Bob', 150, 2024, 2),
    (3, 'Cara', 200, 2025, 1);

# DOCS_TEST_RAW
#| COPY orders
#| TO 'orders' (FORMAT parquet, PARTITION_BY (year, month));

# DOCS_TEST_BODY

statement ok
COPY orders
TO '${__TEST_DIR__}/data_import_and_export_partitioning_hive_partitioning_example_002_orders' (FORMAT parquet, PARTITION_BY (year, month), OVERWRITE_OR_IGNORE);

# DOCS_TEST: example_003

statement ok
DROP TABLE IF EXISTS services;

statement ok
CREATE TABLE services (
    service_id INTEGER,
    service_name VARCHAR,
    timestamp TIMESTAMP
);

statement ok
INSERT INTO services VALUES
    (1, 'search', TIMESTAMP '2024-01-15 10:00:00'),
    (2, 'analytics', TIMESTAMP '2024-02-20 12:30:00'),
    (3, 'storage', TIMESTAMP '2025-01-05 09:15:00');

# DOCS_TEST_RAW
#| COPY (SELECT *, year(timestamp) AS year, month(timestamp) AS month FROM services)
#| TO 'test' (PARTITION_BY (year, month));

# DOCS_TEST_BODY

statement ok
COPY (SELECT *, year(timestamp) AS year, month(timestamp) AS month FROM services)
TO '${__TEST_DIR__}/data_import_and_export_partitioning_hive_partitioning_example_003_test' (PARTITION_BY (year, month), OVERWRITE_OR_IGNORE);

# DOCS_TEST: example_004

statement ok
COPY (SELECT * FROM (VALUES
    (1, 'alpha', 10, 2024, 1),
    (2, 'beta', 20, 2024, 2)
) AS t("id", "name", "value", "year", "month"))
TO '${__TEST_DIR__}/data_import_and_export_partitioning_hive_partitioning_example_004_test'
(FORMAT parquet, PARTITION_BY (year, month), OVERWRITE_OR_IGNORE);

# DOCS_TEST_RAW
#| FROM read_parquet('test/*/*/*.parquet', hive_partitioning = false);
#|
#| FROM read_parquet('test/*/*/*.parquet', hive_partitioning = true);

# DOCS_TEST_BODY

query
FROM read_parquet('${__TEST_DIR__}/data_import_and_export_partitioning_hive_partitioning_example_004_test/*/*/*.parquet', hive_partitioning = false)
ORDER BY id;
----
id	name	value
1	alpha	10
2	beta	20


query
FROM read_parquet('${__TEST_DIR__}/data_import_and_export_partitioning_hive_partitioning_example_004_test/*/*/*.parquet', hive_partitioning = true)
ORDER BY id;
----
id	name	value	month	year
1	alpha	10	1	2024
2	beta	20	2	2024

