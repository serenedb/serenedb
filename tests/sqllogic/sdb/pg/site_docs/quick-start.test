# DOCS_TEST: example_003

# DOCS_TEST_BODY

query
SELECT category, COUNT(*) AS articles, AVG(views) AS avg_views
FROM articles
GROUP BY category
ORDER BY avg_views DESC;
----
category	articles	avg_views
product	2	5650
engineering	3	3633.3333333333335

# DOCS_TEST: example_004

# DOCS_TEST_BODY

statement ok
CREATE TEXT SEARCH DICTIONARY english_dict(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true
);

statement ok
CREATE INDEX articles_search_idx ON articles
    USING inverted(id, title english_dict, body english_dict);

