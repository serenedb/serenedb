# DOCS_TEST: example_002

# DOCS_TEST_BODY

query
-- Define a CTE with an array column
WITH sample_data(a) AS (
    VALUES (ARRAY[1, 2, 3])
)
-- Select the first element of the array
SELECT a[1] AS first_element
FROM sample_data;
----
first_element
1
