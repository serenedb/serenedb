-- Create a table with a binary column
CREATE TABLE example (
    data BYTEA
);

statement ok
-- Insert binary data using hex, escape sequences, and raw bytes
INSERT INTO example VALUES
    (BYTEA '\xDEADBEEF'),
    (BYTEA 'abc \153\154\155'),
    (BYTEA '\xFF');

query
-- Retrieve all rows
SELECT * FROM example;
