# DOCS_TEST: example_002

query
WITH bools(v) AS (VALUES (TRUE), (NULL), (FALSE))
SELECT
    a.v AS a,
    b.v AS b,
    a.v AND b.v AS and_result,
    a.v OR b.v AS or_result
FROM bools a, bools b;
----
a	b	and_result	or_result
t	t	t	t
NULL	t	NULL	t
f	t	f	t
t	NULL	NULL	t
NULL	NULL	NULL	NULL
f	NULL	f	NULL
t	f	f	t
NULL	f	f	NULL
f	f	f	f
