# DOCS_TEST: example_001

statement ok
CREATE TABLE measurements (
    id SERIAL PRIMARY KEY,
    temp REAL,
    pressure DOUBLE PRECISION
);

statement ok
INSERT INTO measurements VALUES
    (1, 36.6, 1013.25),
    (2, 37.2, 1009.50);

query
SELECT * FROM measurements;
----
id	temp	pressure
1	36.6	1013.25
2	37.2	1009.5

# DOCS_TEST: example_002

query
-- Operations that would cause errors in PostgreSQL
SELECT
    1/0::FLOAT AS divide_by_zero,
    0/0::FLOAT AS zero_over_zero,
    POW(-10, 999) AS large_negative_power;
----
divide_by_zero	zero_over_zero	large_negative_power
Infinity	NaN	-Infinity
