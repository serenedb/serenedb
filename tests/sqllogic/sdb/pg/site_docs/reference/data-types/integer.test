# DOCS_TEST: example_001

statement ok
-- Create a table with different integer types
CREATE TABLE counters (
    id BIGINT PRIMARY KEY,
    small_counter SMALLINT,
    regular_counter INTEGER
);

statement ok
-- Insert values
INSERT INTO counters VALUES
    (1, 100, 10000),
    (2, -200, 500000);

query
-- Retrieve all rows
SELECT * FROM counters;
----
id	small_counter	regular_counter
1	100	10000
2	-200	500000

# DOCS_TEST: example_002

statement ok
-- Create a table with integer values close to the upper limit
CREATE TABLE integers(i) AS
VALUES (POWER(2, 29)::INT),
       (POWER(2, 30)::INT);

query error
-- Attempting to double these values produces an overflow
SELECT i + i FROM integers;
----
db error: ERROR: Overflow in addition of INT32 \(1073741824 \+ 1073741824\)!


# DOCS_TEST: example_003

query
SELECT TRY(i + i) AS safe_sum FROM integers;
----
safe_sum
1073741824
NULL

# DOCS_TEST: example_004

query
SELECT i::BIGINT + i AS big_sum FROM integers;
----
big_sum
1073741824
2147483648
