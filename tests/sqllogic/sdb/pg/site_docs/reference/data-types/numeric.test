# DOCS_TEST: example_001

statement ok
-- Create a table with numeric columns
CREATE TEMP TABLE accounts (
    account_id SERIAL PRIMARY KEY,
    balance NUMERIC(18, 2),
    high_precision NUMERIC(38, 8)
);

statement ok
-- Insert values
INSERT INTO accounts VALUES
    (1, 12345.67, 1234567890.12345678),
    (2, 98765.43, 9876543210.87654321);


query
-- Query the data
SELECT * FROM accounts;
----
account_id	balance	high_precision
1	12345.67	1234567890.12345678
2	98765.43	9876543210.87654321

# DOCS_TEST: example_002

statement error
-- Create a table with a large numeric
CREATE TABLE numerics(i) AS
VALUES (POWER(2, 126)::NUMERIC(38,0));
----
db error: ERROR: Unsupported column type for RocksDB serialization: DECIMAL


query error
-- This produces an overflow
SELECT i + i FROM numerics;
----
db error: ERROR: Table with name numerics does not exist!
Did you mean "<slt:ignore>"?


query error
-- Using try() returns NULL instead of an error
SELECT TRY(i + i) FROM numerics;
----
db error: ERROR: Table with name numerics does not exist!
Did you mean "<slt:ignore>"?
