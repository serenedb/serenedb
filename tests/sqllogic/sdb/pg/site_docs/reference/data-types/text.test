statement ok
-- Create a table with different string types
CREATE TABLE users (
    username VARCHAR(20),
    code CHAR(5),
    description TEXT
);

statement ok
-- Insert sample data
INSERT INTO users VALUES
    ('alice', 'A123 ', 'Alice is a developer'),
    ('bob', 'B456 ', 'Bob works in marketing');

query
-- Query all rows
SELECT * FROM users;
----
username	code	description
alice	A123 	Alice is a developer
bob	B456 	Bob works in marketing

