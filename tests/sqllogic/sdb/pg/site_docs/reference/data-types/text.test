query error
WITH strings(a, b) AS (
    VALUES ('foo', 'FOO')
)
SELECT a, b, a = b, a COLLATE "en_US_ci" = b
FROM strings;
----
db error: ERROR: Collation with name en_us_ci does not exist!
Did you mean "<slt:ignore>"?

# DOCS_TEST: example_004

# DOCS_TEST_BODY

query error
WITH strings(s) AS (
    VALUES ('foo'), ('FOO')
)
SELECT MIN(s COLLATE "binary")
FROM strings
GROUP BY s COLLATE "en_US_ci";
