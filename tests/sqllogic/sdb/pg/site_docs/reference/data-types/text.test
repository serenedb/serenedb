query
SELECT
    LENGTH('🪐') AS length,
    CHAR_LENGTH('🪐') AS char_length,
    OCTET_LENGTH('🪐') AS octet_length;
----
length	char_length	octet_length
1	1	4

# DOCS_TEST: example_003

