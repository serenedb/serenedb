# DOCS_TEST: example_001

query error db error: ERROR: Overflow in HUGEINT addition: 99999999999999999999999999999999999999 \+ 99999999999999999999999999999999999999
SELECT AVG(col)
FROM ( VALUES
         (CAST(9999999999999999999999999999999.9999999 AS DECIMAL(38,7))),
       (CAST(9999999999999999999999999999999.9999999 AS DECIMAL(38,7)))
     ) AS t(col);
