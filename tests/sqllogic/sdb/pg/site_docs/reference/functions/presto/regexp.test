	regexp_replace(VARCHAR, VARCHAR, VARCHAR) -> VARCHAR
	regexp_replace(VARCHAR, VARCHAR, VARCHAR, VARCHAR) -> VARCHAR

# DOCS_TEST: example_008

# DOCS_TEST_BODY

query
SELECT regexp_replace('1a 2b 14m', '(\d+)([ab]) ', '3c$2 ');
----
regexp_replace
