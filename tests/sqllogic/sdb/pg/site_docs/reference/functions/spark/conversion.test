query
SELECT cast(cast(2147483648.90 as DECIMAL(12, 2)) as bigint);
----
int8
2147483649

# DOCS_TEST: example_008

query error db error: ERROR: Unimplemented type for cast \(TIMESTAMP \-> BIGINT\)
SELECT cast(cast('1970-01-01 00:00:00' as timestamp) as bigint);

query error db error: ERROR: Unimplemented type for cast \(TIMESTAMP \-> SMALLINT\)
SELECT cast(cast('1970-01-01 00:00:00' as timestamp) as smallint);

query error db error: ERROR: Unimplemented type for cast \(TIMESTAMP \-> TINYINT\)
SELECT cast(cast('1970-01-01 00:00:00' as timestamp) as tinyint);

query error db error: ERROR: Unimplemented type for cast \(TIMESTAMP \-> BIGINT\)
SELECT cast(cast('2000-01-01 12:21:56' as timestamp) as bigint);

query error db error: ERROR: Unimplemented type for cast \(TIMESTAMP \-> BIGINT\)
SELECT cast(cast('2025-02-25 08:00:26.88' as timestamp) as bigint);

query error db error: ERROR: Unimplemented type for cast \(TIMESTAMP \-> INTEGER\)
SELECT cast(cast('2025-02-25 08:00:26.88' as timestamp) as integer);

query error db error: ERROR: Unimplemented type for cast \(TIMESTAMP \-> SMALLINT\)
SELECT cast(cast('2025-02-25 08:00:26.88' as timestamp) as smallint);

query error db error: ERROR: Unimplemented type for cast \(TIMESTAMP \-> TINYINT\)
SELECT cast(cast('2025-02-25 08:00:26.88' as timestamp) as tinyint);

