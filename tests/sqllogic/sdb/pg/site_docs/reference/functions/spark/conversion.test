query
SELECT cast('12345' as bigint);
----
int8
12345

query
SELECT cast('+1' as tinyint);
----
tinyint
1

query
SELECT cast('-1' as tinyint);
----
tinyint
-1

query
SELECT cast('12345.67' as bigint);
----
int8
12346

query
SELECT cast('1.2' as tinyint);
----
tinyint
1

query
SELECT cast('-1.8' as tinyint);
----
tinyint
-2

query
SELECT cast('+1' as tinyint);
----
tinyint
1

query
SELECT cast('1.' as tinyint);
----
tinyint
1

query
SELECT cast('-1' as tinyint);
----
tinyint
-1

query
SELECT cast('-1.' as tinyint);
----
tinyint
-1

query
SELECT cast('0.' as tinyint);
----
tinyint
0

query error db error: ERROR: Could not convert string '\.' to INT8
SELECT cast('.' as tinyint);

query error db error: ERROR: Could not convert string '\-\.' to INT8
SELECT cast('-.' as tinyint);

