numeric
1

query
SELECT cast('1.23 ' as decimal(38, 0));
----
numeric
1

query
SELECT cast('  1.23  ' as decimal(38, 0));
----
numeric
1

query
SELECT cast(' -3E+2' as decimal(12, 2));
----
numeric
-300.00

query
SELECT cast('-3E+2 ' as decimal(12, 2));
----
numeric
-300.00

query
SELECT cast('  -3E+2  ' as decimal(12, 2));
----
numeric
-300.00

