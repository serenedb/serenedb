# DOCS_TEST: example_001

query error db error: ERROR: Type INT32 with value 128 can't be cast because the value is out of range for the destination type INT8
SELECT cast(128 as tinyint);

query error db error: ERROR: invalid date field format: "2012\-Oct\-23", expected format is \(YYYY\-MM\-DD\)
SELECT cast('2012-Oct-23' as date);

# DOCS_TEST: example_002

query
SELECT try_cast(128 as tinyint);
----
tinyint
NULL

query
SELECT try_cast(cast(550000.0 as DECIMAL(8, 1)) as smallint);
----
smallint
NULL

query
SELECT try_cast(1e12 as int);
----
int4
NULL

# DOCS_TEST: example_003

query
SELECT cast(1234567 as bigint);
----
int8
1234567

query
SELECT cast(12 as tinyint);
----
tinyint
12

query error db error: ERROR: Type INT32 with value 1234 can't be cast because the value is out of range for the destination type INT8
SELECT cast(1234 as tinyint);

query error db error: ERROR: Type INT32 with value 1234567 can't be cast because the value is out of range for the destination type INT16
SELECT cast(1234567 as smallint);

# DOCS_TEST: example_004

query
SELECT cast(12345.12 as bigint);
----
int8
12345

query
SELECT cast(12345.67 as bigint);
----
int8
12346

query
SELECT cast(127.1 as tinyint);
----
tinyint
127

query error db error: ERROR: Failed to cast decimal value 128 to type INT8
SELECT cast(127.8 as tinyint);

query error db error: ERROR: Failed to cast decimal value 1234568 to type INT16
SELECT cast(1234567.89 as smallint);

query error db error: ERROR: Type DOUBLE with value inf can't be cast because the value is out of range for the destination type INT64
SELECT cast(cast('inf' as double) as bigint);

query error db error: ERROR: Type DOUBLE with value nan can't be cast because the value is out of range for the destination type INT32
SELECT cast(cast('nan' as double) as integer);

query error db error: ERROR: Type DOUBLE with value nan can't be cast because the value is out of range for the destination type INT16
SELECT cast(cast('nan' as double) as smallint);

query error db error: ERROR: Type DOUBLE with value nan can't be cast because the value is out of range for the destination type INT8
SELECT cast(cast('nan' as double) as tinyint);

query error db error: ERROR: Type DOUBLE with value nan can't be cast because the value is out of range for the destination type INT64
SELECT cast(cast('nan' as double) as bigint);

