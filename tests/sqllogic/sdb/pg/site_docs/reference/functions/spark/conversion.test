# DOCS_TEST: example_011

query
SELECT cast(cast('1970-01-01 00:00:00' as timestamp) as string);
----
text
1970-01-01 00:00:00

query
SELECT cast(cast('2000-01-01 12:21:56.129' as timestamp) as string);
----
text
2000-01-01 12:21:56.129

query
SELECT cast(cast('2000-01-01 12:21:56.100000' as timestamp) as string);
----
text
2000-01-01 12:21:56.1

query
SELECT cast(cast('2000-01-01 12:21:56.129900' as timestamp) as string);
----
text
2000-01-01 12:21:56.1299

query
SELECT cast(cast('10000-02-01 16:00:00.000' as timestamp) as string);
----
text
10000-02-01 16:00:00

query
SELECT cast(cast('0384-01-01 08:00:00.000' as timestamp) as string);
----
text
0384-01-01 08:00:00

query
SELECT cast(cast('-0010-02-01 10:00:00.000' as timestamp) as string);
----
text
0011-02-01 (BC) 10:00:00

# DOCS_TEST: example_012

query error db error: ERROR: invalid date field format: "1970", expected format is \(YYYY\-MM\-DD\)
SELECT cast('1970' as date);

query error db error: ERROR: invalid date field format: "1970\-01", expected format is \(YYYY\-MM\-DD\)
SELECT cast('1970-01' as date);

query
SELECT cast('1970-01-01' as date);
----
date
1970-01-01

query
SELECT cast('1970-01-01T123' as date);
----
date
1970-01-01

query
SELECT cast('1970-01-01 ' as date);
----
date
1970-01-01

query
SELECT cast('1970-01-01 (BC)' as date);
----
date
-1969-01-01

