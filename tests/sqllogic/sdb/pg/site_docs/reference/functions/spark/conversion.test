bool
t

query
SELECT cast('true' as boolean);
----
bool
t

query
SELECT cast('f' as boolean);
----
bool
f

query
SELECT cast('false' as boolean);
----
bool
f

query
SELECT cast('y' as boolean);
----
bool
t

query
SELECT cast('yes' as boolean);
----
bool
t

query
SELECT cast('n' as boolean);
----
bool
f

query
SELECT cast('no' as boolean);
----
bool
f

