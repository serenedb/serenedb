query error
SELECT 3 div 2;
----
db error: ERROR: syntax error at or near "2"


query error
SELECT 1L div 2L;
----
db error: ERROR: syntax error at or near "div"


query error
SELECT 3 div 0;
----
db error: ERROR: syntax error at or near "0"


# DOCS_TEST: example_004

query
SELECT 3 / 2;
----
?column?
1

query error
SELECT 2L / 2L;
----
db error: ERROR: syntax error at or near "/"


query
SELECT 3 / 0;
----
?column?
NULL

# DOCS_TEST: example_005

query
SELECT CAST(1 as DECIMAL(17, 3)) / CAST(2 as DECIMAL(17, 3));
----
?column?
0.5

query
SELECT CAST(1 as DECIMAL(20, 3)) / CAST(20 as DECIMAL(20, 2));
----
?column?
0.05

query
SELECT CAST(1 as DECIMAL(20, 3)) / CAST(0 as DECIMAL(20, 3));
----
?column?
Infinity

# DOCS_TEST: example_006

query
SELECT factorial(0);
----
factorial
1

query
SELECT factorial(5);
----
factorial
120

query
SELECT factorial(20);
----
factorial
2432902008176640000

query
SELECT factorial(21);
----
factorial
51090942171709440000

query
SELECT factorial(-1);
----
factorial
1

# DOCS_TEST: example_007

query error
SELECT hex("Spark SQL");
----
db error: ERROR: Referenced column "Spark SQL" was not found because the FROM clause is missing


query
SELECT hex(17);
----
hex
11

query
SELECT hex(-1);
----
hex
FFFFFFFFFFFFFFFF

# DOCS_TEST: example_008

query
SELECT CAST(1 as DECIMAL(17, 3)) * CAST(2 as DECIMAL(17, 3));
----
?column?
2.000000

query
SELECT CAST(1 as DECIMAL(20, 3)) * CAST(20 as DECIMAL(20, 2));
----
?column?
20.00000

query
SELECT CAST(1 as DECIMAL(20, 3)) * CAST(0 as DECIMAL(20, 3));
----
?column?
0.000000

query error
SELECT CAST(201e-38 as DECIMAL(38, 38)) * CAST(301e-38 as DECIMAL(38, 38));
----
db error: ERROR: Needed scale 76 to accurately represent the multiplication result, but this is out of range of the DECIMAL type\. Max scale is 38; could not perform an accurate multiplication\. Either add a cast to DOUBLE, or add an explicit cast to a decimal with a lower scale\.


