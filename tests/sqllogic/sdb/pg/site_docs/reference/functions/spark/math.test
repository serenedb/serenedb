# DOCS_TEST: example_015

query
SELECT width_bucket(-1.0, 0.0, 10.0, 5);
----
width_bucket
0

query
SELECT width_bucket(0.1, 0.0, 10.0, 5);
----
width_bucket
1

query
SELECT width_bucket(10.1, 0.0, 10.0, 5);
----
width_bucket
6

query error
SELECT width_bucket(-1.0, 10.0, 0.0, 5);
----
db error: ERROR: lower bound must be less than upper bound


query error
SELECT width_bucket(0.1, 10.0, 0.0, 5);
----
db error: ERROR: lower bound must be less than upper bound


query error
SELECT width_bucket(10.1, 10.0, 0.0, 5);
----
db error: ERROR: lower bound must be less than upper bound


query error
SELECT width_bucket(10.1, 10.0, 10.0, 5);
----
db error: ERROR: lower bound must be less than upper bound

