# DOCS_TEST: example_001

query
SELECT abs(-42);
----
abs
42

query
SELECT abs(3.14);
----
abs
3.14

query
SELECT abs(-128);
----
abs
128

query
SELECT abs(-128);
----
abs
128

# DOCS_TEST: example_002

query
SELECT CAST(1.1232100 as DECIMAL(38, 7)) + CAST(1 as DECIMAL(10, 0));
----
?column?
2.1232100

query
SELECT CAST(-999999999999999999999999999.999 as DECIMAL(30, 3)) + CAST(-999999999999999999999999999.999 as DECIMAL(30, 3));
----
?column?
-1999999999999999999999999999.998

query
SELECT CAST(99999999999999999999999999999999.99998 as DECIMAL(38, 6)) + CAST(-99999999999999999999999999999999.99999 as DECIMAL(38, 5));
----
?column?
-0.000010

query error
SELECT CAST(-99999999999999999999999999999999990.0 as DECIMAL(38, 3)) + CAST(-0.00001 as DECIMAL(38, 7));
----
db error: ERROR: Casting value "\-99999999999999999999999999999999990\.000" to type DECIMAL\(38,7\) failed: value is out of range!


