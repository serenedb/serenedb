statement ok
CREATE TABLE employees_with_details AS
SELECT
    *,
    CASE WHEN id = 1 THEN 70 ELSE 80 END AS weight,
    CASE WHEN id = 1 THEN 30 ELSE 40 END AS age,
    id AS department_id
FROM employees;

statement ok
DROP TABLE employees;

statement ok
ALTER TABLE employees_with_details RENAME TO employees;

statement ok
CREATE TABLE departments (id INTEGER, department_name VARCHAR);

statement ok
INSERT INTO departments VALUES
    (1, 'Engineering'),
    (2, 'Product');

# DOCS_TEST_BODY

statement ok
CREATE FUNCTION article_url(slug TEXT)
RETURNS TEXT AS $$
    SELECT '/articles/' || slug
$$ LANGUAGE SQL;

query
SELECT title, article_url(slug) FROM articles;
----
title	article_url
Intro to Search	/articles/intro-to-search
Scaling Analytics	/articles/scaling-analytics

# DOCS_TEST: example_002

# DOCS_TEST_BODY

statement ok
CREATE FUNCTION top_employees()
RETURNS TABLE(name TEXT, grade INTEGER)
AS $$
    SELECT name, (2 * weight + age) / 10 AS grade
    FROM employees
$$ LANGUAGE SQL;


query
SELECT * FROM top_employees();
----
name	grade
alpha	17
beta	20

# DOCS_TEST: example_003

# DOCS_TEST_BODY

statement ok
CREATE FUNCTION employees_above_grade(grade_threshold INTEGER)
RETURNS TABLE(name TEXT, grade INTEGER)
LANGUAGE SQL
BEGIN ATOMIC
    SELECT name, (2 * weight + age) / 10 AS grade
    FROM employees
    WHERE (2 * weight + age) / 10 > grade_threshold;
END;

query
SELECT * FROM employees_above_grade(16);
----
name	grade
alpha	17
beta	20

# DOCS_TEST: example_004

statement ok
DROP FUNCTION IF EXISTS employees_above_grade;

statement ok
CREATE FUNCTION employees_above_grade(grade_threshold INTEGER)
RETURNS TABLE(name TEXT, grade INTEGER, department_id INTEGER)
LANGUAGE SQL
BEGIN ATOMIC
    SELECT name, (2 * weight + age) / 10 AS grade, department_id
    FROM employees
    WHERE (2 * weight + age) / 10 > grade_threshold;
END;

# DOCS_TEST_BODY

query
SELECT e.name, e.grade, d.department_name
FROM employees_above_grade(10) AS e
JOIN departments d ON e.department_id = d.id;
----
name	grade	department_name
alpha	17	Engineering
beta	20	Product
