statement ok
CREATE TEXT SEARCH DICTIONARY french_dict (
    template = 'text',
    locale = 'fr',
    case = 'lower',
    stemming = true,
    accent = true,
    frequency = true,
    position = true
);

statement ok
CREATE INDEX idx_articles_fr ON articles
    USING inverted (id, body french_dict);
