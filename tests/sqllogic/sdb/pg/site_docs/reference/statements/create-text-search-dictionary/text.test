# DOCS_TEST_BODY

statement ok
CREATE TEXT SEARCH DICTIONARY filtered_dict (
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'lower',
    stemming = true,
    stopwords = '"the","a","an","is","at"'
);
