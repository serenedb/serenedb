# DOCS_TEST: example_005

query error
WITH top_articles AS (
    SELECT title, views, category
    FROM articles
    WHERE views > 5000
)
SELECT category, COUNT(*) AS count
FROM top_articles
GROUP BY category;
----
db error: ERROR: Table with name articles does not exist!
Did you mean "<slt:ignore>"?


