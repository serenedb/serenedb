statement ok
DROP TABLE IF EXISTS movies;

statement ok
CREATE TABLE movies (
    title VARCHAR,
    year INTEGER,
    rating DOUBLE
);

statement ok
INSERT INTO movies VALUES
    ('The Shawshank Redemption', 1994, 9.3),
    ('The Godfather', 1972, 9.2),
    ('The Dark Knight', 2008, 9.0),
    ('12 Angry Men', 1957, 8.9),
    ('Schindler''s List', 1993, 8.8),
    ('Pulp Fiction', 1994, 8.7),
    ('The Lord of the Rings: The Return of the King', 2003, 8.6),
    ('The Good, the Bad and the Ugly', 1966, 8.5),
    ('Fight Club', 1999, 8.4),
    ('The Matrix', 1999, 8.3),
    ('Forrest Gump', 1994, 7.8),
    ('A Quiet Example', 2024, 7.9);

# DOCS_TEST_BODY

query
SELECT title, year, rating
FROM movies
WHERE rating > 8.0
ORDER BY rating DESC
LIMIT 10;
----
title	year	rating
The Shawshank Redemption	1994	9.3
The Godfather	1972	9.2
The Dark Knight	2008	9
12 Angry Men	1957	8.9
Schindler's List	1993	8.8
Pulp Fiction	1994	8.7
The Lord of the Rings: The Return of the King	2003	8.6
The Good, the Bad and the Ugly	1966	8.5
Fight Club	1999	8.4
The Matrix	1999	8.3

