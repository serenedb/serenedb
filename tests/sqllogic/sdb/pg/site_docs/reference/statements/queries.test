Intro to Search	4200

# DOCS_TEST: example_003

statement ok
DROP TABLE IF EXISTS articles;

statement ok
CREATE TABLE articles (
    title VARCHAR,
    category VARCHAR,
    views INTEGER
);

statement ok
INSERT INTO articles VALUES
    ('Query Planning Basics', 'engineering', 3000),
    ('Vectorized Execution', 'engineering', 3000),
    ('Indexing Deep Dive', 'engineering', 3000),
    ('Storage Layouts', 'engineering', 3000),
    ('Join Algorithms', 'engineering', 3000),
    ('Profiling Queries', 'engineering', 3000),
    ('Roadmap Notes', 'product', 1200),
    ('Launch Recap', 'product', 1800);

# DOCS_TEST_BODY

query
SELECT category, COUNT(*) AS count, AVG(views) AS avg_views
FROM articles
GROUP BY category
HAVING COUNT(*) > 5;
----
category	count	avg_views
engineering	6	3000

# DOCS_TEST: example_004

statement ok
DROP TABLE IF EXISTS articles;

statement ok
CREATE TABLE articles AS SELECT * FROM articles_2024;

statement ok
CREATE TABLE authors (id INTEGER, name VARCHAR);

statement ok
INSERT INTO authors VALUES (1, 'Ada'), (2, 'Bob');

statement ok
CREATE TABLE articles_2025 AS SELECT * FROM articles_2024;

statement ok
CREATE TABLE categories (name VARCHAR, active BOOLEAN);

statement ok
INSERT INTO categories VALUES ('engineering', TRUE), ('product', TRUE);

# DOCS_TEST_BODY

query ??
-- Inner join
SELECT a.title, s.name
FROM articles a
JOIN authors s ON a.author_id = s.id;
----
title	name
Intro to Search	Ada
Scaling Analytics	Bob

query ??
-- Left join
SELECT a.title, s.name
FROM articles a
LEFT JOIN authors s ON a.author_id = s.id;
----
title	name
Intro to Search	Ada
Scaling Analytics	Bob

# DOCS_TEST: example_005

# DOCS_TEST_BODY

query ??
WITH top_articles AS (
    SELECT title, views, category
    FROM articles
    WHERE views > 5000
)
SELECT category, COUNT(*) AS count
FROM top_articles
GROUP BY category;
----
category	count
product	1

# DOCS_TEST: example_006

# DOCS_TEST_BODY

query ???? rowsort
SELECT title, category, views,
    RANK() OVER (PARTITION BY category ORDER BY views DESC) AS rank
FROM articles;
----
title	category	views	rank
Intro to Search	engineering	4200	1
Scaling Analytics	product	5100	1

# DOCS_TEST: example_007

# DOCS_TEST_BODY

query ? rowsort
-- Union (removes duplicates)
SELECT title FROM articles_2024
UNION
SELECT title FROM articles_2025;
----
title
Intro to Search
Scaling Analytics

query ?
-- Union all (keeps duplicates)
SELECT title FROM articles_2024
UNION ALL
SELECT title FROM articles_2025;
----
title
Intro to Search
Scaling Analytics
Intro to Search
Scaling Analytics

query ? rowsort
-- Intersect
SELECT title FROM articles_2024
INTERSECT
SELECT title FROM articles_2025;
----
title
Intro to Search
Scaling Analytics

# DOCS_TEST: example_008

# DOCS_TEST_BODY

query ??
SELECT title, views
FROM articles
WHERE views > (SELECT AVG(views) FROM articles);
----
title	views
Scaling Analytics	5100

# DOCS_TEST: example_009

# DOCS_TEST_BODY

query ??
SELECT title, views
FROM articles
WHERE category IN (SELECT name FROM categories WHERE active = TRUE);
----
title	views
Intro to Search	4200
Scaling Analytics	5100
