);

# DOCS_TEST_BODY

query error
SELECT a.title AS article_title, COUNT(*) count
FROM articles a
WHERE a.views > 100;
----
db error: ERROR: column "title" must appear in the GROUP BY clause or must be part of an aggregate function.
Either add it to the GROUP BY list, or use "ANY_VALUE(title)" if the exact value of "title" is not important.

# DOCS_TEST: example_002

statement ok
CREATE TABLE comments (article_id INTEGER, body VARCHAR);

statement ok
INSERT INTO comments VALUES (1, 'first comment'), (2, 'second comment');

statement ok
CREATE TABLE tags (tag VARCHAR);

statement ok
INSERT INTO tags VALUES ('search'), ('analytics');

statement ok
CREATE TABLE articles_2025 AS SELECT * FROM articles_2024;

# DOCS_TEST_BODY

query ?? rowsort
-- INNER JOIN (default)
SELECT a.title, c.body
FROM articles a
JOIN comments c ON a.id = c.article_id;
----
title	body
Intro to Search	first comment
Scaling Analytics	second comment

query ?? rowsort
-- LEFT JOIN
SELECT a.title, c.body
FROM articles a
LEFT JOIN comments c ON a.id = c.article_id;
----
title	body
Intro to Search	first comment
Scaling Analytics	second comment


query ?? rowsort
-- CROSS JOIN
SELECT a.title, t.tag
FROM articles a
CROSS JOIN tags t;
----
title	tag
Intro to Search	analytics
Intro to Search	search
Scaling Analytics	analytics
Scaling Analytics	search


query ?? rowsort
-- USING shorthand
SELECT a.title, c.body
FROM articles a
JOIN comments c USING (article_id);
----
title	body
Intro to Search	first comment
Scaling Analytics	second comment

