# DOCS_TEST: example_002

statement ok
DROP TABLE IF EXISTS orders;

statement ok
CREATE TABLE orders (
    id INTEGER,
    status VARCHAR,
    created_at TIMESTAMP,
    shipped_at TIMESTAMP
);

statement ok
INSERT INTO orders VALUES
    (1, 'processing', TIMESTAMP '2025-02-15 10:00:00', NULL),
    (2, 'processing', TIMESTAMP '2025-03-05 10:00:00', NULL),
    (3, 'pending', TIMESTAMP '2025-02-10 10:00:00', NULL);

# DOCS_TEST_BODY

statement ok
UPDATE orders
SET status = 'shipped', shipped_at = NOW()
WHERE status = 'processing' AND created_at < '2025-03-01';

# DOCS_TEST: example_003

statement ok
DROP TABLE IF EXISTS employees;

statement ok
CREATE TABLE employees (id INTEGER, salary DOUBLE, department VARCHAR);

statement ok
INSERT INTO employees VALUES
    (1, 70000, 'engineering'),
    (2, 80000, 'product');

statement ok
DROP TABLE IF EXISTS performance_reviews;

statement ok
CREATE TABLE performance_reviews (department VARCHAR, avg_score DOUBLE);

statement ok
INSERT INTO performance_reviews VALUES
    ('engineering', 4.8),
    ('product', 4.2);

# DOCS_TEST_BODY

statement ok
UPDATE employees
SET salary = salary * 1.10
WHERE department IN (
    SELECT department
    FROM performance_reviews
    WHERE avg_score > 4.5
);
