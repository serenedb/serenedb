# DOCS_TEST: example_001

statement ok
DROP TABLE IF EXISTS doc_sec_reports;

statement ok
DROP ROLE IF EXISTS doc_sec_analysts;

statement ok
DROP ROLE IF EXISTS doc_sec_bob;

# DOCS_TEST_BODY

statement ok
CREATE ROLE doc_sec_analysts;

statement ok
CREATE ROLE doc_sec_bob LOGIN PASSWORD 'doc_sec_bob_pw';

statement ok
CREATE TABLE doc_sec_reports (id int, total int);

statement ok
GRANT SELECT ON doc_sec_reports TO doc_sec_analysts;

statement ok
GRANT doc_sec_analysts TO doc_sec_bob;

# DOCS_TEST: example_002

