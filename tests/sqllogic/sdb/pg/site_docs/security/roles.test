statement ok
ALTER ROLE doc_sec_batch LOGIN PASSWORD 'doc_sec_batch_pw';

# DOCS_TEST: example_005

# DOCS_TEST_BODY

statement ok
ALTER ROLE doc_sec_carol RENAME TO doc_sec_renamed;

query
SELECT count(*) AS remaining FROM pg_roles WHERE rolname = 'doc_sec_carol';
----
remaining
0

