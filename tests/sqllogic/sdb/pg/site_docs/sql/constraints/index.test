db error: ERROR: new row for relation "students" violates check constraint "students_name_check"
DETAIL: Failing row contains (this name contains spaces).

# DOCS_TEST: example_002

statement ok
USE $__DATABASE__;

statement ok
DROP TABLE IF EXISTS students;

# DOCS_TEST_BODY

statement ok
