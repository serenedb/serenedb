# DOCS_TEST: example_002

# DOCS_TEST_BODY

query
SELECT
    '-infinity'::DATE::TEXT AS negative,
    'epoch'::DATE::TEXT AS epoch,
    'infinity'::DATE::TEXT AS positive;
----
negative	epoch	positive
-infinity	1970-01-01	infinity
