# DOCS_TEST: example_004

statement ok
CREATE TABLE sales_data (
    amount INTEGER,
    region VARCHAR
);

statement ok
INSERT INTO sales_data VALUES
    (10, 'north'),
    (20, 'south'),
    (30, 'north');

# DOCS_TEST_BODY

statement ok
CREATE TYPE region AS ENUM (SELECT region FROM sales_data);

# DOCS_TEST: example_005

statement ok
USE $__DATABASE__;

statement ok
DROP TABLE IF EXISTS sales_data;

statement ok
DROP TYPE IF EXISTS region CASCADE;

statement ok
COPY (SELECT * FROM (VALUES
    (10, 'north'),
    (20, 'south'),
    (30, 'north')
) AS t("amount", "region")) TO '/tmp/${__DATABASE__}_sql_data_types_enum_example_005_regions.csv' (FORMAT CSV, HEADER true, DELIMITER ',');

statement ok
COPY (SELECT * FROM (VALUES
    (10, 'north'),
    (20, 'south'),
    (30, 'north')
) AS t("amount", "region")) TO '/tmp/${__DATABASE__}_sql_data_types_enum_example_005_rows.csv' (FORMAT CSV, HEADER false, DELIMITER ',');

# DOCS_TEST_RAW
#| CREATE TYPE region AS ENUM (SELECT region FROM 'sales_data.csv');
#|
#| CREATE TABLE sales_data (amount INTEGER, region region);
#|
#| COPY sales_data FROM 'sales_data.csv';

# DOCS_TEST_BODY

statement ok
CREATE TYPE region AS ENUM (SELECT region FROM '/tmp/${__DATABASE__}_sql_data_types_enum_example_005_regions.csv');

statement ok
CREATE TABLE sales_data (amount INTEGER, region region);

statement ok
COPY sales_data FROM '/tmp/${__DATABASE__}_sql_data_types_enum_example_005_rows.csv';

# DOCS_TEST: example_006

# DOCS_TEST_BODY

statement ok
CREATE TYPE breed AS ENUM ('maltese', 'Maltese');

query
-- Will return false
SELECT 'maltese'::breed = 'Maltese'::breed;
----
?column?
f

query error db error: ERROR: Could not convert string 'MALTESE' to UINT8
-- Will error
SELECT 'MALTESE'::breed;

# DOCS_TEST: example_007

# DOCS_TEST_BODY

statement ok
CREATE TABLE person (
    name TEXT,
    current_mood mood
);

statement ok
INSERT INTO person VALUES
    ('Pedro', 'happy'),
    ('Mark', NULL),
    ('Pagliacci', 'sad'),
    ('Mr. Mackey', 'ok');

# DOCS_TEST: example_008

# DOCS_TEST_BODY

statement error db error: ERROR: Could not convert string 'quackity\-quack' to UINT8
INSERT INTO person VALUES ('Hannes', 'quackity-quack');

# DOCS_TEST: example_009

# DOCS_TEST_BODY

query
SELECT current_mood, regexp_matches(current_mood, '.*a.*') AS contains_a FROM person;
----
current_mood	contains_a
happy	t
NULL	NULL
sad	t
ok	f

# DOCS_TEST: example_010

# DOCS_TEST_BODY

statement ok
CREATE TYPE new_mood AS ENUM ('happy', 'anxious');

query
SELECT * FROM person
WHERE current_mood = 'happy'::new_mood;
----
name	current_mood
Pedro	happy

