# DOCS_TEST: example_015

# DOCS_TEST_BODY

statement ok
CREATE TYPE priority AS ENUM ('low', 'medium', 'high');

query
SELECT 'low'::priority < 'high'::priority AS comp;
----
comp
t

# DOCS_TEST: example_016

# DOCS_TEST_BODY

query
SELECT unnest(['medium'::priority, 'high'::priority, 'low'::priority]) AS m
ORDER BY m;
----
m
low
medium
high

# DOCS_TEST: example_017

# DOCS_TEST_BODY

statement ok
CREATE TABLE tasks (name TEXT, priority_level priority);

statement ok
INSERT INTO tasks VALUES ('a', 'low'), ('b', 'medium'), ('c', 'high');

query
-- WARNING!
-- Equivalent to `WHERE priority_level::VARCHAR >= 'medium'`
SELECT * FROM tasks
WHERE priority_level >= 'medium';
----
name	priority_level
b	medium
c	high

# DOCS_TEST: example_018

# DOCS_TEST_BODY

query
SELECT * FROM tasks
WHERE priority_level >= 'medium'::priority;
----
name	priority_level
b	medium
c	high

