# DOCS_TEST: example_004

statement error
CREATE TYPE region AS ENUM (SELECT region FROM sales_data);
----
db error: ERROR: Table with name sales_data does not exist!
Did you mean "<slt:ignore>"?


# DOCS_SETUP

statement ok
USE $__DATABASE__;

statement ok
DROP TYPE IF EXISTS region CASCADE;

# DOCS_TEST: example_005

statement error (?i)No files found that match the pattern .*
