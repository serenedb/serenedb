# DOCS_TEST: example_005

# DOCS_TEST_BODY

query
SELECT MAP {['a', 'b']: [1.1, 2.2], ['c', 'd']: [3.3, 4.4]};
----
map
{"(\\"{a,b}\\",\\"{1.1,2.2}\\")","(\\"{c,d}\\",\\"{3.3,4.4}\\")"}

