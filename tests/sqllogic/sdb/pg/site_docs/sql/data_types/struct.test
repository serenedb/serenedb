control substitution on

# DOCS_TEST: example_001

# DOCS_TEST_BODY

query
SELECT struct_pack(key1 := 'value1', key2 := 42) AS s;
----
s
(value1,42)

# DOCS_TEST: example_002

# DOCS_TEST_BODY

query
SELECT {'key1': 'value1', 'key2': 42} AS s;
----
s
(value1,42)

# DOCS_TEST: example_003

# DOCS_TEST_BODY

query
SELECT d AS s FROM (SELECT 'value1' AS key1, 42 AS key2) d;
----
s
(value1,42)

# DOCS_TEST: example_004

# DOCS_TEST_BODY

query
SELECT {'x': 1, 'y': 2, 'z': 3} AS s;
----
s
(1,2,3)

# DOCS_TEST: example_005

# DOCS_TEST_BODY

query
SELECT {'yes': 'alpha', 'maybe': 'beta', 'huh': NULL, 'no': 'gamma'} AS s;
----
s
(alpha,beta,,gamma)

# DOCS_TEST: example_006

# DOCS_TEST_BODY

query
SELECT {'key1': 'string', 'key2': 1, 'key3': 12.345} AS s;
----
s
(string,1,12.345)

# DOCS_TEST: example_007

# DOCS_TEST_BODY

query
SELECT {
        'birds': {'yes': 'duck', 'maybe': 'goose', 'huh': NULL, 'no': 'heron'},
        'aliens': NULL,
        'amphibians': {'yes': 'frog', 'maybe': 'salamander', 'huh': 'dragon', 'no': 'toad'}
    } AS s;
----
s
("(duck,goose,,heron)",,"(frog,salamander,dragon,toad)")

# DOCS_TEST: example_008

# DOCS_TEST_BODY

query
SELECT struct_update({'a': 1, 'b': 2}, b := 3, c := 4) AS s;
----
s
(1,3,4)

# DOCS_TEST: example_009

# DOCS_TEST_BODY

query
SELECT a.x FROM (SELECT {'x': 1, 'y': 2, 'z': 3} AS a);
----
x
1

# DOCS_TEST: example_010

# DOCS_TEST_BODY

query
SELECT a."x space" FROM (SELECT {'x space': 1, 'y': 2, 'z': 3} AS a);
----
x space
1

# DOCS_TEST: example_011

# DOCS_TEST_BODY

query
SELECT a['x space'] FROM (SELECT {'x space': 1, 'y': 2, 'z': 3} AS a);
----
a
1

# DOCS_TEST: example_012

# DOCS_TEST_BODY

query
SELECT struct_extract({'x space': 1, 'y': 2, 'z': 3}, 'x space');
----
struct_extract
1

# DOCS_TEST: example_013

# DOCS_TEST_BODY

query
SELECT unnest(a)
FROM (SELECT {'x': 1, 'y': 2, 'z': 3} AS a);
----
x	y	z
1	2	3

# DOCS_TEST: example_014

# DOCS_TEST_BODY

query
SELECT a.* EXCLUDE ('y')
FROM (SELECT {'x': 1, 'y': 2, 'z': 3} AS a);
----
x	z
1	3

# DOCS_TEST: example_015

statement ok
USE $__DATABASE__;

statement ok
CREATE TABLE tbl (
    id INTEGER,
    name VARCHAR,
    col1 DOUBLE,
    col2 DOUBLE,
    "Some Column Name" VARCHAR,
    i INTEGER,
    a INTEGER,
    b INTEGER,
    c INTEGER,
    number INTEGER,
    number1 INTEGER,
    number2 INTEGER
);

statement ok
INSERT INTO tbl VALUES
    (1, 'mark', 1, 2, 'alpha', 1, 10, 20, 30, 10, 100, 1000),
    (3, 'bookmark', 4, 5, 'beta', 2, 11, 21, 31, 20, 200, 2000),
    (7, 'other', 9, 16, 'gamma', 3, 12, 22, 32, NULL, 300, 3000);

statement ok
DROP TABLE IF EXISTS tbl;

statement ok
CREATE TABLE tbl (
    part1 STRUCT(part2 STRUCT(part3 INTEGER))
);

statement ok
INSERT INTO tbl VALUES ({'part2': {'part3': 42}});

# DOCS_TEST_BODY

query
SELECT part1
FROM tbl;
----
part1
("(42)")

# DOCS_TEST: example_016

statement ok
DROP TABLE IF EXISTS tbl;

statement ok
CREATE TABLE tbl (
    part1 STRUCT(part2 STRUCT(part3 INTEGER))
);

statement ok
INSERT INTO tbl VALUES ({'part2': {'part3': 42}});

# DOCS_TEST_BODY

query
SELECT part1.part2
FROM tbl;
----
part2
(42)

# DOCS_TEST: example_017

statement ok
DROP TABLE IF EXISTS tbl;

statement ok
CREATE TABLE tbl (
    part1 STRUCT(part2 STRUCT(part3 INTEGER))
);

statement ok
INSERT INTO tbl VALUES ({'part2': {'part3': 42}});

# DOCS_TEST_BODY

query
SELECT part1.part2.part3
FROM tbl;
----
part3
42

# DOCS_TEST: example_018

# DOCS_TEST_BODY

statement ok
CREATE TABLE t1 (s STRUCT(v VARCHAR, i INTEGER));

statement ok
INSERT INTO t1 VALUES (row('a', 42));

# DOCS_TEST: example_019

# DOCS_TEST_BODY

query
SELECT * FROM t1;
----
s
(a,42)


# DOCS_TEST: example_020

statement ok
USE $__DATABASE__;

statement ok
DROP TABLE IF EXISTS t1;

# DOCS_TEST_BODY

statement ok
CREATE TABLE t1 AS (
    SELECT row('a', 42)::STRUCT(v VARCHAR, i INTEGER)
);

# DOCS_TEST: example_021

# DOCS_TEST_BODY

statement error
CREATE TABLE t2 AS SELECT row('a');
----
db error: ERROR: A table cannot be created from an unnamed struct


# DOCS_TEST: example_022

# DOCS_TEST_BODY

query error
SELECT a::STRUCT(y INTEGER) AS b
FROM
    (SELECT {'x': 42} AS a);
----
db error: ERROR: STRUCT to STRUCT cast must have at least one matching member


# DOCS_TEST: example_023

# DOCS_TEST_BODY

query
SELECT struct_pack(y := a.x) AS b
FROM
    (SELECT {'x': 42} AS a);
----
b
(42)

# DOCS_TEST: example_024

# DOCS_TEST_BODY

query
SELECT row(x, x + 1, y) FROM (SELECT 1 AS x, 'a' AS y) AS s;
----
row
(1,2,a)

