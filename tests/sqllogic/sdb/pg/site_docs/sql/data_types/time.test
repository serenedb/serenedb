# DOCS_TEST: example_001

query
SELECT TIME '1992-09-20 11:30:00.123456';
----
time
11:30:00.123456

# DOCS_TEST: example_002

query
SELECT TIMETZ '1992-09-20 11:30:00.123456';
----
time with time zone
11:30:00.123456+00:00

# DOCS_TEST: example_003

query
SELECT TIMETZ '1992-09-20 11:30:00.123456-02:00';
----
time with time zone
13:30:00.123456+00:00

# DOCS_TEST: example_004

query
SELECT TIMETZ '1992-09-20 11:30:00.123456+05:30';
----
time with time zone
06:00:00.123456+00:00

# DOCS_TEST: example_005

query
SELECT '15:30:00.123456789'::TIME_NS;
----
time_ns
15:30:00.123456
