# DOCS_TEST: example_005

# DOCS_TEST_BODY

query
SELECT TIMESTAMPTZ '1992-09-20 11:30:00.123456789';
----
timestamp with time zone
1992-09-20 11:30:00.123456+00

# DOCS_TEST: example_006

# DOCS_TEST_BODY

query
SELECT TIMESTAMPTZ '1992-09-20 12:30:00.123456789+01:00';
----
timestamp with time zone
1992-09-20 11:30:00.123456+00

# DOCS_TEST: example_007

# DOCS_TEST_BODY

query
SELECT
    timezone('America/Denver', TIMESTAMP '2001-02-16 20:38:40') AS aware1,
    timezone('America/Denver', TIMESTAMPTZ '2001-02-16 04:38:40') AS naive1,
    timezone('UTC', TIMESTAMP '2001-02-16 20:38:40+00:00') AS aware2,
    timezone('UTC', TIMESTAMPTZ '2001-02-16 04:38:40 Europe/Berlin') AS naive2;
----
aware1	naive1	aware2	naive2
2001-02-17 03:38:40+00	2001-02-15 21:38:40	2001-02-16 20:38:40+00	2001-02-16 03:38:40

# DOCS_TEST: example_008

# DOCS_TEST_BODY

query
SELECT '-infinity'::TIMESTAMP, 'epoch'::TIMESTAMP, 'infinity'::TIMESTAMP;
----
timestamp	timestamp	timestamp
-infinity	1970-01-01 00:00:00	infinity

# DOCS_TEST: example_010

# DOCS_TEST_BODY

statement ok
SET TimeZone = 'America/Los_Angeles';

# DOCS_TEST: example_011

# DOCS_TEST_RAW
#| SELECT
#|     name,
#|     abbrev,
#|     utc_offset
#| FROM pg_timezone_names()
#| ORDER BY
#|     name;

# DOCS_TEST_BODY

query ???
SELECT
    name,
    abbrev,
    utc_offset
FROM (
    VALUES
        ('America/Los_Angeles', 'PST', INTERVAL '-8 hours'),
        ('Europe/Berlin', 'CET', INTERVAL '1 hour'),
        ('UTC', 'UTC', INTERVAL '0 hours')
) AS pg_timezone_names(name, abbrev, utc_offset)
ORDER BY
    name;
----
name	abbrev	utc_offset
America/Los_Angeles	PST	-08:00:00
Europe/Berlin	CET	01:00:00
UTC	UTC	00:00:00

