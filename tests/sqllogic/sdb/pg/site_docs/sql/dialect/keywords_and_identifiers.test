# DOCS_SETUP

statement ok
USE $__DATABASE__;

statement ok
CREATE TABLE tbl (
    id INTEGER,
    name VARCHAR,
    col1 DOUBLE,
    col2 DOUBLE,
    "Some Column Name" VARCHAR,
    i INTEGER,
    a INTEGER,
    b INTEGER,
    c INTEGER,
    number INTEGER,
    number1 INTEGER,
    number2 INTEGER
);

statement ok
INSERT INTO tbl VALUES
    (1, 'mark', 1, 2, 'alpha', 1, 10, 20, 30, 10, 100, 1000),
    (3, 'bookmark', 4, 5, 'beta', 2, 11, 21, 31, 20, 200, 2000),
    (7, 'other', 9, 16, 'gamma', 3, 12, 22, 32, NULL, 300, 3000);

# DOCS_TEST: example_005

statement error db error: ERROR: relation "tbl" already exists
CREATE TABLE tbl AS SELECT cos(pi()) AS CosineOfPi;

query error
SELECT cosineofpi FROM tbl;
----
db error: ERROR: Referenced column "cosineofpi" not found in FROM clause!
Candidate bindings: "c", "i", "col1", "col2", "name"


# DOCS_TEST: example_006

query
SELECT MAP(['key1'], [1]) = MAP(['KEY1'], [1]) AS equal;
----
equal
f

# DOCS_TEST: example_007

query
SELECT {'key1': 1} = {'KEY1': 1} AS equal;
----
equal
t

# DOCS_TEST: example_008

query
SELECT union_value(key1 := 1) = union_value(KEY1 := 1) as equal;
----
equal
t

