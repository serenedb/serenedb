statement ok
USE temp2;

# DOCS_TEST: example_003

# DOCS_TEST_BODY

query
select COS(Pi()) as CosineOfPi;
----
cosineofpi
-1

query
SELECT cos(pi()) AS CosineOfPi;
----
cosineofpi
-1

# DOCS_TEST: example_004

# DOCS_TEST_BODY

query
SELECT col_A FROM (SELECT 'x' AS col_a);
----
col_a
x

statement error
SELECT col_á FROM (SELECT 'x' AS col_a);
----
db error: ERROR: Referenced column "col_á" not found in FROM clause!
Candidate bindings: "col_a"


# DOCS_TEST: example_006

# DOCS_TEST_BODY

query
SELECT (MAP {'a': 1})['A'] IS NOT NULL AS found;
----
found
f

# DOCS_TEST: example_007

# DOCS_TEST_BODY

query
SELECT union_extract(union_value(a := 1), 'A') IS NOT NULL AS found;
----
found
t

# DOCS_TEST: example_008

# DOCS_TEST_BODY

query
SELECT ({'a': 1}).A IS NOT NULL AS found;
----
found
t

# DOCS_TEST: example_009

# DOCS_TEST_BODY

query error
SELECT {'a': 1, 'A': 2};
----
db error: ERROR: Duplicate struct entry name "A"
