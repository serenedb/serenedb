# DOCS_TEST: example_003

query
select COS(Pi()) as CosineOfPi;
----
cosineofpi
-1

query
SELECT cos(pi()) AS CosineOfPi;
----
cosineofpi
-1

# DOCS_TEST: example_004

query
SELECT col_A FROM (SELECT 'x' AS col_a);
----
col_a
x

query error
SELECT col_á FROM (SELECT 'x' AS col_a);
