# DOCS_TEST: example_001

# DOCS_TEST_BODY

query
SELECT *
FROM (SELECT unnest({'a': 42, 'b': {'a': 88, 'b': 99}}, recursive := true));
----
a	a	b
42	88	99

# DOCS_TEST: example_002

statement ok
USE $__DATABASE__;

statement ok
DETACH IF EXISTS temp2;

