# DOCS_TEST: example_008

statement ok
USE $__DATABASE__;

statement ok
DROP TABLE IF EXISTS mytable;

# DOCS_TEST_RAW
#| SET preserve_identifier_case = false;
#|
#| CREATE TABLE MyTaBLe (x INTEGER);
#|
#| SELECT tbl FROM duckdb_tables();

# DOCS_TEST_BODY

statement ok
SET preserve_identifier_case = false;

statement ok
CREATE TABLE MyTaBLe (x INTEGER);

query ?
SELECT DISTINCT table_name AS tbl
FROM duckdb_tables()
WHERE table_name = 'mytable';
----
tbl
mytable

