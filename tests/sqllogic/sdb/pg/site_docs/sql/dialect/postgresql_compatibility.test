# DOCS_TEST: example_001

# DOCS_TEST_BODY

query
SELECT 1.0 / 0.0 AS x;
----
x
Infinity

query
SELECT 0.0 / 0.0 AS x;
----
x
NaN

query
SELECT -1.0 / 0.0 AS x;
----
x
-Infinity

query
SELECT 'Infinity'::FLOAT / 'Infinity'::FLOAT AS x;
----
x
NaN

query
SELECT 1.0 / 'Infinity'::FLOAT AS x;
----
x
0

query
SELECT 'Infinity'::FLOAT - 'Infinity'::FLOAT AS x;
----
x
NaN

query
SELECT 'Infinity'::FLOAT - 1.0 AS x;
----
x
Infinity

