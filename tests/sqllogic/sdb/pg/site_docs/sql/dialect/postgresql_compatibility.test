# DOCS_TEST: example_016

# DOCS_TEST_BODY

query
SELECT date_part('year', TIMESTAMP '2021-08-03 11:59:44.123456') AS finite,
       date_part('year', 'infinity'::TIMESTAMP) AS infinite;
----
finite	infinite
2021	NULL
