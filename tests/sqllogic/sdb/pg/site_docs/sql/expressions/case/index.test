# DOCS_TEST: example_001

statement ok
CREATE OR REPLACE TABLE integers AS SELECT unnest([1, 2, 3]) AS i;

query
SELECT i, CASE WHEN i > 2 THEN 1 ELSE 0 END AS test
FROM integers;
----
i	test
1	0
2	0
3	1

# DOCS_TEST: example_002

query
SELECT i, IF(i > 2, 1, 0) AS test
FROM integers;
----
i	test
1	0
2	0
3	1

