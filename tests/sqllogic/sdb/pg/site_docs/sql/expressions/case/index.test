# DOCS_TEST: example_007

statement ok
CREATE OR REPLACE TABLE integers AS SELECT unnest([1, 2, 3]) AS i;

query
SELECT i, SWITCH(i, MAP {1: 'one', 2: 'two', 3: 'three'}) AS test
FROM integers;
----
i	test
1	one
2	two
3	three

# DOCS_TEST: example_008

query
SELECT i, SWITCH(i, MAP {1: 'one', 2: 'two'}, 'other') AS test
FROM integers;
----
i	test
1	one
2	two
3	other
