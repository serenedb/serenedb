# DOCS_TEST: example_001

query
SELECT CAST(i AS VARCHAR) AS i
FROM generate_series(1, 3) tbl(i);
----
i
1
2
3

# DOCS_TEST: example_002

query
SELECT i::DOUBLE AS i
FROM generate_series(1, 3) tbl(i);
----
i
1
2
3

