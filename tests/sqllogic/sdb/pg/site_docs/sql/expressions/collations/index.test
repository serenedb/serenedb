# DOCS_TEST: example_001

# DOCS_TEST_BODY

query
SELECT 'hello' = 'hElLO';
----
?column?
f

# DOCS_TEST: example_002

# DOCS_TEST_BODY

query
SELECT 'hello' COLLATE NOCASE = 'hElLO';
----
?column?
t

# DOCS_TEST: example_003

# DOCS_TEST_BODY

query
SELECT 'hello' = 'hëllo';
----
?column?
f

# DOCS_TEST: example_004

# DOCS_TEST_BODY

query
SELECT 'hello' COLLATE NOACCENT = 'hëllo';
----
?column?
t

# DOCS_TEST: example_005

# DOCS_TEST_BODY

query
SELECT 'hello' COLLATE NOCASE = 'hElLÖ';
----
?column?
f

# DOCS_TEST: example_006

# DOCS_TEST_BODY

query
SELECT 'hello' COLLATE NOACCENT = 'hElLÖ';
----
?column?
f

# DOCS_TEST: example_007

# DOCS_TEST_BODY

query
SELECT 'hello' COLLATE NOCASE.NOACCENT = 'hElLÖ';
----
?column?
t

# DOCS_TEST: example_008

# DOCS_TEST_BODY

statement ok
SET default_collation = NOCASE;

query
SELECT 'hello' = 'HeLlo';
----
?column?
t

# DOCS_TEST: example_009

# default_collation is a GLOBAL setting that leaks across connections, so restore
# it immediately after the example above to avoid contaminating other fixtures.
statement ok
RESET default_collation;

# DOCS_TEST_BODY

statement ok
CREATE TABLE names (name VARCHAR COLLATE NOACCENT);

statement ok
INSERT INTO names VALUES ('hännes');

# DOCS_TEST: example_010

# DOCS_TEST_BODY

query
SELECT name
FROM names
WHERE name = 'hannes';
----
name
hännes

# DOCS_TEST: example_011

# DOCS_TEST_BODY

statement error
SELECT name
FROM names
WHERE name = 'hannes' COLLATE NOCASE;
----
db error: ERROR: Cannot combine types with different collation!


# DOCS_TEST: example_012

# DOCS_TEST_BODY

statement ok
CREATE TABLE other_names (name VARCHAR COLLATE NOCASE);

statement ok
INSERT INTO other_names VALUES ('HÄNNES');

# DOCS_TEST: example_013

# DOCS_TEST_BODY

statement error
SELECT names.name AS name, other_names.name AS other_name
FROM names, other_names
WHERE names.name = other_names.name;
----
db error: ERROR: Cannot combine types with different collation!


# DOCS_TEST: example_014

# DOCS_TEST_BODY

query
SELECT names.name AS name, other_names.name AS other_name
FROM names, other_names
WHERE names.name COLLATE NOACCENT.NOCASE = other_names.name COLLATE NOACCENT.NOCASE;
----
name	other_name
hännes	HÄNNES

# DOCS_TEST: example_015

# The three non-ICU builtins (nfc, noaccent, nocase) are always present.
# ICU locale collations (de, fr, ja, ...) are now included as well. We filter
# to a stable known set instead of asserting the full list because the total
# number of ICU collations varies between ICU versions.

# DOCS_TEST_BODY

query
SELECT collname
FROM pragma_collations()
WHERE collname IN ('nocase', 'noaccent', 'nfc', 'de', 'fr', 'ja')
ORDER BY collname;
----
collname
de
fr
ja
nfc
noaccent
nocase

# DOCS_TEST: example_016

# ICU collations follow region- and language-specific rules. The German (de)
# collation orders the umlaut "ä" next to "a" rather than after "z".

# DOCS_TEST_BODY

statement ok
CREATE TABLE strings (s VARCHAR COLLATE DE);

statement ok
INSERT INTO strings VALUES ('z'), ('ä'), ('a');

query
SELECT s
FROM strings
ORDER BY s;
----
s
a
ä
z

# DOCS_TEST: example_017

# A collation can also be applied per expression with COLLATE inside ORDER BY.

# DOCS_TEST_BODY

query
SELECT s
FROM (VALUES ('z'), ('ä'), ('a')) AS t(s)
ORDER BY s COLLATE DE;
----
s
a
ä
z
