control substitution on

# DOCS_TEST: example_001

statement ok
USE $__DATABASE__;

statement ok
CREATE TABLE tbl (
    id INTEGER,
    name VARCHAR,
    col1 DOUBLE,
    col2 DOUBLE,
    "Some Column Name" VARCHAR,
    i INTEGER,
    a INTEGER,
    b INTEGER,
    c INTEGER,
    number INTEGER,
    number1 INTEGER,
    number2 INTEGER
);

statement ok
INSERT INTO tbl VALUES
    (1, 'mark', 1, 2, 'alpha', 1, 10, 20, 30, 10, 100, 1000),
    (3, 'bookmark', 4, 5, 'beta', 2, 11, 21, 31, 20, 200, 2000),
    (7, 'other', 9, 16, 'gamma', 3, 12, 22, 32, NULL, 300, 3000);

statement ok
CREATE TABLE other_tbl (id INTEGER, other_value VARCHAR);

statement ok
INSERT INTO other_tbl VALUES
    (1, 'one'),
    (3, 'three');

# DOCS_TEST_BODY

query
SELECT *
FROM tbl;
----
id	name	col1	col2	some column name	i	a	b	c	number	number1	number2
1	mark	1	2	alpha	1	10	20	30	10	100	1000
3	bookmark	4	5	beta	2	11	21	31	20	200	2000
7	other	9	16	gamma	3	12	22	32	NULL	300	3000

# DOCS_TEST: example_002

# DOCS_TEST_BODY

query
SELECT tbl.*
FROM tbl
JOIN other_tbl USING (id);
----
id	name	col1	col2	some column name	i	a	b	c	number	number1	number2
1	mark	1	2	alpha	1	10	20	30	10	100	1000
3	bookmark	4	5	beta	2	11	21	31	20	200	2000

# DOCS_TEST: example_003

# DOCS_TEST_BODY

query
SELECT st.* FROM (SELECT {'x': 1, 'y': 2, 'z': 3} AS st);
----
x	y	z
1	2	3

# DOCS_TEST: example_004

statement ok
DROP TABLE tbl;

statement ok
CREATE TABLE tbl (
    id INTEGER,
    name VARCHAR,
    col INTEGER,
    col1 DOUBLE,
    col2 DOUBLE,
    "Some Column Name" VARCHAR,
    i INTEGER,
    a INTEGER,
    b INTEGER,
    c INTEGER,
    number INTEGER,
    number1 INTEGER,
    number2 INTEGER
);

statement ok
INSERT INTO tbl VALUES
    (1, 'mark', 99, 1, 2, 'alpha', 1, 10, 20, 30, 10, 100, 1000),
    (3, 'bookmark', 98, 4, 5, 'beta', 2, 11, 21, 31, 20, 200, 2000),
    (7, 'other', 97, 9, 16, 'gamma', 3, 12, 22, 32, NULL, 300, 3000);

# DOCS_TEST_BODY

query
SELECT * EXCLUDE (col)
FROM tbl;
----
id	name	col1	col2	some column name	i	a	b	c	number	number1	number2
1	mark	1	2	alpha	1	10	20	30	10	100	1000
3	bookmark	4	5	beta	2	11	21	31	20	200	2000
7	other	9	16	gamma	3	12	22	32	NULL	300	3000

# DOCS_TEST: example_005

statement ok
DROP TABLE tbl;

statement ok
CREATE TABLE tbl (
    id INTEGER,
    name VARCHAR,
    col1 DOUBLE,
    col2 DOUBLE,
    "Some Column Name" VARCHAR,
    i INTEGER,
    a INTEGER,
    b INTEGER,
    c INTEGER,
    number INTEGER,
    number1 INTEGER,
    number2 INTEGER
);

statement ok
INSERT INTO tbl VALUES
    (1, 'mark', 1, 2, 'alpha', 1, 10, 20, 30, 10, 100, 1000),
    (3, 'bookmark', 4, 5, 'beta', 2, 11, 21, 31, 20, 200, 2000),
    (7, 'other', 9, 16, 'gamma', 3, 12, 22, 32, NULL, 300, 3000);

# DOCS_TEST_BODY

query
SELECT * REPLACE (col1 / 1_000 AS col1, col2 / 1_000 AS col2)
FROM tbl;
----
id	name	col1	col2	some column name	i	a	b	c	number	number1	number2
1	mark	0.001	0.002	alpha	1	10	20	30	10	100	1000
3	bookmark	0.004	0.005	beta	2	11	21	31	20	200	2000
7	other	0.009	0.016	gamma	3	12	22	32	NULL	300	3000

# DOCS_TEST: example_006

# DOCS_TEST_BODY

query
SELECT * RENAME (col1 AS height, col2 AS width)
FROM tbl;
