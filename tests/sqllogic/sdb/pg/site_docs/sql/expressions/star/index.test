# DOCS_TEST: example_011

# DOCS_TEST_BODY

statement ok
CREATE TABLE numbers (id INTEGER, number INTEGER);

statement ok
INSERT INTO numbers VALUES (1, 10), (2, 20), (3, NULL);

query
SELECT min(COLUMNS(*)), count(COLUMNS(*)) FROM numbers;
----
id	number	id	number
1	10	3	2

# DOCS_TEST: example_012

# DOCS_TEST_BODY

query
SELECT
    min(COLUMNS(* REPLACE (number + id AS number))),
    count(COLUMNS(* EXCLUDE (number)))
FROM numbers;
----
id	min	id
1	11	3

# DOCS_TEST: example_013

# DOCS_TEST_BODY

query
SELECT COLUMNS(*) + COLUMNS(*) FROM numbers;
----
id	number
2	20
4	40
6	NULL

# DOCS_TEST: example_014

# DOCS_TEST_BODY

query ?? rowsort
SELECT *
FROM (
    SELECT 'a', 'a'
    UNION ALL
    SELECT 'a', 'b'
    UNION ALL
    SELECT 'b', 'b'
) _(x, y)
WHERE COLUMNS(*) = 'a';
----
x	y
a	a

# DOCS_TEST: example_015

# DOCS_TEST_BODY

query ?? rowsort
SELECT *
FROM (
    SELECT 'a', 'a'
    UNION ALL
    SELECT 'a', 'b'
    UNION ALL
    SELECT 'b', 'b'
) _(x, y)
WHERE greatest(UNPACK(COLUMNS(*) = 'a'));
----
x	y
a	a
a	b

# DOCS_TEST: example_016

# DOCS_TEST_BODY

query ??? rowsort
SELECT DISTINCT ON (COLUMNS('x|y')) *
FROM (VALUES (1, 2, 'a'), (1, 2, 'b'), (3, 4, 'c')) t(x, y, z);
----
x	y	z
1	2	<slt:ignore>
3	4	c

# DOCS_TEST: example_017

# DOCS_TEST_BODY

query
SELECT COLUMNS('(id|numbers?)') FROM numbers;
----
id	number
1	10
2	20
3	NULL

# DOCS_TEST: example_018

# DOCS_TEST_BODY

control substitution off

query
SELECT COLUMNS('(\w{3}).*') AS '\1' FROM numbers;
----
num
10
20
NULL

control substitution on

# DOCS_TEST: example_020

# DOCS_TEST_BODY

control substitution off

query
SELECT min(COLUMNS(*)) AS "min_\0" FROM numbers;
----
min_id	min_number
1	10

control substitution on

# DOCS_TEST: example_021

# DOCS_TEST_BODY

query
SELECT COLUMNS(lambda c: c LIKE '%num%') FROM numbers;
----
number
10
20
NULL

# DOCS_TEST: example_022

statement ok
DROP TABLE numbers;

statement ok
CREATE TABLE numbers (id INTEGER, num INTEGER);

statement ok
INSERT INTO numbers VALUES (1, 10), (2, 20), (3, NULL);

# DOCS_TEST_BODY

query
SELECT COLUMNS(['id', 'num']) FROM numbers;
----
id	num
1	10
2	20
3	NULL

# DOCS_TEST: example_023

# DOCS_TEST_BODY

query
SELECT coalesce(COLUMNS(['a', 'b', 'c'])) AS result
FROM (SELECT NULL a, 42 b, true c);
----
result	result	result
NULL	42	t

# DOCS_TEST: example_024

# DOCS_TEST_BODY

query
SELECT coalesce(UNPACK(COLUMNS(['a', 'b', 'c']))) AS result
FROM (SELECT NULL AS a, 42 AS b, true AS c);
----
result
42

# DOCS_TEST: example_025

# DOCS_TEST_BODY

query
SELECT coalesce(*COLUMNS(*)) AS result
FROM (SELECT NULL a, 42 AS b, true AS c);
----
result
42

