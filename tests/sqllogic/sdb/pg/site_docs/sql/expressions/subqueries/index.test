math_grades_present
t

# DOCS_TEST: example_012

# DOCS_TEST_BODY

query
SELECT *
FROM grades grades_parent
WHERE grade =
    (SELECT min(grade)
     FROM grades
     WHERE grades.course = grades_parent.course);
----
grade	course
7	Math
8	CS

