control substitution on

# DOCS_TEST: secret

# DOCS_TEST_RAW
#| CREATE SECRET local_ai (
#|     TYPE openai,
#|     base_url 'http://localhost:11434',
#|     embeddings_path '/v1/embeddings'
#| );

# DOCS_TEST_BODY

statement ok
CREATE OR REPLACE SECRET local_ai_${__DATABASE__} (
    TYPE openai,
    base_url 'http://${OLLAMA_HOST}:${OLLAMA_PORT}',
    embeddings_path '/v1/embeddings'
);

# DOCS_TEST: embed_dim

# DOCS_TEST_RAW
#| SELECT array_length(ai_embed('space exploration', 'all-minilm', 'local_ai'), 1) AS dims;

# DOCS_TEST_BODY

query
SELECT array_length(ai_embed('space exploration', '${OLLAMA_MODEL}', 'local_ai_${__DATABASE__}'), 1) AS dims;
----
dims
384

