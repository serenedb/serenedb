# DOCS_TEST: embed_table

statement ok
CREATE TABLE fruits (id INTEGER PRIMARY KEY, name VARCHAR);

statement ok
INSERT INTO fruits VALUES (1, 'apple'), (2, 'orange'), (3, NULL), (4, 'banana'), (5, 'pear');

# DOCS_TEST_RAW
#| SELECT
#|     count(*) FILTER (WHERE e IS NOT NULL) AS embedded,
#|     count(*) FILTER (WHERE e IS NULL)     AS skipped
#| FROM (
#|     SELECT ai_embed(name, 'all-minilm', 'local_ai') AS e
#|     FROM fruits
#| ) t;

# DOCS_TEST_BODY

query
SELECT
    count(*) FILTER (WHERE e IS NOT NULL) AS embedded,
    count(*) FILTER (WHERE e IS NULL)     AS skipped
FROM (
    SELECT ai_embed(name, '${OLLAMA_MODEL}', 'local_ai_${__DATABASE__}') AS e
    FROM fruits
) t;
----
embedded	skipped
4	1

# DOCS_TEST: build_index

# DOCS_TEST_RAW
#| CREATE TABLE catalog (id INTEGER PRIMARY KEY, name VARCHAR, embedding FLOAT[384]);
#|
#| INSERT INTO catalog
#| SELECT id, name, ai_embed(name, 'all-minilm', 'local_ai')::FLOAT[384]
#| FROM fruits
#| WHERE name IS NOT NULL;
#|
#| CREATE INDEX catalog_idx ON catalog
#|     USING inverted (id, name, embedding hnsw (metric = 'cosine'));

# DOCS_TEST_BODY

statement ok
CREATE TABLE catalog (id INTEGER PRIMARY KEY, name VARCHAR, embedding FLOAT[384]);

statement ok
INSERT INTO catalog
SELECT id, name, ai_embed(name, '${OLLAMA_MODEL}', 'local_ai_${__DATABASE__}')::FLOAT[384]
FROM fruits
WHERE name IS NOT NULL;

statement ok
CREATE INDEX catalog_idx ON catalog
    USING inverted (id, name, embedding hnsw (metric = 'cosine'));
