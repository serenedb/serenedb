control substitution on

# DOCS_TEST: string_concat_op
# DOCS_TEST_BODY
query
SELECT 'Serene' || 'DB' AS string_concat, [1, 2, 3] || [4, 5, 6] AS list_concat, '\xAA'::BLOB || '\xBB'::BLOB AS blob_concat;
----
string_concat	list_concat	blob_concat
SereneDB	{1,2,3,4,5,6}	\\xaabb

# DOCS_TEST: decode
# DOCS_TEST_BODY
query
SELECT decode('\xC3BC'::BLOB) AS decode, decode('\xAA'::BLOB, 'replace') AS decode_replace;
----
decode	decode_replace
ü	?

# DOCS_TEST: encode
# DOCS_TEST_BODY
query
SELECT encode('my_string_with_ü') AS encode;
----
encode
\\x6d795f737472696e675f776974685fc3bc

# DOCS_TEST: from_base64
# DOCS_TEST_BODY
query
SELECT from_base64('QQ==') AS from_base64;
----
from_base64
\\x41

# DOCS_TEST: hex
# DOCS_TEST_BODY
query
SELECT hex('\xAABB'::BLOB) AS hex;
----
hex
AABB

# DOCS_TEST: md5
# DOCS_TEST_BODY
query
SELECT md5('\xAABB'::BLOB) AS md5;
----
md5
58cea1f6b2b06520613e09af90dc1c47

# DOCS_TEST: octet_length
