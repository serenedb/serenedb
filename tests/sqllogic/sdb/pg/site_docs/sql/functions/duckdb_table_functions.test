# Shared setup for the metadata-function examples below (executed, not displayed).

statement ok
CREATE OR REPLACE TABLE metadata_demo(id INTEGER, name VARCHAR, score DOUBLE, CHECK (score >= 0));

statement ok
CREATE OR REPLACE VIEW metadata_demo_v AS SELECT id, name FROM metadata_demo;

statement ok
CREATE OR REPLACE SEQUENCE demo_seq START 10;

statement ok
DROP TYPE IF EXISTS mood;

statement ok
CREATE TYPE mood AS ENUM ('happy', 'sad');

statement ok
CREATE INDEX IF NOT EXISTS demo_idx ON metadata_demo(id);

statement ok
DROP SECRET IF EXISTS demo_secret;

statement ok
CREATE SECRET demo_secret (TYPE s3, KEY_ID 'k', SECRET 's');


# DOCS_TEST: example_001

# DOCS_TEST_BODY

statement ok
SELECT * FROM duckdb_settings();

