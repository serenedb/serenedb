# DOCS_TEST: bm25
# DOCS_TEST_BODY
query
SELECT id, BM25(docs_idx.tableoid) AS score
FROM docs_idx
WHERE body @@ ts_phrase('fox')
ORDER BY score DESC, id;
----
id	score
1	1.036356
2	1.036356

