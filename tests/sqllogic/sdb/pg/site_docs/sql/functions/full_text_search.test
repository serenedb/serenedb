# DOCS_TEST: st_intersects_matrix
# DOCS_TEST_BODY
query
SELECT id, name
FROM geo_demo_idx
WHERE ST_Intersects(
        shape,
        '{"type":"Polygon","coordinates":[[[0,0],[10,0],[10,10],[0,10],[0,0]]]}'
     )
ORDER BY id;
----
id	name
1	red_square
2	inner_point
3	edge_point
5	overlap_box

# DOCS_TEST: st_contains_query_field
# DOCS_TEST_BODY
query
SELECT id, name
FROM geo_demo_idx
WHERE ST_Contains(
        '{"type":"Polygon","coordinates":[[[0,0],[10,0],[10,10],[0,10],[0,0]]]}',
        shape
     )
ORDER BY id;
----
id	name
1	red_square
2	inner_point
3	edge_point

# DOCS_TEST: st_contains_field_query
# DOCS_TEST_BODY
query
SELECT id, name
FROM geo_demo_idx
WHERE ST_Contains(shape, '{"type":"Point","coordinates":[5,5]}')
ORDER BY id;
----
id	name
1	red_square
2	inner_point

# DOCS_TEST: st_distance_centroid_ring
# DOCS_TEST_BODY
query
SELECT id, name
FROM cities_idx
WHERE ST_Distance_Centroid(loc, 'POINT(37.617499 55.752023)'::GEOMETRY('OGC:CRS84')) < 3000
ORDER BY id;
----
id	name
1	kremlin
2	red_square
3	gorky_park

# DOCS_TEST: st_distance_between_ring
# DOCS_TEST_BODY
query
SELECT id, name
FROM cities_idx
WHERE ST_Distance_Between(loc, 'POINT(37.617499 55.752023)'::GEOMETRY('OGC:CRS84'), 300, 3000)
ORDER BY id;
----
id	name
3	gorky_park

# DOCS_TEST: ts_lexize
# DOCS_TEST_BODY
query
SELECT ts_lexize('en', 'Quick BROWN') AS ts_lexize;
----
ts_lexize
{quick,brown}

# DOCS_TEST: tfidf_norms
# DOCS_TEST_BODY
query
SELECT id, TFIDF(scored_idx.tableoid, true) AS score
FROM scored_idx
WHERE body @@ ts_phrase('fox')
ORDER BY score DESC, id;
----
id	score
2	0.64791536
1	0.45814538
3	0.30543026

# DOCS_TEST: dfi_saturated
# DOCS_TEST_BODY
query
SELECT id, dfi(scored_idx.tableoid, 'saturated') AS score
FROM scored_idx
WHERE body @@ ts_phrase('fox')
ORDER BY score DESC, id;
----
id	score
2	1.321928
1	0.32192808
3	0

# DOCS_TEST: dfi_chi_squared
# DOCS_TEST_BODY
query
SELECT id, dfi(scored_idx.tableoid, 'chi_squared') AS score
FROM scored_idx
WHERE body @@ ts_phrase('fox')
ORDER BY score DESC, id;
----
id	score
2	1.8875252
1	0.070389315
3	0

# DOCS_TEST: bm25_boost
# DOCS_TEST_BODY
query
SELECT id, BM25(scored_idx.tableoid) AS score
FROM scored_idx
WHERE body @@ (ts_phrase('fox') ^ 3.0)
ORDER BY score DESC, id;
----
id	score
2	2.5223455
1	1.8521354
3	1.3192322
