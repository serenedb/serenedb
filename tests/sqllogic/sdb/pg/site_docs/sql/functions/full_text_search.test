# DOCS_TEST: ts_highlight
# DOCS_TEST_BODY
query
SELECT ts_highlight('the quick brown fox', [4, 9]) AS snippet;
----
snippet
the <b>quick</b> brown fox

# DOCS_TEST: ts_highlight_options
# DOCS_TEST_BODY
query
SELECT ts_highlight('the quick brown fox', [4, 9], 'StartSel=<mark>, StopSel=</mark>') AS snippet;
----
snippet
the <mark>quick</mark> brown fox

