# DOCS_TEST: a---b-distance
# DOCS_TEST_BODY
query
SELECT id, emb <-> [0, 0, 0]::FLOAT[3] AS distance
FROM vecs_l2
ORDER BY distance, id
LIMIT 2;
----
id	distance
1	1
3	1

# DOCS_TEST: a---b-range
# DOCS_TEST_BODY
query
SELECT id, emb <-> [0, 0, 0]::FLOAT[3] AS distance
FROM vecs_l2
WHERE emb <-> [0, 0, 0]::FLOAT[3] < 2
ORDER BY distance, id;
----
id	distance
1	1
3	1

