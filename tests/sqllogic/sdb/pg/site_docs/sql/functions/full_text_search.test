# DOCS_TEST: ts_highlight
# DOCS_TEST_BODY
query
SELECT ts_highlight('the quick brown fox', [4, 9]) AS snippet;
----
snippet
the <b>quick</b> brown fox

# DOCS_TEST: ts_highlight_options
# DOCS_TEST_BODY
query
SELECT ts_highlight('the quick brown fox', [4, 9], 'StartSel=<mark>, StopSel=</mark>') AS snippet;
----
snippet
the <mark>quick</mark> brown fox

# DOCS_TEST: ts_offsets
# DOCS_TEST_BODY
query
SELECT id, ts_offsets(docs_idx.body) AS offsets FROM docs_idx WHERE body @@ ts_phrase('fox') ORDER BY id;
----
id	offsets
1	{12,15}
2	{10,13}

# DOCS_TEST: ts_highlight_pipeline
# DOCS_TEST_BODY
query
SELECT id, ts_highlight(body, ts_offsets(body)) AS snippet
FROM passages_idx
WHERE body @@ ts_phrase('quick')
ORDER BY id;
----
id	snippet
1	the <b>quick</b> brown fox jumps over the lazy dog
2	a <b>quick</b> red fox runs fast
3	The <b>quick</b> brown fox is in this sentence

# DOCS_TEST: ts_highlight_virtual_column
# DOCS_TEST_BODY
query
SELECT id, ts_highlight(body, 'StartSel=<mark>, StopSel=</mark>') AS snippet
FROM passages_idx
WHERE body @@ ts_phrase('fox')
ORDER BY id;
----
id	snippet
1	the quick brown <mark>fox</mark> jumps over the lazy dog
2	a quick red <mark>fox</mark> runs fast
3	The quick brown <mark>fox</mark> is in this sentence

# DOCS_TEST: ts_highlight_highlightall
# DOCS_TEST_BODY
query
SELECT ts_highlight(
    'First sentence here. The quick brown fox is in this sentence. Third one.',
    [25, 30],
    'HighlightAll=true'
) AS snippet;
----
snippet
First sentence here. The <b>quick</b> brown fox is in this sentence. Third one.

# DOCS_TEST: ts_highlight_fragments
# DOCS_TEST_BODY
query
SELECT ts_highlight(
    'A quick fox runs. Slow turtle naps. Another quick fox.',
    [2, 7, 8, 11, 44, 49, 50, 53],
    'MaxFragments=2'
) AS snippet;
----
snippet
A <b>quick fox</b> runs ... Another <b>quick fox</b>

