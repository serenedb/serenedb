# DOCS_TEST: date_part
# DOCS_TEST_BODY
query
SELECT date_part('year', INTERVAL '14 months') AS years;
----
years
1

# DOCS_TEST: datepart
# DOCS_TEST_BODY
query
SELECT datepart('year', INTERVAL '14 months') AS years;
----
years
1

# DOCS_TEST: extract
# DOCS_TEST_BODY
query
SELECT extract('month' FROM INTERVAL '14 months') AS months;
----
months
2

# DOCS_TEST: epoch
# DOCS_TEST_BODY
query
SELECT epoch(INTERVAL 5 HOUR) AS seconds;
----
seconds
18000

