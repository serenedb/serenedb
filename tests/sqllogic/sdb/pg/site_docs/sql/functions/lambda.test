control substitution on

# DOCS_TEST: example_001

query
SELECT list_transform(
        list_filter([0, 1, 2, 3, 4, 5], lambda x: x % 2 = 0),
        lambda y: y * y
    );
----
list_transform
{0,4,16}

# DOCS_TEST: example_002

query
SELECT list_transform(
        [1, 2, 3],
        lambda x :
            list_reduce([4, 5, 6], lambda a, b: a + b) + x
    );
----
list_transform
{16,17,18}

# DOCS_TEST: example_004

query
SELECT list_filter([1, 3, 1, 5], lambda x, i: x > i);
----
list_filter
{3,5}

# DOCS_TEST: example_005

query
SELECT list_transform([1, 2, NULL, 3], lambda x: x + 1);
----
list_transform
{2,3,NULL,4}

# DOCS_TEST: example_006

query
SELECT list_transform(['Duck', 'Goose', 'Sparrow'], lambda s: concat(s, 'DB'));
----
list_transform
{DuckDB,GooseDB,SparrowDB}

# DOCS_TEST: example_007

query
SELECT list_transform([5, NULL, 6], lambda x: coalesce(x, 0) + 1);
----
list_transform
{6,1,7}

# DOCS_TEST: example_008

query
SELECT list_filter([5, -6, NULL, 7], lambda x: x > 0);
----
list_filter
{5,7}

# DOCS_TEST: example_009

query
SELECT list_filter(
        list_filter([2, 4, 3, 1, 20, 10, 3, 30], lambda x: x % 2 = 0),
        lambda y: y % 5 = 0
    );
----
list_filter
{20,10,30}

# DOCS_TEST: example_010

query
SELECT list_filter([1, 2, 3, 4], lambda x: x > range) FROM range(4);
----
list_filter
{1,2,3,4}
{2,3,4}
{3,4}
{4}

# DOCS_TEST: example_011

query
SELECT list_reduce([1, 2, 3, 4], lambda acc, x: acc + x);
----
list_reduce
10

# DOCS_TEST: example_012

query
SELECT list_reduce(
        list_filter([1, 2, 3, 4], lambda x: x > 2),
        lambda acc, x: acc + x
    );
----
list_reduce
7

# DOCS_TEST: example_013

query
SELECT list_reduce(['DuckDB', 'is', 'awesome'], lambda acc, x: concat(acc, ' ', x));
----
list_reduce
DuckDB is awesome

# DOCS_TEST: example_014

query
SELECT list_reduce(
        ['a', 'b', 'c', 'd'],
        lambda x, y, i: x || ' - ' || CAST(i AS VARCHAR) || ' - ' || y
    );
----
list_reduce
a - 2 - b - 3 - c - 4 - d

# DOCS_TEST: example_015

query
SELECT list_reduce(
        ['a', 'b', 'c', 'd'],
        lambda x, y, i: x || ' - ' || CAST(i AS VARCHAR) || ' - ' || y, 'INITIAL'
    );
----
list_reduce
INITIAL - 1 - a - 2 - b - 3 - c - 4 - d

