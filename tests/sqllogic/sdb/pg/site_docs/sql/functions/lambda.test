query
SELECT list_reduce([1, 2, 3, 4], lambda acc, x: acc + x);
----
list_reduce
10

# DOCS_TEST: example_012

# DOCS_TEST_BODY

query
SELECT list_reduce(
        list_filter([1, 2, 3, 4], lambda x: x > 2),
        lambda acc, x: acc + x
    );
----
list_reduce
7

# DOCS_TEST: example_013

# DOCS_TEST_BODY

query
SELECT list_reduce(['SereneDB', 'is', 'awesome'], lambda acc, x: concat(acc, ' ', x));
----
list_reduce
SereneDB is awesome

# DOCS_TEST: example_014

# DOCS_TEST_BODY

query
SELECT list_reduce(
        ['a', 'b', 'c', 'd'],
        lambda x, y, i: x || ' - ' || CAST(i AS VARCHAR) || ' - ' || y
    );
----
list_reduce
a - 2 - b - 3 - c - 4 - d

# DOCS_TEST: example_015

# DOCS_TEST_BODY

query
SELECT list_reduce(
        ['a', 'b', 'c', 'd'],
        lambda x, y, i: x || ' - ' || CAST(i AS VARCHAR) || ' - ' || y, 'INITIAL'
    );
----
list_reduce
INITIAL - 1 - a - 2 - b - 3 - c - 4 - d

