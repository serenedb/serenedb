# DOCS_TEST: example_015

query
SELECT ([1, 2, 3, 4, 5])[2:4:2];
----
?column?
{2,4}

# DOCS_TEST: example_016

query
SELECT([1, 2, 3, 4, 5])[4:2:-2];
----
?column?
{4,2}

# DOCS_TEST: example_017

query
SELECT ([1, 2, 3, 4, 5])[:];
----
?column?
{1,2,3,4,5}

# DOCS_TEST: example_018

query
SELECT ([1, 2, 3, 4, 5])[:-:2];
----
?column?
{1,3,5}

# DOCS_TEST: example_019

query
SELECT ([1, 2, 3, 4, 5])[:-:-2];
----
?column?
{5,3,1}

