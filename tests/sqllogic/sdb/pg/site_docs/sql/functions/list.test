# DOCS_TEST: example_001

# DOCS_TEST_BODY

query
SELECT [lower(x) FOR x IN strings] AS strings
FROM (VALUES (['Hello', '', 'World'])) t(strings);
----
strings
{hello,"",world}

# DOCS_TEST: example_002

# DOCS_TEST_BODY

query
SELECT [upper(x) FOR x IN strings IF len(x) > 0] AS strings
FROM (VALUES (['Hello', '', 'World'])) t(strings);
----
strings
{HELLO,WORLD}

# DOCS_TEST: example_003

# DOCS_TEST_BODY

query
SELECT [4, 5, 6] AS l, [x FOR x, i IN l IF i != 2] AS filtered;
----
l	filtered
{4,5,6}	{4,6}

# DOCS_TEST: example_004

# DOCS_TEST_BODY

statement error
l.list_apply(lambda x, i: {'filter': g(x, i), 'result': f(x, i)})
    .list_filter(lambda x: x.filter)
    .list_apply(lambda x: x.result)
----
db error: ERROR: Referenced column "l" was not found because the FROM clause is missing


