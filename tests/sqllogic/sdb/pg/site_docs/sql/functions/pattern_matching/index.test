# DOCS_TEST: example_011

statement ok
COPY (SELECT 'SereneDB docs fixture' AS content) TO '/tmp/site_docs_pattern_matching_example_011_serened';

statement ok
COPY (SELECT 1 AS id, 'alpha' AS name) TO '/tmp/site_docs_pattern_matching_example_011_test.csv' (FORMAT CSV, HEADER true);

statement ok
COPY (SELECT 1 AS id, 'alpha' AS name) TO '/tmp/site_docs_pattern_matching_example_011_test.json' (FORMAT JSON);

statement ok
COPY (SELECT 1 AS id, 'alpha' AS name) TO '/tmp/site_docs_pattern_matching_example_011_test.parquet' (FORMAT PARQUET);

statement ok
COPY (SELECT 2 AS id, 'beta' AS name) TO '/tmp/site_docs_pattern_matching_example_011_test2.csv' (FORMAT CSV, HEADER true);

statement ok
COPY (SELECT 2 AS id, 'beta' AS name) TO '/tmp/site_docs_pattern_matching_example_011_test2.parquet' (FORMAT PARQUET);

statement ok
COPY (SELECT 1 AS id, 'todo' AS task) TO '/tmp/site_docs_pattern_matching_example_011_todos.json' (FORMAT JSON);

# DOCS_TEST_RAW
#| SELECT * FROM glob('*');

# DOCS_TEST_BODY

query
SELECT replace(
    file,
    '/tmp/site_docs_pattern_matching_example_011_',
    ''
) AS file
FROM glob('/tmp/site_docs_pattern_matching_example_011_*')
ORDER BY file;
----
file
serened
test.csv
test.json
test.parquet
test2.csv
test2.parquet
todos.json

