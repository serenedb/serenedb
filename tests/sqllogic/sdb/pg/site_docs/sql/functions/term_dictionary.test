# DOCS_TEST: setup

# DOCS_TEST_BODY

statement ok
CREATE TEXT SEARCH DICTIONARY kw(template = 'keyword');

statement ok
CREATE TEXT SEARCH DICTIONARY tx (
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'lower',
    stemming = false,
    accent = false,
    frequency = true,
    position = true
);

statement ok
CREATE TABLE products(id INTEGER PRIMARY KEY, cat VARCHAR NOT NULL,
                      promo VARCHAR, body VARCHAR);

statement ok
CREATE INDEX products_idx ON products USING inverted (cat kw, promo kw, body tx)
    WITH (refresh_interval = 0, compaction_interval = 0);

statement ok
INSERT INTO products VALUES
    (1, 'phone',  'sale',   'black phone with a great camera'),
    (2, 'phone',  NULL,     'budget phone'),
    (3, 'laptop', 'sale',   'gaming laptop with a great screen'),
    (4, 'tablet', NULL,     'compact tablet');

statement ok
VACUUM (REFRESH_TABLE) products;

# DOCS_TEST: aligned_lists
# DOCS_TEST_BODY
query
SELECT unnest(ts_dict_agg(body))   AS term,
       unnest(ts_dict_count(body)) AS docs,
       unnest(ts_dict_freq(body))  AS freq
FROM products_idx ORDER BY term;
----
term	docs	freq
a	2	2
black	1	1
budget	1	1
camera	1	1
compact	1	1
gaming	1	1
great	2	2
laptop	1	1
phone	2	2
screen	1	1
tablet	1	1
with	2	2

# DOCS_TEST: min_max
# DOCS_TEST_BODY
query
SELECT ts_dict_min(body) AS lo, ts_dict_max(body) AS hi FROM products_idx;
----
lo	hi
a	with

# DOCS_TEST: where_predicates
# DOCS_TEST_BODY
query
SELECT unnest(ts_dict_agg(body)) AS term
FROM products_idx
WHERE body LIKE 'g%'
ORDER BY term;
----
term
gaming
great

query
SELECT unnest(ts_dict_agg(body)) AS term
FROM products_idx
WHERE body LIKE 'bud%' OR body LIKE 'gam%'
ORDER BY term;
----
term
budget
gaming

query
SELECT unnest(ts_dict_agg(body)) AS term
FROM products_idx
WHERE body @@ ts_starts_with('g')
ORDER BY term;
----
term
a
black
camera
gaming
great
laptop
phone
screen
with

query
SELECT t AS term
FROM (SELECT unnest(ts_dict_agg(body)) AS t FROM products_idx) sub
WHERE t LIKE 'g%'
ORDER BY term;
----
term
gaming
great

# DOCS_TEST: facets
# DOCS_TEST_BODY
query
SELECT cat, count(*) AS n FROM products_idx
GROUP BY cat ORDER BY n DESC, cat LIMIT 3;
----
cat	n
phone	2
laptop	1
tablet	1

# DOCS_TEST: facets_null
# DOCS_TEST_BODY
query
SELECT promo, count(*) AS n FROM products_idx
GROUP BY promo ORDER BY promo NULLS FIRST;
----
promo	n
NULL	2
sale	2

# DOCS_TEST: deletes
# DOCS_TEST_BODY
statement ok
DELETE FROM products WHERE id = 2;

statement ok
VACUUM (REFRESH_TABLE) products;

query
SELECT cat, count(*) AS n FROM products_idx GROUP BY cat ORDER BY cat;
----
cat	n
laptop	1
phone	1
tablet	1
