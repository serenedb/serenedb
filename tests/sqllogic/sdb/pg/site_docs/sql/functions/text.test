# DOCS_TEST: example_003

# DOCS_TEST_BODY

query
SELECT format('I''d rather be {1} than {0}.', 'right', 'happy');
----
format
I'd rather be {1} than {0}.

# DOCS_TEST: example_004

# DOCS_TEST_BODY

query
SELECT format('{} + {} = {}', 3, 5, 3 + 5);
----
format
{} + {} = {}

# DOCS_TEST: example_005

# DOCS_TEST_BODY

query
SELECT format('{} != {}', true, false);
----
format
{} != {}

