# DOCS_TEST: example_001

# DOCS_TEST_BODY

query
SELECT '2022-10-08 13:13:34-07'::TIMESTAMPTZ;
----
timestamp with time zone
2022-10-08 20:13:34+00

# DOCS_TEST: example_002

# DOCS_TEST_BODY

query error
SELECT '2022-10-08 13:13:34 Europe/Amsterdam'::TIMESTAMPTZ::VARCHAR;
----
db error: ERROR: timestamp field value "2022-10-08 13:13:34 Europe/Amsterdam" has a timestamp that is not UTC.
Use the TIMESTAMPTZ type with the ICU extension loaded to handle non-UTC timestamps.

# DOCS_TEST: example_003

# DOCS_TEST_BODY

query error
SELECT TIMESTAMP '2001-02-16 20:38:40' AT TIME ZONE 'America/Denver' AS ts;
----
db error: ERROR: An error occurred while trying to automatically install the required extension 'icu:
Extension "/var/lib/serenedb/.duckdb/extensions/v0.0.1/linux_arm64/icu.duckdb_extension" not found.
Extension "icu" is an existing extension.

Install it first using "INSTALL icu".

