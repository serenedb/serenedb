# DOCS_TEST: setup

# DOCS_TEST_BODY

statement ok
CREATE TABLE t1 (x INTEGER);

statement ok
INSERT INTO t1 VALUES (1), (2);

statement ok
CREATE TABLE t2 (x INTEGER);

statement ok
INSERT INTO t2 VALUES (3);

# DOCS_TEST: alias
# DOCS_TEST_BODY
query
SELECT alias(column1) FROM (SELECT 1 AS column1) t;
----
alias
column1

