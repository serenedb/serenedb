# DOCS_TEST: current_catalog

# The catalog name depends on the active database, so the body just confirms the
# call runs while the RAW block shows a representative value.

# DOCS_TEST_RAW
#| SELECT current_catalog();
#| ----
#| current_catalog
#| postgres

# DOCS_TEST_BODY
query
SELECT current_catalog() AS current_catalog;
----
current_catalog
<slt:ignore>

