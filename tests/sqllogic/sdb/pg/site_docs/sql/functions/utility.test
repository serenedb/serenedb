statement ok
CREATE SEQUENCE seq_nextval;

statement ok
SELECT nextval('seq_nextval');

# DOCS_TEST_BODY
query
SELECT nextval('seq_nextval') AS nextval;
----
nextval
2

# DOCS_TEST: read_blob

statement ok
COPY (SELECT 'hello') TO '/tmp/sdb_docs_utility_read_blob.bin' (FORMAT csv, HEADER false);

# DOCS_TEST_RAW
#| SELECT content FROM read_blob('hello.bin');
#| ----
#| content
#| \x68656c6c6f0a

# DOCS_TEST_BODY
query
SELECT content FROM read_blob('/tmp/sdb_docs_utility_read_blob.bin');
----
content
\\x68656c6c6f0a

# DOCS_TEST: read_text

statement ok
COPY (SELECT 'hello') TO '/tmp/sdb_docs_utility_read_text.txt' (FORMAT csv, HEADER false);

