# DOCS_TEST: getenv

# getenv is only available in the command line client (serened shell), not over
# the server protocol, so this example is illustrative.

# DOCS_TEST_RAW
#| SELECT getenv('HOME');
#| ----
#| getenv
#| /path/to/user/home

# DOCS_TEST_BODY
statement ok
CREATE TEMP TABLE IF NOT EXISTS __docs_utility_getenv (i INTEGER);

# DOCS_TEST: icu_sort_key
# DOCS_TEST_BODY
query
SELECT icu_sort_key('a', 'DE') < icu_sort_key('b', 'DE') AS icu_sort_key;
----
icu_sort_key
t


# DOCS_TEST: md5_number

# The result is a UHUGEINT, which the pg-wire extended protocol cannot transmit;
# cast it to VARCHAR for the runnable body while the RAW block shows the natural
# call and its decimal value.

# DOCS_TEST_RAW
#| SELECT md5_number('abc');
#| ----
#| md5_number
#| 152195979970564155685860391459828531600

# DOCS_TEST_BODY
query
SELECT md5_number('abc')::VARCHAR AS md5_number;
----
md5_number
152195979970564155685860391459828531600

