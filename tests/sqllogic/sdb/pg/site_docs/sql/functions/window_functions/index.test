# DOCS_TEST: example_011

# DOCS_TEST_RAW
#| SELECT points,
#|     sum(points) OVER (
#|         ROWS BETWEEN 1 PRECEDING
#|                  AND 1 FOLLOWING) AS "Moving Sum"
#| FROM results;

# DOCS_TEST_BODY

query ??
SELECT points,
    sum(points) OVER (
        ORDER BY datetime
        ROWS BETWEEN 1 PRECEDING
                 AND 1 FOLLOWING) AS "Moving Sum"
FROM results
ORDER BY datetime;
