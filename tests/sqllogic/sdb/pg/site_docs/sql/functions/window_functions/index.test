# DOCS_SETUP: local_generation_history_fixture

statement ok
DROP TABLE IF EXISTS "Generation History";

statement ok
CREATE TABLE "Generation History" (
    "Plant" VARCHAR,
    "Date" DATE,
    "MWh" DOUBLE
);

statement ok
INSERT INTO "Generation History" VALUES
    ('Plant A', DATE '2025-01-01', 10.0),
    ('Plant A', DATE '2025-01-02', 12.0),
    ('Plant B', DATE '2025-01-01', 8.0);

statement ok
DROP TABLE IF EXISTS results;

statement ok
CREATE TABLE results (
    points INTEGER,
    event VARCHAR,
    date DATE,
    athlete VARCHAR,
    time DOUBLE,
    datetime TIMESTAMP
);

statement ok
INSERT INTO results VALUES
    (10, '100m', DATE '2025-01-01', 'Ada', 12.3, TIMESTAMP '2025-01-01 10:00:00'),
    (12, '100m', DATE '2025-01-02', 'Bob', 12.1, TIMESTAMP '2025-01-02 10:00:00'),
    (9, '200m', DATE '2025-01-01', 'Cy', 24.3, TIMESTAMP '2025-01-01 11:00:00');

# DOCS_TEST: example_010

query ???
SELECT
    "Plant",
    "Date",
    row_number() OVER (PARTITION BY "Plant" ORDER BY "Date") AS "Row"
FROM "Generation History"
ORDER BY 1, 2;
----
plant	date	Row
Plant A	2025-01-01	1
Plant A	2025-01-02	2
Plant B	2025-01-01	1

# DOCS_TEST: example_011

query ??
SELECT points,
    sum(points) OVER (
        ROWS BETWEEN 1 PRECEDING
                 AND 1 FOLLOWING) AS we
FROM results;
----
points	we
10	22
12	31
9	21

# DOCS_TEST: example_012

query ???
SELECT "Plant", "Date",
    avg("MWh") OVER (
        PARTITION BY "Plant"
        ORDER BY "Date" ASC
        RANGE BETWEEN INTERVAL 3 DAYS PRECEDING
                  AND INTERVAL 3 DAYS FOLLOWING)
        AS "MWh 7-day Moving Average"
FROM "Generation History"
ORDER BY 1, 2;
----
plant	date	MWh 7-day Moving Average
Plant A	2025-01-01	11
Plant A	2025-01-02	11
Plant B	2025-01-01	8

# DOCS_TEST: example_013

query ???
SELECT "Date", "Plant",
    avg("MWh") OVER (
        ORDER BY "Date" ASC
        GROUPS BETWEEN 3 PRECEDING
                   AND 3 FOLLOWING)
        AS "MWh 7-day Moving Average"
FROM "Generation History"
ORDER BY 1, 2;
----
date	plant	MWh 7-day Moving Average
2025-01-01	Plant A	10
2025-01-01	Plant B	10
2025-01-02	Plant A	10

# DOCS_TEST: example_014

query ????
SELECT
    event,
    date,
    athlete,
    avg(time) OVER w AS recent,
FROM results
WINDOW w AS (
    PARTITION BY event
    ORDER BY date
    RANGE BETWEEN INTERVAL 10 DAYS PRECEDING AND INTERVAL 10 DAYS FOLLOWING
        EXCLUDE CURRENT ROW
)
ORDER BY event, date, athlete;
----
event	date	athlete	recent
100m	2025-01-01	Ada	12.1
100m	2025-01-02	Bob	12.3
200m	2025-01-01	Cy	NULL

# DOCS_TEST: example_015

query ?????
SELECT "Plant", "Date",
    min("MWh") OVER seven AS "MWh 7-day Moving Minimum",
    avg("MWh") OVER seven AS "MWh 7-day Moving Average",
    max("MWh") OVER seven AS "MWh 7-day Moving Maximum"
FROM "Generation History"
WINDOW seven AS (
    PARTITION BY "Plant"
    ORDER BY "Date" ASC
    RANGE BETWEEN INTERVAL 3 DAYS PRECEDING
              AND INTERVAL 3 DAYS FOLLOWING)
ORDER BY 1, 2;
----
plant	date	MWh 7-day Moving Minimum	MWh 7-day Moving Average	MWh 7-day Moving Maximum
Plant A	2025-01-01	10	11	12
Plant A	2025-01-02	10	11	12
Plant B	2025-01-01	8	8	8

# DOCS_TEST: example_016

query ????????
SELECT "Plant", "Date",
    min("MWh") OVER seven AS "MWh 7-day Moving Minimum",
    avg("MWh") OVER seven AS "MWh 7-day Moving Average",
    max("MWh") OVER seven AS "MWh 7-day Moving Maximum",
    min("MWh") OVER three AS "MWh 3-day Moving Minimum",
    avg("MWh") OVER three AS "MWh 3-day Moving Average",
    max("MWh") OVER three AS "MWh 3-day Moving Maximum"
FROM "Generation History"
WINDOW
    seven AS (
        PARTITION BY "Plant"
        ORDER BY "Date" ASC
        RANGE BETWEEN INTERVAL 3 DAYS PRECEDING
                  AND INTERVAL 3 DAYS FOLLOWING),
    three AS (
        PARTITION BY "Plant"
        ORDER BY "Date" ASC
        RANGE BETWEEN INTERVAL 1 DAYS PRECEDING
        AND INTERVAL 1 DAYS FOLLOWING)
ORDER BY 1, 2;
----
plant	date	MWh 7-day Moving Minimum	MWh 7-day Moving Average	MWh 7-day Moving Maximum	MWh 3-day Moving Minimum	MWh 3-day Moving Average	MWh 3-day Moving Maximum
Plant A	2025-01-01	10	11	12	10	11	12
Plant A	2025-01-02	10	11	12	10	11	12
Plant B	2025-01-01	8	8	8	8	8	8

# DOCS_TEST: example_017

query ?????
SELECT "Plant", "Date",
    min("MWh") OVER seven AS "MWh 7-day Moving Minimum",
    quantile_cont("MWh", [0.25, 0.5, 0.75]) OVER seven
        AS "MWh 7-day Moving IQR",
    max("MWh") OVER seven AS "MWh 7-day Moving Maximum",
FROM "Generation History"
WINDOW seven AS (
    PARTITION BY "Plant"
    ORDER BY "Date" ASC
    RANGE BETWEEN INTERVAL 3 DAYS PRECEDING
              AND INTERVAL 3 DAYS FOLLOWING)
ORDER BY 1, 2;
----
plant	date	MWh 7-day Moving Minimum	MWh 7-day Moving IQR	MWh 7-day Moving Maximum
Plant A	2025-01-01	10	{10.5,11,11.5}	12
Plant A	2025-01-02	10	{10.5,11,11.5}	12
Plant B	2025-01-01	8	{8,8,8}	8
