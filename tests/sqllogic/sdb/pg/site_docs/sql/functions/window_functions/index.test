# DOCS_TEST: example_014

# DOCS_TEST_RAW
#| SELECT event, date, athlete,
#|     avg(time) OVER w AS recent
#| FROM results
#| WINDOW w AS (
#|     PARTITION BY event
#|     ORDER BY date
#|     RANGE BETWEEN INTERVAL 10 DAYS PRECEDING AND INTERVAL 10 DAYS FOLLOWING
#|         EXCLUDE CURRENT ROW
#| );

# DOCS_TEST_BODY

query ????
SELECT event, date, athlete,
    avg(time) OVER w AS recent
FROM results
WINDOW w AS (
    PARTITION BY event
    ORDER BY date
    RANGE BETWEEN INTERVAL 10 DAYS PRECEDING AND INTERVAL 10 DAYS FOLLOWING
        EXCLUDE CURRENT ROW
)
ORDER BY event, date, athlete;
----
event	date	athlete	recent
100m	2025-01-01	Ada	12.1
100m	2025-01-02	Bob	12.3
200m	2025-01-01	Cy	NULL

