control substitution on

# DOCS_TEST: example_001

statement ok
CREATE TABLE sales AS SELECT * FROM (VALUES
    (100, 'north', TIMESTAMP '2025-01-01 09:00:00', 'alpha', 42),
    (250, 'north', TIMESTAMP '2025-01-02 09:00:00', 'beta', 84),
    (180, 'south', TIMESTAMP '2025-01-03 09:00:00', 'alpha', 42),
    (220, 'south', TIMESTAMP '2025-01-04 09:00:00', 'gamma', 17)
) AS t(amount, region, time, name, value);

statement ok
CREATE TABLE results AS SELECT * FROM (VALUES
    ('100m', DATE '2025-01-01', 'Ada', 12.3e0, 10, TIMESTAMP '2025-01-01 10:00:00'),
    ('100m', DATE '2025-01-02', 'Bob', 12.1e0, 12, TIMESTAMP '2025-01-02 10:00:00'),
    ('200m', DATE '2025-01-01', 'Cy', 24.3e0, 9, TIMESTAMP '2025-01-01 11:00:00')
) AS t(event, date, athlete, time, points, datetime);

# DOCS_TEST_RAW
#| SELECT row_number() OVER ()
#| FROM sales;

# DOCS_TEST_BODY

query ?
SELECT row_number() OVER () AS row_number
FROM sales
ORDER BY 1;
----
row_number
1
2
3
4

# DOCS_TEST: example_002

# DOCS_TEST_RAW
#| SELECT row_number() OVER (ORDER BY time)
#| FROM sales;

# DOCS_TEST_BODY

query ?
SELECT row_number() OVER (ORDER BY time) AS row_number
FROM sales
ORDER BY 1;
----
row_number
1
2
3
4

# DOCS_TEST: example_003

# DOCS_TEST_RAW
#| SELECT row_number() OVER (PARTITION BY region ORDER BY time)
#| FROM sales;

# DOCS_TEST_BODY

query ?
SELECT row_number() OVER (PARTITION BY region ORDER BY time) AS row_number
FROM sales
ORDER BY 1;
----
row_number
1
1
2
2

# DOCS_TEST: example_004

# DOCS_TEST_RAW
#| SELECT amount - lag(amount) OVER (ORDER BY time)
#| FROM sales;

# DOCS_TEST_BODY

query ?
SELECT amount - lag(amount) OVER (ORDER BY time) AS difference
FROM sales
ORDER BY time;
----
difference
NULL
150
-70
40

# DOCS_TEST: example_005

# DOCS_TEST_RAW
#| SELECT amount / sum(amount) OVER (PARTITION BY region) AS percentage
#| FROM sales;

# DOCS_TEST_BODY

query ?
WITH sales(amount, region) AS (
    VALUES (100, 'north'), (250, 'north'), (180, 'south'), (220, 'south')
)
SELECT round(amount::DOUBLE / sum(amount) OVER (PARTITION BY region), 4) AS percentage
FROM sales
ORDER BY region, amount;
----
percentage
0.2857
0.7143
0.45
0.55

# DOCS_TEST: example_006

# DOCS_TEST_RAW
#| -- Count the number of distinct names at a given point in time
#| SELECT count(DISTINCT name) OVER (ORDER BY time) FROM sales;

# DOCS_TEST_BODY

query ?
SELECT count(DISTINCT name) OVER (ORDER BY time) AS count
FROM sales
ORDER BY time;
----
count
1
2
2
3

# DOCS_TEST: example_007

# DOCS_TEST_RAW
#| -- Compute the modal value up to each time, breaking ties in favor of the most recent value
#| SELECT mode(value ORDER BY time DESC) OVER (ORDER BY time) FROM sales;

# DOCS_TEST_BODY

query ?
SELECT mode(value ORDER BY time DESC) OVER (ORDER BY time) AS mode
FROM sales
ORDER BY time;
----
mode
42
84
42
42

# DOCS_TEST: example_008

# DOCS_TEST_RAW
#| SELECT event, athlete,
#|     first_value(athlete ORDER BY time) OVER w AS fastest
#| FROM results
#| WINDOW w AS (PARTITION BY event ORDER BY date)
#| ORDER BY event, athlete;

# DOCS_TEST_BODY

query ???
SELECT event, athlete,
    first_value(athlete ORDER BY time) OVER w AS fastest
FROM results
WINDOW w AS (PARTITION BY event ORDER BY date)
ORDER BY event, athlete;
----
event	athlete	fastest
100m	Ada	Ada
100m	Bob	Bob
200m	Cy	Cy

# DOCS_TEST: example_009

# DOCS_TEST_RAW
#| CREATE TABLE "Generation History" AS
#|     FROM 'power-plant-generation-history.csv';

# DOCS_TEST_BODY

statement ok
CREATE TABLE "Generation History" AS SELECT * FROM (VALUES
    ('Boston', DATE '2019-01-02', 564337),
    ('Boston', DATE '2019-01-03', 507405),
    ('Boston', DATE '2019-01-04', 528523),
    ('Boston', DATE '2019-01-05', 469538),
    ('Boston', DATE '2019-01-06', 474163),
    ('Boston', DATE '2019-01-07', 507213),
    ('Boston', DATE '2019-01-08', 613040),
    ('Boston', DATE '2019-01-09', 582588),
    ('Boston', DATE '2019-01-10', 499506),
    ('Boston', DATE '2019-01-11', 482014),
    ('Boston', DATE '2019-01-12', 486134),
    ('Boston', DATE '2019-01-13', 531518),
    ('Worcester', DATE '2019-01-02', 118860),
    ('Worcester', DATE '2019-01-03', 101977),
    ('Worcester', DATE '2019-01-04', 106054),
    ('Worcester', DATE '2019-01-05', 92182),
    ('Worcester', DATE '2019-01-06', 94492),
    ('Worcester', DATE '2019-01-07', 99932),
    ('Worcester', DATE '2019-01-08', 118854),
    ('Worcester', DATE '2019-01-09', 113506),
    ('Worcester', DATE '2019-01-10', 96644),
    ('Worcester', DATE '2019-01-11', 93806),
    ('Worcester', DATE '2019-01-12', 98963),
    ('Worcester', DATE '2019-01-13', 107170)
) AS t("Plant", "Date", "MWh");

