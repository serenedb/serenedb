# DOCS_TEST: example_001

statement ok
CREATE TABLE geo_data (id INTEGER PRIMARY KEY, geo JSON);

statement ok
CREATE TEXT SEARCH DICTIONARY geojson_shape (template = 'geojson');

statement ok
CREATE INDEX geo_idx ON geo_data USING inverted (id, geo geojson_shape);

statement ok
INSERT INTO geo_data VALUES
    (1, '{"type":"Point","coordinates":[37.615895,55.703900]}'),
    (2, '{"type":"Point","coordinates":[37.616297,55.704831]}'),
    (3, '{"type":"Point","coordinates":[37.617053,55.704610]}'),
    (4, '{"type":"Point","coordinates":[37.559509,55.715895]}'),
    (5, '{"type":"Point","coordinates":[37.701645,55.832144]}'),
    (6, '{"type":"Polygon","coordinates":[[[37.614323,55.705898],[37.615825,55.705898],[37.615825,55.706520],[37.614323,55.706520],[37.614323,55.705898]]]}');

statement ok
VACUUM (REFRESH_TABLE) geo_data;

# DOCS_TEST_BODY

query
SELECT id FROM geo_idx
WHERE ST_Intersects(geo, '{"type":"Polygon","coordinates":[[[37.610,55.700],[37.620,55.700],[37.620,55.710],[37.610,55.710],[37.610,55.700]]]}')
ORDER BY id;
----
id
1
2
3
6

