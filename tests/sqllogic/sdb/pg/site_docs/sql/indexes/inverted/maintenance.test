# DOCS_TEST: example_001

statement ok
CREATE TEXT SEARCH DICTIONARY logs_en (
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'lower',
    stemming = false,
    accent = false,
    frequency = true
);

statement ok
CREATE TABLE logs (id INTEGER PRIMARY KEY, msg VARCHAR);

statement ok
CREATE INDEX logs_idx ON logs USING inverted (id, msg logs_en);

statement ok
INSERT INTO logs VALUES (1, 'disk full'), (2, 'connection reset');

# DOCS_TEST_BODY

statement ok
VACUUM (REFRESH_TABLE) logs;

query
SELECT id FROM logs_idx WHERE msg @@ 'disk' ORDER BY id;
----
id
1

