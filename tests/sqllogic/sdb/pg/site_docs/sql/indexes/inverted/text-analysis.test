# DOCS_TEST: example_007

# DOCS_TEST_BODY

statement ok
CREATE TEXT SEARCH DICTIONARY ta_pipeline (
    template = 'pipeline',
    step1_template = 'delimiter',
    step1_delimiter = ',',
    step2_template = 'norm',
    step2_locale = 'en_US.UTF-8',
    step2_case = 'lower'
);

query
SELECT ts_lexize('ta_pipeline', 'RED,Green,BLUE');
----
ts_lexize
{red,green,blue}
