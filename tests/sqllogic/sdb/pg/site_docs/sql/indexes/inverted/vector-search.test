statement ok
CREATE TABLE vectors (id INTEGER, emb FLOAT[3]);

statement ok
CREATE INDEX l2_index ON vectors USING inverted (id, emb hnsw (metric = 'l2'));

# DOCS_TEST: example_004

statement ok
INSERT INTO vectors VALUES
    (1, [100, 0, 0]::FLOAT[3]),
    (2, [50, 50, 50]::FLOAT[3]),
    (3, [50, 25, 50]::FLOAT[3]),
    (4, [50, 50, 100]::FLOAT[3]);

statement ok
VACUUM (REFRESH_TABLE) vectors;

# DOCS_TEST_BODY

query
SELECT id FROM l2_index ORDER BY emb <-> [0, 0, 0]::FLOAT[3] LIMIT 2;
