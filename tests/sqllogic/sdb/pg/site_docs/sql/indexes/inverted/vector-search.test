# DOCS_TEST: example_003

statement ok
CREATE TABLE vectors_c (id INTEGER, emb FLOAT[3]);

statement ok
CREATE INDEX cos_index ON vectors_c USING inverted (id, emb hnsw (metric = 'cosine'));

statement ok
INSERT INTO vectors_c VALUES
    (1, [1, 0, 0]::FLOAT[3]),
    (2, [0, 1, 0]::FLOAT[3]),
    (3, [1, 1, 0]::FLOAT[3]);

statement ok
VACUUM (REFRESH_TABLE) vectors_c;

# DOCS_TEST_BODY

query
SELECT id FROM cos_index ORDER BY cosine_distance(emb, [1, 0, 0]::FLOAT[3]) LIMIT 2;
----
id
1
3
