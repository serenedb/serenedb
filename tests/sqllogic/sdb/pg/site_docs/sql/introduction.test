control substitution on

# DOCS_TEST: example_001

# DOCS_TEST_BODY

statement ok
CREATE TABLE weather (
    city    VARCHAR,
    temp_lo INTEGER, -- minimum temperature on a day
    temp_hi INTEGER, -- maximum temperature on a day
    prcp    FLOAT,
    date    DATE
);

# DOCS_TEST: example_002

# DOCS_TEST_BODY

statement ok
CREATE TABLE cities (
    name VARCHAR,
    lat  DOUBLE,
    lon  DOUBLE
);

# DOCS_TEST: example_003

statement ok
CREATE TABLE tablename (id INTEGER);

# DOCS_TEST_BODY

statement ok
DROP TABLE tablename;

# DOCS_TEST: example_004

# DOCS_TEST_BODY

statement ok
INSERT INTO weather
VALUES ('San Francisco', 46, 50, 0.25, '1994-11-27');

# DOCS_TEST: example_005

# DOCS_TEST_BODY

statement ok
INSERT INTO cities
VALUES ('San Francisco', -194.0, 53.0);

# DOCS_TEST: example_006

# DOCS_TEST_BODY

statement ok
INSERT INTO weather (city, temp_lo, temp_hi, prcp, date)
VALUES ('San Francisco', 43, 57, 0.0, '1994-11-29');

# DOCS_TEST: example_007

# DOCS_TEST_BODY

statement ok
INSERT INTO weather (date, city, temp_hi, temp_lo)
VALUES ('1994-11-29', 'Hayward', 54, 37);

# DOCS_TEST: example_008

statement ok
COPY (SELECT * FROM (VALUES
    ('Oakland', 45, 58, 0.1, DATE '1994-11-30')
) AS t("city", "temp_lo", "temp_hi", "prcp", "date")) TO '/tmp/${__DATABASE__}_sql_introduction_example_008_1_weather_csv.csv' (FORMAT CSV, HEADER false, DELIMITER ',');

# DOCS_TEST_RAW
#| COPY weather
#| FROM 'weather.csv';

# DOCS_TEST_BODY

statement ok
COPY weather
FROM '/tmp/${__DATABASE__}_sql_introduction_example_008_1_weather_csv.csv';

# DOCS_TEST: example_009

# DOCS_TEST_BODY

query
SELECT *
FROM weather;
----
city	temp_lo	temp_hi	prcp	date
San Francisco	46	50	0.25	1994-11-27
San Francisco	43	57	0	1994-11-29
Hayward	37	54	NULL	1994-11-29
Oakland	45	58	0.1	1994-11-30

# DOCS_TEST: example_010

# DOCS_TEST_BODY

query
SELECT city, temp_lo, temp_hi, prcp, date
FROM weather;
----
city	temp_lo	temp_hi	prcp	date
San Francisco	46	50	0.25	1994-11-27
San Francisco	43	57	0	1994-11-29
Hayward	37	54	NULL	1994-11-29
Oakland	45	58	0.1	1994-11-30

# DOCS_TEST: example_011

# DOCS_TEST_BODY

query
SELECT city, (temp_hi + temp_lo) / 2 AS temp_avg, date
FROM weather;
----
city	temp_avg	date
San Francisco	48	1994-11-27
San Francisco	50	1994-11-29
Hayward	45	1994-11-29
Oakland	51	1994-11-30

# DOCS_TEST: example_012

# DOCS_TEST_BODY

query
SELECT *
FROM weather
WHERE city = 'San Francisco'
  AND prcp > 0.0;
----
city	temp_lo	temp_hi	prcp	date
San Francisco	46	50	0.25	1994-11-27

# DOCS_TEST: example_013

# DOCS_TEST_BODY

query
SELECT *
FROM weather
ORDER BY city;
