# DOCS_TEST: example_020

query
SELECT *
FROM weather
INNER JOIN cities ON weather.city = cities.name;
----
city	temp_lo	temp_hi	prcp	date	name	lat	lon

# DOCS_TEST: example_021

query
SELECT *
FROM weather
LEFT OUTER JOIN cities ON weather.city = cities.name;
----
city	temp_lo	temp_hi	prcp	date	name	lat	lon
San Francisco	46	50	0.25	1994-11-27	NULL	NULL	NULL
San Francisco	43	57	0	1994-11-29	NULL	NULL	NULL
Hayward	37	54	NULL	1994-11-29	NULL	NULL	NULL
Oakland	45	58	0.1	1994-11-30	NULL	NULL	NULL

# DOCS_TEST: example_022

query
SELECT max(temp_lo)
FROM weather;
----
max
46

# DOCS_TEST: example_023

query error
SELECT city
FROM weather
WHERE temp_lo = max(temp_lo);
----
db error: ERROR: WHERE clause cannot contain aggregates!


# DOCS_TEST: example_024

query
SELECT city
FROM weather
WHERE temp_lo = (SELECT max(temp_lo) FROM weather);
----
city
San Francisco

# DOCS_TEST: example_025

query ?? rowsort
SELECT city, max(temp_lo)
FROM weather
GROUP BY city;
----
city	max
Hayward	37
Oakland	45
San Francisco	46

# DOCS_TEST: example_026

query ?? rowsort
SELECT city, max(temp_lo)
FROM weather
GROUP BY city
HAVING max(temp_lo) < 40;
----
city	max
Hayward	37

# DOCS_TEST: example_027

query ?? rowsort
SELECT city, max(temp_lo)
FROM weather
WHERE city LIKE 'S%'            -- (1)
GROUP BY city
HAVING max(temp_lo) < 40;
----
city	max

# DOCS_TEST: example_028

statement ok
UPDATE weather
SET temp_hi = temp_hi - 2,  temp_lo = temp_lo - 2
WHERE date > '1994-11-28';

