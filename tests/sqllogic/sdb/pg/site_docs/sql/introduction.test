# DOCS_TEST: example_022

# DOCS_TEST_BODY

query
SELECT max(temp_lo)
FROM weather;
----
max
46

# DOCS_TEST: example_023

# DOCS_TEST_BODY

query error
SELECT city
FROM weather
WHERE temp_lo = max(temp_lo);
----
db error: ERROR: WHERE clause cannot contain aggregates!


# DOCS_TEST: example_024

# DOCS_TEST_BODY

query
SELECT city
FROM weather
WHERE temp_lo = (SELECT max(temp_lo) FROM weather);
----
city
San Francisco

# DOCS_TEST: example_025

# DOCS_TEST_BODY

query ?? rowsort
SELECT city, max(temp_lo)
FROM weather
GROUP BY city;
----
city	max
Hayward	37
Oakland	45
San Francisco	46

# DOCS_TEST: example_026

# DOCS_TEST_BODY

query ?? rowsort
SELECT city, max(temp_lo)
FROM weather
GROUP BY city
HAVING max(temp_lo) < 40;
----
city	max
Hayward	37

# DOCS_TEST: example_027

# DOCS_TEST_BODY

query ?? rowsort
SELECT city, max(temp_lo)
FROM weather
WHERE city LIKE 'S%'            -- (1)
GROUP BY city
HAVING max(temp_lo) < 40;
----
city	max

# DOCS_TEST: example_028

# DOCS_TEST_BODY

statement ok
UPDATE weather
SET temp_hi = temp_hi - 2,  temp_lo = temp_lo - 2
WHERE date > '1994-11-28';

