# DOCS_TEST: example_021

statement ok
CREATE TABLE l_regions (
    r_regionkey INTEGER NOT NULL PRIMARY KEY,
    r_name      CHAR(25) NOT NULL,
    r_comment   VARCHAR(152)
);

statement ok
CREATE TABLE l_nations (
    n_nationkey INTEGER NOT NULL PRIMARY KEY,
    n_name      CHAR(25) NOT NULL,
    n_regionkey INTEGER NOT NULL,
    n_comment   VARCHAR(152),
    FOREIGN KEY (n_regionkey) REFERENCES l_regions(r_regionkey)
);

# DOCS_TEST: example_022

query
SELECT n.*, r.*
FROM l_nations n
JOIN l_regions r ON (n_regionkey = r_regionkey);
----
n_nationkey	n_name	n_regionkey	n_comment	r_regionkey	r_name	r_comment

# DOCS_SETUP

statement ok
USE $__DATABASE__;

statement ok
DROP TABLE IF EXISTS l_regions;

statement ok
DROP TABLE IF EXISTS l_nations;

# DOCS_TEST: example_023

statement ok
CREATE TABLE l_regions (regionkey INTEGER NOT NULL PRIMARY KEY,
                        name      CHAR(25) NOT NULL,
                        comment   VARCHAR(152));

statement ok
CREATE TABLE l_nations (nationkey INTEGER NOT NULL PRIMARY KEY,
                        name      CHAR(25) NOT NULL,
                        regionkey INTEGER NOT NULL,
                        comment   VARCHAR(152),
                        FOREIGN KEY (regionkey) REFERENCES l_regions(regionkey));

# DOCS_TEST: example_024

query
SELECT n.*, r.*
FROM l_nations n
JOIN l_regions r USING (regionkey);
----
nationkey	name	regionkey	comment	regionkey	name	comment

# DOCS_TEST: example_025

query error
SELECT s1.t_id, s2.t_id
FROM west s1, west s2
WHERE s1.time > s2.time
  AND s1.cost < s2.cost;
----
db error: ERROR: Table with name west does not exist!
Did you mean "<slt:ignore>"?


# DOCS_TEST: example_026

statement ok
CREATE TABLE city_airport (city_name VARCHAR, iata VARCHAR);

statement ok
CREATE TABLE airport_names (iata VARCHAR, airport_name VARCHAR);

statement ok
INSERT INTO city_airport VALUES
    ('Amsterdam', 'AMS'),
    ('Rotterdam', 'RTM'),
    ('Eindhoven', 'EIN'),
    ('Groningen', 'GRQ');

statement ok
INSERT INTO airport_names VALUES
    ('AMS', 'Amsterdam Airport Schiphol'),
    ('RTM', 'Rotterdam The Hague Airport'),
    ('MST', 'Maastricht Aachen Airport');

# DOCS_TEST: example_027

query
SELECT *
FROM city_airport
NATURAL JOIN airport_names;
----
iata	city_name	airport_name
AMS	Amsterdam	Amsterdam Airport Schiphol
RTM	Rotterdam	Rotterdam The Hague Airport

# DOCS_TEST: example_028

query
SELECT *
FROM city_airport
JOIN airport_names
USING (iata);
----
iata	city_name	airport_name
AMS	Amsterdam	Amsterdam Airport Schiphol
RTM	Rotterdam	Rotterdam The Hague Airport

# DOCS_TEST: example_029

query
SELECT *
FROM city_airport
SEMI JOIN airport_names
    USING (iata);
----
iata	city_name
AMS	Amsterdam
RTM	Rotterdam

# DOCS_TEST: example_030

query
SELECT *
FROM city_airport
WHERE iata IN (SELECT iata FROM airport_names);
----
city_name	iata
Amsterdam	AMS
Rotterdam	RTM

# DOCS_TEST: example_031

query
SELECT *
FROM city_airport
ANTI JOIN airport_names
    USING (iata);
----
iata	city_name
EIN	Eindhoven
GRQ	Groningen

# DOCS_TEST: example_032

query
SELECT *
FROM city_airport
WHERE iata NOT IN (SELECT iata FROM airport_names WHERE iata IS NOT NULL);
----
city_name	iata
Eindhoven	EIN
Groningen	GRQ

# DOCS_TEST: example_033

query
