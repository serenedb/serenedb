# DOCS_TEST: example_035

statement ok
CREATE TABLE t1 AS
    SELECT *
    FROM range(3) t(i), LATERAL (SELECT i + 1) t2(j);

query
SELECT *
    FROM t1, LATERAL (SELECT i + j) t2(k)
    ORDER BY ALL;
----
i	j	k
0	1	1
1	2	3
2	3	5

