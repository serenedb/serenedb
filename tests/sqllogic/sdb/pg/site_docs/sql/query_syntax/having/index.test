control substitution on

# DOCS_SETUP

statement ok
USE $__DATABASE__;

statement ok
CREATE TABLE addresses (
    address VARCHAR,
    city VARCHAR,
    street_name VARCHAR,
    income DOUBLE,
    zip VARCHAR,
    country VARCHAR,
    population INTEGER,
    number1 INTEGER,
    number2 INTEGER
);

statement ok
INSERT INTO addresses VALUES
    ('123 Quack Blvd', 'DuckTown', 'Quack Blvd', 50000, '11111', 'NL', 100, 1, 10),
    ('111 Duck Duck Goose Ln', 'DuckTown', 'Duck Duck Goose Ln', 60000, '11111', 'NL', 100, 2, 20),
    ('111 Duck Duck Goose Ln', 'Duck Town', 'Duck Duck Goose Ln', 70000, '11111', 'US', 50, 3, 30),
    ('111 Duck Duck Goose Ln', 'Duck Town', 'Duck Duck Goose Ln', 80000, '11111-0001', 'US', 50, 4, 40),
    ('5 Pond Road', 'Mallard', 'Pond Road', 90000, '22222', 'UK', 25, 5, 50),
    ('9 Lake View', 'Mallard', 'Lake View', 40000, '33333', 'UK', 25, 6, 60);

# DOCS_SETUP: local_having_city_counts_fixture

statement ok
DELETE FROM addresses;

statement ok
INSERT INTO addresses
SELECT
    'DuckTown address ' || i,
    'DuckTown',
    'Quack Blvd',
    50000,
    '11111',
    'NL',
    100,
    i,
    i * 10
FROM range(50) t(i);

statement ok
INSERT INTO addresses
SELECT
    'Mallard address ' || i,
    'Mallard',
    'Pond Road',
    90000,
    '22222',
    'UK',
    25,
    i,
    i * 10
FROM range(51) t(i);

statement ok
INSERT INTO addresses
SELECT
    'Duck Town address ' || i,
    'Duck Town',
    'Duck Duck Goose Ln',
    70000,
    '11111',
    'US',
    50,
    i,
    i * 10
FROM range(49) t(i);

# DOCS_TEST: example_001

query ?? rowsort
SELECT city, count(*)
FROM addresses
GROUP BY city
HAVING count(*) >= 50;
----
city	count
DuckTown	50
Mallard	51

