# DOCS_TEST: example_002

# DOCS_TEST_BODY

statement ok
SET default_order = 'DESC';

# DOCS_TEST: example_003

statement ok
RESET default_null_order;

statement ok
RESET default_order;

# DOCS_TEST_BODY

statement ok
CREATE OR REPLACE TABLE planets AS
    SELECT 'Mars' AS planet, 'terrestrial' AS kind, 2 AS moons
    UNION ALL
    SELECT 'Mercury', 'terrestrial', 0
    UNION ALL
    SELECT 'Neptune', 'ice giant', 14
    UNION ALL
    SELECT 'Jupiter', 'gas giant', 95;

# DOCS_TEST: example_004

# DOCS_TEST_BODY

query
SELECT *
FROM planets
ORDER BY kind;
----
planet	kind	moons
Jupiter	gas giant	95
Neptune	ice giant	14
Mars	terrestrial	2
Mercury	terrestrial	0

# DOCS_TEST: example_005

# DOCS_TEST_BODY

query
SELECT *
FROM planets
ORDER BY kind DESC NULLS LAST;
----
planet	kind	moons
Mars	terrestrial	2
Mercury	terrestrial	0
Neptune	ice giant	14
Jupiter	gas giant	95

# DOCS_TEST: example_006

# DOCS_TEST_BODY

query
SELECT *
FROM planets
ORDER BY kind, planet;
----
planet	kind	moons
Jupiter	gas giant	95
Neptune	ice giant	14
Mars	terrestrial	2
Mercury	terrestrial	0

# DOCS_TEST: example_007

# DOCS_TEST_BODY

query error
SELECT *
FROM planets
ORDER BY kind COLLATE DE;
----
db error: ERROR: Collation with name "de" is not in the catalog, but it exists in the icu extension.

This feature relies on the "icu" extension which is not built into this SereneDB binary. Please open an issue at https://github.com/serenedb/serenedb/issues if you need it.


