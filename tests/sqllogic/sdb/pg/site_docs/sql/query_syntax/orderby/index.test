statement ok
SET default_null_order = 'NULLS_FIRST';

# DOCS_TEST: example_002

# DOCS_TEST_BODY

statement ok
SET default_order = 'DESC';

# DOCS_TEST: example_003

# DOCS_TEST_BODY

statement ok
CREATE OR REPLACE TABLE planets AS
    SELECT 'Mars' AS planet, 'terrestrial' AS kind, 2 AS moons
    UNION ALL
    SELECT 'Mercury', 'terrestrial', 0
    UNION ALL
    SELECT 'Neptune', 'ice giant', 14
    UNION ALL
    SELECT 'Jupiter', 'gas giant', 95;

# DOCS_TEST: example_004

# DOCS_TEST_BODY

query
SELECT *
FROM planets
ORDER BY kind;
----
planet	kind	moons
Mars	terrestrial	2
Mercury	terrestrial	0
Neptune	ice giant	14
Jupiter	gas giant	95

# DOCS_TEST: example_005

# DOCS_TEST_BODY

query
SELECT *
FROM planets
ORDER BY kind DESC NULLS LAST;
----
planet	kind	moons
Mars	terrestrial	2
Mercury	terrestrial	0
Neptune	ice giant	14
Jupiter	gas giant	95

# DOCS_TEST: example_006

# DOCS_TEST_BODY

query
SELECT *
FROM planets
ORDER BY kind, planet;
----
planet	kind	moons
Mercury	terrestrial	0
Mars	terrestrial	2
Neptune	ice giant	14
Jupiter	gas giant	95

# DOCS_TEST: example_007

# DOCS_TEST_BODY

query error Collation with name "de" is not in the catalog
SELECT *
FROM planets
ORDER BY kind COLLATE DE;
