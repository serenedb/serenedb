# DOCS_TEST: example_001

statement ok
SET default_null_order = 'NULLS_FIRST';

# DOCS_TEST: example_002

statement ok
SET default_order = 'DESC';

# DOCS_TEST: example_003

statement ok
CREATE OR REPLACE TABLE addresses AS
    SELECT '123 Quack Blvd' AS address, 'DuckTown' AS city, '11111' AS zip
    UNION ALL
    SELECT '111 Duck Duck Goose Ln', 'DuckTown', '11111'
    UNION ALL
    SELECT '111 Duck Duck Goose Ln', 'Duck Town', '11111'
    UNION ALL
    SELECT '111 Duck Duck Goose Ln', 'Duck Town', '11111-0001';

# DOCS_TEST: example_004

query
SELECT *
FROM addresses
ORDER BY city;
----
address	city	zip
123 Quack Blvd	DuckTown	11111
111 Duck Duck Goose Ln	DuckTown	11111
111 Duck Duck Goose Ln	Duck Town	11111
111 Duck Duck Goose Ln	Duck Town	11111-0001

# DOCS_TEST: example_005

query
SELECT *
FROM addresses
ORDER BY city DESC NULLS LAST;
----
address	city	zip
123 Quack Blvd	DuckTown	11111
111 Duck Duck Goose Ln	DuckTown	11111
111 Duck Duck Goose Ln	Duck Town	11111
111 Duck Duck Goose Ln	Duck Town	11111-0001

# DOCS_TEST: example_006

query
SELECT *
FROM addresses
ORDER BY city, zip;
----
address	city	zip
123 Quack Blvd	DuckTown	11111
111 Duck Duck Goose Ln	DuckTown	11111
111 Duck Duck Goose Ln	Duck Town	11111-0001
111 Duck Duck Goose Ln	Duck Town	11111

# DOCS_TEST: example_007

query error
SELECT *
FROM addresses
ORDER BY city COLLATE DE;
----
db error: ERROR: Collation with name "de" is not in the catalog, but it exists in the icu extension.

This feature relies on the "icu" extension which is not built into this SereneDB binary. Please open an issue at https://github.com/serenedb/serenedb/issues if you need it.


