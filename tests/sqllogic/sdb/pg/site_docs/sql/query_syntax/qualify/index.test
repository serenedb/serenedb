# DOCS_TEST: example_005

# DOCS_TEST_BODY

query ??? rowsort
WITH ranked_players AS (
    SELECT
        team,
        player,
        row_number() OVER (PARTITION BY team ORDER BY points DESC) AS player_rank
    FROM scores
)
SELECT
    *
FROM ranked_players
WHERE
    player_rank < 3;
----
team	player	player_rank
Hawks	Ann	1
Hawks	Bob	2
Owls	Dan	1
Owls	Eve	2
