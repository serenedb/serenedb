# DOCS_TEST: example_014

statement ok
DROP TABLE IF EXISTS cities;

statement ok
CREATE TABLE cities (
    city VARCHAR,
    country VARCHAR,
    population INTEGER
);

statement ok
INSERT INTO cities VALUES
    ('Amsterdam', 'NL', 921402),
    ('Rotterdam', 'NL', 664046),
    ('New York', 'US', 8804190),
    ('Los Angeles', 'US', 3898747),
    ('London', 'UK', 8799800),
    ('Manchester', 'UK', 551938);

# DOCS_TEST_BODY

query ??
SELECT DISTINCT ON(country) city, population
FROM cities
ORDER BY population DESC;
----
city	population
New York	8804190
London	8799800
Amsterdam	921402

