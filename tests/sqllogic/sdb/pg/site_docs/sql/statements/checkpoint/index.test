# DOCS_TEST: example_002

statement ok
DETACH IF EXISTS file_db;

statement ok
ATTACH '/tmp/${__DATABASE__}_sql_statements_checkpoint_example_002_file_db.db' AS file_db;

# DOCS_TEST_BODY

statement ok
CHECKPOINT file_db;

# DOCS_TEST: example_003

# DOCS_TEST_BODY

statement ok
FORCE CHECKPOINT;

# DOCS_TEST: example_004

statement ok
DETACH IF EXISTS memory_compressed;

# DOCS_TEST_BODY

statement ok
ATTACH ':memory:' AS memory_compressed (COMPRESS);

statement ok
USE memory_compressed;

statement ok
USE postgres;

statement ok
DETACH IF EXISTS memory_compressed;

statement ok
DETACH IF EXISTS file_db;
