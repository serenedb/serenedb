# DOCS_TEST_BODY

statement ok
ATTACH '${__TEST_DIR__}/sql_statements_copy_copy_database_full_example_037_1_db1.db' AS db1;

statement ok
CREATE TABLE db1.tbl AS SELECT 42 AS x, 3 AS y;

statement ok
CREATE MACRO db1.two_x_plus_y(x, y) AS 2 * x + y;

statement ok
ATTACH '${__TEST_DIR__}/sql_statements_copy_copy_database_full_example_037_1_db2.db' AS db2;

skipif pg-wire-extended
statement ok
COPY FROM DATABASE db1 TO db2;

skipif pg-wire-extended
query ?
SELECT db2.two_x_plus_y(x, y) AS z FROM db2.tbl;
