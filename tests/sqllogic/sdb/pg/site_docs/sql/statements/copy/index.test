# DOCS_TEST: example_001

statement ok
CREATE TABLE lineitem (
    l_orderkey INTEGER,
    l_partkey INTEGER,
    l_comment VARCHAR
);

statement ok
INSERT INTO lineitem VALUES
    (1, 10, 'first lineitem'),
    (2, 20, 'second lineitem');

statement ok
CREATE TABLE test (id INTEGER, name VARCHAR);

statement ok
CREATE TABLE category (name VARCHAR);

statement ok
CREATE TABLE tbl1 (i INTEGER);

statement ok
INSERT INTO tbl1 VALUES (1), (2);

statement ok
CREATE TABLE tbl2 (i INTEGER);

statement ok
COPY (SELECT * FROM (VALUES
    (3, 30, 'fixture lineitem'),
    (4, 40, 'mock lineitem')
) AS t("l_orderkey", "l_partkey", "l_comment")) TO '/tmp/${__DATABASE__}_sql_statements_copy_index_example_001_1_lineitem_csv.csv' (FORMAT CSV, HEADER false, DELIMITER ',');

