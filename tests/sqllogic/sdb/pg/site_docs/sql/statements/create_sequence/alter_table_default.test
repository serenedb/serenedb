# DOCS_TEST_BODY

# The error differs by wire protocol: the simple path fails when backfilling the
# new column's default, the extended path rejects the decomposed multi-statement.
skipif pg-wire-extended
statement error
ALTER TABLE tbl ADD COLUMN id INTEGER DEFAULT nextval('id_sequence');
