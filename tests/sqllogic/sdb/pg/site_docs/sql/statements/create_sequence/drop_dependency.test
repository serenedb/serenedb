statement ok
CREATE SEQUENCE id_sequence START 1;

statement ok
CREATE TABLE tbl (
    id INTEGER DEFAULT nextval('id_sequence'),
    s VARCHAR
);

statement ok
INSERT INTO tbl(s) VALUES ('default is the next value from id_sequence');

statement error
