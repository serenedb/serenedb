CREATE TABLE t5 (id INTEGER UNIQUE, j VARCHAR);

statement error
CREATE TABLE t6 (
    id INTEGER PRIMARY KEY,
    t5_id INTEGER,
    FOREIGN KEY (t5_id) REFERENCES t5(id)
);
