# DOCS_TEST: example_018

statement ok
USE $__DATABASE__;

statement ok
DROP TABLE IF EXISTS t1;

# DOCS_TEST_BODY

statement ok
CREATE TABLE t1 (
    id INTEGER PRIMARY KEY,
    percentage INTEGER CHECK (0 <= percentage AND percentage <= 100)
);

statement ok
INSERT INTO t1 VALUES (1, 5);

statement error
INSERT INTO t1 VALUES (2, -1);
----
db error: ERROR: CHECK constraint failed on table <slt:ignore>.public.t1 with expression CHECK(((0 <= percentage) AND (percentage <= 100)))


# DOCS_TEST: example_019

# DOCS_TEST_BODY

statement error
INSERT INTO t1 VALUES (3, 101);
----
db error: ERROR: CHECK constraint failed on table <slt:ignore>.public.t1 with expression CHECK(((0 <= percentage) AND (percentage <= 100)))


# DOCS_TEST: example_020

statement ok
DROP TABLE IF EXISTS t2;

# DOCS_TEST_BODY

statement ok
CREATE TABLE t2 (id INTEGER PRIMARY KEY, x INTEGER, y INTEGER CHECK (x < y));

statement ok
INSERT INTO t2 VALUES (1, 5, 10);

statement error
INSERT INTO t2 VALUES (2, 5, 3);
----
db error: ERROR: CHECK constraint failed on table <slt:ignore>.public.t2 with expression CHECK((x < y))


# DOCS_TEST: example_021

# DOCS_TEST_BODY

statement ok
CREATE TABLE t3 (
    id INTEGER PRIMARY KEY,
    x INTEGER,
    y INTEGER,
    CONSTRAINT x_smaller_than_y CHECK (x < y)
);

statement ok
INSERT INTO t3 VALUES (1, 5, 10);

statement error
INSERT INTO t3 VALUES (2, 5, 3);
----
db error: ERROR: CHECK constraint failed on table <slt:ignore>.public.t3 with expression CHECK((x < y))


# DOCS_TEST: example_022

statement ok
USE $__DATABASE__;

statement ok
DROP TABLE IF EXISTS t1;

statement ok
DROP TABLE IF EXISTS t2;

# DOCS_TEST_BODY

statement ok
CREATE TABLE t1 (id INTEGER PRIMARY KEY, j VARCHAR);

statement ok
CREATE TABLE t2 (
    id INTEGER PRIMARY KEY,
    t1_id INTEGER,
    FOREIGN KEY (t1_id) REFERENCES t1 (id)
);

# DOCS_TEST: example_023

# DOCS_TEST_BODY

statement ok
INSERT INTO t1 VALUES (1, 'a');

statement ok
INSERT INTO t2 VALUES (1, 1);

statement error
INSERT INTO t2 VALUES (2, 2);
----
db error: ERROR: Violates foreign key constraint because key "id: 2" does not exist in the referenced table


# DOCS_TEST: example_024

statement ok
USE $__DATABASE__;

statement ok
DROP TABLE IF EXISTS t3;

# DOCS_TEST_BODY

statement ok
CREATE TABLE t3 (id INTEGER, j VARCHAR, PRIMARY KEY (id, j));

statement ok
CREATE TABLE t4 (
    id INTEGER PRIMARY KEY, t3_id INTEGER, t3_j VARCHAR,
    FOREIGN KEY (t3_id, t3_j) REFERENCES t3(id, j)
);

# DOCS_TEST: example_025

# DOCS_TEST_BODY

statement ok
INSERT INTO t3 VALUES (1, 'a');

statement ok
INSERT INTO t4 VALUES (1, 1, 'a');

statement error
INSERT INTO t4 VALUES (2, 1, 'b');
----
db error: ERROR: Violates foreign key constraint because key "id: 1, j: b" does not exist in the referenced table


