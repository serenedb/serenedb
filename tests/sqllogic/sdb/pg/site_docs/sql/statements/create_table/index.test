# DOCS_TEST: example_006

statement ok
USE $__DATABASE__;

statement ok
DROP TABLE IF EXISTS t1;

statement ok
COPY (SELECT * FROM (VALUES
    (1, 'alpha', 10),
    (2, 'beta', 20)
) AS t("id", "name", "value")) TO '/tmp/${__DATABASE__}_sql_statements_create_table_index_example_006_1_file_csv.csv' (FORMAT CSV, HEADER true, DELIMITER ',');

# DOCS_TEST_RAW
#| CREATE TABLE t1 AS
#|     SELECT *
#|     FROM read_csv('path/file.csv');

# DOCS_TEST_BODY

statement ok
CREATE TABLE t1 AS
    SELECT *
    FROM read_csv('/tmp/${__DATABASE__}_sql_statements_create_table_index_example_006_1_file_csv.csv');

