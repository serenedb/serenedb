# DOCS_TEST: example_018

statement ok
CREATE TABLE t1 (
    id INTEGER PRIMARY KEY,
    percentage INTEGER CHECK (0 <= percentage AND percentage <= 100)
);

statement ok
INSERT INTO t1 VALUES (1, 5);

statement error
INSERT INTO t1 VALUES (2, -1);
----
db error: ERROR: new row for relation "t1" violates check constraint "t1_percentage_check"
DETAIL: Failing row contains (2, -1).


# DOCS_TEST: example_019

statement error
INSERT INTO t1 VALUES (3, 101);
----
db error: ERROR: new row for relation "t1" violates check constraint "t1_percentage_check"
DETAIL: Failing row contains (3, 101).


# DOCS_SETUP: drop_t2_before_constraint_example

statement ok
DROP TABLE IF EXISTS t2;

# DOCS_TEST: example_020

statement ok
CREATE TABLE t2 (id INTEGER PRIMARY KEY, x INTEGER, y INTEGER CHECK (x < y));

statement ok
INSERT INTO t2 VALUES (1, 5, 10);

statement error
INSERT INTO t2 VALUES (2, 5, 3);
----
db error: ERROR: new row for relation "t2" violates check constraint "t2_check"
DETAIL: Failing row contains (2, 5, 3).


# DOCS_TEST: example_021

statement ok
CREATE TABLE t3 (
    id INTEGER PRIMARY KEY,
    x INTEGER,
    y INTEGER,
    CONSTRAINT x_smaller_than_y CHECK (x < y)
);

statement ok
INSERT INTO t3 VALUES (1, 5, 10);

statement error
INSERT INTO t3 VALUES (2, 5, 3);
----
db error: ERROR: new row for relation "t3" violates check constraint "x_smaller_than_y"
DETAIL: Failing row contains (2, 5, 3).


