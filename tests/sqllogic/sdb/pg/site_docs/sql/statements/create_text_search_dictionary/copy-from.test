# DOCS_TEST: example_005

# DOCS_TEST_RAW
#| CREATE TEXT SEARCH DICTIONARY pipe_variant (
#|     template = 'copy_from',
#|     from = 'pipe_dict',
#|     STEP2_CASE = 'upper'
#| );

# DOCS_TEST_BODY

statement ok
CREATE TEXT SEARCH DICTIONARY pipe_dict (
    template = 'pipeline',
    STEP1_TEMPLATE = 'delimiter',
    STEP1_DELIMITER = ',',
    STEP2_TEMPLATE = 'text',
    STEP2_LOCALE = 'en_US.UTF-8',
    STEP2_CASE = 'lower'
);

statement ok
CREATE TEXT SEARCH DICTIONARY pipe_variant (
    template = 'copy_from',
    from = 'pipe_dict',
    STEP2_CASE = 'upper'
);

# DOCS_TEST: example_006

# DOCS_TEST_BODY

statement ok
CREATE TEXT SEARCH DICTIONARY pipe_extended (
    template = 'copy_from',
    from = 'pipe_dict',
    STEP3_TEMPLATE = 'stopwords',
    STEP3_STOPWORDS = '"bar","foo"'
);

# DOCS_TEST: example_007

# DOCS_TEST_RAW
#| CREATE TEXT SEARCH DICTIONARY minhash_variant (
#|     template = 'copy_from',
#|     from = 'minhash_text',
#|     TOKENIZER_STOPWORDS = '"fox"'
#| );

# DOCS_TEST_BODY

statement ok
CREATE TEXT SEARCH DICTIONARY minhash_text (
    template = 'minhash',
    tokenizer_template = 'text',
    tokenizer_locale = 'en_US.UTF-8',
    numhashes = 2
);

statement ok
CREATE TEXT SEARCH DICTIONARY minhash_variant (
    template = 'copy_from',
    from = 'minhash_text',
    TOKENIZER_STOPWORDS = '"fox"'
);
