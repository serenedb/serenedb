# DOCS_TEST: example_001

statement ok
CREATE TABLE documents (
    id INTEGER PRIMARY KEY,
    title VARCHAR,
    body VARCHAR
);

statement ok
INSERT INTO documents VALUES
    (1, 'Intro to Search', 'A practical guide to searching and ranking documents.'),
    (2, 'Scaling Analytics', 'Processing billions of rows with fast running queries.');

# DOCS_TEST_BODY

statement ok
CREATE TEXT SEARCH DICTIONARY english_dict (
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'lower',
    stemming = true,
    frequency = true,
    position = true
);

statement ok
CREATE INDEX idx_docs ON documents
    USING inverted (id, title english_dict, body english_dict);

# DOCS_TEST: example_002

statement ok
VACUUM (REFRESH_TABLE) documents;

# DOCS_TEST_BODY

query
SELECT id FROM idx_docs WHERE body @@ 'searching';
----
id
1

