# DOCS_TEST: example_003

# DOCS_TEST_BODY

statement ok
CREATE TEXT SEARCH DICTIONARY tok_ngram (
    template = 'ngram',
    mingram = 2,
    maxgram = 3
);

query ?
SELECT ts_lexize('tok_ngram', 'search');
----
ts_lexize
{se,sea,ea,ear,ar,arc,rc,rch,ch}

# DOCS_TEST: example_004

# DOCS_TEST_BODY

statement ok
CREATE TEXT SEARCH DICTIONARY tok_ngram_orig (
    template = 'ngram',
    mingram = 2,
    maxgram = 3,
    preserveoriginal = true
);

query ?
SELECT ts_lexize('tok_ngram_orig', 'search');
----
ts_lexize
{se,sea,search,ea,ear,ar,arc,rc,rch,ch}

# DOCS_TEST: example_005

# DOCS_TEST_BODY

statement ok
CREATE TEXT SEARCH DICTIONARY tok_ngram_mark (
    template = 'ngram',
    mingram = 2,
    maxgram = 3,
    startmarker = '^',
    endmarker = '$'
);

query ?
SELECT ts_lexize('tok_ngram_mark', 'cat');
----
ts_lexize
{^ca,^cat,cat$,at$}
