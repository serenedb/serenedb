# DOCS_TEST_BODY

statement ok
CREATE TEXT SEARCH DICTIONARY norm_upper (
    template = 'norm',
    locale = 'en_US.UTF-8',
    case = 'upper',
    accent = true
);

query ?
SELECT ts_lexize('norm_upper', 'café');
----
ts_lexize
{CAFÉ}
