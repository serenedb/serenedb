statement ok
CREATE TEXT SEARCH DICTIONARY norm_dict (
    template = 'norm',
    locale = 'en_US.UTF-8',
    case = 'lower',
    accent = false
);

query ?
SELECT ts_lexize('norm_dict', 'CAFÉ');
----
ts_lexize
{cafe}

