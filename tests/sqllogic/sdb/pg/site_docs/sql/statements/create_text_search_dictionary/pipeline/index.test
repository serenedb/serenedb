CREATE TEXT SEARCH DICTIONARY ngram_norm (
    template = 'pipeline',
    STEP1_TEMPLATE = 'ngram',
    STEP1_MINGRAM = 2,
    STEP1_MAXGRAM = 3,
    STEP2_TEMPLATE = 'norm',
