statement ok
CREATE TEXT SEARCH DICTIONARY pipe_dict (
    template = 'pipeline',
    STEP1_TEMPLATE = 'delimiter',
    STEP1_DELIMITER = ',',
    STEP2_TEMPLATE = 'text',
    STEP2_LOCALE = 'en_US.UTF-8',
    STEP2_CASE = 'lower',
    STEP2_STEMMING = true
);

# DOCS_TEST: example_002

# DOCS_TEST_BODY

statement ok
CREATE TEXT SEARCH DICTIONARY advanced_pipe (
    template = 'pipeline',
    STEP1_TEMPLATE = 'delimiter',
    STEP1_DELIMITER = 'A',
    STEP2_TEMPLATE = 'text',
    STEP2_LOCALE = 'en_US.UTF-8',
    STEP2_CASE = 'lower',
    STEP2_ACCENT = false,
    STEP2_STEMMING = true,
    STEP2_STOPWORDS = '"fox"',
    STEP3_TEMPLATE = 'norm',
    STEP3_LOCALE = 'en_US.UTF-8',
    STEP3_CASE = 'upper'
);

