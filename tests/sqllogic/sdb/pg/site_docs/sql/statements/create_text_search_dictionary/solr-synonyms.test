# DOCS_TEST: example_001

# DOCS_TEST_BODY

statement ok
CREATE TEXT SEARCH DICTIONARY solr_syn (
    template = 'solr_synonyms',
    -- comma-separated terms are bidirectional; "=>" maps left to right
    synonyms = 'car, automobile, auto
laptop => notebook'
);

# DOCS_TEST: example_002

# DOCS_TEST_BODY

query
SELECT ts_lexize('solr_syn', 'car');
----
ts_lexize
{auto,automobile,car}

