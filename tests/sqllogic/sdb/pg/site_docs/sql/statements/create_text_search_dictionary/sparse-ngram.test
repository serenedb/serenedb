# DOCS_TEST: example_001

# DOCS_TEST_BODY

statement ok
CREATE TEXT SEARCH DICTIONARY code_grams (
    template = 'sparse_ngram',
    frequency = true,
    norm = true
);

query
SELECT ts_lexize('code_grams', 'hello world');
----
ts_lexize
{hel,ell,llo,"lo ","o w","lo w"," wo","lo wo",wor,orl,worl,rld}

