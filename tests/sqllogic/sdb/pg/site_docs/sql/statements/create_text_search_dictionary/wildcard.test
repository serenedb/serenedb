statement ok
CREATE TEXT SEARCH DICTIONARY wildcard_dict (
    template = 'wildcard',
    ngramsize = 3,
    tokenizer_template = 'delimiter',
    tokenizer_delimiter = ' '
);

query ?
SELECT ts_lexize('wildcard_dict', 'search');
----
ts_lexize
{se,sea,ear,arc,rch,ch,h}

