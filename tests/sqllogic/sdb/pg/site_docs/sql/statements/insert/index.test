# DOCS_TEST: example_021

# DOCS_TEST_BODY

statement ok
CREATE TABLE t1 (id INTEGER PRIMARY KEY, val1 DOUBLE, val2 DOUBLE NOT NULL);

statement ok
CREATE TABLE t2 (id INTEGER PRIMARY KEY, val1 DOUBLE);

statement ok
INSERT INTO t1
    VALUES (1, 2, 3);

statement ok
INSERT INTO t2
    VALUES (1, 5);

statement ok
INSERT INTO t1 BY NAME (SELECT id, val1 FROM t2)
    ON CONFLICT DO UPDATE
    SET val1 = EXCLUDED.val1;

# DOCS_TEST: example_022

statement ok
USE $__DATABASE__;

statement ok
DROP TABLE IF EXISTS t1;

# DOCS_TEST_BODY

statement ok
CREATE TABLE t1 (id1 INTEGER, id2 INTEGER, val1 DOUBLE, PRIMARY KEY (id1, id2));

statement ok
INSERT OR REPLACE INTO t1
    VALUES (1, 2, 3);

statement ok
INSERT OR REPLACE INTO t1
    VALUES (1, 2, 4);

# DOCS_TEST: example_027

statement ok
USE $__DATABASE__;

statement ok
DROP TABLE IF EXISTS t1;

# DOCS_TEST_BODY

statement ok
CREATE TABLE t1 (i INTEGER);

query
INSERT INTO t1
    SELECT 42
    RETURNING *;
----
i
42

# DOCS_TEST: example_028

statement ok
USE $__DATABASE__;

statement ok
DROP TABLE IF EXISTS t2;

# DOCS_TEST_BODY

statement ok
CREATE TABLE t2 (i INTEGER, j INTEGER);

query
INSERT INTO t2
    SELECT 2 AS i, 3 AS j
    RETURNING *, i * j AS i_times_j;
----
i	j	i_times_j
2	3	6

# DOCS_TEST: example_029

# DOCS_TEST_BODY

statement ok
CREATE TABLE t3 (i INTEGER PRIMARY KEY, j INTEGER);

statement ok
CREATE SEQUENCE 't3_key';

query
INSERT INTO t3
    SELECT nextval('t3_key') AS i, 42 AS j
    UNION ALL
    SELECT nextval('t3_key') AS i, 43 AS j
    RETURNING *;
----
i	j
1	42
2	43
