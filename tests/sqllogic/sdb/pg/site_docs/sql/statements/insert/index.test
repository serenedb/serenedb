# DOCS_SETUP: wide_tbl_fixture

statement ok
DROP TABLE IF EXISTS other_tbl;

statement ok
DROP TABLE IF EXISTS tbl;

statement ok
CREATE TABLE tbl (
    id INTEGER,
    name VARCHAR,
    col1 DOUBLE,
    col2 DOUBLE,
    "Some Column Name" VARCHAR,
    i INTEGER,
    a INTEGER,
    b INTEGER,
    c INTEGER,
    number INTEGER,
    number1 INTEGER,
    number2 INTEGER
);

statement ok
INSERT INTO tbl VALUES
    (1, 'mark', 1, 2, 'alpha', 1, 10, 20, 30, 10, 100, 1000),
    (3, 'bookmark', 4, 5, 'beta', 2, 11, 21, 31, 20, 200, 2000),
    (7, 'other', 9, 16, 'gamma', 3, 12, 22, 32, NULL, 300, 3000);

statement ok
CREATE TABLE other_tbl AS SELECT * FROM tbl LIMIT 0;

statement ok
INSERT INTO other_tbl VALUES
    (11, 'other mark', 11, 12, 'delta', 11, 110, 120, 130, 110, 1100, 11000),
    (13, 'other bookmark', 14, 15, 'epsilon', 12, 111, 121, 131, 120, 1200, 12000);

# DOCS_TEST: example_002

statement ok
INSERT INTO tbl
    SELECT * FROM other_tbl;

