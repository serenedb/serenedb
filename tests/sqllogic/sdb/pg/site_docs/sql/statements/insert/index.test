control substitution on

# DOCS_TEST: example_001

statement ok
USE $__DATABASE__;

statement ok
DROP TABLE IF EXISTS tbl;

statement ok
CREATE TABLE tbl (i INTEGER);

# DOCS_TEST_BODY

