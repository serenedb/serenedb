# DOCS_TEST: example_001

# DOCS_TEST_BODY

statement ok
CREATE TABLE people (id INTEGER, name VARCHAR, salary FLOAT);

statement ok
INSERT INTO people VALUES (1, 'John', 92_000.0), (2, 'Anna', 100_000.0);

# DOCS_TEST: example_002

# DOCS_TEST_BODY

statement ok
MERGE INTO people
    USING (
        SELECT
            unnest([3, 1]) AS id,
            unnest(['Sarah', 'John']) AS name,
            unnest([95_000.0, 105_000.0]) AS salary
    ) AS upserts
    ON (upserts.id = people.id)
    WHEN MATCHED THEN UPDATE
    WHEN NOT MATCHED THEN INSERT;

query
FROM people
ORDER BY id;
----
id	name	salary
1	John	105000
2	Anna	100000
3	Sarah	95000

# DOCS_TEST: example_003

# DOCS_TEST_BODY

statement ok
MERGE INTO people
    USING (
        SELECT
            1 AS id,
            98_000.0 AS salary
    ) AS salary_updates
    USING (id)
    WHEN MATCHED THEN UPDATE SET salary = salary_updates.salary;

query
FROM people
ORDER BY id;
----
id	name	salary
1	John	98000
2	Anna	100000
3	Sarah	95000

# DOCS_TEST: example_004

# DOCS_TEST_BODY

statement ok
MERGE INTO people
    USING (
        SELECT
            1 AS id,
    ) AS deletes
    USING (id)
    WHEN MATCHED THEN DELETE;

query
FROM people
ORDER BY id;
----
id	name	salary
2	Anna	100000
3	Sarah	95000

# DOCS_TEST: example_005

# DOCS_TEST_BODY

statement ok
MERGE INTO people
    USING (
        SELECT
            unnest([3, 2]) AS id,
    ) AS deletes
    USING (id)
    WHEN MATCHED AND people.salary >= 100_000.0 THEN DELETE;

query
FROM people
ORDER BY id;
----
id	name	salary
3	Sarah	95000

# DOCS_TEST: example_006

# DOCS_TEST_BODY

statement ok
-- Let's get John back in!
INSERT INTO people VALUES (1, 'John', 105_000.0);

query
MERGE INTO people
    USING (
        SELECT
            unnest([3, 1]) AS id,
            unnest([89_000.0, 70_000.0]) AS salary
    ) AS upserts
    USING (id)
    WHEN MATCHED AND people.salary < 100_000.0 THEN UPDATE SET salary = upserts.salary
    -- Second update or delete condition
    WHEN MATCHED AND people.salary > 100_000.0 THEN DELETE
    WHEN NOT MATCHED THEN INSERT BY NAME
    RETURNING merge_action, *;
----
merge_action	id	name	salary
UPDATE	3	Sarah	89000
DELETE	1	John	105000

# DOCS_TEST: example_007

# DOCS_TEST_BODY

statement ok
CREATE TABLE target AS
    SELECT unnest([1,2]) AS id;

query
MERGE INTO target
    USING (SELECT 1 AS id) source
    USING (id)
    WHEN MATCHED THEN UPDATE
    WHEN NOT MATCHED BY SOURCE THEN DELETE
    RETURNING merge_action, *;
----
merge_action	id
UPDATE	1
DELETE	2
