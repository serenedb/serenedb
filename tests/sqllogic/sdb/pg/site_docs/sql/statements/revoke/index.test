# DOCS_TEST: example_001

statement ok
DROP TABLE IF EXISTS doc_vault;

statement ok
DROP ROLE IF EXISTS doc_auditor;

statement ok
DROP ROLE IF EXISTS doc_team;

statement ok
DROP ROLE IF EXISTS doc_member;

# DOCS_TEST_BODY

statement ok
CREATE TABLE doc_vault (id int, secret text);

statement ok
CREATE ROLE doc_auditor;

statement ok
CREATE ROLE doc_team;

statement ok
CREATE ROLE doc_member;

statement ok
GRANT SELECT, INSERT ON doc_vault TO doc_auditor WITH GRANT OPTION;

statement ok
GRANT doc_team TO doc_member;

# DOCS_TEST: example_002

# DOCS_TEST_BODY

statement ok
REVOKE INSERT ON doc_vault FROM doc_auditor;

