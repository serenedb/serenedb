# DOCS_TEST: example_007

statement ok
USE $__DATABASE__;

statement ok
CREATE TABLE addresses (
    address VARCHAR,
    city VARCHAR,
    street_name VARCHAR,
    income DOUBLE,
    zip VARCHAR,
    country VARCHAR,
    population INTEGER,
    number1 INTEGER,
    number2 INTEGER
);

statement ok
INSERT INTO addresses VALUES
    ('123 Maple Blvd', 'Springfield', 'Maple Blvd', 50000, '11111', 'NL', 100, 1, 10),
    ('111 Oak Lane', 'Springfield', 'Oak Lane', 60000, '11111', 'NL', 100, 2, 20),
    ('111 Oak Lane', 'Riverton', 'Oak Lane', 70000, '11111', 'US', 50, 3, 30),
    ('111 Oak Lane', 'Riverton', 'Oak Lane', 80000, '11111-0001', 'US', 50, 4, 40),
    ('5 Pond Road', 'Lakeside', 'Pond Road', 90000, '22222', 'UK', 25, 5, 50),
    ('9 Lake View', 'Lakeside', 'Lake View', 40000, '33333', 'UK', 25, 6, 60);

# DOCS_TEST_BODY

query ? rowsort
SELECT DISTINCT city FROM addresses;
----
city
Lakeside
Riverton
Springfield

