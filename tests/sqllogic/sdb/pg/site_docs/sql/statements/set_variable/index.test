# DOCS_TEST: example_004

# DOCS_TEST_RAW
#| -- write some CSV files
#| COPY (SELECT 42 AS a) TO 'test1.csv' (HEADER);
#|
#| COPY (SELECT 84 AS a) TO 'test2.csv' (HEADER);
#|
#| -- add a list of CSV files to a table
#| CREATE TABLE csv_files (file VARCHAR);
#|
#| INSERT INTO csv_files VALUES ('test1.csv'), ('test2.csv');
#|
#| -- initialize a variable with the list of csv files
#| SET VARIABLE list_of_files = (SELECT list(file) FROM csv_files);
#|
#| -- read the CSV files
#| SELECT * FROM read_csv(getvariable('list_of_files'), filename := True);

# DOCS_TEST_BODY

statement ok
-- write some CSV files
COPY (SELECT 42 AS a) TO '/tmp/${__DATABASE__}_sql_statements_set_variable_index_example_004_1_test1_csv.csv' (HEADER);

statement ok
COPY (SELECT 84 AS a) TO '/tmp/${__DATABASE__}_sql_statements_set_variable_index_example_004_1_test2_csv.csv' (HEADER);

statement ok
-- add a list of CSV files to a table
DROP TABLE IF EXISTS csv_files;

statement ok
CREATE TABLE csv_files (file VARCHAR);

statement ok
INSERT INTO csv_files VALUES (
    '/tmp/${__DATABASE__}_sql_statements_set_variable_index_example_004_1_test1_csv.csv'
), (
    '/tmp/${__DATABASE__}_sql_statements_set_variable_index_example_004_1_test2_csv.csv'
);

statement ok
-- initialize a variable with the list of csv files
SET VARIABLE list_of_files = (SELECT list(file) FROM csv_files);

query ?? rowsort
-- read the CSV files
SELECT
    a,
    replace(replace(filename, '/tmp/${__DATABASE__}_sql_statements_set_variable_index_example_004_1_', ''), '_csv.csv', '.csv') AS filename
FROM read_csv(getvariable('list_of_files'), filename := True);
----
a	filename
42	test1.csv
84	test2.csv

