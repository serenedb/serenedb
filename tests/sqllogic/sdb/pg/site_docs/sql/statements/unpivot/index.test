3	cars	may	500
3	cars	jun	600

# DOCS_TEST: example_009

query ?? rowsort
UNPIVOT
    (SELECT 42 AS col1, 'woot' AS col2)
    ON
        (col1 * 2)::VARCHAR,
        col2;
----
name	value
col1	84
col2	woot

