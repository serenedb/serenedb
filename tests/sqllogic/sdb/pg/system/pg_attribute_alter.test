# pg_attribute reflects ALTER TABLE column DDL against a store-backed table.
# serenedb physically applies ADD/DROP/RENAME in the DuckDB store (no Postgres
# soft-drop): DROP removes the entry entirely and renumbers the columns after
# it (attisdropped stays false), rather than tombstoning the dropped column.

statement ok
CREATE TABLE pa(a INTEGER, b TEXT, c INTEGER);


query
SELECT attname, attnum, attisdropped FROM pg_attribute WHERE attrelid = 'pa'::regclass AND attnum > 0 ORDER BY attnum;
----
attname	attnum	attisdropped
a	1	f
b	2	f
c	3	f


statement ok
ALTER TABLE pa DROP COLUMN b;


query
SELECT attname, attnum, attisdropped FROM pg_attribute WHERE attrelid = 'pa'::regclass AND attnum > 0 ORDER BY attnum;
----
attname	attnum	attisdropped
a	1	f
c	2	f


statement ok
ALTER TABLE pa ADD COLUMN d TEXT;


query
SELECT attname, attnum FROM pg_attribute WHERE attrelid = 'pa'::regclass AND attnum > 0 ORDER BY attnum;
----
attname	attnum
a	1
c	2
d	3


statement ok
ALTER TABLE pa RENAME COLUMN c TO c2;


query
SELECT attname, attnum FROM pg_attribute WHERE attrelid = 'pa'::regclass AND attnum > 0 ORDER BY attnum;
----
attname	attnum
a	1
c2	2
d	3


statement ok
DROP TABLE pa;
