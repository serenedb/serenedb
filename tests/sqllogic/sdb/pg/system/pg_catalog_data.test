query
SELECT count(*) > 0 FROM pg_roles
----
?column?
t


# pg_settings should return settings
query
SELECT count(*) > 0 FROM pg_settings
----
?column?
t


# Cross-table joins (integration)


# Join pg_class with pg_namespace to get schema-qualified table names
query
SELECT n.nspname, c.relname FROM pg_catalog.pg_class c JOIN pg_catalog.pg_namespace n ON c.relnamespace = n.oid WHERE c.relname = 'pg_cat_t1'
----
nspname	relname
public	pg_cat_t1


# Join pg_attribute with pg_type to get type names
query
SELECT a.attname, t.typname FROM pg_catalog.pg_attribute a JOIN pg_catalog.pg_type t ON a.atttypid = t.oid WHERE a.attrelid = (SELECT oid FROM pg_catalog.pg_class WHERE relname = 'pg_cat_t1') ORDER BY a.attnum
----
attname	typname
id	int4
name	text
value	float8


# Join pg_index with pg_attribute to verify index columns reference valid attributes
query
SELECT idx.relname, a.attname FROM pg_catalog.pg_class idx JOIN pg_catalog.pg_index i ON idx.oid = i.indexrelid JOIN pg_catalog.pg_attribute a ON a.attrelid = i.indrelid AND a.attnum = 1 WHERE idx.relname = 'pg_cat_idx1'
----
relname	attname
pg_cat_idx1	id


# Typical pgAdmin/SereneUI query: list tables with their columns
query
SELECT c.relname, a.attname, a.atttypid, a.attnum, a.attnotnull FROM pg_catalog.pg_class c JOIN pg_catalog.pg_attribute a ON a.attrelid = c.oid WHERE c.relname = 'pg_cat_t1' AND a.attnum > 0 AND NOT a.attisdropped ORDER BY a.attnum
----
relname	attname	atttypid	attnum	attnotnull
pg_cat_t1	id	23	1	t
pg_cat_t1	name	25	2	t
pg_cat_t1	value	701	3	f


# Typical pgAdmin query: list indexes for a table
query
SELECT idx.relname AS index_name, i.indisunique, i.indisprimary FROM pg_catalog.pg_index i JOIN pg_catalog.pg_class idx ON idx.oid = i.indexrelid JOIN pg_catalog.pg_class tbl ON tbl.oid = i.indrelid WHERE tbl.relname = 'pg_cat_t1' ORDER BY idx.relname
----
index_name	indisunique	indisprimary
pg_cat_idx1	f	f
pg_cat_t1_pkey	t	t


# Join pg_proc with pg_language
query
SELECT p.proname, l.lanname FROM pg_catalog.pg_proc p JOIN pg_catalog.pg_language l ON p.prolang = l.oid WHERE p.proname = 'pg_cat_add'
----
proname	lanname
pg_cat_add	sql


# Join pg_constraint with pg_class
query
SELECT con.conname, c.relname, con.contype FROM pg_catalog.pg_constraint con JOIN pg_catalog.pg_class c ON con.conrelid = c.oid WHERE c.relname IN ('pg_cat_t1', 'pg_cat_t2') ORDER BY c.relname, con.conname
----
conname	relname	contype
pg_cat_t1_id_not_null	pg_cat_t1	c
pg_cat_t1_name_not_null	pg_cat_t1	c
pg_cat_t1_pkey	pg_cat_t1	p
pg_cat_t2_a_not_null	pg_cat_t2	c
pg_cat_t2_pkey	pg_cat_t2	p


# Cleanup


statement ok
DROP FUNCTION pg_cat_add


statement ok
DROP INDEX pg_cat_idx2


# pg_attribute: attnotnull for NOT NULL columns

# pg_cat_t1 has: id INT PRIMARY KEY (notnull), name TEXT NOT NULL (notnull), value FLOAT8 (nullable)
query
SELECT attname, attnotnull
FROM pg_attribute
WHERE attrelid = (SELECT oid FROM pg_class WHERE relname = 'pg_cat_t1')
ORDER BY attnum;
----
attname	attnotnull
id	t
name	t
value	f


# pg_constraint: OIDs should be non-zero

query
SELECT conname, oid <> 0 AS has_oid
FROM pg_constraint
WHERE conrelid = (SELECT oid FROM pg_class WHERE relname = 'pg_cat_t1')
ORDER BY conname;
----
conname	has_oid
pg_cat_t1_id_not_null	t
pg_cat_t1_name_not_null	t
pg_cat_t1_pkey	t


# pg_proc: provolatile and proparallel return char values

query
SELECT proname, provolatile, proparallel
FROM pg_proc
WHERE proname = 'pg_cat_add';
----
proname	provolatile	proparallel


