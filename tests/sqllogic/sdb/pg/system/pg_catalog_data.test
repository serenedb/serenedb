# Tests that pg_catalog tables return real data from the internal catalog
#
# Setup: create test tables, indexes, and functions for introspection


statement ok
CREATE TABLE pg_cat_t1 (id INT PRIMARY KEY, name TEXT NOT NULL, value FLOAT8)


statement ok
CREATE TABLE pg_cat_t2 (a BIGINT PRIMARY KEY, b VARCHAR, c BOOLEAN, d TIMESTAMP)


statement ok
CREATE INDEX pg_cat_idx1 ON pg_cat_t1 USING inverted (name)


statement ok
CREATE INDEX pg_cat_idx2 ON pg_cat_t2 USING inverted (b, c)


statement ok
CREATE FUNCTION pg_cat_add(a INT, b INT) RETURNS INT LANGUAGE SQL AS 'SELECT a + b'


# pg_database


# Should list databases with correct metadata
query
SELECT COUNT(*) > 0 FROM
(SELECT datname, encoding, datlocprovider, datallowconn, datconnlimit FROM pg_catalog.pg_database ORDER BY datname)
----
?column?
t

# Database should have an OID
query
SELECT count(*) > 0 FROM pg_catalog.pg_database WHERE oid > 0
----
?column?
t


# datcollate and datctype should be set
query
SELECT datcollate, datctype FROM pg_catalog.pg_database LIMIT 1
----
datcollate	datctype
C.UTF-8	C.UTF-8


# pg_namespace


# Should have pg_catalog and public schemas
query
SELECT count(*) > 0 FROM pg_catalog.pg_namespace WHERE nspname = 'pg_catalog'
----
?column?
t


query
SELECT count(*) > 0 FROM pg_catalog.pg_namespace WHERE nspname = 'public'
----
?column?
t


# pg_class


# User tables should appear with correct relkind and relnatts
query
SELECT relname, relkind, relnatts, relpersistence FROM pg_catalog.pg_class WHERE relname = 'pg_cat_t1'
----
relname	relkind	relnatts	relpersistence
pg_cat_t1	r	3	p


query
SELECT relname, relkind, relnatts FROM pg_catalog.pg_class WHERE relname = 'pg_cat_t2'
----
relname	relkind	relnatts
pg_cat_t2	r	4


# Indexes should appear in pg_class with relkind = 'i'
query
SELECT relname, relkind FROM pg_catalog.pg_class WHERE relname IN ('pg_cat_idx1', 'pg_cat_idx2') ORDER BY relname
----
relname	relkind
pg_cat_idx1	i
pg_cat_idx2	i


# Table with index should have relhasindex = true
query
SELECT relhasindex FROM pg_catalog.pg_class WHERE relname = 'pg_cat_t1'
----
relhasindex
t


# relowner should be set (non-zero)
query
SELECT count(*) > 0 FROM pg_catalog.pg_class WHERE relname = 'pg_cat_t1' AND relowner > 0
----
?column?
t


# relispopulated should be true for tables
query
SELECT relispopulated FROM pg_catalog.pg_class WHERE relname = 'pg_cat_t1'
----
relispopulated
t


# System tables should also appear in pg_class
query
SELECT count(*) > 0 FROM pg_catalog.pg_class WHERE relname = 'pg_class'
----
?column?
t


query
SELECT count(*) > 0 FROM pg_catalog.pg_class WHERE relname = 'pg_attribute'
----
?column?
t


# System tables should have relnatts > 0
query
SELECT relnatts > 0 FROM pg_catalog.pg_class WHERE relname = 'pg_type'
----
?column?
t


# pg_attribute


# Columns for pg_cat_t1 (id, name, value)
query
SELECT attname, attnum, attnotnull FROM pg_catalog.pg_attribute WHERE attrelid = (SELECT oid FROM pg_catalog.pg_class WHERE relname = 'pg_cat_t1') ORDER BY attnum
----
attname	attnum	attnotnull
id	1	t
name	2	t
value	3	f


# Columns for pg_cat_t2 (a, b, c, d)
query
SELECT attname, attnum FROM pg_catalog.pg_attribute WHERE attrelid = (SELECT oid FROM pg_catalog.pg_class WHERE relname = 'pg_cat_t2') ORDER BY attnum
----
attname	attnum
a	1
b	2
c	3
d	4


# Type OIDs should match known PG types
query
SELECT attname, atttypid FROM pg_catalog.pg_attribute WHERE attrelid = (SELECT oid FROM pg_catalog.pg_class WHERE relname = 'pg_cat_t1') ORDER BY attnum
----
attname	atttypid
id	23
name	25
value	701


# attlen should be correct for fixed-width types
query
SELECT attname, attlen, attbyval FROM pg_catalog.pg_attribute WHERE attrelid = (SELECT oid FROM pg_catalog.pg_class WHERE relname = 'pg_cat_t1') ORDER BY attnum
----
attname	attlen	attbyval
id	4	t
name	-1	f
value	8	t


# attisdropped should be false
query
SELECT count(*) FROM pg_catalog.pg_attribute WHERE attrelid = (SELECT oid FROM pg_catalog.pg_class WHERE relname = 'pg_cat_t1') AND attisdropped = true
----
count
0


# System table columns should also appear
query
SELECT count(*) > 0 FROM pg_catalog.pg_attribute WHERE attrelid = (SELECT oid FROM pg_catalog.pg_class WHERE relname = 'pg_namespace')
----
?column?
t


# attalign should be set for all columns
query
SELECT count(*) FROM pg_catalog.pg_attribute WHERE attrelid = (SELECT oid FROM pg_catalog.pg_class WHERE relname = 'pg_cat_t1') AND attalign IN ('c', 's', 'i', 'd')
----
count
3


# pg_type


# Common PG types should exist
query
SELECT count(*) > 0 FROM pg_catalog.pg_type WHERE typname = 'int4'
----
?column?
t


query
SELECT count(*) > 0 FROM pg_catalog.pg_type WHERE typname = 'text'
----
?column?
t


query
SELECT count(*) > 0 FROM pg_catalog.pg_type WHERE typname = 'bool'
----
?column?
t


# pg_index


# Index on single column
query
SELECT i.indnatts, i.indnkeyatts, i.indisvalid, i.indisready, i.indislive FROM pg_catalog.pg_index i JOIN pg_catalog.pg_class c ON i.indexrelid = c.oid WHERE c.relname = 'pg_cat_idx1'
----
indnatts	indnkeyatts	indisvalid	indisready	indislive
1	1	t	t	t


# Index on multiple columns
query
SELECT i.indnatts, i.indisvalid FROM pg_catalog.pg_index i JOIN pg_catalog.pg_class c ON i.indexrelid = c.oid WHERE c.relname = 'pg_cat_idx2'
----
indnatts	indisvalid
2	t


# indrelid should point to the correct table
query
SELECT t.relname FROM pg_catalog.pg_class t JOIN pg_catalog.pg_index i ON i.indrelid = t.oid JOIN pg_catalog.pg_class idx ON idx.oid = i.indexrelid WHERE idx.relname = 'pg_cat_idx1'
----
relname
pg_cat_t1


# indisprimary should be false for secondary indexes
query
SELECT i.indisprimary FROM pg_catalog.pg_index i JOIN pg_catalog.pg_class c ON i.indexrelid = c.oid WHERE c.relname = 'pg_cat_idx1'
----
indisprimary
f


# pg_am (access methods)


# serened access methods: iresearch backs tables;
# secondary/inverted back indexes.
query
SELECT amname, amtype FROM pg_catalog.pg_am ORDER BY amname
----
amname	amtype
inverted	i
iresearch	t
secondary	i


# Index vs table access-method counts
query
SELECT count(*) FROM pg_catalog.pg_am WHERE amtype = 'i'
----
count
2


query
SELECT count(*) FROM pg_catalog.pg_am WHERE amtype = 't'
----
count
1


# pg_language


# Should have internal, c, and sql
query
SELECT lanname, lanispl, lanpltrusted FROM pg_catalog.pg_language ORDER BY lanname
----
lanname	lanispl	lanpltrusted
internal	f	f
sql	f	t


# SQL should be trusted
query
SELECT lanpltrusted FROM pg_catalog.pg_language WHERE lanname = 'sql'
----
lanpltrusted
t


# pg_tablespace


# Should have pg_default and pg_global
query
SELECT spcname FROM pg_catalog.pg_tablespace ORDER BY spcname
----
spcname
pg_default
pg_global


query
SELECT count(*) FROM pg_catalog.pg_tablespace
----
count
2


# pg_proc (functions)


# Should list user-defined functions (if any) or at least not error
query
SELECT count(*) >= 0 FROM pg_catalog.pg_proc
----
?column?
t


query
SELECT proname, prokind, pronargs FROM pg_catalog.pg_proc WHERE proname = 'pg_cat_add'
----
proname	prokind	pronargs
pg_cat_add	f	2


# prorettype should be set
query
SELECT prorettype > 0 FROM pg_catalog.pg_proc WHERE proname = 'pg_cat_add'
----
?column?
t


# pronamespace should match schema OID
query
SELECT count(*) > 0 FROM pg_catalog.pg_proc p JOIN pg_catalog.pg_namespace n ON p.pronamespace = n.oid WHERE p.proname = 'pg_cat_add'
----
?column?
t


# pg_constraint (constraints)


# Primary key constraints should be listed
query
SELECT conname, contype FROM pg_catalog.pg_constraint WHERE conrelid = (SELECT oid FROM pg_catalog.pg_class WHERE relname = 'pg_cat_t1') ORDER BY conname
----
conname	contype
pg_cat_t1_id_not_null	c
pg_cat_t1_name_not_null	c
pg_cat_t1_pkey	p


query
SELECT conname, contype FROM pg_catalog.pg_constraint WHERE conrelid = (SELECT oid FROM pg_catalog.pg_class WHERE relname = 'pg_cat_t2') ORDER BY conname
----
conname	contype
pg_cat_t2_a_not_null	c
pg_cat_t2_pkey	p


# convalidated should be true
query
SELECT convalidated FROM pg_catalog.pg_constraint WHERE conrelid = (SELECT oid FROM pg_catalog.pg_class WHERE relname = 'pg_cat_t1') AND contype = 'p'
----
convalidated
t


# conenforced should be true
query
SELECT conenforced FROM pg_catalog.pg_constraint WHERE conrelid = (SELECT oid FROM pg_catalog.pg_class WHERE relname = 'pg_cat_t1') AND contype = 'p'
----
conenforced
t


# pg_authid (roles)


# Should list at least one role
query
SELECT count(*) > 0 FROM pg_catalog.pg_authid
----
?column?
t


# Roles should have rolcanlogin set
query
SELECT rolname, rolcanlogin FROM pg_catalog.pg_authid ORDER BY rolname LIMIT 3
----
rolname	rolcanlogin
postgres	t


# rolsuper should be set for all roles (no RBAC yet)
query
SELECT rolsuper FROM pg_catalog.pg_authid LIMIT 1
----
rolsuper
t


# pg_ts_dict (text search dictionaries / tokenizers)


# Should not error even if no tokenizers exist
query
SELECT count(*) >= 0 FROM pg_catalog.pg_ts_dict
----
?column?
t


# information_schema.schemata


# Should list schemas for the current database
query
SELECT count(*) > 0 FROM information_schema.schemata
----
?column?
t


query
SELECT schema_name FROM information_schema.schemata WHERE schema_name = 'public'
----
schema_name
public


# catalog_name should be set
query
SELECT count(*) > 0 FROM information_schema.schemata WHERE catalog_name IS NOT NULL AND catalog_name != ''
----
?column?
t


# information_schema.tables


# Should list our test tables
query
SELECT table_name, table_type FROM information_schema.tables WHERE table_name = 'pg_cat_t1'
----
table_name	table_type
pg_cat_t1	BASE TABLE


query
SELECT table_name, table_type FROM information_schema.tables WHERE table_name = 'pg_cat_t2'
----
table_name	table_type
pg_cat_t2	BASE TABLE


# is_insertable_into should be true for base tables
query
SELECT is_insertable_into FROM information_schema.tables WHERE table_name = 'pg_cat_t1'
----
is_insertable_into
YES


# table_schema should match
query
SELECT table_schema FROM information_schema.tables WHERE table_name = 'pg_cat_t1'
----
table_schema
public


# information_schema.columns


# Should list columns for our test tables
query
SELECT column_name, ordinal_position, is_nullable, data_type FROM information_schema.columns WHERE table_name = 'pg_cat_t1' ORDER BY ordinal_position
----
column_name	ordinal_position	is_nullable	data_type
id	1	NO	integer
name	2	NO	text
value	3	YES	double precision


query
SELECT column_name, ordinal_position FROM information_schema.columns WHERE table_name = 'pg_cat_t2' ORDER BY ordinal_position
----
column_name	ordinal_position
a	1
b	2
c	3
d	4


# NOT NULL column should have is_nullable = false
query
SELECT column_name, is_nullable FROM information_schema.columns WHERE table_name = 'pg_cat_t1' AND column_name = 'name'
----
column_name	is_nullable
name	NO


# data_type should be set
query
SELECT count(*) FROM information_schema.columns WHERE table_name = 'pg_cat_t1' AND data_type IS NOT NULL AND data_type != ''
----
count
3


# information_schema.table_constraints


# Primary key constraints should appear
query
SELECT constraint_name, constraint_type FROM information_schema.table_constraints WHERE table_name = 'pg_cat_t1' ORDER BY constraint_name
----
constraint_name	constraint_type
pg_cat_t1_id_not_null	CHECK
pg_cat_t1_name_not_null	CHECK
pg_cat_t1_pkey	PRIMARY KEY


query
SELECT constraint_name, constraint_type FROM information_schema.table_constraints WHERE table_name = 'pg_cat_t2' ORDER BY constraint_name
----
constraint_name	constraint_type
pg_cat_t2_a_not_null	CHECK
pg_cat_t2_pkey	PRIMARY KEY


# enforced should be true
query
SELECT enforced FROM information_schema.table_constraints WHERE table_name = 'pg_cat_t1' AND constraint_type = 'PRIMARY KEY'
----
enforced
YES


# information_schema.key_column_usage


# Primary key columns should be listed
query
SELECT constraint_name, column_name, ordinal_position FROM information_schema.key_column_usage WHERE table_name = 'pg_cat_t1' ORDER BY ordinal_position
----
constraint_name	column_name	ordinal_position
pg_cat_t1_pkey	id	1

query
SELECT constraint_name, column_name FROM information_schema.key_column_usage WHERE table_name = 'pg_cat_t2'
----
constraint_name	column_name
pg_cat_t2_pkey	a

