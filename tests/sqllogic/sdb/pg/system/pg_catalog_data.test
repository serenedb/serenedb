data_type
integer


# System views (pg_tables, pg_views, pg_roles)


# pg_tables should list our test tables
query
SELECT tablename, schemaname FROM pg_tables WHERE tablename = 'pg_cat_t1'
----
tablename	schemaname
pg_cat_t1	public


