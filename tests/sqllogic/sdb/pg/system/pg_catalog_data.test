query
SELECT routine_name, routine_type, external_language FROM information_schema.routines WHERE routine_name = 'pg_cat_add'
----
routine_name	routine_type	external_language
pg_cat_add	FUNCTION	SQL


# data_type should be set for the return type
query
SELECT data_type FROM information_schema.routines WHERE routine_name = 'pg_cat_add'
