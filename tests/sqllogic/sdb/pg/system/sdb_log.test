# Default LogConfig::storage is 'stdout' so container / systemd log drivers
# capture serened output. Operators wanting SQL-queryable logs flip to memory.
statement ok
SET enable_logging = true;

statement ok
SET logging_storage = 'memory';

# duckdb_logs() is the upstream table function for the LogManager buffer.
# After flipping storage to memory, the next log line lands there. We don't
# bother probing for a specific message (the startup banner is long gone --
# it went to stdout before the SET above); the smoke is that the table
# function is callable and returns a queryable shape.
query
SELECT (count(*) >= 0)::int AS ok FROM duckdb_logs();
----
ok
1
